---
// Earless garlic silhouette — stem kept, outer ear bumps removed.
// body-bottom → reversed inner-right-slope (path 6) → reversed sprout (path 4)
//             → reversed inner-left-slope (path 1) → Z
// Paths 2 (outer left ear) and 5 (outer right ear) are omitted.
// Path lives in src/data/garlic.ts (single source of truth).
import { GARLIC_BARE_PATH } from "../data/garlic";
const { class: className, ...props } = Astro.props;
---

<svg class:list={["garlic-bare", className]} viewBox="120 140 780 750" fill="currentColor" xmlns="http://www.w3.org/2000/svg" {...props}>
  <path d={GARLIC_BARE_PATH}/>
</svg>

<style>
  .garlic-bare {
    display: block;
    width: 1em;
    height: 1em;
  }
</style>
