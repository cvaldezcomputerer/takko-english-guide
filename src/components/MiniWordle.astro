---
import T from './T.astro';
import { themes } from '../data/pictionary/words';

const SKIP = new Set(['Months', 'Days', 'Dates']);

const pool: { word: string; category: string }[] = [];
const seen = new Set<string>();

for (const [category, words] of Object.entries(themes) as [string, readonly string[]][]) {
    if (SKIP.has(category)) continue;
    for (const w of words) {
        if (
            w !== w.toLowerCase() ||
            w.includes(' ') ||
            !/^[a-z]+$/.test(w) ||
            w.length < 3 ||
            w.length > 5 ||
            seen.has(w)
        ) continue;
        seen.add(w);
        pool.push({ word: w, category });
    }
}

const now = new Date();
const dayOfYear = Math.floor(
    (now.getTime() - new Date(now.getFullYear(), 0, 0).getTime()) / 86_400_000
);
const { word, category } = pool[dayOfYear % pool.length];
const COLS = word.length;
const ROWS = 6;

const KB = [
    ['Q','W','E','R','T','Y','U','I','O','P'],
    ['A','S','D','F','G','H','J','K','L'],
    ['ENT','Z','X','C','V','B','N','M','←'],
];
---

<div class="wordle-card" data-word={word}>
    <div class="wordle-hdr">
        <p class="wordle-title">
            <T>
                <span slot="en">Guess the Word</span>
                <span slot="ja">単語を当てよう</span>
            </T>
        </p>
        <p class="wordle-hint">
            <T>
                <span slot="en">Category: {category}</span>
                <span slot="ja">ヒント: {category}</span>
            </T>
        </p>
        <button class="wordle-help-btn" aria-label="How to play">?</button>
    </div>
    <div class="wordle-body">
        <div class="wordle-help-panel" hidden>
            <button class="wordle-help-close" aria-label="Close">&#x2715;</button>
            <p class="help-heading">
                <T><span slot="en">How to Play</span><span slot="ja">遊び方</span></T>
            </p>
            <ul class="help-list">
                <li>
                    <T>
                        <span slot="en">Guess the word in 6 tries.</span>
                        <span slot="ja">6回以内に単語を当てよう。</span>
                    </T>
                </li>
                <li>
                    <T>
                        <span slot="en">Click letters, then press <strong>ENT</strong>.</span>
                        <span slot="ja">文字をクリックして<strong>ENT</strong>を押そう。</span>
                    </T>
                </li>
                <li class="help-swatch correct">
                    <T>
                        <span slot="en">Right letter, right place.</span>
                        <span slot="ja">正しい文字・正しい場所。</span>
                    </T>
                </li>
                <li class="help-swatch present">
                    <T>
                        <span slot="en">Right letter, wrong place.</span>
                        <span slot="ja">正しい文字・場所が違う。</span>
                    </T>
                </li>
                <li class="help-swatch absent">
                    <T>
                        <span slot="en">Letter not in the word.</span>
                        <span slot="ja">その文字は入っていない。</span>
                    </T>
                </li>
            </ul>
        </div>
        <div class="wordle-grid" style={`--cols: ${COLS}`}>
            {Array.from({ length: ROWS * COLS }, (_, i) => (
                <div
                    class="wordle-cell"
                    data-row={Math.floor(i / COLS)}
                    data-col={i % COLS}
                ></div>
            ))}
        </div>
        <div class="wordle-keyboard">
            {KB.map(row => (
                <div class="kb-row">
                    {row.map(key => (
                        <button
                            class:list={['key-btn', (key === 'ENT' || key === '←') && 'key-wide']}
                            data-key={key === 'ENT' ? 'ENTER' : key === '←' ? 'BACKSPACE' : key}
                        >{key}</button>
                    ))}
                </div>
            ))}
        </div>
        <div class="wordle-msg"></div>
    </div>
</div>

<style>
    .wordle-card {
        width: 100%;
        margin-top: 1.5rem;
        border-radius: 8px;
        overflow: hidden;
        border: 3px solid var(--color-secondary);
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        font-family: var(--font-main);
    }

    .wordle-hdr {
        background: var(--color-primary);
        padding: 0.85rem 1rem 0.65rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
    }

    .wordle-title {
        margin: 0 0 0.1rem;
        color: white;
        font-size: 0.95rem;
        font-weight: 600;
        text-align: center;
        line-height: 1.4;
    }

    .wordle-hint {
        margin: 0;
        color: rgba(255,255,255,0.75);
        font-size: 0.78rem;
        text-align: center;
    }

    .wordle-help-btn {
        position: absolute;
        top: 0.6rem;
        right: 0.75rem;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 1.5px solid rgba(255,255,255,0.6);
        background: none;
        color: rgba(255,255,255,0.75);
        font-size: 0.7rem;
        font-weight: 700;
        cursor: pointer;
        line-height: 1;
        padding: 0;
        transition: background 0.15s, color 0.15s;
    }

    .wordle-help-btn:hover {
        background: rgba(255,255,255,0.2);
        color: white;
    }

    /* ── Help panel ── */
    .wordle-body {
        position: relative;
    }

    .wordle-help-panel {
        position: absolute;
        inset: 0;
        background: #fffbf0;
        padding: 1rem 1rem 1.25rem;
        z-index: 10;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .wordle-help-panel[hidden] { display: none; }

    .wordle-help-close {
        align-self: flex-end;
        background: none;
        border: none;
        font-size: 0.9rem;
        color: #888;
        cursor: pointer;
        padding: 0;
        line-height: 1;
    }

    .wordle-help-close:hover { color: #333; }

    .help-heading {
        margin: 0;
        font-size: 0.9rem;
        font-weight: 700;
        color: #333;
        text-align: center;
    }

    .help-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        font-size: 0.78rem;
        color: #444;
    }

    .help-swatch {
        padding-left: 0.6rem;
        border-left: 4px solid #ccc;
    }

    .help-swatch.correct { border-color: #4a7c59; }
    .help-swatch.present { border-color: #c9a227; }
    .help-swatch.absent  { border-color: #8a8a8a; }

    .wordle-body {
        background: #fffbf0;
        padding: 0.65rem 0.65rem 0.75rem;
    }

    /* ── Grid ── */
    .wordle-grid {
        display: grid;
        grid-template-columns: repeat(var(--cols), 1fr);
        gap: 4px;
        margin-bottom: 0.55rem;
    }

    .wordle-cell {
        aspect-ratio: 1;
        border: 2px solid #ccc8bc;
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #333;
        background: #fff;
        transition: background 0.12s, border-color 0.12s, color 0.12s;
        user-select: none;
    }

    .wordle-cell[data-state="active"] {
        border-color: #999;
        background: #faf6f0;
    }

    .wordle-cell[data-state="correct"] {
        background: #4a7c59;
        border-color: #4a7c59;
        color: white;
    }

    .wordle-cell[data-state="present"] {
        background: #c9a227;
        border-color: #c9a227;
        color: white;
    }

    .wordle-cell[data-state="absent"] {
        background: #8a8a8a;
        border-color: #8a8a8a;
        color: white;
    }

    @keyframes cell-pop {
        0%   { transform: scale(1); }
        50%  { transform: scale(1.14); }
        100% { transform: scale(1); }
    }

    .wordle-cell.pop {
        animation: cell-pop 0.1s ease-out;
    }

    @keyframes row-shake {
        0%, 100% { transform: translateX(0); }
        20%       { transform: translateX(-5px); }
        40%       { transform: translateX(5px); }
        60%       { transform: translateX(-4px); }
        80%       { transform: translateX(4px); }
    }

    .wordle-cell.shake {
        animation: row-shake 0.38s ease-out;
    }

    /* ── Keyboard ── */
    .wordle-keyboard {
        display: flex;
        flex-direction: column;
        gap: 3px;
        margin-bottom: 0.45rem;
    }

    .kb-row {
        display: flex;
        gap: 3px;
        justify-content: center;
    }

    .key-btn {
        flex: 1;
        min-height: 30px;
        font-size: 0.6rem;
        font-weight: 700;
        font-family: var(--font-main);
        border: none;
        border-radius: 3px;
        background: #d3cec6;
        color: #333;
        cursor: pointer;
        text-transform: uppercase;
        padding: 2px 1px;
        transition: background 0.12s, color 0.12s;
    }

    .key-wide {
        flex: 1.6;
        font-size: 0.52rem;
        background: #a8b8a8;
        color: white;
    }

    .key-btn[data-state="correct"] { background: #4a7c59; color: white; }
    .key-btn[data-state="present"] { background: #c9a227; color: white; }
    .key-btn[data-state="absent"]  { background: #878787; color: white; }

    /* ── Message ── */
    .wordle-msg {
        text-align: center;
        font-size: 0.8rem;
        font-weight: 600;
        min-height: 1.1em;
        color: #555;
    }

    .wordle-msg[data-type="win"]  { color: #4a7c59; }
    .wordle-msg[data-type="lose"] { color: #e76f51; }
</style>

<script>
    const card = document.querySelector<HTMLElement>('.wordle-card[data-word]');
    if (card) {
        const helpPanel = card.querySelector<HTMLElement>('.wordle-help-panel')!;
        card.querySelector('.wordle-help-btn')!.addEventListener('click', () => {
            helpPanel.hidden = !helpPanel.hidden;
        });
        card.querySelector('.wordle-help-close')!.addEventListener('click', () => {
            helpPanel.hidden = true;
        });

        const WORD  = card.dataset.word!;
        const COLS  = WORD.length;
        const ROWS  = 6;

        let currentRow   = 0;
        let currentGuess = '';
        let gameOver     = false;

        const msgEl = card.querySelector<HTMLElement>('.wordle-msg')!;

        function cell(row: number, col: number) {
            return card!.querySelector<HTMLElement>(
                `.wordle-cell[data-row="${row}"][data-col="${col}"]`
            )!;
        }

        function keyEl(letter: string) {
            return card!.querySelector<HTMLElement>(`.key-btn[data-key="${letter.toUpperCase()}"]`);
        }

        function redrawCurrentRow() {
            for (let c = 0; c < COLS; c++) {
                const el = cell(currentRow, c);
                el.textContent = currentGuess[c]?.toUpperCase() ?? '';
                el.dataset.state = currentGuess[c] ? 'active' : '';
            }
        }

        function popCell(row: number, col: number) {
            const el = cell(row, col);
            el.classList.remove('pop');
            void el.offsetWidth;
            el.classList.add('pop');
            el.addEventListener('animationend', () => el.classList.remove('pop'), { once: true });
        }

        function shakeRow(row: number) {
            for (let c = 0; c < COLS; c++) {
                const el = cell(row, c);
                el.classList.remove('shake');
                void el.offsetWidth;
                el.classList.add('shake');
                el.addEventListener('animationend', () => el.classList.remove('shake'), { once: true });
            }
        }

        function getColors(guess: string, answer: string): string[] {
            const result   = Array(COLS).fill('absent');
            const ansPool  = answer.split('');
            const guessArr = guess.split('');

            for (let i = 0; i < COLS; i++) {
                if (guessArr[i] === ansPool[i]) {
                    result[i]   = 'correct';
                    ansPool[i]  = '';
                    guessArr[i] = '';
                }
            }
            for (let i = 0; i < COLS; i++) {
                if (!guessArr[i]) continue;
                const j = ansPool.indexOf(guessArr[i]);
                if (j !== -1) {
                    result[i]  = 'present';
                    ansPool[j] = '';
                }
            }
            return result;
        }

        function submit() {
            if (currentGuess.length < COLS) { shakeRow(currentRow); return; }

            const colors = getColors(currentGuess, WORD);

            for (let c = 0; c < COLS; c++) {
                cell(currentRow, c).dataset.state = colors[c];
            }
            for (let c = 0; c < COLS; c++) {
                const k = keyEl(currentGuess[c]);
                if (k && k.dataset.state !== 'correct') k.dataset.state = colors[c];
            }

            if (colors.every(s => s === 'correct')) {
                msgEl.textContent  = 'You got it!';
                msgEl.dataset.type = 'win';
                gameOver = true;
                return;
            }

            currentRow++;
            if (currentRow >= ROWS) {
                msgEl.textContent  = `The word was: ${WORD.toUpperCase()}`;
                msgEl.dataset.type = 'lose';
                gameOver = true;
                return;
            }
            currentGuess = '';
        }

        function handleKey(key: string) {
            if (gameOver) return;
            if (key === 'ENTER') {
                submit();
            } else if (key === 'BACKSPACE') {
                if (currentGuess.length > 0) {
                    currentGuess = currentGuess.slice(0, -1);
                    redrawCurrentRow();
                }
            } else if (/^[A-Z]$/.test(key) && currentGuess.length < COLS) {
                currentGuess += key.toLowerCase();
                redrawCurrentRow();
                popCell(currentRow, currentGuess.length - 1);
            }
        }

        document.addEventListener('keydown', e => {
            if (e.ctrlKey || e.metaKey || e.altKey) return;
            const key = e.key === 'Enter'     ? 'ENTER'
                      : e.key === 'Backspace'  ? 'BACKSPACE'
                      : e.key.toUpperCase();
            handleKey(key);
        });

        card.querySelectorAll<HTMLButtonElement>('.key-btn').forEach(btn => {
            btn.addEventListener('click', () => handleKey(btn.dataset.key!));
        });
    }
</script>
