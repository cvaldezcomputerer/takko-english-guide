  ];

  const tacoIdx = levelsRaw.findIndex((lvl) => (lvl.name || '').includes('Taco ES'));
  const levelsRawOrdered = tacoIdx > 0
    ? [levelsRaw[tacoIdx], ...levelsRaw.slice(0, tacoIdx), ...levelsRaw.slice(tacoIdx + 1)]
    : levelsRaw;

  const levels = levelsRawOrdered.map((lvl) => shiftLevelY(lvl, SCHOOL_SHIFT_Y));

  for (const lvl of levels) {
    if ((lvl.name || '').includes('Kamogo ES')) {
      fillInteriorRoads(lvl);
    }
  }

  for (const lvl of levels) {
    // Cache derived masks so renderGrid stays cheap.
    lvl.__interiorSet = buildInteriorSet(lvl);
    lvl.__entrance = getEntranceConfig(lvl);
    lvl.__locationByKey = buildCoordIndex(lvl.locations);
    lvl.__roadByKey = buildCoordIndex(lvl.roads);
    lvl.__itemByKey = buildCoordIndex(lvl.items);
    warnDuplicateCoords(lvl);
  }

  const GRID_WIDTH = 21;
  const GRID_HEIGHT = 12;
  const GRID_CELL_COUNT = GRID_WIDTH * GRID_HEIGHT;
  const DEBUG_TILE_LOG = false;
  const AVATAR_LINE_COLOR = "#1e3a8a";

  let currentLevelIdx = 0;
  let playerPos = { ...levels[0].startPos };
  let playerHeading = levels[0].startHeading || 0; 
  const directions = [{ dx: 0, dy: -1 }, { dx: 1, dy: 0 }, { dx: 0, dy: 1 }, { dx: -1, dy: 0 }];
  const headingToRotation = [0, 90, 180, 270];
  const MUTE_STORAGE_KEY = 'map-game-muted';
  const FIRST_VISIT_STORAGE_KEY = 'map-game-directions-visited-v1';
  let staticGridLevelIdx = -1;
  let cellEls = [];
  let gridEl = null;
  let gameContainerEl = null;
  let mapTitleEl = null;
  let playerEl = null;
  let playerImgEl = null;
  let currentPlayerImageSrc = playerImageSrc;
  let showFirstVisitHighlight = false;
  let isBlackout = false;
  let avatarModalEl = null;
  let avatarCanvasEl = null;
  let avatarCanvasCtx = null;
  let avatarApplyBtnEl = null;
  let isAvatarDrawing = false;
  let avatarHasInk = false;

  let isMuted = true;
  const meowAudio = new Audio('/audio/map-game/meowDeep.mp3');
  meowAudio.preload = 'auto';
  let locationAudio = null;

  function normalizeLocationAudioKey(name) {
    return String(name || '')
      .toLowerCase()
      .replace(/â€™/g, '')
      .replace(/[’']/g, '')
      .replace(/\d+/g, '')
      .replace(/[^a-z\s-]/g, '')
      .replace(/\s+/g, ' ')
      .trim();
  }

  function getLocationAudioSrc(name) {
    const key = normalizeLocationAudioKey(name);
    if (!key) return null;
    return `/audio/map-game/${key.replace(/\s+/g, '-')}.mp3`;
  }

  function stopLocationAudio() {
    if (!locationAudio) return;
    locationAudio.pause();
    locationAudio.currentTime = 0;
    locationAudio = null;
  }

  function loadMutePreference() {
    try {
      const stored = localStorage.getItem(MUTE_STORAGE_KEY);
      isMuted = stored === null ? true : stored === '1';
    } catch {
      isMuted = true;
    }
  }

  function saveMutePreference() {
    try {
      localStorage.setItem(MUTE_STORAGE_KEY, isMuted ? '1' : '0');
    } catch {
      // Ignore storage errors
    }
  }

  function updateMuteButtonUI() {
    const muteBtn = document.getElementById('btn-mute');
    if (!muteBtn) return;
    muteBtn.classList.toggle('is-muted', isMuted);
    muteBtn.setAttribute('aria-pressed', isMuted ? 'true' : 'false');
    muteBtn.setAttribute('title', isMuted ? 'Unmute Sound' : 'Mute Sound');
    muteBtn.setAttribute('aria-label', isMuted ? 'Unmute sound' : 'Mute sound');
  }

  function updateBlackoutUI() {
    const blackoutBtn = document.getElementById('btn-blackout');
    if (!blackoutBtn) return;

    blackoutBtn.classList.toggle('is-active', isBlackout);
    blackoutBtn.setAttribute('aria-pressed', isBlackout ? 'true' : 'false');
    blackoutBtn.setAttribute('title', isBlackout ? 'Show Board' : 'Hide Board');
    blackoutBtn.setAttribute('aria-label', isBlackout ? 'Show board' : 'Hide board');

    if (gameContainerEl) {
      gameContainerEl.classList.toggle('blackout-active', isBlackout);
    }
  }

  function getAvatarCanvasPoint(event) {
    if (!avatarCanvasEl) return { x: 0, y: 0 };
    const rect = avatarCanvasEl.getBoundingClientRect();
    const scaleX = avatarCanvasEl.width / rect.width;
    const scaleY = avatarCanvasEl.height / rect.height;
    return {
      x: (event.clientX - rect.left) * scaleX,
      y: (event.clientY - rect.top) * scaleY,
    };
  }

  function updateAvatarApplyButtonState() {
    if (avatarApplyBtnEl) avatarApplyBtnEl.disabled = !avatarHasInk;
  }

  function clearAvatarCanvas() {
    if (!avatarCanvasCtx || !avatarCanvasEl) return;
    avatarCanvasCtx.clearRect(0, 0, avatarCanvasEl.width, avatarCanvasEl.height);
    avatarHasInk = false;
    updateAvatarApplyButtonState();
  }

  function setPlayerAvatarImage(src) {
    currentPlayerImageSrc = src || playerImageSrc;
    if (playerImgEl) playerImgEl.src = currentPlayerImageSrc;
    renderGrid();
  }

  function openAvatarModal() {
    if (!avatarModalEl) return;
    avatarModalEl.classList.remove("hidden");
  }

  function closeAvatarModal() {
    if (!avatarModalEl) return;
    avatarModalEl.classList.add("hidden");
  }

  function setupAvatarDrawing() {
    avatarModalEl = document.getElementById("avatar-modal");
    avatarCanvasEl = document.getElementById("avatar-canvas");
    avatarApplyBtnEl = document.getElementById("btn-avatar-apply");
    const avatarOpenBtn = document.getElementById("btn-avatar-draw");
    const avatarCloseBtn = document.getElementById("btn-avatar-modal-close");
    const avatarClearBtn = document.getElementById("btn-avatar-clear");
    const avatarUseDefaultBtn = document.getElementById("btn-avatar-use-default");

    if (!(avatarCanvasEl instanceof HTMLCanvasElement)) return;
    avatarCanvasCtx = avatarCanvasEl.getContext("2d");
    if (!avatarCanvasCtx) return;

    avatarCanvasCtx.lineCap = "round";
    avatarCanvasCtx.lineJoin = "round";
    avatarCanvasCtx.strokeStyle = AVATAR_LINE_COLOR;
    avatarCanvasCtx.lineWidth = 10;
    clearAvatarCanvas();

    avatarOpenBtn?.addEventListener("click", openAvatarModal);
    avatarCloseBtn?.addEventListener("click", closeAvatarModal);
    avatarClearBtn?.addEventListener("click", clearAvatarCanvas);
    avatarUseDefaultBtn?.addEventListener("click", () => {
      setPlayerAvatarImage(playerImageSrc);
      closeAvatarModal();
    });

    avatarApplyBtnEl?.addEventListener("click", () => {
      if (!avatarCanvasEl || !avatarHasInk) return;
      setPlayerAvatarImage(avatarCanvasEl.toDataURL("image/png"));
      closeAvatarModal();
    });

    avatarCanvasEl.addEventListener("pointerdown", (event) => {
      if (!avatarCanvasCtx || !avatarCanvasEl) return;
      event.preventDefault();
      avatarCanvasEl.setPointerCapture(event.pointerId);
      const { x, y } = getAvatarCanvasPoint(event);
      avatarCanvasCtx.beginPath();
      avatarCanvasCtx.moveTo(x, y);
      isAvatarDrawing = true;
      avatarHasInk = true;
      updateAvatarApplyButtonState();
    });

    avatarCanvasEl.addEventListener("pointermove", (event) => {
      if (!avatarCanvasCtx || !isAvatarDrawing) return;
      const { x, y } = getAvatarCanvasPoint(event);
      avatarCanvasCtx.lineTo(x, y);
      avatarCanvasCtx.stroke();
    });

    const endAvatarStroke = (event) => {
      if (!avatarCanvasEl) return;
      if (event && avatarCanvasEl.hasPointerCapture(event.pointerId)) {
        avatarCanvasEl.releasePointerCapture(event.pointerId);
      }
      isAvatarDrawing = false;
    };

    avatarCanvasEl.addEventListener("pointerup", endAvatarStroke);
    avatarCanvasEl.addEventListener("pointercancel", endAvatarStroke);
    avatarCanvasEl.addEventListener("pointerleave", endAvatarStroke);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && avatarModalEl && !avatarModalEl.classList.contains("hidden")) {
        closeAvatarModal();
      }
    });
  }

  function toggleBlackout() {
    isBlackout = !isBlackout;
    updateBlackoutUI();
  }

  function setMuted(nextMuted) {
    isMuted = !!nextMuted;
    if (isMuted) {
      meowAudio.pause();
      meowAudio.currentTime = 0;
      stopLocationAudio();
    }
    updateMuteButtonUI();
    saveMutePreference();
  }

  function toggleMute() {
    setMuted(!isMuted);
  }

  function initFirstVisitHighlight() {
    try {
      const hasVisited = localStorage.getItem(FIRST_VISIT_STORAGE_KEY) === '1';
      if (!hasVisited) {
        showFirstVisitHighlight = true;
        localStorage.setItem(FIRST_VISIT_STORAGE_KEY, '1');
      }
    } catch {
      showFirstVisitHighlight = true;
    }
  }

  function clearFirstVisitHighlight() {
    if (!showFirstVisitHighlight) return;
    showFirstVisitHighlight = false;
    if (playerEl) playerEl.classList.remove("first-visit-highlight");
  }

  function playPlaceNameAudio(name) {
    if (isMuted || !name) return;
    const src = getLocationAudioSrc(name);
    if (!src) return;
    stopLocationAudio();
    locationAudio = new Audio(src);
    locationAudio.preload = 'auto';
    locationAudio.play().catch((e) => console.warn('Location audio play blocked by browser:', e));
  }

  function handleTileAudio(x, y) {
    const location = getLocationAt(x, y);
    if (!location?.name) return;
    playPlaceNameAudio(location.name);
  }

  function getLocationAt(x, y) {
    return levels[currentLevelIdx].__locationByKey.get(keyFor(x, y));
  }

  function getRoadAt(x, y) {
    return levels[currentLevelIdx].__roadByKey.get(keyFor(x, y));
  }

  function getItemAt(x, y) {
    return levels[currentLevelIdx].__itemByKey.get(keyFor(x, y));
  }

  function hasTileContent(x, y) {
    return !!(getRoadAt(x, y) || getLocationAt(x, y) || getItemAt(x, y));
  }

  function tileIndex(x, y) {
    return (y * GRID_WIDTH) + x;
  }

  function getCellAt(x, y) {
    return cellEls[tileIndex(x, y)] || null;
  }

  function warnDuplicateCoords(level) {
    const bucketByKey = (arr) => {
      const map = new Map();
      for (const it of arr || []) {
        const k = keyFor(it.x, it.y);
        const existing = map.get(k) || [];
        existing.push(it);
        map.set(k, existing);
      }
      return map;
    };

    const dupes = [];
    for (const [k, v] of bucketByKey(level.roads)) if (v.length > 1) dupes.push({ type: 'roads', key: k, entries: v });
    for (const [k, v] of bucketByKey(level.locations)) if (v.length > 1) dupes.push({ type: 'locations', key: k, entries: v });
    for (const [k, v] of bucketByKey(level.items)) if (v.length > 1) dupes.push({ type: 'items', key: k, entries: v });

    if (dupes.length) {
      console.warn(`[${level.name}] duplicate coords detected (index keeps first match):`, dupes);
    }
  }

  function logCurrentTile(interiorSet) {
    const level = levels[currentLevelIdx];
    const tileKey = keyFor(playerPos.x, playerPos.y);
    const inside = interiorSet?.has(tileKey) ?? false;
    const road = getRoadAt(playerPos.x, playerPos.y);
    const location = getLocationAt(playerPos.x, playerPos.y);
    const item = getItemAt(playerPos.x, playerPos.y);
    console.log(`[${level.name}] tile=(${playerPos.x},${playerPos.y}) heading=${playerHeading}`, {
      inside,
      road: road?.image || null,
      location: location?.name || null,
      item: item?.icon || null,
    });
  }

  function ensurePlayerElement() {
    if (playerEl && playerImgEl) return;
    playerEl = document.createElement("div");
    playerEl.className = "player";
    playerImgEl = document.createElement("img");
    playerImgEl.src = currentPlayerImageSrc;
    playerImgEl.className = "player-image";
    playerEl.appendChild(playerImgEl);
  }

  function renderStaticGrid() {
    if (!gridEl) return;

    const level = levels[currentLevelIdx];
    const interiorSet = level.__interiorSet || buildInteriorSet(level);
    const entrance = level.__entrance || getEntranceConfig(level);
    const entranceOpenSides = entrance ? new Set(entrance.open || []) : null;
    const fragment = document.createDocumentFragment();
    cellEls = new Array(GRID_CELL_COUNT);

    for (let y = 0; y < GRID_HEIGHT; y++) {
      for (let x = 0; x < GRID_WIDTH; x++) {
        const cell = document.createElement("div");
        cell.className = "cell";
        const location = getLocationAt(x, y);
        const road = getRoadAt(x, y);
        const item = getItemAt(x, y);
        const tileKey = keyFor(x, y);
        const inside = interiorSet.has(tileKey);

        // Interior floor (beige)
        if (inside) cell.classList.add("interior");

        // Walls derived from interior mask
        if (inside) {
          const isEntranceCell = entrance && entrance.x === x && entrance.y === y;

          const upOutside = y === 0 || !interiorSet.has(keyFor(x, y - 1));
          const downOutside = y === GRID_HEIGHT - 1 || !interiorSet.has(keyFor(x, y + 1));
          const leftOutside = x === 0 || !interiorSet.has(keyFor(x - 1, y));
          const rightOutside = x === GRID_WIDTH - 1 || !interiorSet.has(keyFor(x + 1, y));

          if (upOutside && !(isEntranceCell && entranceOpenSides && entranceOpenSides.has('top'))) cell.classList.add("wall-top");
          if (downOutside && !(isEntranceCell && entranceOpenSides && entranceOpenSides.has('bottom'))) cell.classList.add("wall-bottom");
          if (leftOutside && !(isEntranceCell && entranceOpenSides && entranceOpenSides.has('left'))) cell.classList.add("wall-left");
          if (rightOutside && !(isEntranceCell && entranceOpenSides && entranceOpenSides.has('right'))) cell.classList.add("wall-right");
        }

        if (road) {
          const roadBg = document.createElement("div");
          roadBg.className = "road-layer";
          const roadSrc = roadMap[road.image.toLowerCase()];
          if (roadSrc) roadBg.style.backgroundImage = `url('${roadSrc}')`;
          cell.appendChild(roadBg);
        }

        if (location) {
          cell.classList.add("location");
          cell.style.backgroundImage = `url('${location.image}')`;
          cell.style.backgroundSize = 'contain';
          cell.style.backgroundRepeat = 'no-repeat';
          cell.style.backgroundPosition = 'center';
          cell.style.backgroundColor = 'rgba(255, 255, 255, 0.4)'; 
          const label = document.createElement("span");
          label.className = "location-label";
          label.textContent = location.name;
          cell.appendChild(label);
        }

        if (item) {
          const itemEl = document.createElement("div");
          itemEl.className = "item-icon";
          itemEl.textContent = item.icon;
          cell.appendChild(itemEl);
        }

        const index = tileIndex(x, y);
        cellEls[index] = cell;
        fragment.appendChild(cell);
      }
    }

    gridEl.replaceChildren(fragment);
    staticGridLevelIdx = currentLevelIdx;
  }

  function renderPlayer() {
    ensurePlayerElement();
    const nextCell = getCellAt(playerPos.x, playerPos.y);
    if (!nextCell || !playerEl || !playerImgEl) return;

    const prevCell = playerEl.parentElement;
    if (prevCell) {
      prevCell.classList.remove("has-player", "out-of-bounds");
      prevCell.removeChild(playerEl);
    }

    nextCell.classList.add("has-player");
    if (!hasTileContent(playerPos.x, playerPos.y)) {
      nextCell.classList.add("out-of-bounds");
    }
    playerEl.classList.toggle("custom-avatar", currentPlayerImageSrc !== playerImageSrc);
    playerEl.classList.toggle("first-visit-highlight", showFirstVisitHighlight);
    playerImgEl.style.transform = `rotate(${headingToRotation[playerHeading]}deg)`;
    nextCell.appendChild(playerEl);
  }

  function renderGrid() {
    if (!gridEl) gridEl = document.getElementById("grid");
    if (!mapTitleEl) mapTitleEl = document.getElementById("map-title");
    if (mapTitleEl) mapTitleEl.textContent = levels[currentLevelIdx].name;
    if (!gridEl) return;

    if (staticGridLevelIdx !== currentLevelIdx || cellEls.length !== GRID_CELL_COUNT) {
      renderStaticGrid();
    }

    renderPlayer();

    if (DEBUG_TILE_LOG) {
      const level = levels[currentLevelIdx];
      const interiorSet = level.__interiorSet || buildInteriorSet(level);
      logCurrentTile(interiorSet);
    }
  }

  function turnLeft() { playerHeading = (playerHeading + 3) % 4; renderGrid(); }
  function turnRight() { playerHeading = (playerHeading + 1) % 4; renderGrid(); }
  function goStraight() {
    const dir = directions[playerHeading];
    const newX = playerPos.x + dir.dx, newY = playerPos.y + dir.dy;
    if (newX >= 0 && newX <= GRID_WIDTH - 1 && newY >= 0 && newY <= GRID_HEIGHT - 1) {
      playerPos = { x: newX, y: newY };
      const startPos = levels[currentLevelIdx].startPos;
      if (showFirstVisitHighlight && (playerPos.x !== startPos.x || playerPos.y !== startPos.y)) {
        clearFirstVisitHighlight();
      }
      renderGrid();
      handleTileAudio(newX, newY);
      if (!hasTileContent(newX, newY)) triggerExplosion(newX, newY);
    }
  }

  function triggerExplosion(x, y) {
    // Play out-of-bounds sound
    if (!isMuted) {
      meowAudio.currentTime = 0;
      meowAudio.play().catch(e => console.warn("Audio play blocked by browser:", e));
    }

    const cell = getCellAt(x, y);
    if (cell) {
      const img = document.createElement("img");
      img.src = explosionSrc;
      img.className = "explosion-effect";
      cell.appendChild(img);
      setTimeout(() => img.remove(), 1000);
    }
  }

  function resetGame() {
    playerPos = { ...levels[currentLevelIdx].startPos }; 
    playerHeading = levels[currentLevelIdx].startHeading || 0; 
    renderGrid(); 
  }

  function switchMap() {
    currentLevelIdx = (currentLevelIdx + 1) % levels.length;
    resetGame();
  }

  document.addEventListener("DOMContentLoaded", () => {
    loadMutePreference();
    initFirstVisitHighlight();
    updateMuteButtonUI();
    gameContainerEl = document.getElementById("game-container");
    updateBlackoutUI();
    setupAvatarDrawing();

    renderGrid();
    document.getElementById("btn-left")?.addEventListener("click", turnLeft);
    document.getElementById("btn-right")?.addEventListener("click", turnRight);
    document.getElementById("btn-straight")?.addEventListener("click", goStraight);
    document.getElementById("btn-reset")?.addEventListener("click", resetGame);
    document.getElementById("btn-next-map")?.addEventListener("click", switchMap);
    document.getElementById("btn-mute")?.addEventListener("click", toggleMute);
    document.getElementById("btn-blackout")?.addEventListener("click", toggleBlackout);
    
    // Keyboard controls
    document.addEventListener("keydown", (e) => {
      switch(e.key) {
        case "ArrowLeft":
          turnLeft();
          break;
        case "ArrowRight":
          turnRight();
          break;
        case "ArrowUp":
          goStraight();
          break;
      }
    });
  });
</script>
