---
// MapGame.astro - School Map Navigation Game
import lilMeow from '../../assets/map-game/game/lilMeow.png';
import boomGif from '../../assets/map-game/game/boom.gif';

// Optimized image loading from src/assets
const roadImagesGlob = import.meta.glob<any>('../../assets/map-game/game-roads/*.png', { eager: true });
const roomImagesGlob = import.meta.glob<any>('../../assets/map-game/game-rooms/*.png', { eager: true });

const roadMap: Record<string, string> = {};
for (const path in roadImagesGlob) {
  const fileName = path.split('/').pop()?.replace('.png', '') || '';
  // Map both kebab-case and CamelCase to be safe
  const module = roadImagesGlob[path] as any;
  roadMap[fileName.toLowerCase()] = module.default.src;
}

const roomMap: Record<string, string> = {};
for (const path in roomImagesGlob) {
  const fileName = path.split('/').pop()?.replace('.png', '') || '';
  const module = roomImagesGlob[path] as any;
  roomMap[fileName.toLowerCase()] = module.default.src;
}
---

<div class="game-container" id="game-container">
  <div id="map-title" class="map-title"></div>
  <div class="grid-container">
    <div class="grid" id="grid">
      <!-- Grid cells will be rendered by JavaScript -->
    </div>
  </div>
  
  <div class="controls-panel movement-controls">
    <button class="control-btn move-btn" id="btn-left" aria-label="Turn left" title="Turn Left">
      <svg class="control-icon" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
        <circle class="icon-badge" cx="32" cy="32" r="27"></circle>
        <path class="icon-glyph" d="M36 18 22 32l14 14" fill="none" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
    <button class="control-btn move-btn" id="btn-straight" aria-label="Go straight" title="Go Straight">
      <svg class="control-icon" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
        <circle class="icon-badge" cx="32" cy="32" r="27"></circle>
        <path class="icon-glyph" d="M32 45V19m0 0-10 10m10-10 10 10" fill="none" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
    <button class="control-btn move-btn" id="btn-right" aria-label="Turn right" title="Turn Right">
      <svg class="control-icon" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
        <circle class="icon-badge" cx="32" cy="32" r="27"></circle>
        <path class="icon-glyph" d="m28 18 14 14-14 14" fill="none" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
  </div>

  <div class="controls-panel utility-controls">
    <button class="control-btn blackout-toggle-btn" id="btn-blackout" title="Hide Board" aria-label="Hide board" aria-pressed="false">
      <svg class="control-icon icon-eye-open" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
        <path class="icon-badge" d="M8 32s8-14 24-14 24 14 24 14-8 14-24 14S8 32 8 32z"></path>
        <circle class="icon-fill" cx="32" cy="32" r="8"></circle>
      </svg>
      <svg class="control-icon icon-eye-closed" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
        <path class="icon-glyph" d="M12 36c4-6 11-10 20-10s16 4 20 10" fill="none" stroke-width="4" stroke-linecap="round"></path>
        <path class="icon-glyph" d="M18 18 46 46" fill="none" stroke-width="5" stroke-linecap="round"></path>
      </svg>
    </button>
    <button class="control-btn reset-btn" id="btn-reset" aria-label="Reset map" title="Reset Map">
      <svg class="control-icon" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
        <circle class="icon-badge" cx="32" cy="32" r="27"></circle>
        <path class="icon-glyph" d="M44 22a16 16 0 1 0 3 14" fill="none" stroke-width="5" stroke-linecap="round"></path>
        <path class="icon-glyph" d="M46 14v12H34" fill="none" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
    <button class="control-btn" id="btn-next-map" title="Next Map" aria-label="Next map">
      <svg class="control-icon" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
        <path class="icon-badge" d="M8 20 24 13l16 7 16-6v30l-16 7-16-7-16 6z"></path>
        <path class="icon-glyph" d="M24 13v31m16-24v31" fill="none" stroke-width="4"></path>
      </svg>
    </button>
    <button class="control-btn" id="btn-mute" title="Toggle Sound" aria-label="Unmute sound" aria-pressed="true">
      <svg class="control-icon icon-sound-on" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
        <path class="icon-badge" d="M10 36V28h12l14-12v32L22 36z"></path>
        <path class="icon-glyph" d="M44 24c3 2 5 5 5 8s-2 6-5 8m6-22c5 4 8 9 8 14s-3 10-8 14" fill="none" stroke-width="4" stroke-linecap="round"></path>
      </svg>
      <svg class="control-icon icon-sound-off" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
        <path class="icon-badge" d="M10 36V28h12l14-12v32L22 36z"></path>
        <path class="icon-glyph danger" d="M44 22 56 42M56 22 44 42" fill="none" stroke-width="5" stroke-linecap="round"></path>
      </svg>
    </button>
  </div>

  <button class="avatar-tool-btn" id="btn-avatar-draw" type="button" title="アバターをかく" aria-label="アバターをかく">
    <svg class="avatar-tool-btn__icon" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
      <rect x="10" y="10" width="44" height="44" rx="10" fill="#ffffff" stroke="#0f172a" stroke-width="4"></rect>
      <path d="M20 42 42 20l6 6-22 22H20z" fill="#f59e0b" stroke="#92400e" stroke-width="3" stroke-linejoin="round"></path>
      <path d="M40 18l6 6" stroke="#0f172a" stroke-width="3" stroke-linecap="round"></path>
    </svg>
  </button>

  <div class="avatar-modal hidden" id="avatar-modal" role="dialog" aria-modal="true" aria-labelledby="avatar-modal-title">
    <div class="avatar-modal__card">
      <h2 id="avatar-modal-title">アバターをかこう</h2>
      <p>かおをかいて、プレイヤーにしよう。</p>
      <div class="avatar-modal__canvas-wrap">
        <canvas id="avatar-canvas" width="256" height="256" aria-label="アバターおえかき"></canvas>
      </div>
      <div class="avatar-modal__actions">
        <button id="btn-avatar-clear" type="button">けす</button>
        <button id="btn-avatar-use-default" type="button">ねこにもどす</button>
        <button id="btn-avatar-modal-close" type="button">とじる</button>
        <button id="btn-avatar-apply" type="button">このえをつかう</button>
      </div>
    </div>
  </div>
</div>

<style>
  .game-container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    padding: 0;
    box-sizing: border-box;
    background: #b4f1ae;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    overflow: hidden;
  }

  .map-title {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(4px);
    padding: 20px 10px;
    border-radius: 20px;
    font-size: 1.5rem;
    font-weight: bold;
    color: #2c3e50;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    z-index: 1000;
    writing-mode: vertical-rl;
    text-orientation: upright;
    letter-spacing: 2px;
    white-space: nowrap;
  }

  .controls-panel {
    position: absolute;
    display: flex;
    border-radius: 20px;
    justify-content: center;
    align-items: center;
    flex-shrink: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(4px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    transition: all 0.2s ease;
  }

  .movement-controls {
    position: absolute;
    left: 50%;
    bottom: 14px;
    transform: translateX(-50%);
    flex-direction: row;
    gap: 12px;
    padding: 12px 16px;
  }

  .utility-controls {
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    flex-direction: column;
    gap: 15px;
    padding: 20px 10px;
  }

  .control-btn {
    width: 72px;
    height: 72px;
    padding: 0;
    border-radius: 12px;
    border: 3px solid #0f172a;
    background: white;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    cursor: pointer;
    transition: transform 0.1s ease, background-color 0.12s ease, box-shadow 0.12s ease;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .control-btn .control-icon {
    width: 42px;
    height: 42px;
    display: block;
    color: inherit;
  }

  .control-btn .icon-badge {
    fill: #ffffff;
    stroke: currentColor;
    stroke-width: 4;
    stroke-linejoin: round;
  }

  .control-btn .icon-glyph {
    stroke: currentColor;
  }

  .control-btn .icon-fill {
    fill: currentColor;
  }

  #btn-left {
    background: #dbeafe;
    border-color: #1d4ed8;
  }

  #btn-straight {
    background: #d1fae5;
    border-color: #047857;
  }

  #btn-right {
    background: #ffedd5;
    border-color: #c2410c;
  }

  #btn-reset {
    background: #ede9fe;
    border-color: #7c3aed;
  }

  #btn-next-map {
    background: #ccfbf1;
    border-color: #0f766e;
  }

  #btn-mute {
    background: #e2e8f0;
    border-color: #334155;
  }

  #btn-left .icon-badge, #btn-left .icon-glyph { stroke: #1d4ed8; }
  #btn-left .icon-fill { fill: #1d4ed8; }

  #btn-straight .icon-badge, #btn-straight .icon-glyph { stroke: #047857; }
  #btn-straight .icon-fill { fill: #047857; }

  #btn-right .icon-badge, #btn-right .icon-glyph { stroke: #c2410c; }
  #btn-right .icon-fill { fill: #c2410c; }

  #btn-reset .icon-badge, #btn-reset .icon-glyph { stroke: #7c3aed; }
  #btn-reset .icon-fill { fill: #7c3aed; }

  #btn-next-map .icon-badge, #btn-next-map .icon-glyph { stroke: #0f766e; }
  #btn-next-map .icon-fill { fill: #0f766e; }

  #btn-mute .icon-badge, #btn-mute .icon-glyph { stroke: #334155; }
  #btn-mute .icon-fill { fill: #334155; }

  .control-btn:focus-visible {
    outline: 4px solid #fde047;
    outline-offset: 2px;
  }

  .control-btn:hover {
    background: #ecfeff;
    box-shadow: 0 6px 10px rgba(0,0,0,0.22);
  }

  .control-btn:active {
    transform: scale(0.94);
  }

  .blackout-toggle-btn {
    background: #0f172a;
    border-color: #0f172a;
  }

  .blackout-toggle-btn .icon-eye-open .icon-badge {
    fill: #ffffff;
    stroke: #0f172a;
  }

  .blackout-toggle-btn .icon-eye-open .icon-fill {
    fill: #0f172a;
  }

  .blackout-toggle-btn .icon-eye-closed .icon-glyph {
    stroke: #ffffff;
  }

  .blackout-toggle-btn .icon-eye-closed,
  .control-btn .icon-sound-off {
    display: none;
  }

  .blackout-toggle-btn.is-active .icon-eye-open,
  .control-btn.is-muted .icon-sound-on {
    display: none;
  }

  .blackout-toggle-btn.is-active .icon-eye-closed,
  .control-btn.is-muted .icon-sound-off {
    display: block;
  }

  .game-container.blackout-active .grid {
    visibility: hidden;
  }

  .game-container.blackout-active .grid-container {
    background: #000;
  }

  .game-container.blackout-active .map-title {
    opacity: 0.15;
  }

  .game-container.blackout-active .movement-controls {
    left: 50%;
    top: 50%;
    bottom: auto;
    transform: translate(-50%, -50%);
    flex-direction: row;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.5);
    gap: 14px;
    padding: 16px 18px;
  }

  .game-container.blackout-active .utility-controls {
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.4);
  }

  .game-container.blackout-active .movement-controls .control-btn {
    width: 82px;
    height: 82px;
  }

  .game-container.blackout-active .blackout-toggle-btn {
    order: 0;
    background: #e53935;
    color: #ffffff;
    border: 2px solid #fff;
  }

  .control-btn .icon-glyph.danger {
    stroke: #dc2626;
  }

  .grid-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    overflow: hidden;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(21, 1fr);
    grid-template-rows: repeat(12, 1fr);
    gap: 0;
    aspect-ratio: 21/12;
    width: 100%;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    background-color: #7ab371; /* Grass color for outside */
    padding: 0;
    border-radius: 0;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    overflow: visible;
  }

  .grid :global(.cell) {
    background: transparent;
    display: grid;
    place-items: center;
    position: relative;
    box-sizing: border-box;
    border: none;
    --wall-top-shadow: inset 0 0 0 0 transparent;
    --wall-bottom-shadow: inset 0 0 0 0 transparent;
    --wall-left-shadow: inset 0 0 0 0 transparent;
    --wall-right-shadow: inset 0 0 0 0 transparent;
    box-shadow: var(--wall-top-shadow), var(--wall-bottom-shadow), var(--wall-left-shadow), var(--wall-right-shadow);
  }

  /* Interior styling */
  .grid :global(.cell.interior) {
    background-color: #e3c099;
  }

  /* Wall lines via inset shadows (visual only; does not change content box) */
  .grid :global(.wall-top) { --wall-top-shadow: inset 0 4px 0 0 #6b4f3a; }
  .grid :global(.wall-bottom) { --wall-bottom-shadow: inset 0 -4px 0 0 #6b4f3a; }
  .grid :global(.wall-left) { --wall-left-shadow: inset 4px 0 0 0 #6b4f3a; }
  .grid :global(.wall-right) { --wall-right-shadow: inset -4px 0 0 0 #6b4f3a; }

  .grid :global(.cell.location) {
    z-index: 5;
    border-radius: 8px;
    border: 2px solid rgba(255, 255, 255, 0.6) !important;
    box-shadow: var(--wall-top-shadow), var(--wall-bottom-shadow), var(--wall-left-shadow), var(--wall-right-shadow), 0 2px 4px rgba(0,0,0,0.2);
    overflow: visible;
  }

  .grid :global(.road-layer) {
    position: absolute ;
    top: 0 ; 
    left: 0 ; 
    width: 100% ; 
    height: 100% ;
    background-size: cover ;
    background-repeat: no-repeat ;
    background-position: center ;
    z-index: 1 ;
    pointer-events: none;
    display: block;
    transform-origin: center center;
    image-rendering: pixelated;
  }

  .grid :global(.cell.out-of-bounds) {
    background-color: rgba(255, 0, 0, 0.6) !important;
  }

  .grid :global(.player) {
    grid-area: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .grid :global(.player.custom-avatar)::before {
    content: "";
    position: absolute;
    width: 86%;
    height: 86%;
    border-radius: 999px;
    background: #ffffff;
    border: 2px solid rgba(15, 23, 42, 0.24);
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.18);
    z-index: 0;
    pointer-events: none;
  }

  .grid :global(.player.first-visit-highlight)::after {
    content: "";
    position: absolute;
    width: 82%;
    height: 82%;
    border-radius: 999px;
    border: 3px solid #24b74b;
    box-shadow: 0 0 0 3px rgba(36, 183, 75, 0.35), 0 0 18px rgba(36, 183, 75, 0.6);
    animation: first-visit-pulse 1.2s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes first-visit-pulse {
    0%, 100% {
      transform: scale(0.92);
      opacity: 0.75;
    }
    50% {
      transform: scale(1.04);
      opacity: 1;
    }
  }

  .grid :global(.player-image) {
    width: 80%;
    height: 80%;
    object-fit: contain;
    transition: transform 0.2s ease;
    position: relative;
    z-index: 1;
  }

  .grid :global(.location-label) {
    font-size: clamp(8px, 1.2vw, 12px);
    font-weight: bold;
    color: #000;
    background: #ffd93d; /* Yellow from palette */
    padding: 2px 4px;
    border-radius: 4px;
    pointer-events: none;
    z-index: 10;
    position: absolute;
    bottom: -6px; /* Moved down slightly to hang over edge if needed */
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    width: max-content;
    border: 1px solid rgba(0,0,0,0.1);
    box-shadow: 0 1px 2px rgba(0,0,0,0.2);
  }

  .grid :global(.explosion-effect) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    z-index: 200;
    pointer-events: none;
    object-fit: fill;
  }

  .grid :global(.item-icon) {
    font-size: 2rem;
    z-index: 6;
    position: absolute;
  }

  .avatar-tool-btn {
    position: absolute;
    left: 10px;
    bottom: 14px;
    z-index: 1000;
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    padding: 0;
    border-radius: 12px;
    border: 3px solid #0f172a;
    background: #fff2cc;
    color: #0f172a;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.22);
    cursor: pointer;
  }

  .avatar-tool-btn__icon {
    width: 34px;
    height: 34px;
    display: block;
  }

  .avatar-tool-btn:focus-visible {
    outline: 4px solid #fde047;
    outline-offset: 2px;
  }

  .avatar-tool-btn:active {
    transform: scale(0.96);
  }

  .avatar-modal {
    position: absolute;
    inset: 0;
    z-index: 1200;
    display: grid;
    place-items: center;
    padding: 1rem;
    background: rgba(2, 6, 23, 0.58);
  }

  .avatar-modal.hidden {
    display: none;
  }

  .avatar-modal__card {
    width: min(430px, 96vw);
    border-radius: 16px;
    border: 3px solid #1e3a8a;
    background: #f8fbff;
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.35);
    padding: 0.9rem;
    color: #0f172a;
  }

  .avatar-modal__card h2 {
    margin: 0;
    font-size: 1.3rem;
  }

  .avatar-modal__card p {
    margin: 0.35rem 0 0.75rem;
    font-size: 0.95rem;
  }

  .avatar-modal__canvas-wrap {
    border-radius: 12px;
    border: 3px solid #1e3a8a;
    background: #ffffff;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 1 / 1;
  }

  #avatar-canvas {
    display: block;
    width: 100%;
    height: 100%;
    touch-action: none;
    cursor: crosshair;
  }

  .avatar-modal__actions {
    margin-top: 0.7rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .avatar-modal__actions button {
    min-height: 44px;
    border-radius: 10px;
    border: 2px solid #1e3a8a;
    background: #dbeafe;
    color: #1e3a8a;
    font-family: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  #btn-avatar-apply {
    border-color: #065f46;
    background: #d1fae5;
    color: #065f46;
  }

  #btn-avatar-use-default {
    border-color: #7c2d12;
    background: #ffedd5;
    color: #7c2d12;
  }

  .avatar-modal__actions button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (max-width: 900px) {
    .map-title {
      display: none;
    }

    .avatar-tool-btn {
      display: none;
    }

    .utility-controls {
      top: 10px;
      right: 50%;
      transform: translateX(50%);
      flex-direction: row;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 14px;
    }

    .utility-controls .control-btn {
      width: 56px;
      height: 56px;
    }

    .utility-controls .control-btn .control-icon {
      width: 34px;
      height: 34px;
    }

    .grid :global(.item-icon) {
      display: none;
    }
  }
</style>

<script is:inline define:vars={{
  playerImageSrc: lilMeow.src,
  explosionSrc: boomGif.src,
  roadMap,
  roomMap
}}>
  /**
   * TILE / GRID NOTES (quick reference)
   *
   * - Grid size is fixed: 21 columns (x=0..20) and 12 rows (y=0..11).
   * - Coordinates: (0,0) is top-left. x increases → right, y increases ↓ down.
  * - The "school" interior area is not a tilemap; it’s defined per-level as either:
  *     - a rectangle (default for existing maps), or
  *     - an irregular mask built from rects + holes (used for custom building shapes).
  *   Cells inside the interior mask get the beige interior background; outside stays green.
  * - Walls are derived from the interior mask: if a neighbor cell is outside the mask, a wall
  *   border is drawn on that side. Entrances are just “open sides” where we skip drawing a wall.
   * - Roads/locations/items are sparse overlays: only cells listed in arrays get a road sprite,
   *   room image/label, or item icon.
   * - IMPORTANT: A road entry can exist under a location image; it’s just visually covered.
   *   If you see a “road on a room”, remove/move that road coordinate.
   *
   * ROAD TILE PIECES (how to choose images)
   * - straight-horizontal / straight-vertical: simple segments.
   * - corner-* : turn corners (e.g. corner-bot-right).
   * - end-* : dead-end caps. Only use if you intentionally want a dead end.
  * - t-shape-* : 3-way intersections. In this sprite set, the suffix indicates the “stem/open” direction:
  *     - t-shape-up = connects UP + left/right (missing DOWN)
  *     - t-shape-down = connects DOWN + left/right (missing UP)
  *     - t-shape-left = connects LEFT + up/down (missing RIGHT)
  *     - t-shape-right = connects RIGHT + up/down (missing LEFT)
   * - cross: 4-way intersection.
   */

  // Level Configuration
  const SCHOOL_SHIFT_Y = -1;

  const DEFAULT_INTERIOR = {
    rects: [{ x1: 2, y1: 0, x2: 18, y2: 10 }],
    holes: [],
    // Bottom-left opening (keeps the classic entrance gap)
    entrance: { x: 2, y: 10, open: ['left', 'bottom'] },
  };

  function shiftPosY(pos, dy) {
    return { ...pos, y: pos.y + dy };
  }

  function shiftLevelY(level, dy) {
    const interior = level.interior
      ? {
          ...level.interior,
          rects: (level.interior.rects || []).map((r) => ({ ...r, y1: r.y1 + dy, y2: r.y2 + dy })),
          holes: (level.interior.holes || []).map((h) => ({ ...h, y1: h.y1 + dy, y2: h.y2 + dy })),
          entrance: level.interior.entrance
            ? { ...level.interior.entrance, y: level.interior.entrance.y + dy }
            : undefined,
        }
      : undefined;

    return {
      ...level,
      startPos: shiftPosY(level.startPos, dy),
      locations: (level.locations || []).map((loc) => ({ ...loc, y: loc.y + dy })),
      roads: (level.roads || []).map((r) => ({ ...r, y: r.y + dy })),
      items: (level.items || []).map((i) => ({ ...i, y: i.y + dy })),
      interior,
    };
  }

  function clamp(n, min, max) {
    return Math.max(min, Math.min(max, n));
  }

  function keyFor(x, y) {
    return `${x},${y}`;
  }

  function buildInteriorSet(level) {
    const interior = level.interior || DEFAULT_INTERIOR;
    const rects = interior.rects || [];
    const holes = interior.holes || [];
    const set = new Set();

    for (const r of rects) {
      const x1 = clamp(Math.min(r.x1, r.x2), 0, 20);
      const x2 = clamp(Math.max(r.x1, r.x2), 0, 20);
      const y1 = clamp(Math.min(r.y1, r.y2), 0, 11);
      const y2 = clamp(Math.max(r.y1, r.y2), 0, 11);
      for (let y = y1; y <= y2; y++) {
        for (let x = x1; x <= x2; x++) {
          set.add(keyFor(x, y));
        }
      }
    }

    for (const h of holes) {
      const x1 = clamp(Math.min(h.x1, h.x2), 0, 20);
      const x2 = clamp(Math.max(h.x1, h.x2), 0, 20);
      const y1 = clamp(Math.min(h.y1, h.y2), 0, 11);
      const y2 = clamp(Math.max(h.y1, h.y2), 0, 11);
      for (let y = y1; y <= y2; y++) {
        for (let x = x1; x <= x2; x++) {
          set.delete(keyFor(x, y));
        }
      }
    }

    return set;
  }

  function getEntranceConfig(level) {
    const interior = level.interior || DEFAULT_INTERIOR;
    return interior.entrance || null;
  }

  function buildCoordIndex(arr) {
    const map = new Map();
    for (const it of arr || []) {
      const k = keyFor(it.x, it.y);
      // Keep first item so behavior matches previous Array.find() semantics.
      if (!map.has(k)) map.set(k, it);
    }
    return map;
  }

  function pickRoadImageFromNeighbors(up, right, down, left) {
    const count = (up ? 1 : 0) + (right ? 1 : 0) + (down ? 1 : 0) + (left ? 1 : 0);

    if (count === 4) return 'cross';

    if (count === 3) {
      if (!up) return 't-shape-down';
      if (!right) return 't-shape-left';
      if (!down) return 't-shape-up';
      return 't-shape-right';
    }

    if (count === 2) {
      if (up && down) return 'straight-vertical';
      if (left && right) return 'straight-horizontal';
      if (up && right) return 'corner-top-right';
      if (right && down) return 'corner-bot-right';
      if (down && left) return 'corner-bot-left';
      return 'corner-top-left';
    }

    if (count === 1) {
      if (up) return 'end-up';
      if (right) return 'end-right';
      if (down) return 'end-down';
      return 'end-left';
    }

    return 'end-up';
  }

  function fillInteriorRoads(level) {
    const interiorSet = buildInteriorSet(level);
    const locationByKey = buildCoordIndex(level.locations);
    const roadByKey = buildCoordIndex(level.roads);

    // Fill every interior tile that isn't a location.
    for (const k of interiorSet) {
      if (locationByKey.has(k) || roadByKey.has(k)) continue;
      const [xStr, yStr] = k.split(',');
      roadByKey.set(k, { x: Number(xStr), y: Number(yStr), image: 'straight-horizontal' });
    }

    const hasConnection = (x, y) => {
      const k = keyFor(x, y);
      return roadByKey.has(k) || locationByKey.has(k);
    };
    for (const [k, road] of roadByKey.entries()) {
      const [xStr, yStr] = k.split(',');
      const x = Number(xStr);
      const y = Number(yStr);
      road.image = pickRoadImageFromNeighbors(
        hasConnection(x, y - 1),
        hasConnection(x + 1, y),
        hasConnection(x, y + 1),
        hasConnection(x - 1, y)
      );
    }

    level.roads = [...roadByKey.values()];
  }

