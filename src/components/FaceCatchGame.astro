<div class="face-catch-game" id="face-catch-game">

  <!-- HUD -->
  <header class="hud">
    <div class="hud-card">
      <span class="hud-label">Score</span>
      <span class="hud-value" id="fcc-score">0</span>
    </div>
    <div class="hud-card">
      <span class="hud-label">Best</span>
      <span class="hud-value" id="fcc-best">0</span>
    </div>
    <div class="hud-card lives-card">
      <span class="hud-label">Lives</span>
      <span class="hud-value" id="fcc-lives">❤️❤️❤️</span>
    </div>
  </header>

  <!-- Game canvas area -->
  <div class="canvas-wrap">
    <video id="fcc-video" autoplay playsinline muted></video>
    <canvas id="fcc-canvas"></canvas>

    <!-- Idle screen -->
    <div class="overlay-screen" id="fcc-screen-idle">
      <p class="screen-title">Catch</p>
      <p class="screen-sub">Move your face to catch blue circles and dodge red X!</p>
      <div class="mode-btns">
        <button id="fcc-btn-time" class="primary-btn">
          Time Attack
          <span class="btn-sub">60 seconds / 60秒</span>
        </button>
        <button id="fcc-btn-endless" class="primary-btn btn-endless">
          Endless
          <span class="btn-sub">How long can you last? / どこまでいける？</span>
        </button>
      </div>
      <p class="screen-note">Camera access required / カメラが必要です</p>
    </div>

    <!-- Loading screen -->
    <div class="overlay-screen hidden" id="fcc-screen-loading">
      <div class="spinner"></div>
      <p class="screen-title" style="font-size:1.5rem">Loading…</p>
      <p class="screen-sub" id="fcc-loading-msg">Starting up…</p>
    </div>

    <!-- Countdown screen -->
    <div class="overlay-screen hidden" id="fcc-screen-countdown">
      <p class="screen-countdown" id="fcc-countdown">3</p>
    </div>

    <!-- Game Over screen -->
    <div class="overlay-screen hidden" id="fcc-screen-gameover">
      <div class="gameover-card">
        <p class="gameover-label">Game Over</p>
        <p class="gameover-score" id="fcc-final-score">0</p>
        <p class="gameover-meta">points</p>
        <p class="gameover-best" id="fcc-gameover-best"></p>
        <button id="fcc-btn-restart" class="primary-btn">Play Again</button>
      </div>
    </div>
  </div>



</div>

<style>
  .face-catch-game {
    --bg-1: #1a1a2e;
    --bg-2: #16213e;
    --panel: rgba(255, 255, 255, 0.07);
    --border: rgba(255, 255, 255, 0.1);
    --ink: #e8eaf6;
    --muted: #9fa8da;

    position: relative;
    width: min(860px, 94vw);
    margin: 2rem auto;
    padding: 1rem;
    border-radius: 24px;
    background: linear-gradient(150deg, var(--bg-1), var(--bg-2));
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.5);
    font-family: "Trebuchet MS", "Segoe UI", sans-serif;
    color: var(--ink);
  }

  /* HUD */
  .hud {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
    margin-bottom: 0.85rem;
  }

  .hud-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 0.6rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .hud-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hud-value {
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1;
  }

  /* Canvas wrap */
  .canvas-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #000;
    border-radius: 18px;
    overflow: hidden;
  }

  #fcc-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    pointer-events: none;
  }

  #fcc-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Overlay screens */
  .overlay-screen {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    background: rgba(8, 8, 25, 0.86);
    backdrop-filter: blur(6px);
    border-radius: 18px;
    text-align: center;
    padding: 1.5rem;
    z-index: 10;
  }

  .overlay-screen.hidden {
    display: none;
  }

  .screen-title {
    margin: 0;
    font-size: clamp(2rem, 6vw, 3.2rem);
    font-weight: 900;
    line-height: 1.1;
  }

  .screen-sub {
    margin: 0;
    font-size: 1rem;
    color: var(--muted);
    max-width: 340px;
    line-height: 1.5;
  }

  .screen-note {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(159, 168, 218, 0.6);
  }

  .screen-countdown {
    margin: 0;
    font-size: clamp(5rem, 18vw, 10rem);
    font-weight: 900;
    color: #fff;
    text-shadow: 0 0 60px rgba(80, 180, 255, 0.9);
    animation: countdown-pop 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* Buttons */
  .mode-btns {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .primary-btn {
    border: none;
    border-radius: 12px;
    background: #2979ff;
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    padding: 0.75rem 1.6rem;
    cursor: pointer;
    transition: filter 0.12s, transform 0.1s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .btn-sub {
    font-size: 0.72rem;
    font-weight: 400;
    opacity: 0.8;
  }

  .btn-endless {
    background: #7c3aed;
  }

  .primary-btn:hover {
    filter: brightness(1.18);
    transform: scale(1.03);
  }

  .primary-btn:active {
    transform: scale(0.97);
  }

  /* Loading spinner */
  .spinner {
    width: 44px;
    height: 44px;
    border: 4px solid rgba(255, 255, 255, 0.15);
    border-top-color: #2979ff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  /* Game Over card */
  .gameover-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 22px;
    padding: 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .gameover-label {
    margin: 0;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .gameover-score {
    margin: 0.2rem 0 0;
    font-size: clamp(3.5rem, 12vw, 6rem);
    font-weight: 900;
    line-height: 1;
  }

  .gameover-meta {
    margin: 0;
    font-size: 0.95rem;
    color: var(--muted);
  }

  .gameover-best {
    margin: 0.3rem 0 0.6rem;
    font-size: 0.9rem;
    color: #ffd740;
    font-weight: 700;
    min-height: 1.2em;
  }

  /* Animations */
  @keyframes countdown-pop {
    0% { opacity: 0; transform: scale(0.5); }
    60% { opacity: 1; transform: scale(1.12); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 640px) {
    .howto-grid {
      flex-direction: column;
      gap: 0.6rem;
    }
  }
</style>

<script type="module" is:inline>
  // ── DOM refs ──────────────────────────────────────────────────────────────
  const video          = document.getElementById('fcc-video');
  const canvas         = document.getElementById('fcc-canvas');
  const ctx            = canvas.getContext('2d');
  const scoreEl        = document.getElementById('fcc-score');
  const bestEl         = document.getElementById('fcc-best');
  const livesEl        = document.getElementById('fcc-lives');
  const screenIdle     = document.getElementById('fcc-screen-idle');
  const screenLoad     = document.getElementById('fcc-screen-loading');
  const screenCount    = document.getElementById('fcc-screen-countdown');
  const screenOver     = document.getElementById('fcc-screen-gameover');
  const countdownEl    = document.getElementById('fcc-countdown');
  const loadMsgEl      = document.getElementById('fcc-loading-msg');
  const finalScoreEl   = document.getElementById('fcc-final-score');
  const gameoverBestEl = document.getElementById('fcc-gameover-best');
  const btnTime        = document.getElementById('fcc-btn-time');
  const btnEndless     = document.getElementById('fcc-btn-endless');
  const btnRestart     = document.getElementById('fcc-btn-restart');

  // ── Canvas resolution ─────────────────────────────────────────────────────
  const W = 640, H = 480;
  canvas.width  = W;
  canvas.height = H;

  // ── Game config ───────────────────────────────────────────────────────────
  const MAX_LIVES    = 3;
  const SPAWN_MS     = 1600;
  const BASE_SPEED   = 0.0028; // progress per frame (~6s at 60fps)
  const MAX_SPEED    = 0.007;  // cap for time mode (~2.4s)
  const BAD_CHANCE   = 0.3;    // 30% red X
  const ITEM_R       = 26;     // fixed radius
  const HEART_R      = 38;     // collision radius of heart
  const TIME_LIMIT   = 60;     // seconds for time attack

  // ── Game state ────────────────────────────────────────────────────────────
  let state        = 'idle';
  let gameMode     = 'time';   // 'time' | 'endless'
  let score        = 0;
  let lives        = MAX_LIVES;
  let items        = [];
  let effects      = [];
  let missFlash    = 0;
  let nextId       = 0;
  let frameId      = null;
  let spawnTimer   = null;
  let faceDetected = false;
  let gameStartTime = 0;
  let timeLeft      = TIME_LIMIT;

  // Heart position (canvas coords, follows nose)
  let heartX = W / 2, heartY = H / 2;

  // ── MediaPipe ─────────────────────────────────────────────────────────────
  let faceLandmarker = null;

  // ── Persistence ───────────────────────────────────────────────────────────
  const LS_KEY_TIME    = 'fcc-best-time';
  const LS_KEY_ENDLESS = 'fcc-best-endless';
  let bestScore = 0;

  function loadBest() {
    const key = gameMode === 'time' ? LS_KEY_TIME : LS_KEY_ENDLESS;
    bestScore = parseInt(localStorage.getItem(key) ?? '0', 10);
  }

  function saveBest() {
    const key = gameMode === 'time' ? LS_KEY_TIME : LS_KEY_ENDLESS;
    localStorage.setItem(key, String(bestScore));
  }

  // ── Helpers ───────────────────────────────────────────────────────────────
  const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

  function showScreen(name) {
    for (const el of [screenIdle, screenLoad, screenCount, screenOver]) {
      el.classList.add('hidden');
    }
    if (name === 'idle')      screenIdle.classList.remove('hidden');
    if (name === 'loading')   screenLoad.classList.remove('hidden');
    if (name === 'countdown') screenCount.classList.remove('hidden');
    if (name === 'gameover')  screenOver.classList.remove('hidden');
  }

  function updateHud() {
    scoreEl.textContent = String(score);
    bestEl.textContent  = String(bestScore);
    livesEl.textContent = '❤️'.repeat(lives) + '🖤'.repeat(MAX_LIVES - lives);
  }

  function itemSpeed() {
    if (gameMode === 'endless') {
      const elapsed = (performance.now() - gameStartTime) / 1000;
      return BASE_SPEED + elapsed * 0.00018; // no cap — gets faster forever
    }
    // time mode: score-based, capped
    return Math.min(BASE_SPEED + (score / 200) * (MAX_SPEED - BASE_SPEED), MAX_SPEED);
  }

  function drawTimerOverlay() {
    if (gameMode !== 'time') return;
    const secs = Math.ceil(timeLeft);
    ctx.save();
    ctx.fillStyle    = secs <= 10 ? '#ff5252' : 'rgba(255,255,255,0.85)';
    ctx.font         = `bold 20px sans-serif`;
    ctx.textAlign    = 'right';
    ctx.textBaseline = 'top';
    ctx.fillText(`${secs}s`, W - 12, 12);
    ctx.restore();
  }

  // ── MediaPipe init ────────────────────────────────────────────────────────
  async function initMediaPipe() {
    loadMsgEl.textContent = 'Loading AI model… (first load may take a moment)';
    const { FaceLandmarker, FilesetResolver } = await import(
      'https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.14/vision_bundle.mjs'
    );
    const vision = await FilesetResolver.forVisionTasks(
      'https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.14/wasm'
    );
    faceLandmarker = await FaceLandmarker.createFromOptions(vision, {
      baseOptions: {
        modelAssetPath:
          'https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task',
        delegate: 'GPU',
      },
      runningMode: 'VIDEO',
      numFaces: 1,
      outputFaceBlendshapes: false,
      outputFacialTransformationMatrixes: false,
    });
  }

  // ── Camera init ───────────────────────────────────────────────────────────
  async function initCamera() {
    loadMsgEl.textContent = 'Requesting camera access…';
    const stream = await navigator.mediaDevices.getUserMedia({
      video: { width: { ideal: 640 }, height: { ideal: 480 }, facingMode: 'user' },
      audio: false,
    });
    video.srcObject = stream;
    await new Promise((res) => { video.onloadedmetadata = res; });
    await video.play();
  }

  // ── Countdown ─────────────────────────────────────────────────────────────
  async function runCountdown() {
    showScreen('countdown');
    for (let n = 3; n >= 1; n--) {
      countdownEl.textContent = String(n);
      countdownEl.style.animation = 'none';
      void countdownEl.offsetWidth;
      countdownEl.style.animation = '';
      await sleep(850);
    }
    countdownEl.textContent = 'GO!';
    countdownEl.style.animation = 'none';
    void countdownEl.offsetWidth;
    countdownEl.style.animation = '';
    await sleep(600);
  }

  // ── Spawning ──────────────────────────────────────────────────────────────
  function spawnItem() {
    if (state !== 'playing') return;
    const pad = ITEM_R + 4;
    let startX, startY, endX, endY;
    const edge = Math.floor(Math.random() * 4);
    if (edge === 0) {       // left → right
      startX = -pad; startY = pad + Math.random() * (H - pad * 2);
      endX   = W + pad; endY = pad + Math.random() * (H - pad * 2);
    } else if (edge === 1) { // right → left
      startX = W + pad; startY = pad + Math.random() * (H - pad * 2);
      endX   = -pad;    endY   = pad + Math.random() * (H - pad * 2);
    } else if (edge === 2) { // top → bottom
      startX = pad + Math.random() * (W - pad * 2); startY = -pad;
      endX   = pad + Math.random() * (W - pad * 2); endY   = H + pad;
    } else {                 // bottom → top
      startX = pad + Math.random() * (W - pad * 2); startY = H + pad;
      endX   = pad + Math.random() * (W - pad * 2); endY   = -pad;
    }
    items.push({
      id: nextId++, startX, startY, endX, endY,
      progress: 0, speed: itemSpeed(),
      type: Math.random() < BAD_CHANCE ? 'bad' : 'good',
    });
  }

  function startSpawning() {
    stopSpawning();
    spawnItem();
    spawnTimer = setInterval(() => { if (state === 'playing') spawnItem(); }, SPAWN_MS);
  }

  function stopSpawning() {
    if (spawnTimer) { clearInterval(spawnTimer); spawnTimer = null; }
  }

  // ── Face detection ────────────────────────────────────────────────────────
  function detectFace() {
    if (!faceLandmarker || video.readyState < 2) return;
    const results = faceLandmarker.detectForVideo(video, performance.now());
    if (results.faceLandmarks.length > 0) {
      faceDetected = true;
      const lm   = results.faceLandmarks[0];
      // Landmark 1 = nose tip — good center-of-face anchor
      const nose = lm[1];
      const tx   = (1 - nose.x) * W; // mirror X for selfie
      const ty   = nose.y * H;
      heartX = heartX * 0.7 + tx * 0.3;
      heartY = heartY * 0.7 + ty * 0.3;
    } else {
      faceDetected = false;
    }
  }

  // ── Drawing ───────────────────────────────────────────────────────────────
  function drawBackground() {
    // Mirrored camera feed dimmed heavily so objects stand out
    ctx.save();
    ctx.scale(-1, 1);
    ctx.drawImage(video, -W, 0, W, H);
    ctx.restore();
    ctx.fillStyle = 'rgba(0, 0, 0, 0.72)';
    ctx.fillRect(0, 0, W, H);
  }

  function drawHeart(x, y) {
    // Canonical heart centered at (x, y) with fixed HEART_R size
    const s = HEART_R;
    ctx.save();
    ctx.beginPath();
    ctx.moveTo(x, y + s * 0.9);
    ctx.bezierCurveTo(x - s * 1.05, y + s * 0.25, x - s * 1.1, y - s * 0.55, x, y - s * 0.2);
    ctx.bezierCurveTo(x + s * 1.1,  y - s * 0.55, x + s * 1.05, y + s * 0.25, x, y + s * 0.9);
    ctx.closePath();
    ctx.fillStyle   = '#ff4d6d';
    ctx.shadowColor = 'rgba(255, 77, 109, 0.65)';
    ctx.shadowBlur  = 18;
    ctx.fill();
    ctx.restore();
  }

  function itemCoords(item) {
    const t = item.progress;
    return {
      x: item.startX + (item.endX - item.startX) * t,
      y: item.startY + (item.endY - item.startY) * t,
      r: ITEM_R,
    };
  }

  function drawItem(item) {
    const { x, y, r } = itemCoords(item);
    ctx.save();

    if (item.type === 'good') {
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle   = '#3b82f6';
      ctx.shadowColor = 'rgba(59,130,246,0.55)';
      ctx.shadowBlur  = 14;
      ctx.fill();
      ctx.strokeStyle = 'rgba(255,255,255,0.35)';
      ctx.lineWidth   = 2;
      ctx.stroke();
    } else {
      // Red circle
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle   = '#ef4444';
      ctx.shadowColor = 'rgba(239,68,68,0.55)';
      ctx.shadowBlur  = 14;
      ctx.fill();
      // X mark
      const arm = r * 0.52;
      ctx.strokeStyle = '#fff';
      ctx.lineWidth   = Math.max(1.5, r * 0.2);
      ctx.lineCap     = 'round';
      ctx.beginPath();
      ctx.moveTo(x - arm, y - arm); ctx.lineTo(x + arm, y + arm);
      ctx.moveTo(x + arm, y - arm); ctx.lineTo(x - arm, y + arm);
      ctx.stroke();
    }

    ctx.restore();
  }

  function drawEffects() {
    for (const e of effects) {
      const alpha = e.life / e.maxLife;
      ctx.save();
      ctx.globalAlpha  = alpha;
      ctx.fillStyle    = e.color;
      ctx.font         = `bold ${e.fontSize ?? 22}px sans-serif`;
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(e.text, e.x, e.y);
      ctx.restore();
      e.y   -= e.dy ?? 1.5;
      e.life--;
    }
    effects = effects.filter((e) => e.life > 0);
  }

  function drawNoFaceWarning() {
    ctx.save();
    ctx.fillStyle    = 'rgba(255, 210, 50, 0.9)';
    ctx.font         = 'bold 15px sans-serif';
    ctx.textAlign    = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText('Show your face! / 顔をカメラに見せて！', W / 2, 10);
    ctx.restore();
  }

  function drawMissFlash() {
    if (missFlash <= 0) return;
    ctx.save();
    ctx.globalAlpha = (missFlash / 22) * 0.5;
    ctx.fillStyle   = '#ff1f1f';
    ctx.fillRect(0, 0, W, H);
    ctx.restore();
    missFlash--;
  }

  // ── Main game loop ────────────────────────────────────────────────────────
  function gameLoop() {
    if (state !== 'playing') return;

    // 1. Camera feed with dark overlay
    drawBackground();

    // 2. Face detection → update heart position
    detectFace();

    // 3. Red flash feedback
    drawMissFlash();

    // 4. Freeze when no face
    if (!faceDetected) {
      for (const item of items) drawItem(item);
      drawNoFaceWarning();
      drawEffects();
      frameId = requestAnimationFrame(gameLoop);
      return;
    }

    // 5. Advance items & check per-frame collision
    const toRemove = [];
    for (const item of items) {
      item.progress += item.speed;
      const { x, y, r } = itemCoords(item);
      const dist = Math.hypot(x - heartX, y - heartY);
      const hit  = dist < HEART_R * 0.9 + r * 0.7;

      if (hit && !item.resolved) {
        item.resolved = true;
        toRemove.push({ item, hit: true });
      } else if (item.progress >= 1 && !item.resolved) {
        item.resolved = true;
        toRemove.push({ item, hit: false });
      }
    }
    items = items.filter((i) => !i.resolved || toRemove.find((t) => t.item === i));

    for (const { item, hit } of toRemove) {
      items = items.filter((i) => i !== item);
      const { x, y } = itemCoords(item);

      if (item.type === 'good') {
        if (hit) {
          score += 10;
          effects.push({ x, y: y - 10, text: '+10', color: '#69f0ae', life: 42, maxLife: 42, dy: 1.8 });
        } else {
          // No penalty for missing a good item
        }
        updateHud();
        if (lives <= 0) { endGame(); return; }
      } else {
        if (hit) {
          lives--;
          missFlash = 22;
          effects.push({ x, y, text: 'ouch', color: '#ff5252', life: 35, maxLife: 35, dy: 1.5, fontSize: 18 });
          updateHud();
          if (lives <= 0) { endGame(); return; }
        }
      }
    }

    // 6. Time mode: check timer
    if (gameMode === 'time') {
      timeLeft = TIME_LIMIT - (performance.now() - gameStartTime) / 1000;
      if (timeLeft <= 0) { timeLeft = 0; endGame(); return; }
    }

    // 7. Draw items
    for (const item of items) drawItem(item);

    // 8. Draw heart
    drawHeart(heartX, heartY);

    // 9. Floating text effects
    drawEffects();

    // 10. Timer overlay (time mode)
    drawTimerOverlay();

    frameId = requestAnimationFrame(gameLoop);
  }

  // ── Game lifecycle ────────────────────────────────────────────────────────
  function endGame() {
    state = 'gameover';
    stopSpawning();
    if (frameId) { cancelAnimationFrame(frameId); frameId = null; }
    if (score > bestScore) { bestScore = score; saveBest(); }
    document.querySelector('.gameover-label').textContent =
      gameMode === 'time' ? 'Time Up! / 終了！' : 'Game Over';
    finalScoreEl.textContent   = String(score);
    gameoverBestEl.textContent = score >= bestScore && score > 0 ? 'New Best!' : `Best: ${bestScore}`;
    showScreen('gameover');
  }

  async function startGame(mode) {
    gameMode = mode;
    loadBest();
    score = 0; lives = MAX_LIVES; items = []; effects = []; missFlash = 0;
    faceDetected = false;
    heartX = W / 2; heartY = H / 2;
    timeLeft = TIME_LIMIT;
    updateHud();

    state = 'loading';
    showScreen('loading');

    try {
      if (!video.srcObject) await initCamera();
      if (!faceLandmarker)  await initMediaPipe();
    } catch (err) {
      loadMsgEl.textContent = `Error: ${err.message}`;
      return;
    }

    await runCountdown();
    state = 'playing';
    gameStartTime = performance.now();
    showScreen('playing');
    startSpawning();
    frameId = requestAnimationFrame(gameLoop);
  }

  async function restartGame() {
    stopSpawning();
    if (frameId) { cancelAnimationFrame(frameId); frameId = null; }
    score = 0; lives = MAX_LIVES; items = []; effects = []; missFlash = 0;
    faceDetected = false;
    timeLeft = TIME_LIMIT;
    updateHud();

    await runCountdown();
    state = 'playing';
    gameStartTime = performance.now();
    showScreen('playing');
    startSpawning();
    frameId = requestAnimationFrame(gameLoop);
  }

  // ── Button listeners ──────────────────────────────────────────────────────
  btnTime.addEventListener('click',    () => startGame('time'));
  btnEndless.addEventListener('click', () => startGame('endless'));
  btnRestart.addEventListener('click', restartGame);

  // ── Init HUD ──────────────────────────────────────────────────────────────
  updateHud();
</script>
