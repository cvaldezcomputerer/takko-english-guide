<section class="draw-bg-game" id="draw-bg-game">
  <header class="draw-bg-game__header">
    <h1>Draw-to-Background Demo</h1>
    <p>Draw anything, then apply it as the game area background.</p>
  </header>

  <div class="draw-bg-game__layout">
    <aside class="draw-bg-game__panel">
      <p class="draw-bg-game__panel-title">Drawing Pad</p>
      <div class="draw-bg-game__canvas-wrap">
        <canvas id="drawing-canvas" aria-label="Drawing canvas"></canvas>
      </div>
      <div class="draw-bg-game__actions">
        <button id="btn-clear-drawing" type="button">Clear</button>
        <button id="btn-apply-drawing" type="button">Use as Background</button>
      </div>
    </aside>

    <div class="draw-bg-game__play-area" id="play-area">
      <p class="draw-bg-game__play-label">Game Area</p>
    </div>
  </div>
</section>

<style>
  .draw-bg-game {
    padding: 1rem;
    min-height: 100vh;
    background: #f1f6ff;
    color: #10243e;
    font-family: "M PLUS Rounded 1c", "Andika", sans-serif;
  }

  .draw-bg-game__header {
    text-align: center;
    margin-bottom: 1rem;
  }

  .draw-bg-game__header h1 {
    margin: 0;
    font-size: clamp(1.5rem, 4vw, 2.2rem);
  }

  .draw-bg-game__header p {
    margin: 0.4rem 0 0;
    font-size: 1rem;
  }

  .draw-bg-game__layout {
    display: grid;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    gap: 1rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .draw-bg-game__panel {
    background: #ffffff;
    border: 2px solid #bfd4f8;
    border-radius: 14px;
    padding: 0.9rem;
    box-shadow: 0 6px 18px rgba(16, 36, 62, 0.1);
  }

  .draw-bg-game__panel-title {
    margin: 0 0 0.6rem;
    font-weight: 700;
  }

  .draw-bg-game__canvas-wrap {
    border: 2px solid #2a4365;
    border-radius: 10px;
    overflow: hidden;
    background: #ffffff;
    aspect-ratio: 4 / 3;
  }

  #drawing-canvas {
    display: block;
    width: 100%;
    height: 100%;
    touch-action: none;
    cursor: crosshair;
  }

  .draw-bg-game__actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
    margin-top: 0.8rem;
  }

  .draw-bg-game__actions button {
    border: 2px solid #1f4b99;
    background: #dbeafe;
    color: #0b2d63;
    border-radius: 10px;
    min-height: 44px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
  }

  .draw-bg-game__actions button:focus-visible {
    outline: 3px solid #facc15;
    outline-offset: 2px;
  }

  .draw-bg-game__play-area {
    min-height: 420px;
    border-radius: 14px;
    border: 3px solid #2a4365;
    background-color: #d8f4e0;
    position: relative;
    overflow: hidden;
  }

  .draw-bg-game__play-label {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    margin: 0;
    padding: 0.35rem 0.55rem;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid #2a4365;
    border-radius: 8px;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .draw-bg-game__layout {
      grid-template-columns: 1fr;
    }

    .draw-bg-game__play-area {
      min-height: 320px;
    }
  }
</style>

<script>
  import SignaturePad from "signature_pad";

  const canvas = document.getElementById("drawing-canvas");
  const playArea = document.getElementById("play-area");
  const clearBtn = document.getElementById("btn-clear-drawing");
  const applyBtn = document.getElementById("btn-apply-drawing");

  if (!(canvas instanceof HTMLCanvasElement) || !playArea || !clearBtn || !applyBtn) {
    throw new Error("Draw background game UI failed to initialize.");
  }

  const signaturePad = new SignaturePad(canvas, {
    penColor: "#1e3a8a",
    minWidth: 2,
    maxWidth: 4,
    backgroundColor: "rgb(255,255,255)",
  });

  function resizeCanvas() {
    const ratio = Math.max(window.devicePixelRatio || 1, 1);
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * ratio;
    canvas.height = rect.height * ratio;
    const ctx = canvas.getContext("2d");
    if (ctx) ctx.scale(ratio, ratio);
    signaturePad.clear();
  }

  resizeCanvas();
  window.addEventListener("resize", resizeCanvas);

  clearBtn.addEventListener("click", () => {
    signaturePad.clear();
  });

  applyBtn.addEventListener("click", () => {
    if (signaturePad.isEmpty()) return;
    const drawnImage = signaturePad.toDataURL("image/png");
    playArea.style.backgroundImage = `url(${drawnImage})`;
    playArea.style.backgroundSize = "cover";
    playArea.style.backgroundPosition = "center";
    playArea.style.backgroundRepeat = "no-repeat";
  });
</script>
