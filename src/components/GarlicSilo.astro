---
// Closed outer silhouette of the garlic/cat logo — fillable with no holes.
// Path lives in src/data/garlic.ts (single source of truth).
import { GARLIC_SILO_PATH } from "../data/garlic";
const { class: className, ...props } = Astro.props;
---

<svg class:list={["garlic-silo", className]} viewBox="120 140 780 750" fill="currentColor" xmlns="http://www.w3.org/2000/svg" {...props}>
  <path d={GARLIC_SILO_PATH}/>
</svg>

<style>
  .garlic-silo {
    display: block;
    width: 1em;
    height: 1em;
  }
</style>
