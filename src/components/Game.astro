---
// Game.astro - School Map Navigation Game
import lilMeow from '../assets/game/lilMeow.png';
import boomGif from '../assets/game/boom.gif';
// Road images are now served from /public/game-roads/ for reliable dynamic access
---

<div class="game-container">
  <div class="status-bar" id="status-bar">You are at: Starting Point</div>
  
  <div class="grid-container">
    <div class="grid" id="grid">
      <!-- Grid cells will be rendered by JavaScript -->
    </div>
  </div>
  
  <div class="controls">
    <button class="control-btn" id="btn-left">⬅️ Left</button>
    <button class="control-btn" id="btn-straight">⬆️ Straight</button>
    <button class="control-btn" id="btn-right">➡️ Right</button>
    <button class="control-btn reset-btn" id="btn-reset">🔄 Reset</button>
  </div>
</div>

<style>
  .game-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100vh;
    padding: 1vh 2vw;
    box-sizing: border-box;
    background: #b4f1ae;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  .status-bar {
    background: rgba(97, 78, 78, 0.95);
    padding: 1.5vh 3vw;
    border-radius: 12px;
    font-size: clamp(14px, 2.5vh, 24px);
    font-weight: 600;
    color: #333;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    margin-bottom: 2vh;
    text-align: center;
    min-width: 250px;
  }

  .grid-container {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-height: 65vh;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(11, 1fr);
    grid-template-rows: repeat(10, 1fr);
    gap: 0;
    aspect-ratio: 11/10;
    width: min(65vh * 11/10, 90vw);
    height: min(65vh, 90vw * 10/11);
    background: transparent;
    padding: 0;
    border-radius: 0;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .grid :global(.cell) {
    background: rgb(255, 0, 0);
    border-radius: 0;
    display: grid;
    place-items: center;
    position: relative;
    transition: all 0.2s ease;
    overflow: hidden;
    min-width: 0;
    min-height: 0;
    isolation: isolate;
    box-sizing: border-box;
    border: none;
    margin: 0;
    padding: 0;
  }

  .grid :global(.cell.location) {
    padding: 0;
    background-color: transparent;
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
  }

  .grid :global(.road-layer) {
    position: absolute ;
    top: 0 ; 
    left: 0 ; 
    width: 100% ; 
    height: 100% ;
    background-size: cover ;
    background-repeat: no-repeat ;
    background-position: center ;
    z-index: 1 ;
    pointer-events: none;
    display: block;
    transform-origin: center center;
    image-rendering: pixelated;
  }

  .grid :global(.cell.road) {
    background-color: transparent;
    position: relative;
  }

  .grid :global(.cell.has-player) {
    background-color: rgba(76, 175, 80, 0.3);
    border: 2px solid #4caf50;
  }

  .grid :global(.player) {
    grid-area: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    width: 100%;
    height: 100%;
    overflow: hidden;
    position: absolute;
    top: 0;
    left: 0;
  }

  .grid :global(.player-image) {
    width: 80%;
    height: 80%;
    object-fit: contain;
    transition: transform 0.2s ease;
  }

  /* Road Rotation Utilities */
  .rotate-0 { transform: rotate(0deg); }
  .rotate-90 { transform: rotate(90deg); }
  .rotate-180 { transform: rotate(180deg); }
  .rotate-270 { transform: rotate(270deg); }

  .grid :global(.explosion-effect) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    z-index: 200;
    pointer-events: none;
    object-fit: fill;
  }
</style>

<script is:inline define:vars={{
  playerImageSrc: lilMeow.src,
  explosionSrc: boomGif.src,
  roadImages: {
    straight: '/game-roads/Straight.png',
    corner: '/game-roads/Corner.png',
    t_shape: '/game-roads/T-Shape.png',
    end: '/game-roads/End.png',
    cross: '/game-roads/Cross.png'
  }
}}>
  // Location data
  const locations = [
    { x: 2, y: 1, name: "Music Room", image: "/images/yo2.jpg" },
    { x: 7, y: 1, name: "Library", image: "/images/yo2.jpg" },
    { x: 1, y: 3, name: "Art Room", image: "/images/yo2.jpg" },
    { x: 5, y: 4, name: "Principal's Office", image: "/images/yo2.jpg" },
    { x: 8, y: 5, name: "Science Room", image: "/images/yo2.jpg" },
    { x: 3, y: 7, name: "Gym", image: "/images/yo2.jpg" },
    { x: 6, y: 8, name: "Nurse's Office", image: "/images/yo2.jpg" },
  ];

  // Mixed map with rotated and non-rotated tiles
  const roads = [
    // Start area
    { x: 5, y: 9, type: 'end', variant: 'south' },
    
    // Vertical path going up
    { x: 5, y: 8, type: 'straight', variant: 'vertical' },
    { x: 5, y: 7, type: 'straight', variant: 'vertical' },
    
    // Turn left (corner: coming from south, going west)
    { x: 5, y: 6, type: 't_shape', variant: 'left' },
    
    // Horizontal path going left
    { x: 4, y: 6, type: 'straight', variant: 'horizontal' },
    { x: 3, y: 6, type: 'straight', variant: 'horizontal' },
    
    // Turn up again
    { x: 2, y: 6, type: 'corner', variant: 'ne' },
    
    // Vertical path going up
    { x: 2, y: 5, type: 'straight', variant: 'vertical' },
    { x: 2, y: 4, type: 'straight', variant: 'vertical' },
    
    // T-junction (rotated to face right)
    { x: 2, y: 3, type: 't_shape', variant: 'right' },
    
    // Branch going up from T
    { x: 2, y: 2, type: 'end', variant: 'north' },
    
    // Branch going right from T
    { x: 3, y: 3, type: 'straight', variant: 'horizontal' },
    { x: 4, y: 3, type: 'straight', variant: 'horizontal' },
    { x: 5, y: 3, type: 'corner', variant: 'sw' },
    { x: 5, y: 4, type: 'straight', variant: 'vertical' },
    { x: 5, y: 5, type: 'cross', variant: 'all' },
    
    // Cross branches
    { x: 4, y: 5, type: 'end', variant: 'west' },
    { x: 6, y: 5, type: 'straight', variant: 'horizontal' },
    { x: 5, y: 4, type: 'straight', variant: 'vertical' },
    
    // Right side path
    { x: 7, y: 5, type: 't_shape', variant: '' },
    { x: 7, y: 6, type: 'straight', variant: 'vertical' },
    { x: 7, y: 7, type: 'end', variant: 'south' },
  ];

  // Game state
  let playerPos = { x: 5, y: 9 };
  let playerHeading = 0; // 0=North, 1=East, 2=South, 3=West

  // Direction vectors: [dx, dy] for each heading
  const directions = [
    { dx: 0, dy: -1 },  // North (up on grid)
    { dx: 1, dy: 0 },   // East (right)
    { dx: 0, dy: 1 },   // South (down on grid)
    { dx: -1, dy: 0 },  // West (left)
  ];

  // Heading to rotation degrees (Adjusted: 0=North faces Up)
  const headingToRotation = [0, 90, 180, 270];

  // Tile rotation mapping (Maps logical direction to CSS rotation degrees)
  const tileRotations = {
    straight: {
      horizontal: 90, // Need 90° rotation for horizontal
      vertical: 0     // No rotation needed for vertical
    },
    corner: {
      se: 0,    // Base: South-to-East └
      sw: 90,   // South-to-East -> South-to-West  
      nw: 180,  // South-to-East -> North-to-West
      ne: 270   // South-to-East -> North-to-East
    },
    t_shape: {
      down: 0,   // Base: South opening with West-East arms ┬
      left: 90,  // Rotate 90° - West opening with North-South arms
      up: 180,   // Rotate 180° - North opening with West-East arms
      right: 270 // Rotate 270° - East opening with North-South arms
    },
    end: {
      south: 180, // Base opens North, so South needs 180°
      west: 270,  // South -> West (was 90, now 270)
      north: 0,   // Base: Opens North ╵
      east: 90    // South -> East (was 270, now 90)
    },
    cross: {
      all: 0     // Source: + (Symmetrical)
    }
  };

  function getLocationAt(x, y) {
    return locations.find(loc => loc.x === x && loc.y === y);
  }

  function getRoadAt(x, y) {
    return roads.find(r => r.x === x && r.y === y);
  }

  function renderGrid() {
    const grid = document.getElementById("grid");
    if (!grid) return;
    
    grid.innerHTML = "";

    for (let y = 0; y < 10; y++) {
      for (let x = 0; x < 11; x++) {
        const cell = document.createElement("div");
        cell.className = "cell";
        
        const location = getLocationAt(x, y);
        const road = getRoadAt(x, y);
        
        const isPlayerHere = playerPos.x === x && playerPos.y === y;

        if (location) {
          cell.classList.add("location");
          cell.style.backgroundImage = `url('${location.image}')`;
          cell.style.backgroundSize = 'contain';
          cell.style.backgroundRepeat = 'no-repeat';
          cell.style.backgroundPosition = 'center';
          cell.title = location.name;
        } else if (road) {
          cell.classList.add("road");
          cell.style.position = "relative";
          
          // Create a separate background div for the road image
          const roadBg = document.createElement("div");
          roadBg.className = "road-layer";
          
          const imageSrc = roadImages[road.type];
          
          if (imageSrc) {
            // Apply background image to the separate div
            roadBg.style.backgroundImage = `url('${imageSrc}')`;
          }
          
          const rotation = tileRotations[road.type][road.variant];
          if (rotation !== undefined) {
            // Apply rotation only to the background div, not the cell
            roadBg.style.transform = `rotate(${rotation}deg)`;
          }
          
          cell.appendChild(roadBg);
        }

        if (isPlayerHere) {
          cell.classList.add("has-player");
          const playerEl = document.createElement("div");
          playerEl.className = "player";
          
          const img = document.createElement("img");
          img.src = playerImageSrc;
          img.className = "player-image";
          
          // Player rotation is now independent of cell/road rotation
          img.style.transform = `rotate(${headingToRotation[playerHeading]}deg)`;
          
          playerEl.appendChild(img);
          cell.appendChild(playerEl);
        }

        grid.appendChild(cell);
      }
    }
  }

  function updateStatus() {
    const statusBar = document.getElementById("status-bar");
    if (!statusBar) return;

    const location = getLocationAt(playerPos.x, playerPos.y);
    if (location) {
      statusBar.textContent = `You are at: ${location.name}`;
    } else {
      statusBar.textContent = `You are at: Hallway (${playerPos.x}, ${playerPos.y})`;
    }
  }

  function turnLeft() {
    playerHeading = (playerHeading + 3) % 4;
    renderGrid();
  }

  function turnRight() {
    playerHeading = (playerHeading + 1) % 4;
    renderGrid();
  }

  function goStraight() {
    const dir = directions[playerHeading];
    const newX = playerPos.x + dir.dx;
    const newY = playerPos.y + dir.dy;

    // Bounds check
    if (newX >= 0 && newX <= 10 && newY >= 0 && newY <= 9) {
      playerPos = { x: newX, y: newY };
      renderGrid();
      updateStatus();

      // Trigger explosion if player is NOT on a road AND NOT at a valid location
      if (!getRoadAt(newX, newY) && !getLocationAt(newX, newY)) {
        triggerExplosion(newX, newY);
      }
    }
  }

  function reset() {
    playerPos = { x: 5, y: 9 };
    playerHeading = 0;
    renderGrid();
    updateStatus();
  }

  // Function to play explosion effect at specific coordinates
  window.triggerExplosion = function(x, y) {
    const grid = document.getElementById("grid");
    if (!grid) return;
    
    // Calculate cell index: y * width + x
    const index = y * 11 + x;
    const cell = grid.children[index];
    
    if (cell) {
      const img = document.createElement("img");
      // Add timestamp to force restart of GIF animation
      img.src = explosionSrc + "?t=" + Date.now(); 
      img.className = "explosion-effect";
      cell.appendChild(img);
      
      // Remove after 1 second (adjust based on GIF duration)
      setTimeout(() => {
        img.remove();
      }, 1000);
    }
  };

  // Initialize
  document.addEventListener("DOMContentLoaded", () => {
    renderGrid();
    updateStatus();

    document.getElementById("btn-left")?.addEventListener("click", turnLeft);
    document.getElementById("btn-right")?.addEventListener("click", turnRight);
    document.getElementById("btn-straight")?.addEventListener("click", goStraight);
    document.getElementById("btn-reset")?.addEventListener("click", reset);
  });
</script>
