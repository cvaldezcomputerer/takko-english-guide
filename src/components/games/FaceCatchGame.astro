---
import badcat1  from "../../assets/DirectionsReactionGame/bad-cat-1.png";
import badcat10 from "../../assets/DirectionsReactionGame/bad-cat-10.png";
import badcat11 from "../../assets/DirectionsReactionGame/bad-cat-11.png";
import badcat2  from "../../assets/DirectionsReactionGame/bad-cat-2.jpg";
import badcat3  from "../../assets/DirectionsReactionGame/bad-cat-3.jpg";
import goodCat1  from "../../assets/DirectionsReactionGame/good-cat-1.png";
import goodCat10 from "../../assets/DirectionsReactionGame/good-cat-10.png";
import goodCat12 from "../../assets/DirectionsReactionGame/good-cat-12.png";
import goodCat2  from "../../assets/DirectionsReactionGame/good-cat-2.png";
import goodCat3  from "../../assets/DirectionsReactionGame/good-cat-3.png";
import goodCat4  from "../../assets/DirectionsReactionGame/good-cat-4.png";

const GOOD_IMGS = [goodCat1.src, goodCat2.src, goodCat3.src, goodCat4.src, goodCat10.src, goodCat12.src];
const BAD_IMGS  = [badcat1.src,  badcat2.src,  badcat3.src,  badcat10.src, badcat11.src];
---

<div
  class="face-catch-game"
  id="face-catch-game"
  data-good-images={JSON.stringify(GOOD_IMGS)}
  data-bad-images={JSON.stringify(BAD_IMGS)}
>

  <!-- HUD -->
  <header class="hud">
    <div class="hud-card">
      <span class="hud-label">Score</span>
      <span class="hud-value" id="fcc-score">0</span>
    </div>
    <div class="hud-card">
      <span class="hud-label">Best</span>
      <span class="hud-value" id="fcc-best">0</span>
    </div>
    <div class="hud-card">
      <span class="hud-label">Lives</span>
      <span class="hud-value" id="fcc-lives">❤️❤️❤️</span>
    </div>
  </header>

  <!-- Game canvas area -->
  <div class="canvas-wrap">
    <video id="fcc-video" autoplay playsinline muted></video>
    <canvas id="fcc-canvas"></canvas>

    <!-- Idle screen -->
    <div class="overlay-screen" id="fcc-screen-idle">
      <p class="screen-title">Catch</p>
      <p class="screen-sub">Catch the capital letters! / 大文字をキャッチしよう！</p>

      <div class="theme-row">
        <span class="theme-label">Players / 人数:</span>
        <div class="theme-btns" id="fcc-player-btns">
          <button class="theme-btn active" data-players="1">1</button>
          <button class="theme-btn" data-players="2">2</button>
          <button class="theme-btn" data-players="3">3</button>
          <button class="theme-btn" data-players="4">4</button>
          <button class="theme-btn" data-players="5">5</button>
        </div>
      </div>
      <p class="screen-note player-warn" id="fcc-player-warn"></p>

      <div class="mode-btns">
        <button id="fcc-btn-time" class="primary-btn">
          Time Attack
          <span class="btn-sub">60 seconds / 60秒</span>
        </button>
        <button id="fcc-btn-endless" class="primary-btn btn-endless">
          Endless
          <span class="btn-sub">How long can you last? / どこまでいける？</span>
        </button>
        <button id="fcc-btn-challenge" class="primary-btn btn-challenge">
          Challenge
          <span class="btn-sub">No emojis! / 絵文字なし！</span>
        </button>
      </div>
      <p class="screen-note">Camera access required / カメラが必要です</p>
    </div>

    <!-- Loading screen -->
    <div class="overlay-screen hidden" id="fcc-screen-loading">
      <div class="spinner"></div>
      <p class="screen-title" style="font-size:1.5rem">Loading…</p>
      <p class="screen-sub" id="fcc-loading-msg">Starting up…</p>
    </div>

    <!-- Countdown screen -->
    <div class="overlay-screen hidden" id="fcc-screen-countdown">
      <p class="screen-countdown" id="fcc-countdown">3</p>
    </div>

    <!-- Game Over screen -->
    <div class="overlay-screen hidden" id="fcc-screen-gameover">
      <div class="gameover-card">
        <p class="gameover-label">Game Over</p>
        <p class="gameover-score" id="fcc-final-score">0</p>
        <p class="gameover-meta">points</p>
        <p class="gameover-best" id="fcc-gameover-best"></p>
        <button id="fcc-btn-restart" class="primary-btn">Play Again</button>
      </div>
    </div>
  </div>

  <!-- Feedback image — outside canvas-wrap so overflow:hidden doesn't clip it -->
  <img id="fcc-feedback-img" class="fcc-feedback-img" src="" alt="" aria-hidden="true" />

</div>

<style>
  .face-catch-game {
    --bg-1: #1a1a2e;
    --bg-2: #16213e;
    --panel: rgba(255, 255, 255, 0.07);
    --border: rgba(255, 255, 255, 0.1);
    --ink: #e8eaf6;
    --muted: #9fa8da;

    position: relative;
    width: min(1032px, 96vw);
    margin: 2rem auto;
    padding: 1rem;
    border-radius: var(--radius-xl);
    background: var(--bg-1);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.5);
    font-family: "Trebuchet MS", "Segoe UI", sans-serif;
    color: var(--ink);
  }

  /* HUD */
  .hud {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
    margin-bottom: 0.85rem;
  }

  .hud-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 0.6rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .hud-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hud-value {
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1;
  }

  /* Canvas wrap */
  .canvas-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #000;
    border-radius: 18px;
    overflow: hidden;
  }

  #fcc-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    pointer-events: none;
  }

  #fcc-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Overlay screens */
  .overlay-screen {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    background: rgba(8, 8, 25, 0.55);
    backdrop-filter: blur(10px);
    border-radius: 18px;
    text-align: center;
    padding: 1.5rem;
    z-index: 10;
  }

  .overlay-screen.hidden {
    display: none;
  }

  #fcc-screen-idle {
    background: #2a2c4a;
    backdrop-filter: none;
  }

  .screen-title {
    margin: 0;
    font-size: clamp(2rem, 6vw, 3.2rem);
    font-weight: 900;
    line-height: 1.1;
  }

  .screen-sub {
    margin: 0;
    font-size: 1rem;
    color: var(--muted);
    max-width: 340px;
    line-height: 1.5;
  }

  .screen-note {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(159, 168, 218, 0.6);
  }

  .player-warn {
    color: rgba(255, 200, 80, 0.85);
    min-height: 1.1em;
  }

  .screen-countdown {
    margin: 0;
    font-size: clamp(5rem, 18vw, 10rem);
    font-weight: 900;
    color: var(--color-white);
    text-shadow: 0 0 60px rgba(80, 180, 255, 0.9);
    animation: countdown-pop 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* Buttons */
  .theme-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .theme-label {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .theme-btns {
    display: flex;
    gap: 0.4rem;
  }

  .theme-btn {
    border: 2px solid rgba(255,255,255,0.18);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.3rem 0.9rem;
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }

  .theme-btn.active {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.5);
    color: var(--color-white);
  }

  .mode-btns {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .mode-btns .primary-btn {
    flex: 1;
    min-width: 140px;
  }

  .primary-btn {
    border: none;
    border-radius: var(--radius-md);
    background: #2979ff;
    color: var(--color-white);
    font-size: 1.05rem;
    font-weight: 700;
    padding: 0.75rem 1.6rem;
    cursor: pointer;
    transition: filter 0.12s, transform 0.1s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .btn-sub {
    font-size: 0.72rem;
    font-weight: 400;
    opacity: 0.8;
  }

  .btn-endless {
    background: #7c3aed;
  }

  .btn-challenge {
    background: #0d7a5f;
  }

  .primary-btn:hover {
    filter: brightness(1.18);
    transform: scale(1.03);
  }

  .primary-btn:active {
    transform: scale(0.97);
  }

  /* Loading spinner */
  .spinner {
    width: 44px;
    height: 44px;
    border: 4px solid rgba(255, 255, 255, 0.15);
    border-top-color: #2979ff;
    border-radius: var(--radius-round);
    animation: spin 0.8s linear infinite;
  }

  /* Game Over card */
  .gameover-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 22px;
    padding: 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .gameover-label {
    margin: 0;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .gameover-score {
    margin: 0.2rem 0 0;
    font-size: clamp(3.5rem, 12vw, 6rem);
    font-weight: 900;
    line-height: 1;
  }

  .gameover-meta {
    margin: 0;
    font-size: 0.95rem;
    color: var(--muted);
  }

  .gameover-best {
    margin: 0.3rem 0 0.6rem;
    font-size: 0.9rem;
    color: #ffd740;
    font-weight: 700;
    min-height: 1.2em;
  }

  /* Animations */
  @keyframes countdown-pop {
    0% { opacity: 0; transform: scale(0.5); }
    60% { opacity: 1; transform: scale(1.12); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Feedback image — sibling of canvas-wrap, escapes its overflow:hidden */
  .fcc-feedback-img {
    position: absolute;
    bottom: 6%;
    width: clamp(100px, 20vw, 200px);
    max-height: 55%;
    object-fit: contain;
    pointer-events: none;
    z-index: 20;
    opacity: 0;
    display: none;
  }

  .fcc-feedback-img.show-left {
    display: block;
    left: 0;
    animation: fcc-pop-left 1s ease forwards;
  }

  .fcc-feedback-img.show-right {
    display: block;
    right: 0;
    animation: fcc-pop-right 1s ease forwards;
  }

  @keyframes fcc-pop-left {
    0%   { opacity: 0; transform: translateX(-90%) scale(0.8); }
    20%  { opacity: 1; transform: translateX(-62%) scale(1.05); }
    70%  { opacity: 1; transform: translateX(-62%) scale(1); }
    100% { opacity: 0; transform: translateX(-68%) scale(0.92); }
  }

  @keyframes fcc-pop-right {
    0%   { opacity: 0; transform: translateX(90%) scale(0.8); }
    20%  { opacity: 1; transform: translateX(62%) scale(1.05); }
    70%  { opacity: 1; transform: translateX(62%) scale(1); }
    100% { opacity: 0; transform: translateX(68%) scale(0.92); }
  }

</style>

<script type="module" is:inline>
  // ── DOM refs ──────────────────────────────────────────────────────────────
  const gameRoot       = document.getElementById('face-catch-game');
  const GOOD_IMG_POOL  = JSON.parse(gameRoot?.dataset.goodImages ?? '[]');
  const BAD_IMG_POOL   = JSON.parse(gameRoot?.dataset.badImages  ?? '[]');

  const video          = document.getElementById('fcc-video');
  const canvas         = document.getElementById('fcc-canvas');
  const ctx            = canvas.getContext('2d');
  const scoreEl        = document.getElementById('fcc-score');
  const bestEl         = document.getElementById('fcc-best');
  const livesEl        = document.getElementById('fcc-lives');
  const screenIdle     = document.getElementById('fcc-screen-idle');
  const screenLoad     = document.getElementById('fcc-screen-loading');
  const screenCount    = document.getElementById('fcc-screen-countdown');
  const screenOver     = document.getElementById('fcc-screen-gameover');
  const countdownEl    = document.getElementById('fcc-countdown');
  const loadMsgEl      = document.getElementById('fcc-loading-msg');
  const finalScoreEl   = document.getElementById('fcc-final-score');
  const gameoverBestEl = document.getElementById('fcc-gameover-best');
  const btnTime        = document.getElementById('fcc-btn-time');
  const btnEndless     = document.getElementById('fcc-btn-endless');
  const btnChallenge   = document.getElementById('fcc-btn-challenge');
  const btnRestart     = document.getElementById('fcc-btn-restart');

  // ── Canvas resolution ─────────────────────────────────────────────────────
  const W = 640, H = 480;
  canvas.width  = W;
  canvas.height = H;

  // ── Game config ───────────────────────────────────────────────────────────
  const MAX_LIVES    = 3;
  const SPAWN_MS     = 1600;
  const BASE_SPEED   = 0.0028; // progress per frame (~6s at 60fps)
  const MAX_SPEED    = 0.007;  // cap for time mode (~2.4s)
  const BAD_CHANCE   = 0.28;   // 28% bad items
  const BONUS_CHANCE = 0.07;   // 7% rare ABC bonus
  const ITEM_R       = 26;     // fixed radius
  const HEART_R      = 38;     // collision radius of heart
  const TIME_LIMIT   = 60;     // seconds for time attack

  const CAPITAL_LETTERS  = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
  const BAD_EMOJIS       = ['😈','💀','👾','🕷️','🦠','🐛','🦂','💣','⚡','🔥'];
  const BAD_NUMBERS      = '0123456789'.split('');
  const BAD_POOL         = [...BAD_EMOJIS, ...BAD_NUMBERS];

  const HIRAGANA_BAD     = ['あ','い','う','え','お','か','き','く','け','こ','さ','し','す','せ','そ','な','に','ぬ','の','は','ま','み','む','も','や','よ'];
  const KATAKANA_BAD     = ['ア','イ','ウ','エ','オ','カ','キ','ク','ケ','コ','サ','シ','ス','セ','ソ','ナ','ニ','ノ','ハ','マ','ミ','モ','ヤ','ヨ'];
  const KANJI_BAD        = ['一','二','三','四','五','六','七','八','九','十','日','月','火','水','木','金','土','山','川','人','大','小','中','上','下'];
  const CHALLENGE_BAD_POOL = [...BAD_NUMBERS, ...HIRAGANA_BAD, ...KATAKANA_BAD, ...KANJI_BAD];

  // ── Audio ─────────────────────────────────────────────────────────────────
  const SFX_BASE = '/audio/directions-reaction-game/feedback/';
  const GOOD_SFX = ['good-yeah-5','good-great-4','good-ohyeah-3','good-nice-2','good-nice-1']
    .map(n => { const a = new Audio(`${SFX_BASE}${n}.mp3`); a.preload = 'auto'; return a; });
  const BAD_SFX  = ['bad-woops-3','bad-ohno-1','bad-ohno-2']
    .map(n => { const a = new Audio(`${SFX_BASE}${n}.mp3`); a.preload = 'auto'; return a; });

  const feedbackImg = document.getElementById('fcc-feedback-img');
  let feedbackAnimId = null;

  function showFeedbackImage(isGood) {
    const pool = isGood ? GOOD_IMG_POOL : BAD_IMG_POOL;
    if (!pool.length || !feedbackImg) return;
    const src  = pool[Math.floor(Math.random() * pool.length)];
    const side = Math.random() < 0.5 ? 'show-left' : 'show-right';
    feedbackImg.src = src;
    feedbackImg.className = 'fcc-feedback-img';
    void feedbackImg.offsetWidth; // force reflow to restart animation
    feedbackImg.className = `fcc-feedback-img ${side}`;
    if (feedbackAnimId) clearTimeout(feedbackAnimId);
    feedbackAnimId = setTimeout(() => {
      feedbackImg.className = 'fcc-feedback-img';
      feedbackImg.src = '';
    }, 1050);
  }

  function playSound(pool) {
    const snd = pool[Math.floor(Math.random() * pool.length)];
    snd.currentTime = 0;
    snd.play().catch(() => {});
  }

  // ── Game state ────────────────────────────────────────────────────────────
  let state        = 'idle';
  let gameMode     = 'time';    // 'time' | 'endless' | 'challenge'
  let score        = 0;
  let lives        = MAX_LIVES;
  let items        = [];
  let effects      = [];
  let missFlash    = 0;
  let frameId      = null;
  let spawnTimer   = null;
  let faceDetected = false;
  let gameStartTime = 0;
  let timeLeft      = TIME_LIMIT;

  // One heart per detected face (up to 2)
  let hearts = []; // [{x, y}, ...]

  // ── MediaPipe ─────────────────────────────────────────────────────────────
  let faceLandmarker = null;
  let faceLandmarkerNumFaces = 0; // numFaces the current instance was created with
  let numPlayers = 1;

  // ── Persistence ───────────────────────────────────────────────────────────
  const LS_KEY_TIME      = 'fcc-best-time';
  const LS_KEY_ENDLESS   = 'fcc-best-endless';
  const LS_KEY_CHALLENGE = 'fcc-best-challenge';
  let bestScore = 0;

  function lsKey() {
    if (gameMode === 'endless')   return LS_KEY_ENDLESS;
    if (gameMode === 'challenge') return LS_KEY_CHALLENGE;
    return LS_KEY_TIME;
  }

  function loadBest() { bestScore = parseInt(localStorage.getItem(lsKey()) ?? '0', 10); }
  function saveBest() { localStorage.setItem(lsKey(), String(bestScore)); }

  // ── Helpers ───────────────────────────────────────────────────────────────
  const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

  function showScreen(name) {
    for (const el of [screenIdle, screenLoad, screenCount, screenOver]) {
      el.classList.add('hidden');
    }
    if (name === 'idle')      screenIdle.classList.remove('hidden');
    if (name === 'loading')   screenLoad.classList.remove('hidden');
    if (name === 'countdown') screenCount.classList.remove('hidden');
    if (name === 'gameover')  screenOver.classList.remove('hidden');
  }

  function updateHud() {
    scoreEl.textContent = String(score);
    bestEl.textContent  = String(bestScore);
    livesEl.textContent = gameMode === 'endless'
      ? '❤️'.repeat(lives) + '🖤'.repeat(MAX_LIVES - lives)
      : '—';
  }

  function itemSpeed() {
    if (gameMode === 'endless') {
      const elapsed = (performance.now() - gameStartTime) / 1000;
      return BASE_SPEED + elapsed * 0.00018; // no cap — gets faster forever
    }
    // time mode: score-based, capped
    return Math.min(BASE_SPEED + (score / 200) * (MAX_SPEED - BASE_SPEED), MAX_SPEED);
  }

  function drawTimerOverlay() {
    if (gameMode === 'endless') return;
    const secs = Math.ceil(timeLeft);
    ctx.save();
    ctx.fillStyle    = secs <= 10 ? '#ff5252' : 'rgba(255,255,255,0.85)';
    ctx.font         = `bold 20px sans-serif`;
    ctx.textAlign    = 'right';
    ctx.textBaseline = 'top';
    ctx.fillText(`${secs}s`, W - 12, 12);
    ctx.restore();
  }

  // ── MediaPipe init ────────────────────────────────────────────────────────
  async function initMediaPipe() {
    loadMsgEl.textContent = 'Loading AI model… (first load may take a moment)';
    const { FaceLandmarker, FilesetResolver } = await import(
      'https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.14/vision_bundle.mjs'
    );
    const vision = await FilesetResolver.forVisionTasks(
      'https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.14/wasm'
    );
    faceLandmarker = await FaceLandmarker.createFromOptions(vision, {
      baseOptions: {
        modelAssetPath:
          'https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task',
        delegate: 'GPU',
      },
      runningMode: 'VIDEO',
      numFaces: numPlayers,
      outputFaceBlendshapes: false,
      outputFacialTransformationMatrixes: false,
    });
    faceLandmarkerNumFaces = numPlayers;
  }

  // ── Camera init ───────────────────────────────────────────────────────────
  async function initCamera() {
    loadMsgEl.textContent = 'Requesting camera access…';
    const stream = await navigator.mediaDevices.getUserMedia({
      video: { width: { ideal: 640 }, height: { ideal: 480 }, facingMode: 'user' },
      audio: false,
    });
    video.srcObject = stream;
    await new Promise((res) => { video.onloadedmetadata = res; });
    await video.play();
  }

  // ── Countdown ─────────────────────────────────────────────────────────────
  async function runCountdown() {
    showScreen('countdown');
    for (let n = 3; n >= 1; n--) {
      countdownEl.textContent = String(n);
      countdownEl.style.animation = 'none';
      void countdownEl.offsetWidth;
      countdownEl.style.animation = '';
      await sleep(850);
    }
    countdownEl.textContent = 'GO!';
    countdownEl.style.animation = 'none';
    void countdownEl.offsetWidth;
    countdownEl.style.animation = '';
    await sleep(600);
  }

  // ── Spawning ──────────────────────────────────────────────────────────────
  function spawnItem() {
    if (state !== 'playing') return;
    const pad = ITEM_R + 4;
    let startX, startY, endX, endY;
    const edge = Math.floor(Math.random() * 4);
    if (edge === 0) {       // left → right
      startX = -pad; startY = pad + Math.random() * (H - pad * 2);
      endX   = W + pad; endY = pad + Math.random() * (H - pad * 2);
    } else if (edge === 1) { // right → left
      startX = W + pad; startY = pad + Math.random() * (H - pad * 2);
      endX   = -pad;    endY   = pad + Math.random() * (H - pad * 2);
    } else if (edge === 2) { // top → bottom
      startX = pad + Math.random() * (W - pad * 2); startY = -pad;
      endX   = pad + Math.random() * (W - pad * 2); endY   = H + pad;
    } else {                 // bottom → top
      startX = pad + Math.random() * (W - pad * 2); startY = H + pad;
      endX   = pad + Math.random() * (W - pad * 2); endY   = -pad;
    }
    const roll = Math.random();
    const type = roll < BONUS_CHANCE ? 'bonus' : roll < BONUS_CHANCE + BAD_CHANCE ? 'bad' : 'good';
    const badPool = gameMode === 'challenge' ? CHALLENGE_BAD_POOL : BAD_POOL;
    const label = type === 'bonus'
      ? 'ABC'
      : type === 'good'
        ? CAPITAL_LETTERS[Math.floor(Math.random() * CAPITAL_LETTERS.length)]
        : badPool[Math.floor(Math.random() * badPool.length)];
    items.push({ startX, startY, endX, endY, progress: 0, speed: itemSpeed(), type, label });
  }

  function startSpawning() {
    stopSpawning();
    spawnItem();
    spawnTimer = setInterval(() => { if (state === 'playing') spawnItem(); }, SPAWN_MS);
  }

  function stopSpawning() {
    if (spawnTimer) { clearInterval(spawnTimer); spawnTimer = null; }
  }

  // ── Face detection ────────────────────────────────────────────────────────
  function detectFace() {
    if (!faceLandmarker || video.readyState < 2) return;
    const detected = faceLandmarker.detectForVideo(video, performance.now()).faceLandmarks;
    faceDetected = detected.length > 0;
    for (let i = 0; i < detected.length; i++) {
      const nose = detected[i][1]; // landmark 1 = nose tip
      const tx = (1 - nose.x) * W;
      const ty = nose.y * H;
      if (hearts[i]) {
        hearts[i].x = hearts[i].x * 0.7 + tx * 0.3;
        hearts[i].y = hearts[i].y * 0.7 + ty * 0.3;
      } else {
        hearts[i] = { x: tx, y: ty };
      }
    }
    hearts.length = detected.length;
  }

  // ── Drawing ───────────────────────────────────────────────────────────────
  function drawBackground() {
    // Mirrored camera feed dimmed heavily so objects stand out
    ctx.save();
    ctx.scale(-1, 1);
    ctx.drawImage(video, -W, 0, W, H);
    ctx.restore();
    ctx.fillStyle = 'rgba(0, 0, 0, 0.72)';
    ctx.fillRect(0, 0, W, H);
  }

  function drawHeart(x, y) {
    // Canonical heart centered at (x, y) with fixed HEART_R size
    const s = HEART_R;
    ctx.save();
    ctx.beginPath();
    ctx.moveTo(x, y + s * 0.9);
    ctx.bezierCurveTo(x - s * 1.05, y + s * 0.25, x - s * 1.1, y - s * 0.55, x, y - s * 0.2);
    ctx.bezierCurveTo(x + s * 1.1,  y - s * 0.55, x + s * 1.05, y + s * 0.25, x, y + s * 0.9);
    ctx.closePath();
    ctx.fillStyle   = '#ff4d6d';
    ctx.shadowColor = 'rgba(255, 77, 109, 0.65)';
    ctx.shadowBlur  = 18;
    ctx.fill();
    ctx.restore();
  }

  function itemCoords(item) {
    const t = item.progress;
    return {
      x: item.startX + (item.endX - item.startX) * t,
      y: item.startY + (item.endY - item.startY) * t,
      r: ITEM_R,
    };
  }

  function drawItem(item) {
    const { x, y, r } = itemCoords(item);
    ctx.save();

    if (item.type === 'bonus') {
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle   = '#ffffff';
      ctx.shadowColor = 'rgba(255, 215, 0, 0.9)';
      ctx.shadowBlur  = 22;
      ctx.fill();
      ctx.shadowBlur = 0;
      ctx.fillStyle    = '#92400e';
      ctx.font         = `bold ${Math.round(r * 0.8)}px Georgia, 'Times New Roman', serif`;
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText('ABC', x, y + 1);
    } else {
      // All circles are yellow — content tells good from bad
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle   = '#facc15';
      ctx.shadowColor = 'rgba(250,204,21,0.55)';
      ctx.shadowBlur  = 14;
      ctx.fill();
      ctx.shadowBlur = 0;
      if (item.type === 'good') {
        ctx.fillStyle    = '#1a1a1a';
        ctx.font         = `bold ${Math.round(r * 1.3)}px Georgia, 'Times New Roman', serif`;
        ctx.textAlign    = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(item.label, x, y + 1);
      } else {
        ctx.fillStyle    = '#1a1a1a';
        ctx.font         = `${Math.round(r * 1.05)}px sans-serif`;
        ctx.textAlign    = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(item.label, x, y + 2);
      }
    }

    ctx.restore();
  }

  function drawEffects() {
    for (const e of effects) {
      const alpha = e.life / e.maxLife;
      ctx.save();
      ctx.globalAlpha  = alpha;
      ctx.fillStyle    = e.color;
      ctx.font         = `bold ${e.fontSize ?? 22}px sans-serif`;
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(e.text, e.x, e.y);
      ctx.restore();
      e.y   -= e.dy ?? 1.5;
      e.life--;
    }
    effects = effects.filter((e) => e.life > 0);
  }

  function drawNoFaceWarning() {
    ctx.save();
    ctx.fillStyle    = 'rgba(255, 210, 50, 0.9)';
    ctx.font         = 'bold 15px sans-serif';
    ctx.textAlign    = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText('Show your face! / 顔をカメラに見せて！', W / 2, 10);
    ctx.restore();
  }

  function drawMissFlash() {
    if (missFlash <= 0) return;
    ctx.save();
    ctx.globalAlpha = (missFlash / 22) * 0.5;
    ctx.fillStyle   = '#ff1f1f';
    ctx.fillRect(0, 0, W, H);
    ctx.restore();
    missFlash--;
  }

  // ── Main game loop ────────────────────────────────────────────────────────
  function gameLoop() {
    if (state !== 'playing') return;

    // 1. Camera feed with dark overlay
    drawBackground();

    // 2. Face detection → update heart position
    detectFace();

    // 3. Red flash feedback
    drawMissFlash();

    // 4. Freeze when no face
    if (!faceDetected) {
      for (const item of items) drawItem(item);
      drawNoFaceWarning();
      drawEffects();
      frameId = requestAnimationFrame(gameLoop);
      return;
    }

    // 5. Advance items & check per-frame collision against all hearts
    const toRemove = [];
    for (const item of items) {
      item.progress += item.speed;
      const { x, y, r } = itemCoords(item);
      const hit = hearts.some((h) => Math.hypot(x - h.x, y - h.y) < HEART_R * 0.9 + r * 0.7);

      if (hit && !item.resolved) {
        item.resolved = true;
        toRemove.push({ item, hit: true });
      } else if (item.progress >= 1 && !item.resolved) {
        item.resolved = true;
        toRemove.push({ item, hit: false });
      }
    }
    items = items.filter((i) => !i.resolved || toRemove.find((t) => t.item === i));

    for (const { item, hit } of toRemove) {
      items = items.filter((i) => i !== item);
      const { x, y } = itemCoords(item);

      if (item.type === 'bonus') {
        if (hit) {
          score += 5;
          effects.push({ x, y: y - 10, text: '+5', color: '#ffd700', life: 42, maxLife: 42, dy: 1.8, fontSize: 26 });
          playSound(GOOD_SFX);
          showFeedbackImage(true);
          updateHud();
        }
      } else if (item.type === 'good') {
        if (hit) {
          score += 10;
          effects.push({ x, y: y - 10, text: '+10', color: '#69f0ae', life: 42, maxLife: 42, dy: 1.8 });
          playSound(GOOD_SFX);
          showFeedbackImage(true);
          updateHud();
        }
      } else {
        // bad item
        if (hit) {
          playSound(BAD_SFX);
          showFeedbackImage(false);
          if (gameMode !== 'endless') {
            score = Math.max(0, score - 1);
            effects.push({ x, y, text: '-1', color: '#ff5252', life: 35, maxLife: 35, dy: 1.5, fontSize: 18 });
            missFlash = 12;
            updateHud();
          } else {
            lives--;
            missFlash = 22;
            effects.push({ x, y, text: 'ouch', color: '#ff5252', life: 35, maxLife: 35, dy: 1.5, fontSize: 18 });
            updateHud();
            if (lives <= 0) { endGame(); return; }
          }
        }
      }
    }

    // 6. Time mode: check timer
    if (gameMode !== 'endless') {
      timeLeft = TIME_LIMIT - (performance.now() - gameStartTime) / 1000;
      if (timeLeft <= 0) { timeLeft = 0; endGame(); return; }
    }

    // 7. Draw items
    for (const item of items) drawItem(item);

    // 8. Draw all hearts
    for (const h of hearts) drawHeart(h.x, h.y);

    // 9. Floating text effects
    drawEffects();

    // 10. Timer overlay (time mode)
    drawTimerOverlay();

    frameId = requestAnimationFrame(gameLoop);
  }

  // ── Game lifecycle ────────────────────────────────────────────────────────
  function endGame() {
    state = 'gameover';
    stopSpawning();
    if (frameId) { cancelAnimationFrame(frameId); frameId = null; }
    if (score > bestScore) { bestScore = score; saveBest(); }
    document.querySelector('.gameover-label').textContent =
      gameMode === 'endless' ? 'Game Over' : 'Time Up! / 終了！';
    finalScoreEl.textContent   = String(score);
    gameoverBestEl.textContent = score >= bestScore && score > 0 ? 'New Best!' : `Best: ${bestScore}`;
    showScreen('gameover');
  }

  async function startGame(mode) {
    gameMode = mode;
    loadBest();
    score = 0; lives = MAX_LIVES; items = []; effects = []; missFlash = 0;
    faceDetected = false; hearts = [];
    timeLeft = TIME_LIMIT;
    updateHud();

    state = 'loading';
    showScreen('loading');

    try {
      if (!video.srcObject) await initCamera();
      if (faceLandmarker && faceLandmarkerNumFaces !== numPlayers) {
        faceLandmarker.close();
        faceLandmarker = null;
      }
      if (!faceLandmarker) await initMediaPipe();
    } catch (err) {
      loadMsgEl.textContent = `Error: ${err.message}`;
      return;
    }

    await runCountdown();
    state = 'playing';
    gameStartTime = performance.now();
    showScreen('playing');
    startSpawning();
    frameId = requestAnimationFrame(gameLoop);
  }

  async function restartGame() {
    stopSpawning();
    if (frameId) { cancelAnimationFrame(frameId); frameId = null; }
    score = 0; lives = MAX_LIVES; items = []; effects = []; missFlash = 0;
    faceDetected = false; hearts = [];
    timeLeft = TIME_LIMIT;
    updateHud();

    await runCountdown();
    state = 'playing';
    gameStartTime = performance.now();
    showScreen('playing');
    startSpawning();
    frameId = requestAnimationFrame(gameLoop);
  }

  // ── Button listeners ──────────────────────────────────────────────────────
  btnTime.addEventListener('click',      () => startGame('time'));
  btnEndless.addEventListener('click',   () => startGame('endless'));
  btnChallenge.addEventListener('click', () => startGame('challenge'));
  btnRestart.addEventListener('click', restartGame);

  // ── Player count selection ────────────────────────────────────────────────
  const playerWarnEl = document.getElementById('fcc-player-warn');
  const PLAYER_WARNINGS = {
    1: '',
    2: '',
    3: 'May be slow on older computers. / 古いパソコンでは遅くなる場合があります。',
    4: 'May be slow on older computers. / 古いパソコンでは遅くなる場合があります。',
    5: 'May run slowly on most computers. / ほとんどのパソコンで動作が遅くなる場合があります。',
  };
  document.querySelectorAll('#fcc-player-btns .theme-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      numPlayers = parseInt(btn.dataset.players, 10);
      document.querySelectorAll('#fcc-player-btns .theme-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      playerWarnEl.textContent = PLAYER_WARNINGS[numPlayers];
    });
  });

  // ── Init HUD ──────────────────────────────────────────────────────────────
  updateHud();
</script>
