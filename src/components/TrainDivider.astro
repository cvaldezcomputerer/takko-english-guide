---
interface Props {
  class?: string;
  /**
   * "outline" — full stroke detail (body, windows, doors, wheels), no fills.
   * "filled"  — solid silhouette only (body + wheels), no interior detail.
   *             Each car shape defined once in <defs> and reused with <use>.
   */
  variant?: "outline" | "filled";
}
const { class: className, variant = "outline" } = Astro.props;
const filled = variant === "filled";
---
<!--
  8-car E5 Hayabusa divider. Path data comes from hayabusa-front.svg and
  hayabusa-car.svg — same geometry, fills/strokes toggled by variant prop.

  <defs> + <use> means each car shape is written once; the 6 middle cars
  and mirrored rear reuse those definitions via transform="translate(…)".

  ViewBox: front(475) + 6×car(467) + rear(475) = 3752 × 105 units.
  At width="100%" the height auto-scales (~27 px in a 960 px container).
-->
<svg
  class:list={["train-divider", className]}
  viewBox="0 0 3752 105"
  width="100%"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <!-- Front-car body silhouette (nose on the left). -->
    <path
      id="td-front-body"
      d="M3.5 84.5C0.8 79.8 0.2 70.8 3.5 65.5C17.4 49.6 37.6 57.4 72 45C86.3 39.9 106.1 21.6 125.5 15C141.4 9.6 160.9 10.5 176.5 8.5C185.4 7.4 196.1 3 205.5 2.3L463.5 1.3C467.8 1.3 471.2 2.3 473.5 4.5V84.3C473.5 90.3 470.5 93.3 464.5 93.3H20.5C11 92.5 7.8 92 3.5 84.5Z"
    />
    <!-- Middle-car body silhouette (rounded rectangle). -->
    <path
      id="td-car-body"
      d="M456.3 1.3H10.3C5.3 1.3 1.3 5.3 1.3 10.3V87.3C1.3 92.2 5.3 96.3 10.3 96.3H456.3C461.2 96.3 465.3 92.2 465.3 87.3V10.3C465.3 5.3 461.2 1.3 456.3 1.3Z"
    />
    {!filled && (
      <>
        <!-- Front-car detail (separator, door frame, 4 windows). -->
        <g id="td-front-detail">
          <path d="M456 6V90" stroke-width="2" stroke="currentColor"/>
          <path d="M310 8H288C284.7 8 282 10.7 282 14V84C282 87.3 284.7 90 288 90H310C313.3 90 316 87.3 316 84V14C316 10.7 313.3 8 310 8Z" stroke-width="2.5" stroke="currentColor"/>
          <path d="M304 15H294C291.8 15 290 16.8 290 19V35C290 37.2 291.8 39 294 39H304C306.2 39 308 37.2 308 35V19C308 16.8 306.2 15 304 15Z" stroke-width="1.5" stroke="currentColor"/>
          <path d="M350 12H339C336.2 12 334 14.2 334 17V32C334 34.8 336.2 37 339 37H350C352.8 37 355 34.8 355 32V17C355 14.2 352.8 12 350 12Z" stroke-width="1.5" stroke="currentColor"/>
          <path d="M386 12H375C372.2 12 370 14.2 370 17V32C370 34.8 372.2 37 375 37H386C388.8 37 391 34.8 391 32V17C391 14.2 388.8 12 386 12Z" stroke-width="1.5" stroke="currentColor"/>
          <path d="M422 12H411C408.2 12 406 14.2 406 17V32C406 34.8 408.2 37 411 37H422C424.8 37 427 34.8 427 32V17C427 14.2 424.8 12 422 12Z" stroke-width="1.5" stroke="currentColor"/>
        </g>
        <!-- Middle-car detail (separators, 2 door frames, 2 door windows, 6 passenger windows). -->
        <g id="td-car-detail">
          <path d="M15.3 5.3V92.3" stroke-width="2" stroke="currentColor"/>
          <path d="M451.3 5.3V92.3" stroke-width="2" stroke="currentColor"/>
          <path d="M55.3 9.3H33.3C30 9.3 27.3 12 27.3 15.3V87.3C27.3 90.6 30 93.3 33.3 93.3H55.3C58.6 93.3 61.3 90.6 61.3 87.3V15.3C61.3 12 58.6 9.3 55.3 9.3Z" stroke-width="2.5" stroke="currentColor"/>
          <path d="M433.3 9.3H411.3C408 9.3 405.3 12 405.3 15.3V87.3C405.3 90.6 408 93.3 411.3 93.3H433.3C436.6 93.3 439.3 90.6 439.3 87.3V15.3C439.3 12 436.6 9.3 433.3 9.3Z" stroke-width="2.5" stroke="currentColor"/>
          <path d="M49.3 15.3H39.3C37.1 15.3 35.3 17.1 35.3 19.3V35.3C35.3 37.5 37.1 39.3 39.3 39.3H49.3C51.5 39.3 53.3 37.5 53.3 35.3V19.3C53.3 17.1 51.5 15.3 49.3 15.3Z" stroke-width="1.5" stroke="currentColor"/>
          <path d="M427.3 15.3H417.3C415.1 15.3 413.3 17.1 413.3 19.3V35.3C413.3 37.5 415.1 39.3 417.3 39.3H427.3C429.5 39.3 431.3 37.5 431.3 35.3V19.3C431.3 17.1 429.5 15.3 427.3 15.3Z" stroke-width="1.5" stroke="currentColor"/>
          <path d="M108.3 14.3H96.3C93.5 14.3 91.3 16.5 91.3 19.3V34.3C91.3 37.1 93.5 39.3 96.3 39.3H108.3C111.1 39.3 113.3 37.1 113.3 34.3V19.3C113.3 16.5 111.1 14.3 108.3 14.3Z" stroke-width="1.5" stroke="currentColor"/>
          <path d="M158.3 14.3H146.3C143.5 14.3 141.3 16.5 141.3 19.3V34.3C141.3 37.1 143.5 39.3 146.3 39.3H158.3C161.1 39.3 163.3 37.1 163.3 34.3V19.3C163.3 16.5 161.1 14.3 158.3 14.3Z" stroke-width="1.5" stroke="currentColor"/>
          <path d="M208.3 14.3H196.3C193.5 14.3 191.3 16.5 191.3 19.3V34.3C191.3 37.1 193.5 39.3 196.3 39.3H208.3C211.1 39.3 213.3 37.1 213.3 34.3V19.3C213.3 16.5 211.1 14.3 208.3 14.3Z" stroke-width="1.5" stroke="currentColor"/>
          <path d="M258.3 14.3H246.3C243.5 14.3 241.3 16.5 241.3 19.3V34.3C241.3 37.1 243.5 39.3 246.3 39.3H258.3C261.1 39.3 263.3 37.1 263.3 34.3V19.3C263.3 16.5 261.1 14.3 258.3 14.3Z" stroke-width="1.5" stroke="currentColor"/>
          <path d="M308.3 14.3H296.3C293.5 14.3 291.3 16.5 291.3 19.3V34.3C291.3 37.1 293.5 39.3 296.3 39.3H308.3C311.1 39.3 313.3 37.1 313.3 34.3V19.3C313.3 16.5 311.1 14.3 308.3 14.3Z" stroke-width="1.5" stroke="currentColor"/>
          <path d="M358.3 14.3H346.3C343.5 14.3 341.3 16.5 341.3 19.3V34.3C341.3 37.1 343.5 39.3 346.3 39.3H358.3C361.1 39.3 363.3 37.1 363.3 34.3V19.3C363.3 16.5 361.1 14.3 358.3 14.3Z" stroke-width="1.5" stroke="currentColor"/>
        </g>
        <!-- Front-car wheels (outline variant only). -->
        <g id="td-front-wheels">
          <circle cx="228" cy="95" r="10" stroke-width="2" stroke="currentColor"/>
          <circle cx="254" cy="95" r="10" stroke-width="2" stroke="currentColor"/>
          <circle cx="394" cy="95" r="10" stroke-width="2" stroke="currentColor"/>
          <circle cx="420" cy="95" r="10" stroke-width="2" stroke="currentColor"/>
        </g>
        <!-- Middle-car wheels (outline variant only). -->
        <g id="td-car-wheels">
          <circle cx="104" cy="95" r="10" stroke-width="2" stroke="currentColor"/>
          <circle cx="130" cy="95" r="10" stroke-width="2" stroke="currentColor"/>
          <circle cx="337" cy="95" r="10" stroke-width="2" stroke="currentColor"/>
          <circle cx="363" cy="95" r="10" stroke-width="2" stroke="currentColor"/>
        </g>
      </>
    )}
  </defs>

  <!-- ── FRONT CAR ── -->
  <use
    href="#td-front-body"
    fill={filled ? "currentColor" : "none"}
    stroke={filled ? "none" : "currentColor"}
    stroke-width="2.5"
    stroke-linejoin="round"
  />
  {!filled && <use href="#td-front-detail"/>}
  {!filled && <use href="#td-front-wheels"/>}

  <!-- ── 6 MIDDLE CARS ── same shapes, shifted right by car-width each time -->
  {[475, 942, 1409, 1876, 2343, 2810].map((x) => (
    <g transform={`translate(${x}, 0)`}>
      <use
        href="#td-car-body"
        fill={filled ? "currentColor" : "none"}
        stroke={filled ? "none" : "currentColor"}
        stroke-width="2.5"
      />
      {!filled && <use href="#td-car-detail"/>}
      {!filled && <use href="#td-car-wheels"/>}
    </g>
  ))}

  <!-- ── REAR CAR (front mirrored; nose points right) ── -->
  <g transform="translate(3752, 0) scale(-1, 1)">
    <use
      href="#td-front-body"
      fill={filled ? "currentColor" : "none"}
      stroke={filled ? "none" : "currentColor"}
      stroke-width="2.5"
      stroke-linejoin="round"
    />
    {!filled && <use href="#td-front-detail"/>}
    {!filled && <use href="#td-front-wheels"/>}
  </g>
</svg>

<style>
  .train-divider {
    display: block;
    color: #d9cfb5;
    overflow: visible;
  }
</style>
