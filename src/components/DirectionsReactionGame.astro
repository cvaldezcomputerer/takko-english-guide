---
import badcat1 from "../assets/DirectionsReactionGame/badcat1-nobg.png";
import badcat2 from "../assets/DirectionsReactionGame/badcat2.jpg";
import badcat3 from "../assets/DirectionsReactionGame/badcat3.jpg";
import goodCat1 from "../assets/DirectionsReactionGame/goodCat1-nobg.png";
import goodCat2 from "../assets/DirectionsReactionGame/goodCat2-nobg.png";
import goodCat3 from "../assets/DirectionsReactionGame/goodCat3-nobg.png";
import goodCat4 from "../assets/DirectionsReactionGame/goodcat4-nobg.png";

const GOOD_FEEDBACK_IMAGES = [goodCat1.src, goodCat2.src, goodCat3.src, goodCat4.src];
const BAD_FEEDBACK_IMAGES = [badcat1.src, badcat2.src, badcat3.src];
---

<div
  class="reaction-game"
  id="reaction-game"
  data-good-images={JSON.stringify(GOOD_FEEDBACK_IMAGES)}
  data-bad-images={JSON.stringify(BAD_FEEDBACK_IMAGES)}
>
  <header class="hud">
    <div class="hud-card">
      <span class="hud-label">Time</span>
      <span class="hud-value" id="time-left">60.0s</span>
    </div>
    <div class="hud-card">
      <span class="hud-label">Score</span>
      <span class="hud-value" id="score">0</span>
    </div>
    <div class="hud-card">
      <span class="hud-label">Round</span>
      <span class="hud-value" id="round-count">0</span>
    </div>
  </header>

  <main class="stage" id="stage">
    <div class="stage-visual neutral" id="stage-visual">
      <div class="placeholder-icon" id="placeholder-icon">?</div>
      <img id="feedback-image" class="feedback-image hidden left" src="" alt="" />
      <p class="stage-title" id="stage-title">Press Play</p>
      <p class="stage-subtitle" id="stage-subtitle">Audio will say: Left, Right, or Straight.</p>
    </div>
  </main>

  <footer class="controls">
    <button id="btn-left" class="input-btn" type="button" aria-label="Left">&lt;</button>
    <button id="btn-straight" class="input-btn" type="button" aria-label="Straight">^</button>
    <button id="btn-right" class="input-btn" type="button" aria-label="Right">&gt;</button>
  </footer>

  <div class="meta-row">
    <button id="btn-start" class="start-btn" type="button">Play</button>
    <p class="result-text" id="result-text">Press Play when ready.</p>
  </div>

  <section class="howto-ja" aria-label="あそびかた / How to play">
    <div class="howto-grid">
      <div class="howto-col">
        <p class="howto-title">あそびかた</p>
        <p class="howto-line">1. Playをおす。</p>
        <p class="howto-line">2. こえをきいて、むきをえらぶ。</p>
        <p class="howto-line">3. ただしいむきを、はやくおす。</p>
        <p class="howto-subtitle">おしかたは3つあるよ</p>
        <p class="howto-line">・マウスでボタンをおす</p>
        <p class="howto-line">・キーボードの やじるし（← ↑ →）</p>
        <p class="howto-line">・キーボードの A / W / D</p>
      </div>
      <div class="howto-col">
        <p class="howto-title">How to Play</p>
        <p class="howto-line">1. Press Play.</p>
        <p class="howto-line">2. Listen and pick a direction.</p>
        <p class="howto-line">3. Press the correct one fast.</p>
        <p class="howto-subtitle">3 ways to answer</p>
        <p class="howto-line">- Click the buttons with a mouse</p>
        <p class="howto-line">- Use arrow keys (Left, Up, Right)</p>
        <p class="howto-line">- Use A / W / D keys</p>
      </div>
    </div>
  </section>

  <div id="finish-popup" class="finish-popup hidden" role="dialog" aria-modal="true" aria-live="polite">
    <div class="finish-card">
      <p class="finish-label">Final Score</p>
      <p class="finish-score" id="finish-score">0</p>
      <p class="finish-meta" id="finish-meta">0 rounds</p>
    </div>
  </div>
</div>

<style>
  .reaction-game {
    --bg-1: #f9f5ff;
    --bg-2: #d9f4ff;
    --panel: #ffffff;
    --ink: #1f2937;
    --muted: #5b6472;
    --ok: #13955a;
    --bad: #c9382d;

    position: relative;
    width: min(860px, 94vw);
    margin: 2rem auto;
    padding: 1rem;
    border-radius: 24px;
    background: linear-gradient(150deg, var(--bg-1), var(--bg-2));
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
    font-family: "Trebuchet MS", "Segoe UI", sans-serif;
    color: var(--ink);
  }

  .hud {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .hud-card {
    background: var(--panel);
    border-radius: 14px;
    padding: 0.65rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
  }

  .hud-label {
    font-size: 0.78rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hud-value {
    font-size: 1.4rem;
    font-weight: 800;
  }

  .stage {
    margin-top: 0.85rem;
    min-height: 350px;
    background: var(--panel);
    border-radius: 18px;
    display: grid;
    place-items: center;
    padding: 1rem;
    box-shadow: inset 0 0 0 2px rgba(18, 24, 40, 0.04);
  }

  .stage-visual {
    width: 100%;
    min-height: 300px;
    border-radius: 14px;
    position: relative;
    overflow: hidden;
    display: grid;
    place-items: center;
    text-align: center;
    padding: 1.2rem;
    transition: background 0.12s ease;
  }

  .stage-visual.neutral {
    background: linear-gradient(180deg, #f7fbff, #edf5ff);
  }

  .stage-visual.correct {
    background: linear-gradient(180deg, #ecfff4, #d5ffe8);
    animation: flash-correct 0.8s ease;
  }

  .stage-visual.wrong {
    background: linear-gradient(180deg, #fff4f2, #ffe2de);
    animation: flash-wrong 0.8s ease;
  }

  .placeholder-icon {
    font-size: clamp(4rem, 10vw, 6rem);
    line-height: 1;
    margin-bottom: 0.6rem;
    z-index: 2;
  }

  .feedback-image {
    position: absolute;
    top: 50%;
    width: clamp(120px, 24vw, 220px);
    max-height: 82%;
    object-fit: contain;
    pointer-events: none;
    opacity: 0;
    z-index: 1;
    filter: drop-shadow(0 10px 16px rgba(0, 0, 0, 0.22));
  }

  .feedback-image.left {
    left: 0.5rem;
  }

  .feedback-image.right {
    right: 0.5rem;
  }

  .feedback-image.hidden {
    display: none;
  }

  .feedback-image.show.left {
    display: block;
    animation: pop-in-left 0.8s ease forwards;
  }

  .feedback-image.show.right {
    display: block;
    animation: pop-in-right 0.8s ease forwards;
  }

  .stage-title {
    margin: 0;
    font-size: clamp(1.3rem, 3.2vw, 2rem);
    font-weight: 800;
    z-index: 2;
  }

  .stage-subtitle {
    margin: 0.4rem 0 0;
    font-size: 1rem;
    color: var(--muted);
    z-index: 2;
  }

  .controls {
    margin-top: 0.85rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .input-btn {
    border: none;
    border-radius: 14px;
    background: #111827;
    color: white;
    font-size: clamp(2rem, 5vw, 2.5rem);
    font-weight: 800;
    height: 76px;
    cursor: pointer;
    transition: transform 0.07s ease, filter 0.12s ease;
  }

  .input-btn:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .input-btn:not(:disabled):active {
    transform: scale(0.96);
  }

  .meta-row {
    margin-top: 0.85rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .start-btn {
    border: none;
    border-radius: 12px;
    background: #1463ff;
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    padding: 0.7rem 1rem;
    cursor: pointer;
  }

  .result-text {
    margin: 0;
    font-weight: 700;
    color: var(--muted);
  }

  .howto-ja {
    margin-top: 0.75rem;
    background: rgba(255, 255, 255, 0.92);
    border-radius: 12px;
    padding: 0.65rem 0.8rem;
    box-shadow: inset 0 0 0 1px rgba(17, 24, 39, 0.08);
  }

  .howto-grid {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .howto-col {
    flex: 1 1 0;
    min-width: 0;
  }

  .howto-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 800;
    color: #1f2937;
  }

  .howto-subtitle {
    margin: 0.35rem 0 0.15rem;
    font-size: 0.9rem;
    font-weight: 800;
    color: #334155;
  }

  .howto-line {
    margin: 0.1rem 0;
    font-size: 0.9rem;
    color: #334155;
    line-height: 1.35;
  }

  .finish-popup {
    position: absolute;
    inset: 0;
    z-index: 30;
    display: grid;
    place-items: center;
    border-radius: 24px;
    background: rgba(12, 20, 38, 0.56);
    backdrop-filter: blur(3px);
    padding: 1rem;
  }

  .finish-popup.hidden {
    display: none;
  }

  .finish-card {
    width: min(480px, 92%);
    border-radius: 20px;
    padding: 1.2rem 1rem;
    text-align: center;
    color: #ffffff;
    background: radial-gradient(circle at top, #2b8cff 0%, #145eff 62%, #0d3fb6 100%);
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.36);
    animation: finish-pop 240ms ease-out;
  }

  .finish-label {
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 800;
    font-size: 0.86rem;
    opacity: 0.92;
  }

  .finish-score {
    margin: 0.25rem 0;
    line-height: 1;
    font-size: clamp(3rem, 12vw, 6rem);
    font-weight: 900;
    text-shadow: 0 4px 12px rgba(0, 0, 0, 0.22);
  }

  .finish-meta {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    opacity: 0.95;
  }

  @keyframes flash-correct {
    0% { transform: scale(1); }
    30% { transform: scale(1.02); }
    100% { transform: scale(1); }
  }

  @keyframes flash-wrong {
    0% { transform: translateX(0); }
    30% { transform: translateX(4px); }
    60% { transform: translateX(-4px); }
    100% { transform: translateX(0); }
  }

  @keyframes finish-pop {
    0% { opacity: 0; transform: scale(0.94) translateY(8px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }

  @keyframes pop-in-left {
    0% { opacity: 0; transform: translate(-28px, -50%) scale(0.8) rotate(-5deg); }
    25% { opacity: 1; transform: translate(-10px, -50%) scale(1.04) rotate(-2deg); }
    75% { opacity: 1; transform: translate(-12px, -50%) scale(1) rotate(-1deg); }
    100% { opacity: 0; transform: translate(-18px, -50%) scale(0.95) rotate(-2deg); }
  }

  @keyframes pop-in-right {
    0% { opacity: 0; transform: translate(28px, -50%) scale(0.8) rotate(5deg); }
    25% { opacity: 1; transform: translate(10px, -50%) scale(1.04) rotate(2deg); }
    75% { opacity: 1; transform: translate(12px, -50%) scale(1) rotate(1deg); }
    100% { opacity: 0; transform: translate(18px, -50%) scale(0.95) rotate(2deg); }
  }

  @media (max-width: 640px) {
    .reaction-game {
      margin: 1rem auto;
      padding: 0.8rem;
    }

    .stage {
      min-height: 280px;
    }

    .stage-visual {
      min-height: 230px;
    }

    .howto-grid {
      flex-direction: column;
      gap: 0.55rem;
    }

    .howto-subtitle,
    .howto-line,
    .howto-title {
      font-size: 0.84rem;
    }

  }
</style>

<script is:inline>
  const TOTAL_DURATION_MS = 60000;
  const ANSWER_WINDOW_MS = 3000;
  const FEEDBACK_MS = 800;

  const DIRECTIONS = [
    { key: "left", label: "Left", symbol: "<" },
    { key: "straight", label: "Straight", symbol: "^" },
    { key: "right", label: "Right", symbol: ">" },
  ];
  const gameRoot = document.getElementById("reaction-game");
  const GOOD_IMAGE_POOL = JSON.parse(gameRoot?.dataset.goodImages ?? "[]");
  const BAD_IMAGE_POOL = JSON.parse(gameRoot?.dataset.badImages ?? "[]");

  const HAPPY_PLACEHOLDERS = [
    { icon: "😺", label: "Happy Cat Meme A" },
    { icon: "😸", label: "Happy Cat Meme B" },
    { icon: "😻", label: "Happy Cat Meme C" },
    { icon: "🐱", label: "Happy Cat Meme D" },
  ];

  const BAD_PLACEHOLDERS = [
    { icon: "🥦", label: "Vegetable Pic A" },
    { icon: "🥕", label: "Vegetable Pic B" },
    { icon: "💩", label: "Poop Pic A" },
    { icon: "🍆", label: "Vegetable Pic C" },
  ];

  const ui = {
    time: document.getElementById("time-left"),
    score: document.getElementById("score"),
    round: document.getElementById("round-count"),
    stageVisual: document.getElementById("stage-visual"),
    icon: document.getElementById("placeholder-icon"),
    feedbackImage: document.getElementById("feedback-image"),
    title: document.getElementById("stage-title"),
    subtitle: document.getElementById("stage-subtitle"),
    result: document.getElementById("result-text"),
    finishPopup: document.getElementById("finish-popup"),
    finishScore: document.getElementById("finish-score"),
    finishMeta: document.getElementById("finish-meta"),
    startBtn: document.getElementById("btn-start"),
    leftBtn: document.getElementById("btn-left"),
    straightBtn: document.getElementById("btn-straight"),
    rightBtn: document.getElementById("btn-right"),
  };

  const inputButtons = [ui.leftBtn, ui.straightBtn, ui.rightBtn];

  let score = 0;
  let roundCount = 0;
  let gameActive = false;
  let currentPrompt = null;
  let promptStartTs = 0;
  let roundAnswered = false;
  let gameStartTs = 0;
  let remainingMs = TOTAL_DURATION_MS;

  let gameClockInterval = null;
  let answerTimeout = null;
  let feedbackTimeout = null;
  let currentAudio = null;

  const AUDIO_BASE = "/audio/directions-reaction-game/recorded";
  const START_AUDIO = [
    `${AUDIO_BASE}/start-1.mp3`,
    `${AUDIO_BASE}/start-2.mp3`,
  ];
  const FINISH_AUDIO = [
    `${AUDIO_BASE}/finish-1.mp3`,
    `${AUDIO_BASE}/finish-2.mp3`,
    `${AUDIO_BASE}/finish-3.mp3`,
  ];
  const DIRECTION_AUDIO_SRC = {
    left: [
      `${AUDIO_BASE}/turn-left-1.mp3`,
      `${AUDIO_BASE}/turn-left-2.mp3`,
      `${AUDIO_BASE}/turn-left-3.mp3`,
      `${AUDIO_BASE}/turn-left-4.mp3`,
    ],
    straight: [
      `${AUDIO_BASE}/go-straight-1.mp3`,
      `${AUDIO_BASE}/go-straight-2.mp3`,
      `${AUDIO_BASE}/go-straight-3.mp3`,
    ],
    right: [
      `${AUDIO_BASE}/turn-right-1.mp3`,
      `${AUDIO_BASE}/turn-right-2.mp3`,
      `${AUDIO_BASE}/turn-right-3.mp3`,
      `${AUDIO_BASE}/turn-right-4.mp3`,
    ],
  };

  function randomFrom(list) {
    return list[Math.floor(Math.random() * list.length)];
  }

  function getPointsByResponseMs(responseMs) {
    if (responseMs < 1000) return 100;
    if (responseMs < 2000) return 50;
    return 20;
  }

  function waitMs(ms) {
    return new Promise((resolve) => setTimeout(resolve, ms));
  }

  function setInputEnabled(enabled) {
    for (const btn of inputButtons) {
      btn.disabled = !enabled;
    }
  }

  function updateHud() {
    ui.score.textContent = String(score);
    ui.round.textContent = String(roundCount);
    ui.time.textContent = `${(Math.max(remainingMs, 0) / 1000).toFixed(1)}s`;
  }

  function setNeutralVisual() {
    ui.stageVisual.className = "stage-visual neutral";
    ui.icon.textContent = "?";
    ui.feedbackImage.className = "feedback-image hidden left";
    ui.feedbackImage.src = "";
    ui.feedbackImage.alt = "";
    ui.title.textContent = "Listening...";
    ui.subtitle.textContent = "Audio cue is playing. Tap <, ^, or >.";
  }

  function setFeedbackVisual(isCorrect, pointsAwarded, detailText) {
    ui.stageVisual.className = `stage-visual ${isCorrect ? "correct" : "wrong"}`;
    ui.icon.textContent = isCorrect ? "OK" : "NO";
    ui.title.textContent = isCorrect ? "Correct!" : "Wrong!";
    const imageSrc = randomFrom(isCorrect ? GOOD_IMAGE_POOL : BAD_IMAGE_POOL);
    const imageSide = Math.random() < 0.5 ? "left" : "right";
    ui.feedbackImage.src = imageSrc;
    ui.feedbackImage.alt = isCorrect ? "Good cat reaction" : "Bad cat reaction";
    ui.feedbackImage.className = `feedback-image show ${imageSide}`;
    ui.subtitle.textContent = isCorrect
      ? `${detailText}  +${pointsAwarded} pts`
      : detailText;
  }

  function hideFinishPopup() {
    ui.finishPopup.classList.add("hidden");
  }

  function showFinishPopup() {
    ui.finishScore.textContent = String(score);
    ui.finishMeta.textContent = `${roundCount} rounds`;
    ui.finishPopup.classList.remove("hidden");
  }

  function stopCurrentAudio() {
    if (!currentAudio) return;
    currentAudio.pause();
    currentAudio.currentTime = 0;
    currentAudio = null;
  }

  function playAudio(src, waitForEnd = false) {
    if (!src) return Promise.resolve();
    stopCurrentAudio();
    currentAudio = new Audio(src);
    currentAudio.preload = "auto";
    const activeAudio = currentAudio;
    const playPromise = activeAudio.play().catch((e) => {
      console.warn("Audio play blocked by browser:", e);
    });

    if (!waitForEnd) return playPromise;
    return new Promise((resolve) => {
      const cleanupAndResolve = () => {
        if (currentAudio === activeAudio) {
          currentAudio = null;
        }
        resolve();
      };
      activeAudio.addEventListener("ended", cleanupAndResolve, { once: true });
      activeAudio.addEventListener("error", cleanupAndResolve, { once: true });
      playPromise.then(() => {
        if (activeAudio.paused) cleanupAndResolve();
      });
    });
  }

  function playRandomFromPool(pool, waitForEnd = false) {
    if (!pool || pool.length === 0) return Promise.resolve();
    return playAudio(randomFrom(pool), waitForEnd);
  }

  function playDirectionCue(directionKey) {
    return playRandomFromPool(DIRECTION_AUDIO_SRC[directionKey], false);
  }

  async function runStartCountdown(seconds = 3) {
    ui.stageVisual.className = "stage-visual neutral";
    ui.feedbackImage.className = "feedback-image hidden left";
    ui.feedbackImage.src = "";
    ui.feedbackImage.alt = "";
    ui.subtitle.textContent = "Get ready...";
    for (let n = seconds; n >= 1; n -= 1) {
      if (!gameActive) return false;
      ui.icon.textContent = String(n);
      ui.title.textContent = `Starting in ${n}`;
      ui.result.textContent = `Starting in ${n}...`;
      await waitMs(1000);
    }
    return gameActive;
  }

  function clearTimers() {
    if (answerTimeout) clearTimeout(answerTimeout);
    if (feedbackTimeout) clearTimeout(feedbackTimeout);
    if (gameClockInterval) clearInterval(gameClockInterval);
    answerTimeout = null;
    feedbackTimeout = null;
    gameClockInterval = null;
  }

  function endGame() {
    gameActive = false;
    clearTimers();
    stopCurrentAudio();
    setInputEnabled(false);
    ui.startBtn.textContent = "Play Again";

    ui.stageVisual.className = "stage-visual neutral";
    ui.icon.textContent = "🏁";
    ui.feedbackImage.className = "feedback-image hidden left";
    ui.feedbackImage.src = "";
    ui.feedbackImage.alt = "";
    ui.title.textContent = "Time Up!";
    ui.subtitle.textContent = `Final score: ${score} points across ${roundCount} rounds.`;
    ui.result.textContent = "Round complete. Press Play Again to restart.";
    showFinishPopup();

    remainingMs = 0;
    updateHud();
    playRandomFromPool(FINISH_AUDIO, false);
  }

  function resetToIdle() {
    gameActive = false;
    clearTimers();
    stopCurrentAudio();
    currentPrompt = null;
    roundAnswered = false;
    score = 0;
    roundCount = 0;
    remainingMs = TOTAL_DURATION_MS;

    setInputEnabled(false);
    ui.startBtn.textContent = "Play";
    ui.stageVisual.className = "stage-visual neutral";
    ui.icon.textContent = "?";
    ui.feedbackImage.className = "feedback-image hidden left";
    ui.feedbackImage.src = "";
    ui.feedbackImage.alt = "";
    ui.title.textContent = "Press Play";
    ui.subtitle.textContent = "Audio will say: Left, Right, or Straight.";
    ui.result.textContent = "Press Play when ready.";
    hideFinishPopup();
    updateHud();
  }

  function runGameClock() {
    if (gameClockInterval) clearInterval(gameClockInterval);
    gameClockInterval = setInterval(() => {
      const elapsed = performance.now() - gameStartTs;
      remainingMs = Math.max(0, TOTAL_DURATION_MS - elapsed);
      updateHud();
      if (remainingMs <= 0) {
        endGame();
      }
    }, 100);
  }

  function queueNextPrompt() {
    if (!gameActive) return;
    if (remainingMs <= 0) {
      endGame();
      return;
    }

    setNeutralVisual();
    currentPrompt = randomFrom(DIRECTIONS);
    promptStartTs = performance.now();
    roundAnswered = false;
    roundCount += 1;
    updateHud();
    ui.result.textContent = `Round ${roundCount}: waiting for your input.`;

    playDirectionCue(currentPrompt.key);

    answerTimeout = setTimeout(() => {
      resolveAnswer(null);
    }, ANSWER_WINDOW_MS);
  }

  function resolveAnswer(answerKey) {
    if (!gameActive || roundAnswered || !currentPrompt) return;
    roundAnswered = true;
    if (answerTimeout) {
      clearTimeout(answerTimeout);
      answerTimeout = null;
    }

    const responseMs = performance.now() - promptStartTs;
    const isCorrect = answerKey === currentPrompt.key;
    const speedPoints = isCorrect ? getPointsByResponseMs(responseMs) : 0;

    if (isCorrect) {
      score += speedPoints;
    }

    const speedTag = responseMs < 1000 ? "Super" : responseMs < 2000 ? "Good" : "OK";
    const wrongReason = answerKey === null ? "Too slow." : "Wrong direction.";
    const detailText = isCorrect
      ? `${speedTag} reaction (${(responseMs / 1000).toFixed(2)}s).`
      : wrongReason;

    setFeedbackVisual(isCorrect, speedPoints, detailText);
    ui.result.textContent = isCorrect
      ? `Correct: ${currentPrompt.label} (${speedTag}, +${speedPoints})`
      : `Incorrect. Cue was ${currentPrompt.label}.`;

    updateHud();

    feedbackTimeout = setTimeout(() => {
      if (!gameActive) return;
      queueNextPrompt();
    }, FEEDBACK_MS);
  }

  async function startGame() {
    clearTimers();
    stopCurrentAudio();

    score = 0;
    roundCount = 0;
    remainingMs = TOTAL_DURATION_MS;
    gameStartTs = performance.now();
    gameActive = true;
    currentPrompt = null;
    roundAnswered = false;

    setInputEnabled(true);
    ui.startBtn.textContent = "Reset";
    ui.result.textContent = "Get ready...";
    hideFinishPopup();
    updateHud();
    runGameClock();
    playRandomFromPool(START_AUDIO, false);
    const shouldContinue = await runStartCountdown(3);
    if (!shouldContinue) return;
    ui.result.textContent = "Listen and react as fast as possible.";
    queueNextPrompt();
  }

  ui.leftBtn?.addEventListener("click", () => resolveAnswer("left"));
  ui.straightBtn?.addEventListener("click", () => resolveAnswer("straight"));
  ui.rightBtn?.addEventListener("click", () => resolveAnswer("right"));
  ui.startBtn?.addEventListener("click", () => {
    if (gameActive) {
      resetToIdle();
      return;
    }
    startGame();
  });

  document.addEventListener("keydown", (event) => {
    if (!gameActive) return;
    const key = event.key.toLowerCase();

    if (key === "arrowleft" || key === "a") {
      event.preventDefault();
      resolveAnswer("left");
    }
    if (key === "arrowup" || key === "w") {
      event.preventDefault();
      resolveAnswer("straight");
    }
    if (key === "arrowright" || key === "d") {
      event.preventDefault();
      resolveAnswer("right");
    }
  });

  setInputEnabled(false);
  updateHud();
</script>
