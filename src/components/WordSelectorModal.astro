---
// Shared word-selector modal. Slot content goes between subcats and the GO button.
// Each page wires up the GO button via initModalListeners() from wordSelector.ts.
---

<div id="category-modal" class="modal-overlay hidden" role="dialog" aria-modal="true">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-title-wrap">
        <span class="modal-group-name" id="modal-group-name"></span>
        <span class="modal-group-ja" id="modal-group-ja"></span>
      </div>
      <button class="modal-close" id="modal-close" aria-label="Close">✕</button>
    </div>

    <label class="select-all-row">
      <input type="checkbox" id="select-all-cb" />
      <span>Select all ／ すべてえらぶ</span>
    </label>

    <div class="modal-subcats" id="modal-subcats"></div>

    <slot />

    <div class="modal-footer">
      <button class="modal-go-btn" id="modal-go-btn">GO</button>
    </div>
  </div>
</div>

<style>

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    padding: 1rem;
  }

  .modal-box {
    background: white;
    border-radius: 16px;
    width: 100%;
    max-width: 480px;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.2);
    border-top: 5px solid var(--modal-color, #557153);
  }

  .modal-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1.25rem 1.25rem 0.75rem;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
  }

  .modal-title-wrap { display: flex; flex-direction: column; gap: 0.2rem; }
  .modal-group-name { font-size: 1.2rem; font-weight: 700; color: #222; }
  .modal-group-ja {
    font-size: 1rem;
    font-weight: 600;
    color: #555;
    font-family: 'M PLUS Rounded 1c', sans-serif;
  }

  .modal-close {
    background: none;
    border: none;
    font-size: 1.1rem;
    color: #aaa;
    cursor: pointer;
    padding: 0.2rem 0.4rem;
    line-height: 1;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .modal-close:hover { background: #f5f5f5; color: #555; }

  .select-all-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid #f0f0f0;
    font-size: 0.9rem;
    color: #555;
    cursor: pointer;
    flex-shrink: 0;
  }
  .select-all-row input[type=checkbox] {
    width: 18px;
    height: 18px;
    accent-color: var(--modal-color, #557153);
    cursor: pointer;
    flex-shrink: 0;
  }

  .modal-subcats {
    overflow-y: auto;
    flex: 1;
    padding: 0.5rem 0;
  }

  .modal-footer {
    padding: 1rem 1.25rem;
    border-top: 1px solid #f0f0f0;
    flex-shrink: 0;
  }

  .modal-go-btn {
    width: 100%;
    background: var(--modal-color, #557153);
    color: white;
    border: none;
    border-radius: 50px;
    padding: 0.85rem 1rem;
    font-size: 1rem;
    font-family: inherit;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .modal-go-btn:hover    { opacity: 0.88; }
  .modal-go-btn:disabled { opacity: 0.4; cursor: default; }

  /* JS-created subcat rows */
  :global(.subcat-wrap)            { border-bottom: 1px solid #f0f0f0; }
  :global(.subcat-wrap:last-child) { border-bottom: none; }

  :global(.subcat-row) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1.25rem;
    cursor: pointer;
    transition: background 0.12s;
  }
  :global(.subcat-row:hover) { background: #f5f8f5; }

  :global(.subcat-row input[type=checkbox]) {
    width: 18px;
    height: 18px;
    accent-color: var(--modal-color, #557153);
    cursor: pointer;
    flex-shrink: 0;
  }

  :global(.subcat-info)    { display: flex; flex-direction: column; gap: 0.1rem; }
  :global(.subcat-name-row) { display: flex; align-items: baseline; gap: 0.35rem; }
  :global(.subcat-name-en) { font-size: 0.95rem; font-weight: 700; color: #333; }
  :global(.subcat-sep)     { font-size: 0.85rem; color: #ccc; }
  :global(.subcat-name-ja) {
    font-size: 0.88rem;
    font-weight: 600;
    color: #888;
    font-family: 'M PLUS Rounded 1c', sans-serif;
  }
  :global(.subcat-count) { font-size: 0.78rem; color: #aaa; }

  /* Preview button & panel */
  :global(.preview-btn) {
    background: none;
    border: 1.5px solid #e0e0e0;
    border-radius: 6px;
    padding: 0.3rem 0.4rem;
    cursor: pointer;
    color: #bbb;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    margin-left: auto;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  :global(.preview-btn:hover) {
    border-color: var(--modal-color, #557153);
    color: var(--modal-color, #557153);
  }
  :global(.preview-btn.active) {
    border-color: var(--modal-color, #557153);
    color: var(--modal-color, #557153);
    background: #f0f5ff;
  }

  :global(.preview-panel) {
    padding: 0.6rem 1.25rem 0.85rem 3.4rem;
    background: #f7f9ff;
    border-top: 1px solid #eef2ff;
  }

  :global(.word-chips) { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  :global(.word-chip) {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: white;
    border: 1.5px solid #dbeafe;
    border-radius: 8px;
    padding: 0.25rem 0.6rem;
    line-height: 1.3;
  }
  :global(.chip-en) { font-size: 0.78rem; font-weight: 700; color: #1e3a8a; }
  :global(.chip-ja) {
    font-size: 0.72rem;
    color: #555;
    font-family: 'M PLUS Rounded 1c', sans-serif;
  }

  /* Category grid buttons (JS-created by buildCategoryGrid) */
  :global(.group-header) {
    -webkit-appearance: none;
    appearance: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    height: 56px;
    background: white;
    border: 1px solid #eee;
    border-left: 5px solid #ccc;
    border-radius: 0 10px 10px 0;
    padding: 0 1rem;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: background 0.15s;
    box-sizing: border-box;
    color: inherit;
  }
  :global(.group-header:hover) { background: #f5f8f5; }

  :global(.group-header-text) {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  :global(.group-label)   { font-weight: 700; font-size: 0.9rem; color: #222; }
  :global(.group-chevron) { font-size: 0.9rem; color: #aaa; flex-shrink: 0; }
</style>
