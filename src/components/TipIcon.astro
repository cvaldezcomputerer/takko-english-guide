---
// Placeholder pixel-style mascot for the homepage tip widgets ("tutorial guy").
// All three sidebar widgets render this, so when the real pixel logo is ready,
// swap the SVG below and every widget updates at once.
const { class: className } = Astro.props;
---

<img
  class:list={["tip-icon", className]}
  src="/images/logo-pixel.png"
  alt=""
  aria-hidden="true"
/>

<style>
  .tip-icon {
    display: block;
    width: 32px;
    height: 32px;
    image-rendering: pixelated;
  }
</style>
