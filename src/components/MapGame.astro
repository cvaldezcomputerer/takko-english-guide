---
// MapGame.astro - School Map Navigation Game
import lilMeow from '../assets/game/lilMeow.png';
import boomGif from '../assets/game/boom.gif';

// Optimized image loading from src/assets
const roadImagesGlob = import.meta.glob<any>('../assets/game-roads/*.png', { eager: true });
const roomImagesGlob = import.meta.glob<any>('../assets/game-rooms/*.png', { eager: true });

const roadMap: Record<string, string> = {};
for (const path in roadImagesGlob) {
  const fileName = path.split('/').pop()?.replace('.png', '') || '';
  // Map both kebab-case and CamelCase to be safe
  const module = roadImagesGlob[path] as any;
  roadMap[fileName.toLowerCase()] = module.default.src;
}

const roomMap: Record<string, string> = {};
for (const path in roomImagesGlob) {
  const fileName = path.split('/').pop()?.replace('.png', '') || '';
  const module = roomImagesGlob[path] as any;
  roomMap[fileName.toLowerCase()] = module.default.src;
}
---

<div class="game-container">
  <div id="map-title" class="map-title"></div>
  <div class="grid-container">
    <div class="grid" id="grid">
      <!-- Grid cells will be rendered by JavaScript -->
    </div>
  </div>
  
  <div class="controls">
    <button class="control-btn" id="btn-left">⬅️</button>
    <button class="control-btn" id="btn-straight">⬆️</button>
    <button class="control-btn" id="btn-right">➡️</button>
    <button class="control-btn reset-btn" id="btn-reset">🔄</button>
    <button class="control-btn" id="btn-next-map" title="Next Map">🗺️</button>
  </div>
</div>

<style>
  .game-container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    padding: 0;
    box-sizing: border-box;
    background: #b4f1ae;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    overflow: hidden;
  }

  .map-title {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(4px);
    padding: 20px 10px;
    border-radius: 20px;
    font-size: 1.5rem;
    font-weight: bold;
    color: #2c3e50;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    z-index: 1000;
    writing-mode: vertical-rl;
    text-orientation: upright;
    letter-spacing: 2px;
  }

  .controls {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 15px;
    padding: 20px 10px;
    border-radius: 20px;
    justify-content: center;
    flex-shrink: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(4px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }

  .control-btn {
    font-size: 2rem;
    padding: 10px 20px;
    border-radius: 12px;
    border: none;
    background: white;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    cursor: pointer;
    transition: all 0.1s;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .control-btn:hover {
    background: #f0f0f0;
  }

  .control-btn:active {
    transform: scale(0.9);
  }

  .grid-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    overflow: hidden;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(21, 1fr);
    grid-template-rows: repeat(12, 1fr);
    gap: 0;
    aspect-ratio: 21/12;
    width: 100%;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    background-color: #7ab371; /* Grass color for outside */
    padding: 0;
    border-radius: 0;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    overflow: visible;
  }

  .grid :global(.cell) {
    background: transparent;
    display: grid;
    place-items: center;
    position: relative;
    box-sizing: border-box;
    border: none;
    --wall-top-shadow: inset 0 0 0 0 transparent;
    --wall-bottom-shadow: inset 0 0 0 0 transparent;
    --wall-left-shadow: inset 0 0 0 0 transparent;
    --wall-right-shadow: inset 0 0 0 0 transparent;
    box-shadow: var(--wall-top-shadow), var(--wall-bottom-shadow), var(--wall-left-shadow), var(--wall-right-shadow);
  }

  /* Interior styling */
  .grid :global(.cell.interior) {
    background-color: #e3c099;
  }

  /* Wall lines via inset shadows (visual only; does not change content box) */
  .grid :global(.wall-top) { --wall-top-shadow: inset 0 4px 0 0 #6b4f3a; }
  .grid :global(.wall-bottom) { --wall-bottom-shadow: inset 0 -4px 0 0 #6b4f3a; }
  .grid :global(.wall-left) { --wall-left-shadow: inset 4px 0 0 0 #6b4f3a; }
  .grid :global(.wall-right) { --wall-right-shadow: inset -4px 0 0 0 #6b4f3a; }

  .grid :global(.cell.location) {
    z-index: 5;
    border-radius: 8px;
    border: 2px solid rgba(255, 255, 255, 0.6) !important;
    box-shadow: var(--wall-top-shadow), var(--wall-bottom-shadow), var(--wall-left-shadow), var(--wall-right-shadow), 0 2px 4px rgba(0,0,0,0.2);
    overflow: visible;
  }

  .grid :global(.road-layer) {
    position: absolute ;
    top: 0 ; 
    left: 0 ; 
    width: 100% ; 
    height: 100% ;
    background-size: cover ;
    background-repeat: no-repeat ;
    background-position: center ;
    z-index: 1 ;
    pointer-events: none;
    display: block;
    transform-origin: center center;
    image-rendering: pixelated;
  }

  .grid :global(.cell.out-of-bounds) {
    background-color: rgba(255, 0, 0, 0.6) !important;
  }

  .grid :global(.player) {
    grid-area: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .grid :global(.player-image) {
    width: 80%;
    height: 80%;
    object-fit: contain;
    transition: transform 0.2s ease;
  }

  .grid :global(.location-label) {
    font-size: clamp(8px, 1.2vw, 12px);
    font-weight: bold;
    color: #000;
    background: #ffd93d; /* Yellow from palette */
    padding: 2px 4px;
    border-radius: 4px;
    pointer-events: none;
    z-index: 10;
    position: absolute;
    bottom: -6px; /* Moved down slightly to hang over edge if needed */
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    width: max-content;
    border: 1px solid rgba(0,0,0,0.1);
    box-shadow: 0 1px 2px rgba(0,0,0,0.2);
  }

  .grid :global(.explosion-effect) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    z-index: 200;
    pointer-events: none;
    object-fit: fill;
  }
</style>

<script is:inline define:vars={{
  playerImageSrc: lilMeow.src,
  explosionSrc: boomGif.src,
  roadMap,
  roomMap
}}>
  /**
   * TILE / GRID NOTES (quick reference)
   *
   * - Grid size is fixed: 21 columns (x=0..20) and 12 rows (y=0..11).
   * - Coordinates: (0,0) is top-left. x increases → right, y increases ↓ down.
  * - The "school" interior area is not a tilemap; it’s defined per-level as either:
  *     - a rectangle (default for existing maps), or
  *     - an irregular mask built from rects + holes (used for custom building shapes).
  *   Cells inside the interior mask get the beige interior background; outside stays green.
  * - Walls are derived from the interior mask: if a neighbor cell is outside the mask, a wall
  *   border is drawn on that side. Entrances are just “open sides” where we skip drawing a wall.
   * - Roads/locations/items are sparse overlays: only cells listed in arrays get a road sprite,
   *   room image/label, or item icon.
   * - IMPORTANT: A road entry can exist under a location image; it’s just visually covered.
   *   If you see a “road on a room”, remove/move that road coordinate.
   *
   * ROAD TILE PIECES (how to choose images)
   * - straight-horizontal / straight-vertical: simple segments.
   * - corner-* : turn corners (e.g. corner-bot-right).
   * - end-* : dead-end caps. Only use if you intentionally want a dead end.
  * - t-shape-* : 3-way intersections. In this sprite set, the suffix indicates the “stem/open” direction:
  *     - t-shape-up = connects UP + left/right (missing DOWN)
  *     - t-shape-down = connects DOWN + left/right (missing UP)
  *     - t-shape-left = connects LEFT + up/down (missing RIGHT)
  *     - t-shape-right = connects RIGHT + up/down (missing LEFT)
   * - cross: 4-way intersection.
   */

  // Level Configuration
  const SCHOOL_SHIFT_Y = -1;

  const DEFAULT_INTERIOR = {
    rects: [{ x1: 2, y1: 0, x2: 18, y2: 10 }],
    holes: [],
    // Bottom-left opening (keeps the classic entrance gap)
    entrance: { x: 2, y: 10, open: ['left', 'bottom'] },
  };

  function shiftPosY(pos, dy) {
    return { ...pos, y: pos.y + dy };
  }

  function shiftLevelY(level, dy) {
    const interior = level.interior
      ? {
          ...level.interior,
          rects: (level.interior.rects || []).map((r) => ({ ...r, y1: r.y1 + dy, y2: r.y2 + dy })),
          holes: (level.interior.holes || []).map((h) => ({ ...h, y1: h.y1 + dy, y2: h.y2 + dy })),
          entrance: level.interior.entrance
            ? { ...level.interior.entrance, y: level.interior.entrance.y + dy }
            : undefined,
        }
      : undefined;

    return {
      ...level,
      startPos: shiftPosY(level.startPos, dy),
      locations: (level.locations || []).map((loc) => ({ ...loc, y: loc.y + dy })),
      roads: (level.roads || []).map((r) => ({ ...r, y: r.y + dy })),
      items: (level.items || []).map((i) => ({ ...i, y: i.y + dy })),
      interior,
    };
  }

  function clamp(n, min, max) {
    return Math.max(min, Math.min(max, n));
  }

  function keyFor(x, y) {
    return `${x},${y}`;
  }

  function buildInteriorSet(level) {
    const interior = level.interior || DEFAULT_INTERIOR;
    const rects = interior.rects || [];
    const holes = interior.holes || [];
    const set = new Set();

    for (const r of rects) {
      const x1 = clamp(Math.min(r.x1, r.x2), 0, 20);
      const x2 = clamp(Math.max(r.x1, r.x2), 0, 20);
      const y1 = clamp(Math.min(r.y1, r.y2), 0, 11);
      const y2 = clamp(Math.max(r.y1, r.y2), 0, 11);
      for (let y = y1; y <= y2; y++) {
        for (let x = x1; x <= x2; x++) {
          set.add(keyFor(x, y));
        }
      }
    }

    for (const h of holes) {
      const x1 = clamp(Math.min(h.x1, h.x2), 0, 20);
      const x2 = clamp(Math.max(h.x1, h.x2), 0, 20);
      const y1 = clamp(Math.min(h.y1, h.y2), 0, 11);
      const y2 = clamp(Math.max(h.y1, h.y2), 0, 11);
      for (let y = y1; y <= y2; y++) {
        for (let x = x1; x <= x2; x++) {
          set.delete(keyFor(x, y));
        }
      }
    }

    return set;
  }

  function getEntranceConfig(level) {
    const interior = level.interior || DEFAULT_INTERIOR;
    return interior.entrance || null;
  }

  // We keep authoring coordinates in `levelsRaw`, then apply a uniform shift so the school doesn't
  // sit flush to the bottom of the viewport/grid. This preserves the grid size and just moves
  // the school content (player + roads + locations + items) together.
  const levelsRaw = [
    {
      name: "Mizu Gashira ES",
