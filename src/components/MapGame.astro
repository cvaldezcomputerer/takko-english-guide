        { x: 3, y: 5, image: 'straight-horizontal' }, { x: 4, y: 5, image: 'straight-horizontal' },
        { x: 5, y: 5, image: 't-shape-down' }, { x: 6, y: 5, image: 'straight-horizontal' },
        { x: 7, y: 5, image: 'straight-horizontal' }, { x: 8, y: 5, image: 'straight-horizontal' },
        { x: 9, y: 5, image: 'straight-horizontal' }, { x: 10, y: 5, image: 't-shape-down' }, 
        { x: 11, y: 5, image: 'straight-horizontal' }, { x: 12, y: 5, image: 'straight-horizontal' },
        { x: 13, y: 5, image: 'straight-horizontal' }, { x: 14, y: 5, image: 'straight-horizontal' },
        { x: 15, y: 5, image: 'cross' }, { x: 16, y: 5, image: 'straight-horizontal' },
        { x: 17, y: 5, image: 'straight-horizontal' },
        { x: 3, y: 8, image: 'straight-horizontal' }, { x: 4, y: 8, image: 't-shape-down' }, 
        { x: 5, y: 8, image: 'straight-horizontal' }, { x: 6, y: 8, image: 't-shape-up' },    
        { x: 7, y: 8, image: 'straight-horizontal' }, { x: 8, y: 8, image: 'straight-horizontal' },
        { x: 9, y: 8, image: 'straight-horizontal' }, { x: 10, y: 8, image: 'straight-horizontal' },
        { x: 11, y: 8, image: 'straight-horizontal' }, { x: 12, y: 8, image: 't-shape-down' }, 
        { x: 13, y: 8, image: 'straight-horizontal' }, { x: 14, y: 8, image: 't-shape-up' },    
        { x: 15, y: 8, image: 'end-left' },
      ],
      items: []
    },
    {
      name: "The Maze",
      startPos: { x: 2, y: 11 },
      locations: [
         { x: 2, y: 11, name: "Entrance", image: roomMap['entrance'] },
         { x: 2, y: 1, name: "Staff Room", image: roomMap['staff-room'] },
         { x: 3, y: 5, name: "Nurse’s Office", image: roomMap['nurses-office'] },
         { x: 4, y: 4, name: "Lunch Room", image: roomMap['lunch-room'] },
         { x: 6, y: 2, name: "Class Room", image: roomMap['class-room'] },
         { x: 6, y: 9, name: "Sumo Ring", image: roomMap['sumo-ring'] },
         { x: 10, y: 2, name: "Principals Office", image: roomMap['principals-office'] },
         { x: 10, y: 9, name: "Home Ec Room", image: roomMap['home-ec-room'] },
         { x: 12, y: 5, name: "Gym", image: roomMap['gym'] },
         { x: 14, y: 2, name: "Library", image: roomMap['library'] },
         { x: 14, y: 9, name: "Restroom", image: roomMap['rest-room'] },
         { x: 18, y: 1, name: "Music Room", image: roomMap['music-room'] },
         { x: 17, y: 4, name: "Science Lab", image: roomMap['science-lab'] },
         { x: 17, y: 9, name: "Computer Lab", image: roomMap['computer-lab'] },
         { x: 18, y: 11, name: "Art Room", image: roomMap['art-room'] },
         { x: 8, y: 8, name: "Secret Room", image: roomMap['playground'] },
         { x: 12, y: 11, name: "Playground", image: roomMap['playground'] }
      ],
      roads: [
        // Trunk (Left)
        { x: 2, y: 10, image: 'straight-vertical' }, { x: 2, y: 9, image: 'straight-vertical' },
        { x: 2, y: 8, image: 'straight-vertical' }, { x: 2, y: 7, image: 'straight-vertical' },
        { x: 2, y: 6, image: 't-shape-right' }, // Hub
        { x: 2, y: 5, image: 't-shape-right' }, // To Nurse
        { x: 2, y: 4, image: 'straight-vertical' }, { x: 2, y: 3, image: 'straight-vertical' }, 
        { x: 2, y: 2, image: 'straight-vertical' }, // Leads to Staff (2,1)

        // Main Horizontal Spine (Row 6)
        { x: 3, y: 6, image: 'straight-horizontal' }, 
        { x: 4, y: 6, image: 't-shape-up' }, // To Lunch (4,4)
        { x: 5, y: 6, image: 'straight-horizontal' }, 
        { x: 6, y: 6, image: 'cross' }, // Branch 1
        { x: 7, y: 6, image: 'straight-horizontal' }, 
        { x: 8, y: 6, image: 'cross' }, // To Secret and Money
        { x: 9, y: 6, image: 'straight-horizontal' }, 
        { x: 10, y: 6, image: 'cross' }, // Branch 2
        { x: 11, y: 6, image: 'straight-horizontal' }, 
        { x: 12, y: 6, image: 't-shape-up' }, // To Gym (12,5)
        { x: 13, y: 6, image: 'straight-horizontal' }, 
        { x: 14, y: 6, image: 'cross' }, // Branch 3
        { x: 15, y: 6, image: 'straight-horizontal' }, 
        { x: 16, y: 6, image: 't-shape-down' }, // To Dog
        { x: 17, y: 6, image: 'straight-horizontal' }, 
        { x: 18, y: 6, image: 't-shape-left' }, // Right End

        // Branches
        // Lunch Branch
        { x: 4, y: 5, image: 'straight-vertical' }, // (4,4) is Lunch

        // Branch 1 (Col 6)
        { x: 6, y: 5, image: 'straight-vertical' }, { x: 6, y: 4, image: 'straight-vertical' }, { x: 6, y: 3, image: 'straight-vertical' }, // To Class (6,2)
        { x: 6, y: 7, image: 'straight-vertical' }, { x: 6, y: 8, image: 'straight-vertical' }, // To Sumo (6,9)

        // Money/Secret Branch
        { x: 8, y: 5, image: 'cross' }, // Money is here
        { x: 8, y: 7, image: 'straight-vertical' }, // To Secret (8,8)

        // Branch 2 (Col 10)
        { x: 10, y: 5, image: 'straight-vertical' }, { x: 10, y: 4, image: 'straight-vertical' }, { x: 10, y: 3, image: 'straight-vertical' }, // To Principal (10,2)
        { x: 10, y: 7, image: 'straight-vertical' }, { x: 10, y: 8, image: 'cross' }, // To HomeEc (10,9) and Playground path

        // Playground Path
        { x: 11, y: 8, image: 'straight-horizontal' }, { x: 12, y: 8, image: 'corner-bot-left' },
        { x: 12, y: 9, image: 'straight-vertical' }, { x: 12, y: 10, image: 'straight-vertical' }, // To Playground (12,11)

        // Branch 3 (Col 14)
        { x: 14, y: 5, image: 'straight-vertical' }, { x: 14, y: 4, image: 'straight-vertical' }, { x: 14, y: 3, image: 'straight-vertical' }, // To Library (14,2)
        { x: 14, y: 7, image: 'straight-vertical' }, { x: 14, y: 8, image: 'straight-vertical' }, // To Restroom (14,9)

        // Right Spine (Col 18)
        { x: 18, y: 5, image: 'straight-vertical' }, { x: 18, y: 4, image: 't-shape-left' }, // To Science
        { x: 18, y: 3, image: 'straight-vertical' }, { x: 18, y: 2, image: 'straight-vertical' }, // To Music (18,1)
        { x: 18, y: 7, image: 'straight-vertical' }, { x: 18, y: 8, image: 'straight-vertical' }, 
        { x: 18, y: 9, image: 't-shape-left' }, // To Comp
        { x: 18, y: 10, image: 'straight-vertical' }, // To Art (18,11)
      ],
      items: [
        { x: 8, y: 5, icon: "💰" },
        { x: 16, y: 7, icon: "🐕" }
      ]
    }
  ];

  let currentLevelIdx = 0;
  let playerPos = { ...levels[0].startPos };
  let playerHeading = 0; 
  const directions = [{ dx: 0, dy: -1 }, { dx: 1, dy: 0 }, { dx: 0, dy: 1 }, { dx: -1, dy: 0 }];
  const headingToRotation = [0, 90, 180, 270];

  function getLocationAt(x, y) { return levels[currentLevelIdx].locations.find(loc => loc.x === x && loc.y === y); }
  function getRoadAt(x, y) { return levels[currentLevelIdx].roads.find(r => r.x === x && r.y === y); }
  function getItemAt(x, y) { return (levels[currentLevelIdx].items || []).find(i => i.x === x && i.y === y); }

  function renderGrid() {
    const grid = document.getElementById("grid");
    if (!grid) return;
    grid.innerHTML = "";
    
    // Update status to show level name
    const statusEl = document.getElementById("status-display");
    if (statusEl) {
      const location = getLocationAt(playerPos.x, playerPos.y);
      statusEl.textContent = `${levels[currentLevelIdx].name} | Pos: (${playerPos.x}, ${playerPos.y})${location ? ' | At: ' + location.name : ''}`;
    }

    const minX = 2, maxX = 18, minY = 1, maxY = 11;

    for (let y = 0; y < 12; y++) {
      for (let x = 0; x < 21; x++) {
        const cell = document.createElement("div");
        cell.className = "cell";
        const location = getLocationAt(x, y);
        const road = getRoadAt(x, y);
        const item = getItemAt(x, y);
        const isPlayerHere = playerPos.x === x && playerPos.y === y;

        // Interior floor
        if (x >= minX && x <= maxX && y >= minY && y <= maxY) cell.classList.add("interior");

        // Walls
        if (y === 0 && x >= minX && x <= maxX) cell.classList.add("wall-bottom"); // School Top
        if (x === minX && y >= minY && y <= maxY && !(x === 2 && y === 11)) cell.classList.add("wall-left"); // School Left
        if (x === maxX && y >= minY && y <= maxY) cell.classList.add("wall-right"); // School Right
        if (y === maxY && x >= minX && x <= maxX && !(x === 2 && y === 11)) cell.classList.add("wall-bottom"); // School Bottom

        if (road) {
          const roadBg = document.createElement("div");
          roadBg.className = "road-layer";
          const roadSrc = roadMap[road.image.toLowerCase()];
          if (roadSrc) roadBg.style.backgroundImage = `url('${roadSrc}')`;
          cell.appendChild(roadBg);
        }

        if (location) {
          cell.classList.add("location");
          cell.style.backgroundImage = `url('${location.image}')`;
          cell.style.backgroundSize = 'contain';
          cell.style.backgroundRepeat = 'no-repeat';
          cell.style.backgroundPosition = 'center';
          cell.style.backgroundColor = 'rgba(255, 255, 255, 0.4)'; 
          const label = document.createElement("span");
          label.className = "location-label";
          label.textContent = location.name;
          cell.appendChild(label);
        }

        if (item) {
          const itemEl = document.createElement("div");
          itemEl.style.fontSize = "2rem";
          itemEl.style.zIndex = "6";
          itemEl.style.position = "absolute";
          itemEl.textContent = item.icon;
          cell.appendChild(itemEl);
        }

        if (isPlayerHere) {
          const playerEl = document.createElement("div");
          playerEl.className = "player";
          const img = document.createElement("img");
          img.src = playerImageSrc;
          img.className = "player-image";
          img.style.transform = `rotate(${headingToRotation[playerHeading]}deg)`;
          playerEl.appendChild(img);
          cell.appendChild(playerEl);
        }
        grid.appendChild(cell);
      }
    }
  }

  function updateStatus() {
     // Already handled in renderGrid, but kept for movement updates
    const location = getLocationAt(playerPos.x, playerPos.y);
    const item = getItemAt(playerPos.x, playerPos.y);
    const statusEl = document.getElementById("status-display");
    if (statusEl) statusEl.textContent = `${levels[currentLevelIdx].name} | Pos: (${playerPos.x}, ${playerPos.y})${location ? ' | At: ' + location.name : ''}${item ? ' | Found: ' + item.icon : ''}`;
  }

  function turnLeft() { playerHeading = (playerHeading + 3) % 4; renderGrid(); }
  function turnRight() { playerHeading = (playerHeading + 1) % 4; renderGrid(); }
  function goStraight() {
    const dir = directions[playerHeading];
    const newX = playerPos.x + dir.dx, newY = playerPos.y + dir.dy;
    if (newX >= 0 && newX <= 20 && newY >= 0 && newY <= 11) {
      playerPos = { x: newX, y: newY };
      renderGrid();
      // Status updated in renderGrid
      if (!getRoadAt(newX, newY) && !getLocationAt(newX, newY) && !getItemAt(newX, newY)) triggerExplosion(newX, newY);
    }
  }

  window.triggerExplosion = function(x, y) {
    // Play out-of-bounds sound
    const meow = new Audio('/audio/meowDeep.mp3');
    meow.play().catch(e => console.warn("Audio play blocked by browser:", e));

    const grid = document.getElementById("grid");
    const index = y * 21 + x;
    const cell = grid?.children[index];
    if (cell) {
      const img = document.createElement("img");
      img.src = explosionSrc + "?t=" + Date.now(); 
      img.className = "explosion-effect";
      cell.appendChild(img);
      setTimeout(() => img.remove(), 1000);
    }
  };

  function resetGame() {
    playerPos = { ...levels[currentLevelIdx].startPos }; 
    playerHeading = 0; 
    renderGrid(); 
  }

  function switchMap() {
    currentLevelIdx = (currentLevelIdx + 1) % levels.length;
    resetGame();
  }

  document.addEventListener("DOMContentLoaded", () => {
    renderGrid();
    document.getElementById("btn-left")?.addEventListener("click", turnLeft);
    document.getElementById("btn-right")?.addEventListener("click", turnRight);
    document.getElementById("btn-straight")?.addEventListener("click", goStraight);
    document.getElementById("btn-reset")?.addEventListener("click", resetGame);
    document.getElementById("btn-next-map")?.addEventListener("click", switchMap);
  });
</script>