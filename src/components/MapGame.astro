        { x: 15, y: 5, image: 'cross' }, { x: 16, y: 5, image: 'straight-horizontal' },
        { x: 17, y: 5, image: 'straight-horizontal' },

        // Connector paths between corridors (Row 5 <-> Row 8)
        { x: 8, y: 6, image: 'straight-vertical' }, { x: 8, y: 7, image: 'straight-vertical' },
        { x: 11, y: 6, image: 'straight-vertical' }, { x: 11, y: 7, image: 'straight-vertical' },

        { x: 3, y: 8, image: 'straight-horizontal' }, { x: 4, y: 8, image: 't-shape-down' }, 
