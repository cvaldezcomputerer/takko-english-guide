        { x: 13, y: 8, image: 'straight-horizontal' }, { x: 14, y: 8, image: 't-shape-up' },    
        { x: 15, y: 8, image: 'end-left' },
      ],
      items: []
    },
    {
      name: "Kamogo ES 🦆",
      startPos: { x: 2, y: 11 },
      startHeading: 0,
      locations: [
         { x: 2, y: 11, name: "Entrance", image: roomMap['entrance'] },
         { x: 2, y: 1, name: "Staff Room", image: roomMap['staff-room'] },
         { x: 3, y: 5, name: "Nurse’s Office", image: roomMap['nurses-office'] },
         { x: 4, y: 4, name: "Lunch Room", image: roomMap['lunch-room'] },
