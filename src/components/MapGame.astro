        { x: 2, y: 10, image: 'straight-vertical' }, { x: 2, y: 9, image: 'straight-vertical' },
        { x: 2, y: 8, image: 't-shape-right' }, { x: 2, y: 7, image: 'straight-vertical' },
        { x: 2, y: 6, image: 'straight-vertical' }, { x: 2, y: 5, image: 't-shape-right' },
        { x: 2, y: 4, image: 'straight-vertical' }, { x: 2, y: 3, image: 'straight-vertical' },
        { x: 2, y: 2, image: 'corner-bot-right' }, 
        { x: 3, y: 2, image: 'straight-horizontal' }, { x: 4, y: 2, image: 'cross' },    
        { x: 5, y: 2, image: 'straight-horizontal' }, { x: 6, y: 2, image: 't-shape-up' },
        { x: 7, y: 2, image: 't-shape-down' }, { x: 8, y: 2, image: 't-shape-down' }, 
