        { x: 14, y: 5, image: 'straight-vertical' }, { x: 14, y: 4, image: 'straight-vertical' }, { x: 14, y: 3, image: 'cross' }, // To Library (14,2)
        { x: 14, y: 7, image: 'cross' }, { x: 14, y: 8, image: 'straight-vertical' }, // To Restroom (14,9)

        // Right Spine (Col 18)
        { x: 18, y: 5, image: 'straight-vertical' }, { x: 18, y: 4, image: 't-shape-left' }, // To Science
        { x: 18, y: 3, image: 't-shape-left' }, { x: 18, y: 2, image: 'straight-vertical' }, // To Music (18,1)
        { x: 18, y: 7, image: 't-shape-left' }, { x: 18, y: 8, image: 'straight-vertical' }, 
        { x: 18, y: 9, image: 't-shape-left' }, // To Comp
