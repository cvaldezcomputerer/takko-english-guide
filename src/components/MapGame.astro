        { x: 10, y: 7, image: 'cross' }, { x: 10, y: 8, image: 'cross' }, // To HomeEc (10,9) and Playground path

        // Playground Path
        { x: 11, y: 8, image: 'straight-horizontal' }, { x: 12, y: 8, image: 't-shape-left' },
        { x: 12, y: 9, image: 'straight-vertical' }, { x: 12, y: 10, image: 'straight-vertical' }, // To Playground (12,11)

