        { x: 12, y: 9, name: "Home Ec Room", image: roomMap['home-ec-room'] },
        { x: 14, y: 7, name: "Playground", image: roomMap['playground'] },
        { x: 6, y: 1, name: "Class Room", image: roomMap['class-room'] },
        { x: 4, y: 3, name: "Principals Office", image: roomMap['principals-office'] },
      ],
