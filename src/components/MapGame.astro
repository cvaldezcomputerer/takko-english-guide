        { x: 17, y: 9, image: 'straight-horizontal' },
        { x: 16, y: 9, image: 't-shape-down' },
          { x: 15, y: 9, image: 'straight-horizontal' },
        { x: 14, y: 9, image: 't-shape-up' },
        { x: 13, y: 9, image: 'straight-horizontal' },
        { x: 12, y: 9, image: 'cross' },
