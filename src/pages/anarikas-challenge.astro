---
import Layout from '../layouts/ToolLayout.astro';
import { categories } from '../data/anarika/words';
const categoriesJson = JSON.stringify(categories);
---

<Layout title="Anarika's Challenge" description="A Japanese vocabulary quiz game.">
<div class="game-wrap">

  <!-- Category Select -->
  <div id="screen-select" class="screen">
    <div class="anarika-card">
      <div class="anarika-avatar">
        <img src="/images/anarika-challenge/anarika-face.png" alt="Anarika" class="avatar-img" />
      </div>
      <h1 class="game-title">Anarika's Challenge<span class="title-ja">アナリカのちょうせん</span></h1>
      <p class="game-desc"><span class="bilingual-line"><span>Choose a category.</span><span>カテゴリーをえらぼう。</span></span><span class="bilingual-line"><span>Type the Japanese answer for each word.</span><span>にほんごでこたえてね。</span></span></p>
    </div>

    <div class="category-grid" id="category-grid"></div>
  </div>

  <!-- Category Modal -->
  <div id="category-modal" class="modal-overlay hidden" role="dialog" aria-modal="true">
    <div class="modal-box">
      <div class="modal-header">
        <div class="modal-title-wrap">
          <span class="modal-group-name" id="modal-group-name"></span>
          <span class="modal-group-ja" id="modal-group-ja"></span>
        </div>
        <button class="modal-close" id="modal-close" aria-label="Close">✕</button>
      </div>

      <label class="select-all-row">
        <input type="checkbox" id="select-all-cb" />
        <span>Select all ／ すべてえらぶ</span>
      </label>

      <div class="modal-subcats" id="modal-subcats"></div>

      <div class="mode-select" id="mode-select">
        <button class="mode-btn active" data-mode="easy">Easy ／ かんたん</button>
        <button class="mode-btn" data-mode="medium">Medium ／ ふつう</button>
        <button class="mode-btn" data-mode="hard">Hard ／ むずかしい</button>
        <button class="mode-btn" data-mode="challenge">Challenge ／ チャレンジ</button>
      </div>

      <div class="modal-footer">
        <button class="modal-start-btn" id="modal-start-btn">Start Quiz ／ はじめる</button>
      </div>
    </div>
  </div>

  <!-- Quiz Screen -->
  <div id="screen-quiz" class="screen hidden">
    <div class="quiz-header">
      <button class="back-btn" id="back-btn">← Back / もどる</button>
      <div class="progress-wrap">
        <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
        <span class="progress-label" id="progress-label"></span>
      </div>
      <div class="score-display" id="score-display">0 / 0</div>
    </div>

    <div class="question-card">
      <p class="question-label" id="question-label"></p>
      <div class="english-word" id="english-word"></div>
      <div class="choices-grid hidden" id="choices-grid"></div>
      <input
        type="text"
        id="answer-input"
        class="answer-input"
        placeholder="ひらがなでこたえてください"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
      />
      <button class="submit-btn" id="submit-btn">Check / かくにん</button>
    </div>

    <div class="feedback-card hidden" id="feedback-card">
      <div class="feedback-icon" id="feedback-icon"></div>
      <div class="feedback-text" id="feedback-text"></div>
      <div class="accepted-answers" id="accepted-answers"></div>
      <button class="next-btn" id="next-btn">Next / つぎ →</button>
    </div>
  </div>

  <!-- Results Screen -->
  <div id="screen-results" class="screen hidden">
    <div class="anarika-card">
      <div class="anarika-avatar">
        <img src="/images/anarika-challenge/anarika-face.png" alt="Anarika" class="avatar-img" />
      </div>
      <h2 class="result-title" id="result-title"></h2>
      <div class="score-big" id="score-big"></div>
    </div>

    <div class="missed-section" id="missed-section">
      <h3 class="missed-title">Review ／ ふくしゅう</h3>
      <table class="missed-table" id="missed-table">
        <thead>
          <tr>
            <th>English ／ えいご</th>
            <th>Your answer ／ こたえ</th>
            <th>Correct ／ せいかい</th>
          </tr>
        </thead>
        <tbody id="missed-body"></tbody>
      </table>
    </div>

    <div class="results-actions">
      <button class="play-again-btn" id="play-again-btn">Play again / もういちど</button>
      <button class="back-to-select-btn" id="back-to-select-btn">Categories / もどる</button>
    </div>
  </div>

</div>
</Layout>

<script define:vars={{ categoriesJson }}>
  const categories = JSON.parse(categoriesJson);

  // State
  let words = [];
  let lastWordsForReplay = [];
  let wordIndex = 0;
  let score = 0;
  let missed = [];
  let quizMode = 'easy';
  let lastMode = 'easy';

  // Elements
  const screenSelect  = document.getElementById('screen-select');
  const screenQuiz    = document.getElementById('screen-quiz');
  const screenResults = document.getElementById('screen-results');

  const categoryGrid  = document.getElementById('category-grid');
  const englishWord   = document.getElementById('english-word');
  const answerInput   = document.getElementById('answer-input');
  const submitBtn     = document.getElementById('submit-btn');
  const feedbackCard  = document.getElementById('feedback-card');
  const feedbackIcon  = document.getElementById('feedback-icon');
  const feedbackText  = document.getElementById('feedback-text');
  const acceptedEl    = document.getElementById('accepted-answers');
  const nextBtn       = document.getElementById('next-btn');
  const backBtn       = document.getElementById('back-btn');
  const progressFill  = document.getElementById('progress-fill');
  const progressLabel = document.getElementById('progress-label');
  const scoreDisplay  = document.getElementById('score-display');
  const questionLabel = document.getElementById('question-label');
  const choicesGrid   = document.getElementById('choices-grid');

  const resultTitle   = document.getElementById('result-title');
  const scoreBig      = document.getElementById('score-big');
  const missedSection = document.getElementById('missed-section');
  const missedBody    = document.getElementById('missed-body');
  const playAgainBtn  = document.getElementById('play-again-btn');
  const backToSelectBtn = document.getElementById('back-to-select-btn');

  // Modal elements
  const modal         = document.getElementById('category-modal');
  const modalClose    = document.getElementById('modal-close');
  const modalGroupName = document.getElementById('modal-group-name');
  const modalGroupJa  = document.getElementById('modal-group-ja');
  const modalSubcats  = document.getElementById('modal-subcats');
  const selectAllCb   = document.getElementById('select-all-cb');
  const modalStartBtn = document.getElementById('modal-start-btn');
  const modeBtns      = document.querySelectorAll('.mode-btn');

  modeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      quizMode = btn.dataset.mode;
      modeBtns.forEach(b => b.classList.toggle('active', b === btn));
    });
  });

  // Screens
  function showScreen(id) {
    [screenSelect, screenQuiz, screenResults].forEach(s => s.classList.add('hidden'));
    document.getElementById(id).classList.remove('hidden');
  }

  function normalize(str) {
    return str.trim().replace(/\s+/g, '');
  }

  function checkAnswer(input, accepted) {
    const norm = normalize(input);
    return accepted.some(a => normalize(a) === norm);
  }

  const categoryGroups = [
    { label: "Food & Drink", ja: "たべもの・のみもの", color: "#e6a817", categories: [
      { name: "Drinks", ja: "のみもの" },
      { name: "Dessert", ja: "おかし" },
      { name: "Food", ja: "たべもの" },
      { name: "Japanese Food", ja: "にほんのたべもの" },
      { name: "Fruit and Vegetables", ja: "くだもの・やさい" },
      { name: "Meals", ja: "しょくじ" },
      { name: "Ingredients", ja: "ざいりょう" },
      { name: "Taste", ja: "あじ" },
    ]},
    { label: "People & Self", ja: "ひと・じぶん", color: "#d64f8a", categories: [
      { name: "Feelings", ja: "きもち" },
      { name: "People", ja: "ひと" },
      { name: "Personality", ja: "せいかく" },
      { name: "Family", ja: "かぞく" },
      { name: "Body Parts", ja: "からだ" },
      { name: "Frequency", ja: "ひんど" },
      { name: "Daily Routines", ja: "にちじょう" },
    ]},
    { label: "Clothes & Belongings", ja: "ふく・もちもの", color: "#7c5cbf", categories: [
      { name: "Clothes", ja: "ふく" },
      { name: "Personal Belongings", ja: "もちもの" },
      { name: "Stationery", ja: "ぶんぼうぐ" },
    ]},
    { label: "Nature & Animals", ja: "しぜん・どうぶつ", color: "#3a9e5f", categories: [
      { name: "Animals", ja: "どうぶつ" },
      { name: "Sea Animals", ja: "うみのいきもの" },
      { name: "Bugs", ja: "むし" },
      { name: "Nature", ja: "しぜん" },
      { name: "Environment and 4Rs", ja: "かんきょう" },
    ]},
    { label: "Date / Time", ja: "じかん・にちじ", color: "#1a8fa0", categories: [
      { name: "Months", ja: "つき" },
      { name: "Dates", ja: "ひにち" },
      { name: "Days", ja: "ようび" },
      { name: "Seasons", ja: "きせつ" },
      { name: "Weather", ja: "てんき" },
    ]},
    { label: "School", ja: "がっこう", color: "#2a6db5", categories: [
      { name: "School Subjects", ja: "きょうか" },
      { name: "School Places", ja: "がっこうのばしょ" },
      { name: "Club Activities", ja: "クラブかつどう" },
      { name: "School Events", ja: "がっこうのイベント" },
    ]},
    { label: "Arts & Play", ja: "おんがく・あそび", color: "#d9622b", categories: [
      { name: "Musical Instruments", ja: "がっき" },
      { name: "Play and Activities", ja: "あそび" },
      { name: "Sports", ja: "スポーツ" },
    ]},
    { label: "Town & Travel", ja: "まち・いどう", color: "#5a7a8a", categories: [
      { name: "Town and Places", ja: "まち・ばしょ" },
      { name: "Vehicles", ja: "のりもの" },
      { name: "Directions", ja: "ほうこう" },
      { name: "Positions", ja: "いち" },
    ]},
    { label: "Language & Concepts", ja: "ことば・がいねん", color: "#c0394b", categories: [
      { name: "Jobs", ja: "しごと" },
      { name: "Annual Events", ja: "ねんじゅうぎょうじ" },
      { name: "Impressions", ja: "いんしょう" },
      { name: "Conditions", ja: "じょうたい" },
      { name: "Colors", ja: "いろ" },
      { name: "Shapes", ja: "かたち" },
      { name: "Verbs (5th Grade)", ja: "どうし（5ねんせい）" },
      { name: "Verbs (6th Grade)", ja: "どうし（6ねんせい）" },
      { name: "Past Tense Verbs", ja: "かこのどうし" },
    ]},
  ];

  // Build group header buttons
  categoryGroups.forEach(group => {
    const header = document.createElement('button');
    header.className = 'group-header';
    header.style.borderLeftColor = group.color;
    header.innerHTML = `
      <span class="group-header-text">
        <span class="group-label">${group.label} ／ ${group.ja}</span>
      </span>
      <span class="group-chevron">▸</span>
    `;
    header.addEventListener('click', () => openModal(group));
    categoryGrid.appendChild(header);
  });

  // Modal logic
  function openModal(group) {
    modalGroupName.textContent = group.label;
    modalGroupJa.textContent = group.ja;
    modal.style.setProperty('--modal-color', group.color);

    // Populate subcategory checkboxes
    modalSubcats.innerHTML = '';
    group.categories.forEach(groupCat => {
      const cat = categories.find(c => c.name === groupCat.name);
      if (!cat) return;

      const label = document.createElement('label');
      label.className = 'subcat-row';

      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.value = groupCat.name;
      cb.checked = true;
      cb.addEventListener('change', syncSelectAll);

      const info = document.createElement('span');
      info.className = 'subcat-info';

      const nameRow = document.createElement('span');
      nameRow.className = 'subcat-name-row';
      const enSpan = document.createElement('span');
      enSpan.className = 'subcat-name-en';
      enSpan.textContent = groupCat.name;
      const sep = document.createElement('span');
      sep.className = 'subcat-sep';
      sep.textContent = '／';
      const jaSpan = document.createElement('span');
      jaSpan.className = 'subcat-name-ja';
      jaSpan.textContent = groupCat.ja;
      nameRow.appendChild(enSpan);
      nameRow.appendChild(sep);
      nameRow.appendChild(jaSpan);

      const countSpan = document.createElement('span');
      countSpan.className = 'subcat-count';
      countSpan.textContent = `${cat.words.length} words ／ ${cat.words.length} たんご`;

      info.appendChild(nameRow);
      info.appendChild(countSpan);

      label.appendChild(cb);
      label.appendChild(info);
      modalSubcats.appendChild(label);
    });

    // Default: all checked
    selectAllCb.checked = true;
    selectAllCb.indeterminate = false;
    updateStartBtn();

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function syncSelectAll() {
    const cbs = [...modalSubcats.querySelectorAll('input[type=checkbox]')];
    const checkedCount = cbs.filter(c => c.checked).length;
    if (checkedCount === 0) {
      selectAllCb.checked = false;
      selectAllCb.indeterminate = false;
    } else if (checkedCount === cbs.length) {
      selectAllCb.checked = true;
      selectAllCb.indeterminate = false;
    } else {
      selectAllCb.checked = false;
      selectAllCb.indeterminate = true;
    }
    updateStartBtn();
  }

  function updateStartBtn() {
    const cbs = [...modalSubcats.querySelectorAll('input[type=checkbox]')];
    const anyChecked = cbs.some(c => c.checked);
    modalStartBtn.disabled = !anyChecked;
  }

  selectAllCb.addEventListener('change', () => {
    const checked = selectAllCb.checked;
    modalSubcats.querySelectorAll('input[type=checkbox]').forEach(cb => cb.checked = checked);
    selectAllCb.indeterminate = false;
    updateStartBtn();
  });

  modalClose.addEventListener('click', closeModal);

  modal.addEventListener('click', e => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeModal();
  });

  modalStartBtn.addEventListener('click', () => {
    const cbs = [...modalSubcats.querySelectorAll('input[type=checkbox]')];
    const selectedNames = cbs.filter(c => c.checked).map(c => c.value);
    const merged = [];
    selectedNames.forEach(name => {
      const cat = categories.find(c => c.name === name);
      if (cat) merged.push(...cat.words);
    });
    closeModal();
    startQuiz(merged, quizMode);
  });

  function startQuiz(wordsArray, mode) {
    words = [...wordsArray];
    lastWordsForReplay = [...wordsArray];
    lastMode = mode;
    wordIndex = 0;
    score = 0;
    missed = [];
    showScreen('screen-quiz');
    showQuestion();
  }

  function getChoices(correctWord) {
    const pool = words.filter(w => w.en !== correctWord.en);
    const shuffled = pool.sort(() => Math.random() - 0.5).slice(0, 3);
    return [correctWord, ...shuffled].sort(() => Math.random() - 0.5);
  }

  function showQuestion() {
    feedbackCard.classList.add('hidden');

    const word = words[wordIndex];

    const pct = (wordIndex / words.length) * 100;
    progressFill.style.width = pct + '%';
    progressLabel.textContent = `${wordIndex + 1} / ${words.length}`;
    scoreDisplay.textContent = `${score} / ${wordIndex}`;

    if (lastMode === 'easy' || lastMode === 'medium') {
      const isMedium = lastMode === 'medium';
      questionLabel.textContent = isMedium
        ? 'What does this mean? ／ どういう いみ？'
        : 'What is this in Japanese? ／ にほんごでなんですか？';
      englishWord.textContent = isMedium ? word.ja[0] : word.en;
      answerInput.classList.add('hidden');
      submitBtn.classList.add('hidden');
      choicesGrid.classList.remove('hidden');

      const choices = getChoices(word);
      choicesGrid.innerHTML = '';
      choices.forEach(choice => {
        const btn = document.createElement('button');
        btn.className = 'choice-btn';
        const display = isMedium ? choice.en : choice.ja[0];
        const correctText = isMedium ? word.en : word.ja[0];
        btn.textContent = display;
        btn.addEventListener('click', () => submitChoiceAnswer(display, correctText, word));
        choicesGrid.appendChild(btn);
      });
    } else {
      // hard: show English, type Japanese
      // challenge: show Japanese, type English
      const isChallenge = lastMode === 'challenge';
      questionLabel.textContent = isChallenge
        ? 'What is this in English? ／ えいごでなんですか？'
        : 'What is this in Japanese? ／ にほんごでなんですか？';
      englishWord.textContent = isChallenge ? word.ja[0] : word.en;
      choicesGrid.classList.add('hidden');
      answerInput.classList.remove('hidden');
      submitBtn.classList.remove('hidden');
      answerInput.value = '';
      answerInput.disabled = false;
      answerInput.placeholder = isChallenge ? 'Type in English' : 'ひらがなでこたえてください';
      submitBtn.disabled = false;
      answerInput.focus();
    }
  }

  function submitChoiceAnswer(chosenText, correctText, word) {
    choicesGrid.querySelectorAll('.choice-btn').forEach(btn => {
      btn.disabled = true;
      if (btn.textContent === correctText) btn.classList.add('choice-correct');
      else if (btn.textContent === chosenText) btn.classList.add('choice-wrong');
    });

    const correct = chosenText === correctText;
    if (correct) {
      score++;
      feedbackIcon.textContent = 'O';
      feedbackIcon.className = 'feedback-icon correct';
      feedbackText.innerHTML = 'Correct! ／ <span class="ja">せいかい！</span>';
    } else {
      missed.push({ en: word.en, yourAnswer: chosenText, correct: correctText });
      feedbackIcon.textContent = 'X';
      feedbackIcon.className = 'feedback-icon wrong';
      feedbackText.innerHTML = 'Not quite. ／ <span class="ja">ざんねん！</span>';
    }
    acceptedEl.innerHTML = `<span class="accepted-label">Answer ／ こたえ：</span> ${correctText}`;
    feedbackCard.classList.remove('hidden');
  }

  function submitAnswer() {
    const word = words[wordIndex];
    const input = answerInput.value;

    if (!input.trim()) return;

    answerInput.disabled = true;
    submitBtn.disabled = true;

    const isChallenge = lastMode === 'challenge';
    const correct = isChallenge
      ? normalize(input) === normalize(word.en)
      : checkAnswer(input, word.ja);

    if (correct) {
      score++;
      feedbackIcon.textContent = 'O';
      feedbackIcon.className = 'feedback-icon correct';
      feedbackText.innerHTML = 'Correct! ／ <span class="ja">せいかい！</span>';
    } else {
      const correctAnswer = isChallenge ? word.en : word.ja[0];
      missed.push({ en: word.en, yourAnswer: input, correct: correctAnswer });
      feedbackIcon.textContent = 'X';
      feedbackIcon.className = 'feedback-icon wrong';
      feedbackText.innerHTML = 'Not quite. ／ <span class="ja">ざんねん！</span>';
    }

    const answersLabel = isChallenge ? word.en : word.ja.join('、 ');
    acceptedEl.innerHTML = `<span class="accepted-label">Answer ／ こたえ：</span> ${answersLabel}`;
    feedbackCard.classList.remove('hidden');
  }

  function nextQuestion() {
    wordIndex++;
    if (wordIndex >= words.length) {
      showResults();
    } else {
      showQuestion();
    }
  }

  function showResults() {
    scoreDisplay.textContent = `${score} / ${words.length}`;
    showScreen('screen-results');

    const pct = Math.round((score / words.length) * 100);
    scoreBig.textContent = `${score} / ${words.length}`;

    if (pct === 100) {
      resultTitle.textContent = 'Perfect! かんぺき！';
    } else if (pct >= 70) {
      resultTitle.textContent = 'Well done! よくできました！';
    } else if (pct >= 40) {
      resultTitle.textContent = 'Good try! よくがんばりました！';
    } else {
      resultTitle.textContent = 'Keep practicing! もっとれんしゅうしよう！';
    }

    if (missed.length === 0) {
      missedSection.classList.add('hidden');
    } else {
      missedSection.classList.remove('hidden');
      missedBody.innerHTML = '';
      missed.forEach(m => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${m.en}</td>
          <td class="wrong-answer">${m.yourAnswer || '—'}</td>
          <td class="right-answer">${m.correct}</td>
        `;
        missedBody.appendChild(tr);
      });
    }
  }

  // Events
  submitBtn.addEventListener('click', submitAnswer);
  answerInput.addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      if (!feedbackCard.classList.contains('hidden')) {
        nextQuestion();
      } else {
        submitAnswer();
      }
    }
  });
  nextBtn.addEventListener('click', nextQuestion);
  backBtn.addEventListener('click', () => showScreen('screen-select'));
  playAgainBtn.addEventListener('click', () => startQuiz(lastWordsForReplay, lastMode));
  backToSelectBtn.addEventListener('click', () => showScreen('screen-select'));
</script>

<style>
  .game-wrap {
    min-height: 100vh;
    background: #fff5f5;
    font-family: 'Andika', sans-serif;
    padding: 2rem 1rem;
  }

  .screen { max-width: 800px; margin: 0 auto; }
  .hidden { display: none !important; }

  /* Anarika Card */
  .anarika-card {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .anarika-avatar {
    width: 140px;
    height: 140px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid #f4a0aa;
    box-shadow: 0 4px 16px rgba(192, 57, 75, 0.15);
  }

  .avatar-img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }

  .game-title {
    font-size: 2rem;
    color: #c0394b;
    margin: 0 0 0.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .title-ja {
    font-size: 1.3rem;
    color: #c0394b;
    font-weight: 700;
  }

  .game-desc {
    color: #555;
    font-size: 0.95rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .bilingual-line {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .bilingual-line span:first-child { color: #777; }
  .bilingual-line span:last-child  { color: #333; font-weight: 600; }

  /* Category Grid */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.4rem;
  }

  :global(.group-header) {
    -webkit-appearance: none;
    appearance: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    height: 56px;
    background: white;
    border: 1px solid #eee;
    border-left: 5px solid #c0394b;
    border-radius: 0 10px 10px 0;
    padding: 0 1rem;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: background 0.15s;
    box-sizing: border-box;
    color: inherit;
  }

  :global(.group-header:hover) { background: #fafafa; }

  :global(.group-header-text) {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  :global(.group-label) {
