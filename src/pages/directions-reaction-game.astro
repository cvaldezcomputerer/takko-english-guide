---
import GameLayout from "../layouts/GameLayout.astro";
import DirectionsGame from "../components/DirectionsReactionGame.astro";
---

<GameLayout title="Directions Reaction Game">
  <div class="directions-page">
    <main>
      <DirectionsGame />
    </main>
  </div>
</GameLayout>

<style>
  .directions-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: linear-gradient(160deg, #f4fbff 0%, #f7f3ff 100%);
    padding-bottom: 1.5rem;
  }
</style>
