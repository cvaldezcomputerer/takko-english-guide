---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Logo from '../components/Logo.astro';
import T from '../components/T.astro';

// Common HTTP error pages — friendly one-liners for students.
// `here: true` marks the page you're currently on (404).
const ERRORS = [
  { code: '404', en: 'Not Found',             ja: '見つかりません',   note: { en: "This page isn't here.",        ja: 'このページはありません。' }, here: true },
  { code: '403', en: 'Forbidden',             ja: 'アクセス禁止',     note: { en: "You can't open this.",         ja: 'これは開けません。' } },
  { code: '401', en: 'Unauthorized',          ja: 'ログインが必要',   note: { en: 'Please log in first.',         ja: 'まずログインしてください。' } },
  { code: '500', en: 'Server Error',          ja: 'サーバーエラー',   note: { en: 'The server made a mistake.',   ja: 'サーバーがこわれました。' } },
  { code: '503', en: 'Service Unavailable',   ja: '利用できません',   note: { en: 'The server is too busy.',      ja: 'サーバーがいそがしいです。' } },
];
---

<Layout
  title="404 — Page Not Found — TakkoTaco"
  description="This page could not be found."
>
  <div class="nf-body">
    <Navbar />

    <main class="nf-main">
      <section class="nf-hero">
        <div class="nf-faces">
          <button type="button" class="nf-face-btn" data-ohno aria-label="Oh no!">
            <Logo class="nf-logo" mouthOpen />
          </button>
          <button type="button" class="nf-face-btn" data-ohno aria-label="Oh no!">
            <img class="nf-selfie" src="/images/selfies/thinking-3.png" alt="" width="450" height="450" />
          </button>
        </div>

        <p class="nf-code">404</p>
        <h1 class="nf-title">
          <T>
            <span slot="en">Page not found</span>
            <span slot="ja">ページが見つかりません</span>
          </T>
        </h1>
        <p class="nf-text">
          <T>
            <span slot="en">Hmm… this page isn't here. Let's go back home.</span>
            <span slot="ja">あれ…このページはありません。ホームにもどりましょう。</span>
          </T>
        </p>
        <a class="nf-home" href="/">
          <T>
            <span slot="en">Go home</span>
            <span slot="ja">ホームへ</span>
          </T>
        </a>
      </section>

      <section class="nf-chart" aria-labelledby="nf-chart-title">
        <h2 id="nf-chart-title" class="nf-chart-title">
          <T>
            <span slot="en">Common error pages</span>
            <span slot="ja">よくあるエラーページ</span>
          </T>
        </h2>
        <ul class="nf-rows">
          {ERRORS.map((e) => (
            <li class={`nf-row${e.here ? ' is-here' : ''}`}>
              <span class="nf-row-code">{e.code}</span>
              <span class="nf-row-name">
                <span class="nf-row-en">{e.en}</span>
                <span class="nf-row-ja">{e.ja}</span>
                {e.here && (
                  <span class="nf-here-tag">
                    <T>
                      <span slot="en">You are here</span>
                      <span slot="ja">ここです</span>
                    </T>
                  </span>
                )}
              </span>
              <span class="nf-row-note">
                <T>
                  <span slot="en">{e.note.en}</span>
                  <span slot="ja">{e.note.ja}</span>
                </T>
              </span>
            </li>
          ))}
        </ul>
      </section>
    </main>
  </div>
</Layout>

<script>
  import { speakMii } from '../lib/speak';
  // Click either face → the little Mii sighs "oh no".
  document.querySelectorAll<HTMLButtonElement>('.nf-face-btn').forEach((btn) => {
    btn.addEventListener('click', () => speakMii('Oh no'));
  });
</script>

<style>
  .nf-body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg);
    background-image: url("/images/garlic-tile.svg");
    background-size: 192px 184px;
    background-repeat: repeat;
  }

  .nf-main {
    flex: 1;
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ── Hero ── */
  .nf-hero {
    text-align: center;
    background: var(--color-white);
    border: 3px solid var(--color-secondary);
    border-radius: var(--radius-xl);
    padding: 2rem 1.5rem 2.25rem;
  }

  .nf-faces {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 0.5rem;
  }

  /* Faces are clickable — they sigh "oh no" in the Mii voice. */
  .nf-face-btn {
    display: inline-flex;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    border-radius: var(--radius-lg);
    transition: transform var(--transition-fast) ease;
  }
  .nf-face-btn:hover { transform: scale(1.05) rotate(-2deg); }
  .nf-face-btn:active { transform: scale(0.97); }
  .nf-face-btn:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 4px;
  }

  .nf-logo {
    width: 120px;
    height: 120px;
    color: var(--color-primary);
  }

  .nf-selfie {
    width: 110px;
    height: 110px;
    border-radius: var(--radius-round);
    object-fit: cover;
    border: 3px solid var(--color-primary);
    transform: rotate(4deg);
  }

  .nf-code {
    font-family: var(--font-main);
    font-size: 3.5rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-accent);
    margin: 1rem 0 0.25rem;
  }

  .nf-title {
    font-family: var(--font-main);
    font-size: 1.5rem;
    color: var(--color-primary);
    margin: 0 0 0.5rem;
  }

  .nf-text {
    color: var(--color-text);
    margin: 0 auto 1.5rem;
    max-width: 28rem;
  }

  .nf-home {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-white);
    font-family: var(--font-main);
    font-weight: 500;
    text-decoration: none;
    padding: 0.7rem 1.6rem;
    border-radius: var(--radius-button);
    transition: transform var(--transition-fast) ease, background var(--transition-fast) ease;
  }
  .nf-home:hover {
    transform: translateY(-2px);
    background: #d65f43;
  }

  /* ── Error chart ── */
  .nf-chart {
    background: var(--color-white);
    border: 3px solid var(--color-secondary);
    border-radius: var(--radius-xl);
    padding: 1.25rem 1.25rem 1.5rem;
  }

  .nf-chart-title {
    font-family: var(--font-main);
    font-size: 1.15rem;
    color: var(--color-primary);
    margin: 0 0 1rem;
    text-align: center;
  }

  .nf-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nf-row {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    grid-template-areas:
      "code name"
      "code note";
    align-items: center;
    gap: 0.1rem 0.9rem;
    padding: 0.6rem 0.75rem;
    border: 2px solid var(--color-beige);
    border-radius: var(--radius-md);
  }

  .nf-row.is-here {
    border-color: var(--color-accent);
    background: #fdf1ec;
  }

  .nf-row-code {
    grid-area: code;
    font-family: var(--font-main);
    font-weight: 600;
    font-size: 1.4rem;
    color: var(--color-secondary);
    text-align: center;
  }
  .is-here .nf-row-code { color: var(--color-accent); }

  .nf-row-name {
    grid-area: name;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .nf-row-en {
    font-family: var(--font-main);
    font-weight: 500;
    color: var(--color-text);
  }
  .nf-row-ja {
    font-size: 0.85rem;
    color: var(--color-light-green);
  }

  .nf-row-note {
    grid-area: note;
    font-size: 0.9rem;
    color: #6b6b6b;
  }

  .nf-here-tag {
    margin-left: auto;
    align-self: center;
    font-family: var(--font-main);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-white);
    background: var(--color-accent);
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  @media (max-width: 420px) {
    .nf-faces { flex-direction: column; align-items: center; gap: 0.75rem; }
    .nf-selfie { transform: none; }
  }
</style>
