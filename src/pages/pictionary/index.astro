---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import teacherImg from '../../assets/pictionary-game/Teach_image.png';
import studentsImg from '../../assets/pictionary-game/Students_computer_image.png';
---

<Layout title="Pictionary – Takkotaco" description="Draw a word while your class watches and guesses in real time.">
  <div class="page">
    <div class="hero">
      <h1>Pictionary</h1>
    </div>
    <div class="cards">
      <a href="/pictionary/host" class="card card--host">
        <Image src={teacherImg} alt="Teacher" class="card-img" width={200} />
        <h2>HOST<span class="ja">ホスト</span></h2>
        <span class="role">先生 / TEACHER</span>
      </a>
      <a href="/pictionary/play" class="card card--play">
        <Image src={studentsImg} alt="Students" class="card-img" width={200} />
        <h2>JOIN<span class="ja">ジョイン</span></h2>
        <span class="role">生徒 / STUDENT</span>
      </a>
    </div>
  </div>
</Layout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: #f5f3ee;
  }

  .hero {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .hero h1 {
    font-size: 3rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .cards {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: white;
    border-radius: 20px;
    padding: 2rem;
    width: 260px;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border: 3px solid #e5e0d8;
    transition: all var(--transition) ease;
    cursor: pointer;
  }

  .card--host { border-color: var(--color-primary); }
  .card--play { border-color: var(--color-secondary); }

  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.13);
  }

  .card-img {
    width: 100%;
    height: 160px;
    object-fit: contain;
    margin-bottom: 0.75rem;
    border: 2px solid #e5e0d8;
    border-radius: 14px;
  }

  .card h2 {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .card h2 .ja {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-faint);
  }

  .role {
    font-size: 0.85rem;
    color: var(--color-border-strong);
    letter-spacing: 0.05em;
    margin-top: -0.75rem;
  }
</style>
