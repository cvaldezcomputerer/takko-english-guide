---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import T from '../components/T.astro';
import StrokeLetter from '../components/StrokeLetter.astro';
import Logo from '../components/Logo.astro';

// Background side letters live in a hidden pool: all 26 letters + the logo. The
// client script below picks 11 random letters + the logo on every page load,
// places them down the sides, colors each randomly, and times them so they're
// written one stroke at a time in order, hold, then un-draw in order.
const alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");
// One full-width 4-line guide row per letter (12 total), at staggered positions
// down the two sides. The script drops one letter onto each row (its side).
const LEFT_TOPS = [5, 20, 35, 51, 66, 82];
const RIGHT_TOPS = [12, 27, 42, 58, 73, 89];
// 11 rows (dropped the bottom-most so it doesn't dip into the footer).
const slots = Array.from({ length: 11 }, (_, i) => {
  const side = i % 2 === 0 ? "left" : "right";
  const row = Math.floor(i / 2);
  return { side, top: side === "left" ? LEFT_TOPS[row] : RIGHT_TOPS[row] };
});
---

