<style>
  /* Decorative drawing letters down the page sides. Absolute (not fixed) so they
     scroll with the page; body is the containing block. The script below fills
     .abc-side-deco from the hidden pool on each load; per-item layout + the draw
     animation live in the is:global block (the script creates those at runtime). */
  :global(body) { position: relative; }

  .abc-side-deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: -1;
  }

  /* On smaller screens keep the writing lines but drop the letters — they
     don't fit beside the full-width content card. */
  @media (max-width: 1100px) {
    .abc-side-deco .sd { display: none; }
  }

  /* Container */
  .container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  /* Content */
  .content {
    background: var(--color-white);
    padding: 3rem;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    margin-top: 2rem;
  }

  .intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .intro h2 {
    color: var(--color-primary);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .intro p {
    color: #666;
    font-size: 1.1rem;
  }

  .activity-section + .activity-section {
    margin-top: 2.5rem;
  }

  .section-heading {
    margin-bottom: 1.2rem;
    padding-bottom: 0.85rem;
    border-bottom: 3px dashed #d9cfb5;
  }

