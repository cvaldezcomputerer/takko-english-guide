  <div class="abc-side-deco" aria-hidden="true">
    {slots.map((s) => <div class="guide-row" data-side={s.side} style={`top:${s.top}%`}></div>)}
    <div class="deco-pool" hidden>
      {alphabet.map((L) => (
        <div class="pool-item" data-kind="letter"><StrokeLetter letter={L} color="currentColor" /></div>
