<!-- Side-letter deco internals. Global (not scoped) because the script creates
     these elements/classes at runtime; all rules are confined to .abc-side-deco,
     which only exists on this page. -->
<style is:global>
  /* Japanese-style English 4-line writing guides: full-width rows across the
     page (three rows of writing space each). Lines are the site tan "paper";
     the baseline (line 3) is red, as on real Japanese English notebooks. The
     letters sit on these lines (the guides sit under the letters). */
  .abc-side-deco .guide-row {
    position: absolute;
    left: 0;
    right: 0;
    height: 124px;
    opacity: 0.5;
    box-sizing: border-box;
    border-top: 1.5px solid var(--color-text);    /* line 1 (top) */
    border-bottom: 1.5px solid var(--color-text); /* line 4 (bottom) */
  }
  .abc-side-deco .guide-row::before,
  .abc-side-deco .guide-row::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    border-top: 1.5px solid var(--color-text);
  }
  .abc-side-deco .guide-row::before {
    top: 33.33%;                 /* line 2 (midline) */
    border-top-style: dashed;
  }
  .abc-side-deco .guide-row::after {
    top: 66.66%;                  /* line 3 (baseline) */
    border-top-color: #d94b3e;   /* red baseline */
  }

  /* letter/logo cell: no lines of its own; same height as a row, placed on the
     row the script assigns, so its baseline lands on the red line. */
  .abc-side-deco .sd {
    position: absolute;
    width: 124px;
    height: 124px;
    opacity: 0.6;
  }
  .abc-side-deco .sd-left { left: 2%; }
  .abc-side-deco .sd-right { right: 2%; }
  .abc-side-deco .sd svg {
    position: absolute;
    top: -6%;       /* cap on line 1, baseline on line 3 */
    left: 10%;
    width: 80%;
    height: 80%;
    display: block;
  }
  .abc-side-deco #nose { display: none; } /* logo nose is a fill — not drawable */

  /* One shared keyframe; each stroke is offset by an inline animation-delay the
     script sets (= its global stroke index × slot). Constant draw→un-draw gap,
     so this produces: write all in order → hold → un-draw in order → loop. */
  .abc-side-deco .sd-draw {
    stroke-dasharray: 1 2;
    stroke-dashoffset: 1.05;
    animation: sd-cycle var(--sd-cycle, 60s) linear infinite;
  }
  @keyframes sd-cycle {
    0%    { stroke-dashoffset: 1.05; }  /* hidden */
    1.5%  { stroke-dashoffset: 0; }     /* this stroke draws on (stays on) */
    48%   { stroke-dashoffset: 0; }     /* all drawn — hold */
    49.5% { stroke-dashoffset: 1.05; }  /* un-draw (reverse) */
    100%  { stroke-dashoffset: 1.05; }  /* all gone — pause, then loop */
  }
</style>

<script>
  // Build the side-letter background on each load: pick 11 random letters + the
  // logo from the hidden pool, lay them down the sides, color each randomly, and
  // set per-stroke delays so they're written one stroke at a time in order, hold,
  // then un-draw in order. Just rearranges build-rendered SVGs — no SVG gen here.
  const SPEED = 3.2;         // overall slowness (higher = slower)
  const SS = 0.35 * SPEED;   // seconds between consecutive strokes
  const PALETTE = ["#e63946", "#2a9d8f", "#457b9d"]; // red / green / blue

  function shuffle<T>(arr: T[]): T[] {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  function buildDeco() {
    const deco = document.querySelector<HTMLElement>(".abc-side-deco");
    const pool = deco && deco.querySelector<HTMLElement>(".deco-pool");
    if (!deco || !pool) return;

    const items = Array.from(pool.children) as HTMLElement[];
    const logo = items.find((el) => el.dataset.kind === "logo");
    const letters = shuffle(items.filter((el) => el.dataset.kind === "letter"));

    // One letter per full-width guide row, placed on that row's side/position.
    const rows = Array.from(deco.querySelectorAll<HTMLElement>(".guide-row"));
    const chosen = shuffle([logo, ...letters.slice(0, rows.length - 1)]).filter(Boolean) as HTMLElement[];

    let cursor = 0; // running global stroke index
    rows.forEach((row, i) => {
      const item = chosen[i];
      if (!item) return;
      const side = row.dataset.side === "right" ? "right" : "left";
      item.className = "sd sd-" + side;
      item.style.top = row.style.top;
      item.style.color = PALETTE[(Math.random() * PALETTE.length) | 0];

      const strokes = Array.from(
        item.querySelectorAll<SVGPathElement>("path"),
      ).filter((p) => {
        const s = p.getAttribute("stroke");
        return s && s !== "none";
      });
      strokes.forEach((p, j) => {
        p.setAttribute("pathLength", "1");
        p.classList.add("sd-draw");
        p.style.animationDelay = ((cursor + j) * SS).toFixed(2) + "s";
      });
      cursor += strokes.length;
      deco.appendChild(item); // lift out of the (hidden) pool
    });

    const cycle = ((cursor - 1) * SS + 2 * SPEED) / 0.48;
    deco.style.setProperty("--sd-cycle", cycle.toFixed(1) + "s");
    pool.remove();
  }

  buildDeco();
</script>
