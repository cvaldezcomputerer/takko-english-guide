---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import T from '../components/T.astro';
---

<Layout title="Takko Town Games and Tools">
  <Navbar />

  <div class="container">
    <main class="content">
      <div class="intro">
        <h2>
          <T>
            <span slot="en">Choose an Activity</span>
            <span slot="ja">アクティビティを選ぶ</span>
          </T>
        </h2>
        <p>
          <T>
            <span slot="en">Pick a game or classroom tool below.</span>
            <span slot="ja">下からゲームまたはクラス用ツールを選びましょう。</span>
          </T>
        </p>
      </div>

      <section class="activity-section">
        <div class="section-heading">
          <h3>
            <T>
              <span slot="en">Games</span>
              <span slot="ja">ゲーム</span>
            </T>
          </h3>
          <p>
            <T>
              <span slot="en">Interactive activities for class play.</span>
              <span slot="ja">授業で遊べるインタラクティブなアクティビティです。</span>
            </T>
          </p>
        </div>

        <div class="games-grid games-grid--games">
          <!-- School Map Game Card -->
          <a href="/games/school-map-game" class="game-card">
              <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/school-map-game.png" alt="School Map Game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">School Map Game</span>
                      <span slot="ja">校内マップゲーム</span>
                    </T>
                  </h3>
                  <p class="card-topics">Directions · Turn left · Turn right · Go straight · School rooms</p>
                  <p class="card-desc">
                    <T>
                      <span slot="en">School map game to practice directions in English.</span>
                      <span slot="ja">英語で道案内を練習する学校マップゲーム。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Pictionary Game Card -->
          <a href="/pictionary" class="game-card">
              <div class="card-image pictionary-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false">
                      <rect x="16" y="24" width="88" height="64" rx="10" fill="#fff8f0" stroke="#557153" stroke-width="4"/>
                      <path d="M32 72 50 44l16 20 12-12 18 20" fill="none" stroke="#557153" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                      <circle cx="88" cy="38" r="6" fill="#f97316" stroke="#7c2d12" stroke-width="2"/>
                      <rect x="38" y="88" width="44" height="10" rx="5" fill="#94b49f" stroke="#557153" stroke-width="2"/>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>Pictionary</h3>
                  <p class="card-topics">Any vocabulary · Whole class</p>
                  <p class="card-desc">
                    <T>
                      <span slot="en">Draw a word while your class watches and guesses in real time!</span>
                      <span slot="ja">クラスみんなで、お題を描いてリアルタイムで当てよう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Letter Flip Game Card -->
          <a href="/games/letter-game" class="game-card">
               <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/letter-flip-game.png" alt="Letter Flip Game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Letter Flip Game</span>
                      <span slot="ja">文字めくりゲーム</span>
                    </T>
                  </h3>
                  <p class="card-topics">Letters · Colors · Emotions</p>
                  <p class="card-desc">
                    <T>
                      <span slot="en">Flip cards to match letters, colors, and emotions.</span>
                      <span slot="ja">カードをめくって文字・色・気持ちを学ぼう。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Face Catch Game Card -->
          <a href="/games/face-catch-game" class="game-card">
              <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/face-catch-game.png" alt="Face Catch Game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Face Catch</span>
                      <span slot="ja">フェイスキャッチ</span>
                    </T>
                  </h3>
                  <p class="card-topics">Letter recognition</p>
                  <p class="card-desc">
                    <T>
                      <span slot="en">Use your face to catch letters flying across the screen!</span>
                      <span slot="ja">顔を動かして、画面を飛ぶ文字をキャッチしよう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Say It Game Card -->
          <a href="/games/say-it-game" class="game-card">
              <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/letter-or-not-game.png" alt="Say It game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Letter or Not?</span>
                      <span slot="ja">文字？それとも違う？</span>
                    </T>
                  </h3>
                  <p class="card-topics">Letter recognition</p>
                  <p class="card-desc">
                    <T>
                      <span slot="en">Is it a letter? Say YES or NO into the microphone!</span>
                      <span slot="ja">文字かな？マイクに向かって YES か NO と言おう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Odd One Out Game Card -->
          <a href="/games/odd-one-out" class="game-card">
              <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/odd-one-out.png" alt="Odd One Out Game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Odd One Out</span>
                      <span slot="ja">なかまはずれ</span>
                    </T>
                  </h3>
                  <p class="card-topics">Any vocabulary · Whole class</p>
                  <p class="card-desc">
                    <T>
                      <span slot="en">Find the word that doesn't belong. Play as a whole class!</span>
                      <span slot="ja">なかまはずれを見つけよう。クラス全体で遊べます。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Anarika's Challenge Card -->
          <a href="/games/anarikas-challenge" class="game-card">
              <div class="card-image anarika-bg">
                  <img src="/images/anarika-challenge/anarika-face.png" alt="Anarika" class="anarika-face-img" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Anarika's Challenge</span>
                      <span slot="ja">アナリカのちょうせん</span>
                    </T>
                  </h3>
                  <p class="card-topics">Any vocabulary</p>
                  <p class="card-desc">
                    <T>
                      <span slot="en">A simple quiz. Choose any vocabulary and answer questions!</span>
                      <span slot="ja">好きな単語を選んでクイズに挑戦しよう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- ABC Order Game Card -->
          <a href="/games/abc-order-game" class="game-card">
              <div class="card-image abc-order-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false" xmlns="http://www.w3.org/2000/svg">
                      <!-- Shelf -->
                      <rect x="10" y="76" width="100" height="32" rx="5" fill="#f0ece0" stroke="#c5b99a" stroke-width="2.5"/>
                      <text x="22" y="99" font-family="Georgia, serif" font-size="22" font-weight="700" fill="#e76f51">A</text>
                      <text x="49" y="99" font-family="Georgia, serif" font-size="22" font-weight="700" fill="#2a9d8f">B</text>
                      <text x="76" y="99" font-family="Georgia, serif" font-size="22" font-weight="700" fill="#e9c46a">C</text>
                      <!-- Scattered tiles -->
                      <rect x="14" y="22" width="30" height="30" rx="6" fill="white" stroke="#457b9d" stroke-width="2.5"/>
                      <text x="20" y="44" font-family="Georgia, serif" font-size="22" font-weight="700" fill="#457b9d">F</text>
                      <rect x="52" y="12" width="30" height="30" rx="6" fill="white" stroke="#8338ec" stroke-width="2.5"/>
                      <text x="58" y="34" font-family="Georgia, serif" font-size="22" font-weight="700" fill="#8338ec">D</text>
                      <rect x="80" y="30" width="28" height="28" rx="6" fill="white" stroke="#e76f51" stroke-width="2.5"/>
                      <text x="86" y="51" font-family="Georgia, serif" font-size="20" font-weight="700" fill="#e76f51">E</text>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">ABC Order</span>
                      <span slot="ja">ABC順ゲーム</span>
                    </T>
                  </h3>
                  <p class="card-topics">Alphabet · ABC order</p>
                  <p class="card-desc">
                    <T>
                      <span slot="en">Click all 26 letters in ABC order to line them up!</span>
                      <span slot="ja">26文字をABC順にクリックして並べよう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Directions Reaction Game Card -->
          <a href="/games/directions-reaction-game" class="game-card">
               <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/directions-reactions-game.png" alt="Directions Reaction Game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Directions Reaction Game</span>
                      <span slot="ja">方向リアクションゲーム</span>
                    </T>
                  </h3>
                  <p class="card-topics">Directions · Turn left · Turn right · Go straight</p>
                  <p class="card-desc">
                    <T>
                      <span slot="en">Fast-paced reaction game to practice directions in English.</span>
                      <span slot="ja">英語の方向指示に素早く反応する速さ重視のゲーム。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>
        </div>
      </section>

      <section class="activity-section activity-section--tools">
        <div class="section-heading">
          <h3>
            <T>
              <span slot="en">Tools</span>
              <span slot="ja">ツール</span>
            </T>
          </h3>
          <p>
            <T>
              <span slot="en">Quick classroom helpers for points, timing, and voting.</span>
              <span slot="ja">得点、時間、投票に使えるクラス用の便利ツールです。</span>
            </T>
          </p>
        </div>

        <div class="games-grid games-grid--tools">
          <!-- Points Card Game Card -->
          <a href="/games/points-card-game" class="game-card">
               <div class="card-image points-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false">
                      <rect x="22" y="22" width="76" height="76" rx="16" fill="#fff7ed" stroke="#9a3412" stroke-width="4"/>
                      <circle cx="42" cy="42" r="6.5" fill="#9a3412"/>
                      <circle cx="78" cy="42" r="6.5" fill="#9a3412"/>
                      <circle cx="60" cy="60" r="6.5" fill="#9a3412"/>
                      <circle cx="42" cy="78" r="6.5" fill="#9a3412"/>
                      <circle cx="78" cy="78" r="6.5" fill="#9a3412"/>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Random Point Button</span>
                      <span slot="ja">ランダムポイントボタン</span>
                    </T>
                  </h3>
                  <p class="card-desc">
                    <T>
                      <span slot="en">Gives random points or point-related events.</span>
                      <span slot="ja">ランダムポイント、またはポイント関連イベントが出ます。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Timer Game Card -->
          <a href="/games/timer-game" class="game-card">
               <div class="card-image timer-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false">
                      <circle cx="60" cy="66" r="34" fill="#fff7ed" stroke="#7c2d12" stroke-width="4"/>
                      <rect x="48" y="18" width="24" height="12" rx="4" fill="#f97316" stroke="#7c2d12" stroke-width="4"/>
                      <path d="M60 66V48m0 18 12 8" stroke="#7c2d12" stroke-width="4" stroke-linecap="round"/>
                      <path d="M34 34 28 27m58 7 6-7" stroke="#7c2d12" stroke-width="4" stroke-linecap="round"/>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Countdown Timer</span>
                      <span slot="ja">カウントダウンタイマー</span>
                    </T>
                  </h3>
                  <p class="card-desc">
                    <T>
                      <span slot="en">Set your time and run a simple countdown with a final 5-second alert.</span>
                      <span slot="ja">時間を設定して、最後5秒のアラート付きカウントダウン。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Blooket/Quizlet Exporter Card -->
          <a href="/games/quizlet-creator" class="game-card">
               <div class="card-image quizlet-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false">
                      <rect x="34" y="20" width="54" height="38" rx="8" fill="#dbeafe" stroke="#2563eb" stroke-width="3.5"/>
                      <rect x="24" y="30" width="54" height="38" rx="8" fill="white" stroke="#2563eb" stroke-width="3.5"/>
                      <text x="51" y="53" text-anchor="middle" font-size="13" font-weight="700" fill="#1d4ed8" font-family="sans-serif">あ→A</text>
                      <path d="M51 76 L51 96" stroke="#2563eb" stroke-width="3.5" stroke-linecap="round"/>
                      <path d="M41 88 L51 98 L61 88" fill="none" stroke="#2563eb" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Blooket / Quizlet Exporter</span>
                      <span slot="ja">エクスポートツール</span>
                    </T>
                  </h3>
                  <p class="card-desc">
                    <T>
                      <span slot="en">Make sets for Quizlet or Blooket based on 5th and 6th grade New Horizons vocab.</span>
                      <span slot="ja">小5・小6のニューホライズンの単語からセットを作れます。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Open Tool</span>
                      <span slot="ja">ツールを開く</span>
                    </T>
                    <i class="fas fa-arrow-right"></i>
                  </span>
              </div>
          </a>

          <!-- Color Vote Tool Card -->
          <a href="/games/color-vote-tool" class="game-card">
               <div class="card-image color-vote-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false">
                      <rect x="18" y="18" width="38" height="38" rx="8" fill="#ef4444" stroke="#7f1d1d" stroke-width="4"/>
                      <rect x="64" y="18" width="38" height="38" rx="8" fill="#2563eb" stroke="#1e3a8a" stroke-width="4"/>
                      <rect x="18" y="64" width="38" height="38" rx="8" fill="#facc15" stroke="#854d0e" stroke-width="4"/>
                      <rect x="64" y="64" width="38" height="38" rx="8" fill="#22c55e" stroke="#166534" stroke-width="4"/>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Color Vote Tool</span>
                      <span slot="ja">カラー投票ツール</span>
                    </T>
                  </h3>
                  <p class="card-desc">
                    <T>
                      <span slot="en">A simple way for students to answer questions or vote with colors.</span>
                      <span slot="ja">色を使って、生徒が質問に答えたり投票したりできるシンプルなツールです。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  /* Content */
  .content {
    background: var(--color-white);
    padding: 3rem;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    margin-top: 2rem;
  }

  .intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .intro h2 {
    color: var(--color-primary);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .intro p {
    color: #666;
    font-size: 1.1rem;
  }

  .activity-section + .activity-section {
    margin-top: 2.5rem;
  }

  .section-heading {
    margin-bottom: 1.2rem;
    padding-bottom: 0.85rem;
    border-bottom: 3px dashed #d9cfb5;
  }

  .section-heading h3 {
    color: var(--color-primary);
    font-size: 1.8rem;
    margin-bottom: 0.2rem;
  }

  .section-heading p {
    color: #666;
    font-size: 1rem;
  }

  /* Grid */
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .games-grid--games,
  .games-grid--tools {
    max-width: 1040px;
    margin: 0 auto;
  }

  /* Card */
  .game-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    border: 3px solid transparent;
  }

  .game-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.12);
    border-color: var(--color-secondary);
  }

  .card-image {
    height: 180px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .card-image--screenshot {
    padding: 0;
    overflow: hidden;
  }

  .card-image--screenshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .pictionary-bg {
    background: #d8f4e3;
  }

  .points-bg {
    background: #ffe8cf;
  }

  .timer-bg {
    background: #ffe2da;
  }

  .color-vote-bg {
    background: #fce7f3;
  }

  .quizlet-bg {
    background: #dbeafe;
  }

  .anarika-bg {
    background: #fff0f2;
  }

  .abc-order-bg {
    background: #f5f2eb;
  }

  .anarika-face-img {
    width: 110px;
    height: 110px;
    object-fit: cover;
    object-position: center top;
    border-radius: 50%;
    border: 4px solid #f4a0aa;
  }

  .icon {
    width: clamp(88px, 24vw, 116px);
    height: clamp(88px, 24vw, 116px);
    display: grid;
    place-items: center;
    background: #ffffff;
    border: 3px solid rgba(0, 0, 0, 0.16);
    border-radius: 22px;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
    transition: transform 0.3s ease;
  }

  .icon svg {
    width: 88%;
    height: 88%;
    display: block;
  }

  .game-card:hover .icon {
    transform: scale(1.1) rotate(5deg);
  }

  .card-content {
    padding: 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  .card-content h3 {
    color: var(--color-primary);
    font-size: 1.5rem;
    margin-bottom: 0.3rem;
    font-weight: 700;
  }

  .card-topics {
    font-size: 0.72rem;
    font-weight: 700;
    color: #e76f51;
    letter-spacing: 0.04em;
