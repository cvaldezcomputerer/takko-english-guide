---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import T from '../components/T.astro';
---

<Layout title="Takko Town Games and Tools">
  <div class="banner">
    <div class="banner-content">
      <h1>
        <T>
          <span slot="en">Games/Tools</span>
          <span slot="ja">ゲーム・ツール</span>
        </T>
      </h1>
      <p>
        <T>
          <span slot="en">Games and tools to use in class</span>
          <span slot="ja">授業で使えるゲームとツール</span>
        </T>
      </p>
    </div>
  </div>

  <Navbar />

  <div class="container">
    <main class="content">
      <div class="intro">
        <h2>
          <T>
            <span slot="en">Choose an Activity</span>
            <span slot="ja">アクティビティを選ぶ</span>
          </T>
        </h2>
        <p>
          <T>
            <span slot="en">Pick a game or classroom tool below.</span>
            <span slot="ja">下からゲームまたはクラス用ツールを選びましょう。</span>
          </T>
        </p>
      </div>
      
      <section class="activity-section">
        <div class="section-heading">
          <h3>
            <T>
              <span slot="en">Games</span>
              <span slot="ja">ゲーム</span>
            </T>
          </h3>
          <p>
            <T>
              <span slot="en">Interactive activities for class play.</span>
              <span slot="ja">授業で遊べるインタラクティブなアクティビティです。</span>
            </T>
          </p>
        </div>

        <div class="games-grid games-grid--games">
          <!-- School Map Game Card -->
          <a href="/school-map-game" class="game-card">
              <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/school-map-game.png" alt="School Map Game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">School Map Game</span>
                      <span slot="ja">校内マップゲーム</span>
                    </T>
                  </h3>
                  <p>
                    <T>
                      <span slot="en">Navigate the school, find rooms, and explore the map!</span>
                      <span slot="ja">学校を案内して、部屋を見つけ、マップを探索しよう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Pictionary Game Card -->
          <a href="/pictionary" class="game-card">
              <div class="card-image pictionary-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false">
                      <rect x="16" y="24" width="88" height="64" rx="10" fill="#fff8f0" stroke="#557153" stroke-width="4"/>
                      <path d="M32 72 50 44l16 20 12-12 18 20" fill="none" stroke="#557153" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                      <circle cx="88" cy="38" r="6" fill="#f97316" stroke="#7c2d12" stroke-width="2"/>
                      <rect x="38" y="88" width="44" height="10" rx="5" fill="#94b49f" stroke="#557153" stroke-width="2"/>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>Pictionary</h3>
                  <p>
                    <T>
                      <span slot="en">Draw a word while your class watches and guesses in real time!</span>
                      <span slot="ja">クラスが見ている中でお題を描いて、リアルタイムで当てよう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Letter Flip Game Card -->
          <a href="/letter-game" class="game-card">
               <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/letter-flip-game.png" alt="Letter Flip Game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Letter Flip Game</span>
                      <span slot="ja">文字めくりゲーム</span>
                    </T>
                  </h3>
                  <p>
                    <T>
                      <span slot="en">Flip cards, learn letters, and discover animals!</span>
                      <span slot="ja">カードをめくって、文字を学び、動物を見つけよう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Face Catch Game Card -->
          <a href="/face-catch-game" class="game-card">
              <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/face-catch-game.png" alt="Face Catch Game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Face Catch</span>
                      <span slot="ja">フェイスキャッチ</span>
                    </T>
                  </h3>
                  <p>
                    <T>
                      <span slot="en">Use your face to catch letters flying across the screen!</span>
                      <span slot="ja">顔を動かして画面を飛ぶ文字をキャッチしよう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Odd One Out Game Card -->
          <a href="/odd-one-out" class="game-card">
              <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/odd-one-out.png" alt="Odd One Out Game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Odd One Out</span>
                      <span slot="ja">なかまはずれ</span>
                    </T>
                  </h3>
                  <p>
                    <T>
                      <span slot="en">Find the word that doesn't belong in the group!</span>
                      <span slot="ja">グループにあわない単語を見つけよう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Anarika's Challenge Card -->
          <a href="/anarikas-challenge" class="game-card">
              <div class="card-image anarika-bg">
                  <img src="/images/anarika-challenge/anarika-face.png" alt="Anarika" class="anarika-face-img" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Anarika's Challenge</span>
                      <span slot="ja">アナリカのちょうせん</span>
                    </T>
                  </h3>
                  <p>
                    <T>
                      <span slot="en">A simple English quiz. Choose a category and answer questions!</span>
                      <span slot="ja">かんたんな英語クイズ。カテゴリーを選んで答えよう！</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Directions Reaction Game Card -->
          <a href="/directions-reaction-game" class="game-card">
               <div class="card-image card-image--screenshot">
                  <img src="/images/game-screenshots/directions-reactions-game.png" alt="Directions Reaction Game screenshot" loading="lazy" />
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Directions Reaction Game</span>
                      <span slot="ja">方向リアクションゲーム</span>
                    </T>
                  </h3>
                  <p>
                    <T>
                      <span slot="en">Listen fast, react faster, and stack points by speed.</span>
                      <span slot="ja">音声を聞いて素早く反応し、スピードで得点を伸ばそう。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>
        </div>
      </section>

      <section class="activity-section activity-section--tools">
        <div class="section-heading">
          <h3>
            <T>
              <span slot="en">Tools</span>
              <span slot="ja">ツール</span>
            </T>
          </h3>
          <p>
            <T>
              <span slot="en">Quick classroom helpers for points, timing, and voting.</span>
              <span slot="ja">得点、時間、投票に使えるクラス用の便利ツールです。</span>
            </T>
          </p>
        </div>

        <div class="games-grid games-grid--tools">
          <!-- Points Card Game Card -->
          <a href="/points-card-game" class="game-card">
               <div class="card-image points-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false">
                      <rect x="22" y="22" width="76" height="76" rx="16" fill="#fff7ed" stroke="#9a3412" stroke-width="4"/>
                      <circle cx="42" cy="42" r="6.5" fill="#9a3412"/>
                      <circle cx="78" cy="42" r="6.5" fill="#9a3412"/>
                      <circle cx="60" cy="60" r="6.5" fill="#9a3412"/>
                      <circle cx="42" cy="78" r="6.5" fill="#9a3412"/>
                      <circle cx="78" cy="78" r="6.5" fill="#9a3412"/>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Random Point Button</span>
                      <span slot="ja">ランダムポイントボタン</span>
                    </T>
                  </h3>
                  <p>
                    <T>
                      <span slot="en">Gives random points or point-related events.</span>
                      <span slot="ja">ランダムポイント、またはポイント関連イベントが出ます。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Timer Game Card -->
          <a href="/timer-game" class="game-card">
               <div class="card-image timer-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false">
                      <circle cx="60" cy="66" r="34" fill="#fff7ed" stroke="#7c2d12" stroke-width="4"/>
                      <rect x="48" y="18" width="24" height="12" rx="4" fill="#f97316" stroke="#7c2d12" stroke-width="4"/>
                      <path d="M60 66V48m0 18 12 8" stroke="#7c2d12" stroke-width="4" stroke-linecap="round"/>
                      <path d="M34 34 28 27m58 7 6-7" stroke="#7c2d12" stroke-width="4" stroke-linecap="round"/>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Countdown Timer</span>
                      <span slot="ja">カウントダウンタイマー</span>
                    </T>
                  </h3>
                  <p>
                    <T>
                      <span slot="en">Set your time and run a simple countdown with a final 5-second alert.</span>
                      <span slot="ja">時間を設定して、最後5秒のアラート付きカウントダウン。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>

          <!-- Blooket/Quizlet Exporter Card -->
          <a href="/quizlet-creator" class="game-card">
               <div class="card-image quizlet-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false">
                      <rect x="34" y="20" width="54" height="38" rx="8" fill="#dbeafe" stroke="#2563eb" stroke-width="3.5"/>
                      <rect x="24" y="30" width="54" height="38" rx="8" fill="white" stroke="#2563eb" stroke-width="3.5"/>
                      <text x="51" y="53" text-anchor="middle" font-size="13" font-weight="700" fill="#1d4ed8" font-family="sans-serif">あ→A</text>
                      <path d="M51 76 L51 96" stroke="#2563eb" stroke-width="3.5" stroke-linecap="round"/>
                      <path d="M41 88 L51 98 L61 88" fill="none" stroke="#2563eb" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Blooket / Quizlet Exporter</span>
                      <span slot="ja">エクスポートツール</span>
                    </T>
                  </h3>
                  <p>
                    <T>
                      <span slot="en">Make sets for Quizlet or Blooket based on 5th and 6th grade New Horizons vocab.</span>
                      <span slot="ja">小5・小6のニューホライズンの単語からセットを作れます。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Open Tool</span>
                      <span slot="ja">ツールを開く</span>
                    </T>
                    <i class="fas fa-arrow-right"></i>
                  </span>
              </div>
          </a>

          <!-- Color Vote Tool Card -->
          <a href="/color-vote-tool" class="game-card">
               <div class="card-image color-vote-bg">
                  <div class="icon" aria-hidden="true">
                    <svg viewBox="0 0 120 120" role="img" focusable="false">
                      <rect x="18" y="18" width="38" height="38" rx="8" fill="#ef4444" stroke="#7f1d1d" stroke-width="4"/>
                      <rect x="64" y="18" width="38" height="38" rx="8" fill="#2563eb" stroke="#1e3a8a" stroke-width="4"/>
                      <rect x="18" y="64" width="38" height="38" rx="8" fill="#facc15" stroke="#854d0e" stroke-width="4"/>
                      <rect x="64" y="64" width="38" height="38" rx="8" fill="#22c55e" stroke="#166534" stroke-width="4"/>
                    </svg>
                  </div>
              </div>
              <div class="card-content">
                  <h3>
                    <T>
                      <span slot="en">Color Vote Tool</span>
                      <span slot="ja">カラー投票ツール</span>
                    </T>
                  </h3>
                  <p>
                    <T>
                      <span slot="en">A simple way for students to answer questions or vote with colors.</span>
                      <span slot="ja">色を使って、生徒が質問に答えたり投票したりできるシンプルなツールです。</span>
                    </T>
                  </p>
                  <span class="play-btn">
                    <T>
                      <span slot="en">Play Now</span>
                      <span slot="ja">今すぐプレイ</span>
                    </T>
                    <i class="fas fa-play"></i>
                  </span>
              </div>
          </a>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  /* Banner */
  .banner {
    width: 100%;
    height: 250px;
    background-color: var(--color-primary);
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 0;
  }

  .banner-content {
    text-align: center;
    color: white;
    z-index: 1;
    text-shadow: 0 2px 4px rgba(0,0,0,0.2);
  }

  .banner-content h1 {
    font-size: 3rem;
    margin: 0;
    font-weight: 800;
  }

  .banner-content p {
    font-size: 1.2rem;
    opacity: 0.9;
    margin-top: 0.5rem;
  }

  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  /* Content */
  .content {
    background: var(--color-white);
    padding: 3rem;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    margin-top: 2rem;
  }

  .intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .intro h2 {
    color: var(--color-primary);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .intro p {
    color: #666;
    font-size: 1.1rem;
  }

  .activity-section + .activity-section {
    margin-top: 2.5rem;
  }

  .section-heading {
    margin-bottom: 1.2rem;
    padding-bottom: 0.85rem;
    border-bottom: 3px dashed #d9cfb5;
  }

  .section-heading h3 {
    color: var(--color-primary);
    font-size: 1.8rem;
    margin-bottom: 0.2rem;
  }

  .section-heading p {
    color: #666;
    font-size: 1rem;
  }

  /* Grid */
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .games-grid--games,
  .games-grid--tools {
    max-width: 1040px;
    margin: 0 auto;
  }

  /* Card */
  .game-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    border: 3px solid transparent;
  }

  .game-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.12);
    border-color: var(--color-secondary);
  }

  .card-image {
    height: 180px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .card-image--screenshot {
    padding: 0;
    overflow: hidden;
  }

  .card-image--screenshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .pictionary-bg {
    background: #d8f4e3;
  }

  .points-bg {
    background: #ffe8cf;
  }

  .timer-bg {
    background: #ffe2da;
  }

  .color-vote-bg {
    background: #fce7f3;
  }

  .quizlet-bg {
    background: #dbeafe;
  }

  .anarika-bg {
    background: #fff0f2;
  }

  .anarika-face-img {
    width: 110px;
    height: 110px;
    object-fit: cover;
    object-position: center top;
    border-radius: 50%;
    border: 4px solid #f4a0aa;
  }

  .icon {
    width: clamp(88px, 24vw, 116px);
    height: clamp(88px, 24vw, 116px);
    display: grid;
    place-items: center;
    background: #ffffff;
    border: 3px solid rgba(0, 0, 0, 0.16);
    border-radius: 22px;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
    transition: transform 0.3s ease;
  }

  .icon svg {
    width: 88%;
    height: 88%;
    display: block;
  }

  .game-card:hover .icon {
    transform: scale(1.1) rotate(5deg);
  }

  .card-content {
    padding: 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  .card-content h3 {
    color: var(--color-primary);
    font-size: 1.5rem;
    margin-bottom: 0.8rem;
    font-weight: 700;
  }

  .card-content p {
    color: #555;
    margin-bottom: 1.5rem;
    flex: 1;
    line-height: 1.6;
  }

  .play-btn {
    display: inline-block;
    padding: 0.8rem 1.5rem;
    background: var(--color-primary);
    color: white;
    border-radius: 50px;
    font-weight: bold;
    transition: background 0.2s;
    align-self: center;
  }

  .game-card:hover .play-btn {
    background: var(--color-secondary);
  }

  @media (min-width: 1024px) {
    .banner {
      height: 170px;
    }

    .container {
      max-width: 1320px;
      padding: 1.25rem 1.5rem;
    }

    .content {
      padding: 1.5rem;
      margin-top: 1rem;
    }

    .intro {
      margin-bottom: 1.25rem;
    }

    .intro h2 {
      font-size: 2rem;
      margin-bottom: 0.35rem;
    }

    .intro p {
      font-size: 1rem;
    }

    .section-heading {
      margin-bottom: 0.9rem;
      padding-bottom: 0.65rem;
    }

    .section-heading h3 {
      font-size: 1.35rem;
    }

    .section-heading p {
      font-size: 0.92rem;
    }

    .activity-section + .activity-section {
      margin-top: 1.5rem;
    }

    .games-grid--games {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      max-width: 980px;
    }

    .games-grid--tools {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      max-width: 980px;
    }

    .game-card {
      border-radius: 16px;
    }

    .card-image {
      height: 120px;
    }

    .icon {
      width: 84px;
      height: 84px;
      border-radius: 18px;
    }

    .card-content {
      padding: 1rem 1rem 1.1rem;
    }

    .card-content h3 {
      font-size: 1.2rem;
      margin-bottom: 0.45rem;
    }

    .card-content p {
      font-size: 0.92rem;
      line-height: 1.35;
      margin-bottom: 0.85rem;
    }

    .play-btn {
      padding: 0.55rem 1rem;
      font-size: 0.92rem;
    }
  }

  @media (max-width: 768px) {
    .content {
      padding: 1.5rem;
    }
    
    .games-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
