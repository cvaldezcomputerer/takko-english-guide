---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import T from '../components/T.astro';
---

<Layout title="Takko Town Games">
  <div class="banner">
    <div class="banner-content">
      <h1>
        <T>
          <span slot="en">Game Center</span>
          <span slot="ja">ゲームセンター</span>
        </T>
      </h1>
      <p>
        <T>
          <span slot="en">Play and Learn with Takko!</span>
          <span slot="ja">タッコと一緒に遊んで学ぼう！</span>
        </T>
      </p>
    </div>
  </div>

  <Navbar />

  <div class="container">
    <main class="content">
      <div class="intro">
        <h2>
          <T>
            <span slot="en">Choose a Game</span>
            <span slot="ja">ゲームを選ぶ</span>
          </T>
        </h2>
        <p>
          <T>
            <span slot="en">Select a game below to start playing!</span>
            <span slot="ja">下のゲームを選んで遊び始めましょう！</span>
          </T>
        </p>
      </div>
      
      <div class="games-grid">
        <!-- School Map Game Card -->
        <a href="/school-map-game" class="game-card">
            <div class="card-image map-bg">
                <div class="icon" aria-hidden="true">
                  <svg viewBox="0 0 120 120" role="img" focusable="false">
                    <path d="M14 30 40 18l40 12 26-10v70l-26 12-40-12-26 10z" fill="#e9f4ff" stroke="#214764" stroke-width="4" stroke-linejoin="round"/>
                    <path d="M40 18v70m40-58v70" stroke="#214764" stroke-width="4"/>
                    <circle cx="60" cy="56" r="15" fill="#f97316" stroke="#7c2d12" stroke-width="4"/>
                    <path d="M60 41v30m-15-15h30" stroke="#fff7ed" stroke-width="4" stroke-linecap="round"/>
                  </svg>
                </div>
            </div>
            <div class="card-content">
                <h3>
                  <T>
                    <span slot="en">School Map Game</span>
                    <span slot="ja">校内マップゲーム</span>
                  </T>
                </h3>
                <p>
                  <T>
                    <span slot="en">Navigate the school, find rooms, and explore the map!</span>
                    <span slot="ja">学校を案内して、部屋を見つけ、マップを探索しよう！</span>
                  </T>
                </p>
                <span class="play-btn">
                  <T>
                    <span slot="en">Play Now</span>
                    <span slot="ja">今すぐプレイ</span>
                  </T>
                  <i class="fas fa-play"></i>
                </span>
            </div>
        </a>

        <!-- Letter Flip Game Card -->
        <a href="/letter-game" class="game-card">
             <div class="card-image letter-bg">
                <div class="icon" aria-hidden="true">
                  <svg viewBox="0 0 120 120" role="img" focusable="false">
                    <rect x="14" y="28" width="36" height="36" rx="8" fill="#fff7cc" stroke="#7a5b12" stroke-width="4"/>
                    <rect x="44" y="56" width="36" height="36" rx="8" fill="#d7f9ff" stroke="#1f5f70" stroke-width="4"/>
                    <rect x="70" y="22" width="36" height="36" rx="8" fill="#ffd8d8" stroke="#7f1d1d" stroke-width="4"/>
                    <text x="32" y="52" text-anchor="middle" font-size="20" font-weight="800" fill="#7a5b12">A</text>
                    <text x="62" y="80" text-anchor="middle" font-size="20" font-weight="800" fill="#1f5f70">B</text>
                    <text x="88" y="46" text-anchor="middle" font-size="20" font-weight="800" fill="#7f1d1d">C</text>
                  </svg>
                </div>
            </div>
            <div class="card-content">
                <h3>
                  <T>
                    <span slot="en">Letter Flip Game</span>
                    <span slot="ja">文字めくりゲーム</span>
                  </T>
                </h3>
                <p>
                  <T>
                    <span slot="en">Flip cards, learn letters, and discover animals!</span>
                    <span slot="ja">カードをめくって、文字を学び、動物を見つけよう！</span>
                  </T>
                </p>
                <span class="play-btn">
                  <T>
                    <span slot="en">Play Now</span>
                    <span slot="ja">今すぐプレイ</span>
                  </T>
                  <i class="fas fa-play"></i>
                </span>
            </div>
        </a>

        <!-- Directions Reaction Game Card -->
        <a href="/directions-reaction-game" class="game-card">
             <div class="card-image reaction-bg">
                <div class="icon" aria-hidden="true">
                  <svg viewBox="0 0 120 120" role="img" focusable="false">
                    <circle cx="60" cy="60" r="42" fill="#fff4d6" stroke="#7c4a03" stroke-width="4"/>
                    <path d="M64 24 44 66h18l-8 30 22-38H58z" fill="#facc15" stroke="#7c4a03" stroke-width="4" stroke-linejoin="round"/>
                  </svg>
                </div>
            </div>
            <div class="card-content">
                <h3>
                  <T>
                    <span slot="en">Directions Reaction Game</span>
                    <span slot="ja">方向リアクションゲーム</span>
                  </T>
                </h3>
                <p>
                  <T>
                    <span slot="en">Listen fast, react faster, and stack points by speed.</span>
                    <span slot="ja">音声を聞いて素早く反応し、スピードで得点を伸ばそう。</span>
                  </T>
                </p>
                <span class="play-btn">
                  <T>
                    <span slot="en">Play Now</span>
                    <span slot="ja">今すぐプレイ</span>
                  </T>
                  <i class="fas fa-play"></i>
                </span>
            </div>
        </a>
      </div>
    </main>
  </div>
</Layout>

<style>
  /* Banner */
  .banner {
    width: 100%;
    height: 250px;
    background-color: var(--color-primary);
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 0;
  }

  .banner-content {
    text-align: center;
    color: white;
    z-index: 1;
    text-shadow: 0 2px 4px rgba(0,0,0,0.2);
  }

  .banner-content h1 {
    font-size: 3rem;
    margin: 0;
    font-weight: 800;
  }

  .banner-content p {
    font-size: 1.2rem;
    opacity: 0.9;
    margin-top: 0.5rem;
  }

  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  /* Content */
  .content {
    background: var(--color-white);
    padding: 3rem;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    margin-top: 2rem;
  }

  .intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .intro h2 {
    color: var(--color-primary);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .intro p {
    color: #666;
    font-size: 1.1rem;
  }

  /* Grid */
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  /* Card */
  .game-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    border: 3px solid transparent;
  }

  .game-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.12);
    border-color: var(--color-secondary);
  }

  .card-image {
    height: 180px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .map-bg {
    background: #cfe8ff;
  }

  .letter-bg {
    background: #e4dbff;
  }

  .reaction-bg {
    background: #d8f0dd;
  }

  .icon {
    width: clamp(88px, 24vw, 116px);
    height: clamp(88px, 24vw, 116px);
    display: grid;
    place-items: center;
    background: #ffffff;
    border: 3px solid rgba(0, 0, 0, 0.16);
    border-radius: 22px;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
    transition: transform 0.3s ease;
  }

  .icon svg {
    width: 88%;
    height: 88%;
    display: block;
  }

  .game-card:hover .icon {
    transform: scale(1.1) rotate(5deg);
  }

  .card-content {
    padding: 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  .card-content h3 {
    color: var(--color-primary);
    font-size: 1.5rem;
    margin-bottom: 0.8rem;
    font-weight: 700;
  }

  .card-content p {
    color: #555;
    margin-bottom: 1.5rem;
    flex: 1;
    line-height: 1.6;
  }

  .play-btn {
    display: inline-block;
    padding: 0.8rem 1.5rem;
    background: var(--color-primary);
    color: white;
    border-radius: 50px;
    font-weight: bold;
    transition: background 0.2s;
    align-self: center;
  }

  .game-card:hover .play-btn {
    background: var(--color-secondary);
  }

  @media (min-width: 1024px) {
    .banner {
      height: 170px;
    }

    .container {
      max-width: 1320px;
      padding: 1.25rem 1.5rem;
    }

    .content {
      padding: 1.5rem;
      margin-top: 1rem;
    }

    .intro {
      margin-bottom: 1.25rem;
    }

    .intro h2 {
      font-size: 2rem;
      margin-bottom: 0.35rem;
    }

    .intro p {
      font-size: 1rem;
    }

    .games-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .game-card {
      border-radius: 16px;
    }

    .card-image {
      height: 120px;
    }

    .icon {
      width: 84px;
      height: 84px;
      border-radius: 18px;
    }

    .card-content {
      padding: 1rem 1rem 1.1rem;
    }

    .card-content h3 {
      font-size: 1.2rem;
      margin-bottom: 0.45rem;
    }

    .card-content p {
      font-size: 0.92rem;
      line-height: 1.35;
      margin-bottom: 0.85rem;
    }

    .play-btn {
      padding: 0.55rem 1rem;
      font-size: 0.92rem;
    }
  }

  @media (max-width: 768px) {
    .content {
      padding: 1.5rem;
    }
    
    .games-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
