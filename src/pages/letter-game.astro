---
import GameLayout from "../layouts/GameLayout.astro";
import LetterFlipGame from "../components/LetterFlipGame.astro";
---

<GameLayout title="Letter Flip Game">
  <div class="letter-game-page">
    <main>
        <LetterFlipGame />
    </main>
  </div>
</GameLayout>

<style>
  .letter-game-page {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding-bottom: 2rem;
  }
</style>
