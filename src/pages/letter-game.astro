---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout title="Letter Flip Game">
  <div class="letter-game-page">
    <Navbar />

    <main class="letter-game">
      <div class="letter-game__header">
        <h1 class="letter-game__title">Letter Flip Game</h1>
        <a href="/" class="letter-game__back-link" data-astro-reload>
          ← Back to Site
        </a>
      </div>

      <!-- Settings -->
      <section class="letter-game__settings">
        <button
          class="letter-game__settings-toggle"
          data-testid="settings-toggle"
          aria-expanded="false"
          aria-controls="lg-settings-panel"
        >
          Settings
        </button>
        <div class="letter-game__settings-panel" id="lg-settings-panel" hidden>
          <!-- Letters selection with checkboxes -->
          <div class="letter-game__field">
            <label class="letter-game__field-label">Select Letters:</label>
            <div class="letter-game__letter-grid" id="lg-letter-grid">
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="A" checked /><span
                  >A</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="B" checked /><span
                  >B</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="C" checked /><span
                  >C</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="D" checked /><span
                  >D</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="E" checked /><span
                  >E</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="F" checked /><span
                  >F</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="G" checked /><span
                  >G</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="H" checked /><span
                  >H</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="I" checked /><span
                  >I</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="J" checked /><span
                  >J</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="K" checked /><span
                  >K</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="L" checked /><span
                  >L</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="M" checked /><span
                  >M</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="N" checked /><span
                  >N</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="O" checked /><span
                  >O</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="P" checked /><span
                  >P</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="Q" checked /><span
                  >Q</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="R" checked /><span
                  >R</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="S" checked /><span
                  >S</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="T" checked /><span
                  >T</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="U" checked /><span
                  >U</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="V" checked /><span
                  >V</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="W" checked /><span
                  >W</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="X" checked /><span
                  >X</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="Y" checked /><span
                  >Y</span
                ></label
              >
              <label class="letter-game__checkbox-label"
                ><input type="checkbox" name="lg-letter" value="Z" checked /><span
                  >Z</span
                ></label
              >
            </div>
          </div>

          <div class="letter-game__field">
            <label><input type="checkbox" id="lg-randomize" /> Randomize</label>
          </div>
        </div>
      </section>

      <!-- Progress -->
      <div class="letter-game__progress" aria-live="polite"></div>

      <!-- Cards -->
      <section class="letter-game__board" aria-label="Flip letters to reveal images">
        <div class="letter-game__card-wrapper">
          <button
            class="letter-game__card"
            data-testid="card-0"
            aria-label="Left letter card - click to flip"
          ></button>
        </div>
        <div class="letter-game__card-wrapper">
          <button
            class="letter-game__card"
            data-testid="card-1"
            aria-label="Right letter card - click to flip"
          ></button>
        </div>
      </section>

      <!-- Toast / feedback -->
      <div class="letter-game__toast" data-testid="toast" aria-live="polite"></div>

      <!-- Controls -->
      <div class="letter-game__controls">
        <button class="letter-game__next" data-testid="next-btn" disabled>
          Next
        </button>
      </div>
    </main>
  </div>

  <style>
    .letter-game-page {
      min-height: 100vh;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      font-family: "M PLUS Rounded 1c", system-ui, -apple-system, sans-serif;
      padding-bottom: 2rem;
    }

    /* Full-screen gaming experience */
    .letter-game {
      min-height: 90vh;
      width: 100%;
      display: flex;
      flex-direction: column;
      padding: 2rem;
      box-sizing: border-box;
    }

    .letter-game__header {
      display: flex;
      justify-content: flex-start;
      align-items: center;
      margin-bottom: 2rem;
      flex-shrink: 0;
      gap: 3rem;
    }

    .letter-game__title {
      margin: 0;
      font-size: 2.5rem;
      font-weight: 800;
      color: white;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .letter-game__back-link {
      color: white;
      text-decoration: none;
      padding: 0.75rem 1.5rem;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 0.5rem;
      font-weight: 600;
      transition: background-color 0.2s ease;
      backdrop-filter: blur(10px);
    }

    .letter-game__back-link:hover {
      background: rgba(255, 255, 255, 0.3);
    }

    .letter-game__settings {
      margin-bottom: 2rem;
      flex-shrink: 0;
    }

    .letter-game__settings-toggle {
      border: 2px solid rgba(255, 255, 255, 0.3);
      background: rgba(255, 255, 255, 0.1);
      color: white;
      padding: 0.75rem 1.5rem;
      cursor: pointer;
      border-radius: 0.5rem;
      font-weight: 600;
      transition: all 0.2s ease;
      backdrop-filter: blur(10px);
    }

    .letter-game__settings-toggle:hover {
      background: rgba(255, 255, 255, 0.2);
      border-color: rgba(255, 255, 255, 0.5);
    }

    .letter-game__settings-panel {
      margin-top: 1rem;
      border: 2px solid rgba(255, 255, 255, 0.2);
      border-radius: 1rem;
      padding: 1.5rem;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }

    .letter-game__field {
      margin-bottom: 1rem;
    }

    .letter-game__field-label {
      display: block;
      font-weight: 700;
      margin-bottom: 0.75rem;
      color: #1f2937;
      font-size: 1.1rem;
    }

    .letter-game__letter-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
      gap: 0.75rem;
      max-height: 300px;
      overflow-y: auto;
      padding: 1rem;
      border: 2px solid #e5e7eb;
      border-radius: 0.75rem;
      background: #f9fafb;
    }

    .letter-game__checkbox-label {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.5rem 0.75rem;
      border-radius: 0.5rem;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 600;
      transition: all 0.2s ease;
      background: white;
      border: 2px solid transparent;
    }

    .letter-game__checkbox-label:hover {
      background: #f3f4f6;
      border-color: #d1d5db;
    }

    .letter-game__checkbox-label input[type="checkbox"] {
      margin: 0;
      transform: scale(1.2);
    }

    .letter-game__progress {
      text-align: center;
      margin-bottom: 2rem;
      font-weight: 700;
      font-size: 1.5rem;
      color: white;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
      flex-shrink: 0;
    }

    .letter-game__board {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      align-items: start;
      flex: 1;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      position: relative;
      padding-bottom: 120px; /* Space for celebration GIFs below */
    }

    /* Wrapper for each card + its celebration */
    .letter-game__card-wrapper {
      position: relative;
      width: 100%;
    }

    @media (max-width: 768px) {
      .letter-game__board {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      .letter-game__title {
        font-size: 2rem;
      }
      .letter-game {
        padding: 1rem;
      }
    }

    .letter-game__card {
      position: relative;
      display: grid;
      place-items: center;
      height: 350px;
      width: 100%;
      border: 4px solid rgba(255, 255, 255, 0.3);
      border-radius: 1.5rem;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      font-size: clamp(5rem, 12vw, 10rem);
      font-weight: 700;
      font-family: "M PLUS Rounded 1c", "Comic Sans MS", "Marker Felt",
        "Chalkboard SE", cursive, sans-serif;
      color: white;
      text-shadow: 4px 4px 0px rgba(0, 0, 0, 0.5),
        -2px -2px 0px rgba(0, 0, 0, 0.3),
        2px 2px 0px rgba(0, 0, 0, 0.3);
      letter-spacing: 0.05em;
      cursor: pointer;
      transition: all 0.3s ease;
      outline: none;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
      overflow: hidden;
    }

    /* Random colors for each card */
    .letter-game__card:nth-child(1) {
      background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
    }
    .letter-game__card:nth-child(2) {
      background: linear-gradient(135deg, #4ecdc4 0%, #44a08d 100%);
    }
    .letter-game__card:nth-child(3) {
      background: linear-gradient(135deg, #45b7d1 0%, #96c93d 100%);
    }
    .letter-game__card:nth-child(4) {
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }
    .letter-game__card:nth-child(5) {
      background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }
    .letter-game__card:nth-child(6) {
      background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
    }
    .letter-game__card:nth-child(7) {
      background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
    }
    .letter-game__card:nth-child(8) {
      background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
    }

    .letter-game__card:hover {
      transform: translateY(-4px) scale(1.02);
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.2);
      border-color: rgba(255, 255, 255, 0.6);
    }

    /* Hover animation effect - shows on hover ONLY before card is flipped, hidden on mobile */
    .letter-game__card:not(.letter-game__card--flipped):hover::after {
      content: "";
      background-image: url("/letter-game/animations/takko-frame-1.png");
      background-size: contain;
      background-repeat: no-repeat;
      background-position: center;
      background-color: rgba(0, 0, 0, 0.85);
      width: 180px;
      height: 180px;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6),
        inset 0 0 20px rgba(255, 255, 255, 0.1);
      border: 4px solid rgba(255, 255, 255, 0.3);
      z-index: 5;
      animation: takko-frames 10s ease-in-out infinite;
    }

    @keyframes takko-frames {
      0% {
        background-image: url("/letter-game/animations/takko-frame-1.png");
        transform: translate(-50%, -50%) scale(1);
      }
      20% {
        background-image: url("/letter-game/animations/takko-frame-2.png");
        transform: translate(-50%, -50%) scale(1.05);
      }
      50% {
        background-image: url("/letter-game/animations/takko-frame-3.png");
        transform: translate(-50%, -50%) scale(1.08);
      }
      100% {
        background-image: url("/letter-game/animations/takko-frame-3.png");
        transform: translate(-50%, -50%) scale(1.08);
      }
    }

    /* Show celebration GIF below card when clicked/flipped */
    .letter-game__card-wrapper:has(.letter-game__card--flipped)::after {
      content: "";
      position: absolute;
      top: calc(100% + 10px);
      left: 50%;
      transform: translateX(-50%);
      width: 120px;
      height: 120px;
      background-image: url("/letter-game/animations/takko-celebrate.gif");
      background-size: contain;
      background-repeat: no-repeat;
      background-position: center;
      background-color: rgba(0, 0, 0, 0.85);
      border-radius: 50%;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6),
        inset 0 0 20px rgba(255, 255, 255, 0.1);
      border: 4px solid rgba(255, 255, 255, 0.3);
      z-index: 10;
      opacity: 1;
      animation: celebrate-bounce-up 0.6s ease-out;
    }

    @keyframes celebrate-bounce-up {
      0% {
        transform: translateX(-50%) translateY(20px) scale(0);
        opacity: 0;
      }
      50% {
        transform: translateX(-50%) translateY(-10px) scale(1.15);
      }
      100% {
        transform: translateX(-50%) translateY(0) scale(1);
        opacity: 1;
      }
    }

    /* Show center GIF when both cards are flipped */
    .letter-game__board::after {
      content: "";
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(0);
      width: 200px;
      height: 200px;
      background-image: url("/letter-game/animations/takko-both-opened.gif");
      background-size: contain;
      background-repeat: no-repeat;
      background-position: center;
      background-color: rgba(0, 0, 0, 0.9);
      border-radius: 50%;
      box-shadow: 0 12px 48px rgba(0, 0, 0, 0.8),
        inset 0 0 30px rgba(255, 255, 255, 0.2);
      border: 5px solid rgba(255, 255, 255, 0.4);
      z-index: 15;
      opacity: 0;
      pointer-events: none;
      transition: all 0.5s ease-out;
    }

    .letter-game__board.both-flipped::after {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
      animation: center-celebration 0.8s ease-out;
    }

    @keyframes center-celebration {
      0% {
        transform: translate(-50%, -50%) scale(0) rotate(-10deg);
      }
      50% {
        transform: translate(-50%, -50%) scale(1.15) rotate(5deg);
      }
      100% {
        transform: translate(-50%, -50%) scale(1) rotate(0deg);
      }
    }

    /* Hide hover effect on mobile */
    @media (max-width: 768px) {
      .letter-game__card:hover::after {
        background-image: none;
        background: #e53e3e;
        width: 40px;
        height: 60px;
        top: 15px;
        left: 50%;
        transform: translateX(-50%);
        border-radius: 0 0 20px 20px;
        animation: none;
        box-shadow: 0 0 0 4px #f56565, 0 4px 12px rgba(0, 0, 0, 0.3);
      }
    }

    .letter-game__card:focus-visible {
      box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.8);
    }

    /* Pop animation */
    .letter-game__card--flipped {
      animation: lg-pop 400ms ease forwards;
    }

    @keyframes lg-pop {
      0% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.15);
      }
      100% {
        transform: scale(1);
      }
    }

    .letter-game__card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 1rem;
      position: absolute;
      top: 0;
      left: 0;
      z-index: 1;
    }

    .letter-game__card > * {
      position: relative;
      z-index: 5;
    }

    .letter-game__controls {
      display: flex;
      justify-content: center;
      margin-top: 2rem;
      flex-shrink: 0;
    }

    .letter-game__next {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: 2px solid rgba(255, 255, 255, 0.3);
      padding: 1rem 2rem;
      border-radius: 1rem;
      cursor: pointer;
      font-weight: 700;
      font-size: 1.2rem;
      transition: all 0.2s ease;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    }

    .letter-game__next:hover:not([disabled]) {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    }

    .letter-game__next[disabled] {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    .letter-game__toast {
      text-align: center;
      margin-top: 1rem;
      color: white;
      font-weight: 600;
      font-size: 1.1rem;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
      min-height: 1.5rem;
    }
  </style>

  <script type="module">
    import "../scripts/letter-game.js";
  </script>
</Layout>
