---
import GameLayout from "../../layouts/GameLayout.astro";
---

<GameLayout showBackBar title="Points Event Game">
  <div class="points-game-page">
    <main class="game-shell">

      <div class="play-layout">
        <aside class="side-panel event-list-wrap">
          <h2>
            Event Cards <span class="jp">イベントカード</span>
            <span id="eventCount" class="event-count">0/10</span>
          </h2>
          <ul id="eventList" class="event-list"></ul>

          <form id="addEventForm" class="add-event">
            <input
              id="newEventText"
              class="event-input"
              type="text"
              maxlength="40"
              autocomplete="off"
              placeholder="New card text / 新しいカード"
            />
            <div class="add-row">
              <select id="newEventTone" class="event-tone" aria-label="Card type">
                <option value="positive">Good / よい</option>
                <option value="neutral">Neutral / ふつう</option>
                <option value="negative">Bad / わるい</option>
              </select>
              <button id="addEventBtn" class="add-btn" type="submit">Add <span class="jp">追加</span></button>
            </div>
            <p id="eventHint" class="event-hint" hidden>Up to 10 cards. <span class="jp">カードは10まい まで。</span></p>
          </form>
        </aside>

        <section class="center-stage" aria-live="polite">
          <div class="result-box">
            <div class="result-label">Result <span class="jp">けっか</span></div>
            <div id="resultText" class="result-text">PRESS ME</div>
          </div>
          <button id="rollBtn" class="roll-btn" type="button">
            <span class="roll-en">PRESS ME</span>
            <span class="roll-jp">おして！</span>
          </button>
        </section>

        <aside class="side-panel stats-wrap">
          <h2>Point Range <span class="jp">ポイントのはんい</span></h2>
          <div class="stats-row">
            <label class="stat-key" for="minPoints">Min <span class="jp">さいしょう</span></label>
            <input id="minPoints" class="stat-input" type="number" min="-10000" max="10000" step="50" value="-500" />
          </div>
          <div class="stats-row">
            <label class="stat-key" for="maxPoints">Max <span class="jp">さいだい</span></label>
            <input id="maxPoints" class="stat-input" type="number" min="-10000" max="10000" step="50" value="1000" />
          </div>
          <p class="stats-note">Point rolls land on a multiple of 50 in this range. Cards are not affected.<span class="jp jp-block">ポイントは50ごとの数になります（イベントカードは別）。</span></p>
        </aside>
      </div>
    </main>
  </div>
</GameLayout>

<script>
  const rollBtn      = document.getElementById("rollBtn") as HTMLButtonElement;
  const resultText   = document.getElementById("resultText")!;
  const minInput     = document.getElementById("minPoints") as HTMLInputElement;
  const maxInput     = document.getElementById("maxPoints") as HTMLInputElement;
  const eventList    = document.getElementById("eventList")!;
  const eventCount   = document.getElementById("eventCount")!;
  const addForm      = document.getElementById("addEventForm") as HTMLFormElement;
  const newEventText = document.getElementById("newEventText") as HTMLInputElement;
  const newEventTone = document.getElementById("newEventTone") as HTMLSelectElement;
  const addBtn       = document.getElementById("addEventBtn") as HTMLButtonElement;
  const eventHint    = document.getElementById("eventHint")!;

  const countdownTickSrc = "/audio/directions-reaction-game/countdown-tick.ogg";
  const positiveSounds = [
    "/audio/directions-reaction-game/feedback/good-nice-1.mp3",
    "/audio/directions-reaction-game/feedback/good-nice-2.mp3",
    "/audio/directions-reaction-game/feedback/good-ohyeah-3.mp3",
    "/audio/directions-reaction-game/feedback/good-great-4.mp3",
    "/audio/directions-reaction-game/feedback/good-yeah-5.mp3",
  ];
  const negativeSounds = [
    "/audio/directions-reaction-game/feedback/bad-ohno-1.mp3",
    "/audio/directions-reaction-game/feedback/bad-ohno-2.mp3",
    "/audio/directions-reaction-game/feedback/bad-woops-3.mp3",
  ];

  type Tone = "positive" | "negative" | "neutral";
  interface EventCard { text: string; tone: Tone; }

  const RANGE_LIMIT = 10000; // hard cap on min/max so input can't break the roll
  const ROLL_STEP = 50;      // point rolls land on a multiple of this
  const MAX_EVENTS = 10;
  const TEXT_LIMIT = 40;
  const EVENTS_KEY = "points-tool:events";
  const RANGE_KEY = "points-tool:range";
  const TONES: Tone[] = ["positive", "negative", "neutral"];

  const DEFAULT_EVENTS: EventCard[] = [
    { text: "Point Swap", tone: "negative" },
    { text: "Double Points (+400)", tone: "positive" },
    { text: "Half Points (-100)", tone: "negative" },
    { text: "Swap with a random team", tone: "neutral" },
    { text: "Steal +300", tone: "positive" },
    { text: "Oops -1000", tone: "negative" },
    { text: "Jackpot +1000", tone: "positive" },
  ];

  const randInt = (min: number, max: number): number => Math.floor(Math.random() * (max - min + 1)) + min;
  const clampRange = (n: number): number =>
    Number.isFinite(n) ? Math.max(-RANGE_LIMIT, Math.min(RANGE_LIMIT, Math.round(n))) : 0;
  const asTone = (v: unknown): Tone => (TONES.includes(v as Tone) ? (v as Tone) : "neutral");

  // ── Event cards: load (or seed defaults on first visit), render, persist ──
  let events: EventCard[] = loadEvents();

  function loadEvents(): EventCard[] {
    try {
      const raw = localStorage.getItem(EVENTS_KEY);
      if (raw === null) return [...DEFAULT_EVENTS]; // first visit only
      const parsed = JSON.parse(raw);
      if (!Array.isArray(parsed)) return [...DEFAULT_EVENTS];
      return parsed // a saved empty list is respected (user deleted them all)
        .filter((e) => e && typeof e.text === "string" && e.text.trim() !== "")
        .map((e) => ({ text: String(e.text).slice(0, TEXT_LIMIT), tone: asTone(e.tone) }))
        .slice(0, MAX_EVENTS);
    } catch {
      return [...DEFAULT_EVENTS];
    }
  }

  function saveEvents(): void {
    try { localStorage.setItem(EVENTS_KEY, JSON.stringify(events)); } catch {}
  }

  function renderEvents(): void {
    eventList.replaceChildren();
    events.forEach((ev, i) => {
      const li = document.createElement("li");
      li.className = "event-item";
      li.dataset.tone = ev.tone;

      const dot = document.createElement("span");
      dot.className = "event-dot";
      dot.setAttribute("aria-hidden", "true");

      const text = document.createElement("span");
      text.className = "event-text";
      text.textContent = ev.text; // textContent, never innerHTML — user input

      const del = document.createElement("button");
      del.type = "button";
      del.className = "event-del";
      del.textContent = "×";
      del.setAttribute("aria-label", `Delete ${ev.text}`);
      del.addEventListener("click", () => {
        events.splice(i, 1);
        saveEvents();
        renderEvents();
      });

      li.append(dot, text, del);
      eventList.appendChild(li);
    });

    eventCount.textContent = `${events.length}/${MAX_EVENTS}`;
    const full = events.length >= MAX_EVENTS;
    newEventText.disabled = full;
    newEventTone.disabled = full;
    addBtn.disabled = full;
    eventHint.hidden = !full;
  }

  addForm.addEventListener("submit", (e) => {
    e.preventDefault();
    const text = newEventText.value.trim();
    if (text === "" || events.length >= MAX_EVENTS) return;
    events.push({ text: text.slice(0, TEXT_LIMIT), tone: asTone(newEventTone.value) });
    saveEvents();
    newEventText.value = "";
    renderEvents();
    newEventText.focus();
  });

  // ── Point range: editable, clamped, ordered, persisted ──────────────────
  function saveRange(min: number, max: number): void {
    try { localStorage.setItem(RANGE_KEY, JSON.stringify({ min, max })); } catch {}
  }

  function normalizeRange(): { min: number; max: number } {
    let min = clampRange(Number(minInput.value));
    let max = clampRange(Number(maxInput.value));
    if (min > max) max = min; // keep ordered so the roll always has a range
    minInput.value = String(min);
    maxInput.value = String(max);
    saveRange(min, max);
    return { min, max };
  }

  function loadRange(): void {
    try {
      const raw = localStorage.getItem(RANGE_KEY);
      if (raw !== null) {
        const r = JSON.parse(raw);
        if (r && Number.isFinite(r.min) && Number.isFinite(r.max)) {
          minInput.value = String(clampRange(r.min));
          maxInput.value = String(clampRange(r.max));
        }
      }
    } catch {}
    normalizeRange();
  }

  function rollPoints(): number {
    const { min, max } = normalizeRange();
    const lo = Math.ceil(min / ROLL_STEP) * ROLL_STEP;
    const hi = Math.floor(max / ROLL_STEP) * ROLL_STEP;
    if (hi < lo) return randInt(min, max); // range too narrow for a step of 50
    return lo + ROLL_STEP * randInt(0, (hi - lo) / ROLL_STEP);
  }

  minInput.addEventListener("change", () => { normalizeRange(); });
  maxInput.addEventListener("change", () => { normalizeRange(); });

  let rolling = false;
  let drumrollInterval: number | null = null;

  const playFeedbackSound = async (tone: string): Promise<void> => {
    const pool = tone === "negative" ? negativeSounds : positiveSounds;
    const src = pool[randInt(0, pool.length - 1)];
    const sfx = new Audio(src);
    sfx.preload = "auto";
    try {
      await sfx.play();
    } catch {}
  };

  const playDrumroll = () => {
    let step = 0;
    const maxSteps = 10;
    const timer = window.setInterval(() => {
      const tick = new Audio(countdownTickSrc);
      tick.volume = 0.38;
      tick.playbackRate = 1 + step * 0.05;
      tick.play().catch(() => {});
      step += 1;
      if (step >= maxSteps) {
        window.clearInterval(timer);
      }
    }, 130);

    return () => {
      window.clearInterval(timer);
    };
  };

  const startVisualRoll = () => {
    const states = ["...", "..", ".", "...."];
    let idx = 0;
    drumrollInterval = window.setInterval(() => {
      resultText.textContent = `Rolling${states[idx]}`;
      idx = (idx + 1) % states.length;
    }, 220);
    resultText.classList.add("rolling");
  };

  const stopVisualRoll = () => {
    if (drumrollInterval !== null) {
      window.clearInterval(drumrollInterval);
      drumrollInterval = null;
    }
    resultText.classList.remove("rolling");
  };

  const reveal = (): Tone => {
    const useEvent = events.length > 0 && Math.random() < 0.33;
    if (useEvent) {
      const ev = events[randInt(0, events.length - 1)];
      resultText.textContent = ev.text;
      resultText.classList.add("event");
      resultText.classList.remove("points");
      return ev.tone;
    }

    const value = rollPoints();
    resultText.textContent = value >= 0 ? `+${value} POINTS` : `${value} POINTS`;
    resultText.classList.add("points");
    resultText.classList.remove("event");
    return value < 0 ? "negative" : "positive";
  };

  rollBtn.addEventListener("click", async () => {
    if (rolling) return;
    rolling = true;
    rollBtn.disabled = true;
    rollBtn.classList.add("is-rolling");
    resultText.classList.remove("event", "points");

    startVisualRoll();
    const stopAudio = playDrumroll();

    window.setTimeout(async () => {
      stopVisualRoll();
      stopAudio();
      const tone = reveal();
      await playFeedbackSound(tone);
      rollBtn.classList.remove("is-rolling");
      rollBtn.disabled = false;
      rolling = false;
    }, 1400);
  });

  loadRange();
  renderEvents();
</script>

<style>
  .points-game-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 1.25rem;
    background: var(--color-bg);
  }

  .game-shell {
    width: min(940px, 100%);
    background: var(--color-white);
    border: 2px solid var(--color-secondary);
    border-radius: 8px;
    box-shadow: 0 4px 14px rgba(85, 113, 83, 0.12);
    padding: 1.1rem;
  }

  .play-layout {
    display: grid;
    grid-template-columns: minmax(200px, 1fr) minmax(360px, 1.8fr) minmax(200px, 1fr);
    gap: 0.9rem;
    align-items: stretch;
  }

.side-panel {
    border: 2px solid var(--color-secondary);
    border-radius: 5px;
    background: #fffdf8;
    padding: 0.9rem;
  }

  .center-stage {
    min-height: 340px;
    border: 2px solid var(--color-secondary);
    border-radius: 5px;
    background: var(--color-beige);
    display: grid;
    place-content: center;
    gap: 1rem;
    text-align: center;
    padding: 1.1rem;
  }

  .result-box {
    border: 2px solid var(--color-primary);
    background: #fffdf8;
    border-radius: 4px;
    padding: 1rem 1.2rem;
    width: 100%;
    max-width: 520px;
  }

  .result-label {
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    font-weight: 700;
    margin-bottom: 0.45rem;
  }

  /* Japanese sub-text shown alongside English (no lang toggle on tool pages). */
  .jp {
    font-family: 'M PLUS Rounded 1c', sans-serif;
    font-weight: 500;
    font-size: 0.82em;
    color: var(--color-dark-teal);
    opacity: 0.72;
  }

  .jp-block {
    display: block;
    margin-top: 0.1rem;
  }

  .result-text {
    font-size: clamp(1.6rem, 5.5vw, 3.2rem);
    font-weight: 900;
    letter-spacing: 0.02em;
    color: var(--color-dark-teal);
    min-height: 3.2rem;
    display: grid;
    place-items: center;
  }

  .result-text.rolling {
    animation: jitter 0.3s ease-in-out infinite;
    color: var(--color-primary);
  }

  .result-text.points {
    color: var(--color-dark-green);
    animation: pop 520ms ease-out;
  }

  .result-text.event {
    color: var(--color-accent);
    animation: pop 520ms ease-out;
  }

  .roll-btn {
    justify-self: center;
    border: 0;
    border-radius: 12px;
    background: #d90000;
    color: #ffffff;
    font-weight: 900;
    letter-spacing: 0.06em;
    padding: 0.9rem 3.4rem;
    cursor: pointer;
    box-shadow: 0 8px 0 #8f0000;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    display: grid;
    gap: 0.1rem;
    line-height: 1.1;
  }

  .roll-en {
    font-size: clamp(1.2rem, 3.4vw, 2rem);
  }

  .roll-jp {
    font-family: 'M PLUS Rounded 1c', sans-serif;
    font-size: clamp(0.78rem, 2vw, 1rem);
    font-weight: 700;
    opacity: 0.92;
  }

  .roll-btn:hover {
    background: #ee0000;
  }

  .roll-btn:active {
    transform: translateY(4px);
    box-shadow: 0 3px 0 #8f0000;
  }

  .roll-btn:disabled {
    cursor: not-allowed;
    opacity: 0.9;
  }

  .roll-btn.is-rolling {
    animation: pulse 1.2s ease-in-out infinite;
  }

  h2 {
    margin: 0 0 0.6rem;
    font-size: 1rem;
    color: var(--color-primary);
  }

  .event-count {
    font-family: 'M PLUS Rounded 1c', sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    color: var(--color-dark-teal);
    opacity: 0.7;
  }

  .event-list {
    margin: 0 0 0.7rem;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.4rem;
  }

  .event-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--color-secondary);
    border-radius: 4px;
    background: var(--color-white);
    padding: 0.4rem 0.45rem 0.4rem 0.55rem;
  }

  .event-dot {
    flex-shrink: 0;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-secondary);
  }

  .event-item[data-tone="positive"] .event-dot { background: #4a7c59; }
  .event-item[data-tone="negative"] .event-dot { background: #d94b3e; }
  .event-item[data-tone="neutral"]  .event-dot { background: #c8a24a; }

  .event-text {
    flex: 1;
    min-width: 0;
    color: var(--color-dark-teal);
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  .event-del {
    flex-shrink: 0;
    border: 0;
    background: transparent;
    color: #b0563f;
    font-size: 1.15rem;
    line-height: 1;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 4px;
    cursor: pointer;
  }

  .event-del:hover {
    background: #f7e3dd;
    color: #8f3a28;
  }

  .add-event {
    display: grid;
    gap: 0.45rem;
  }

  .event-input {
    width: 100%;
    box-sizing: border-box;
    border: 2px solid var(--color-secondary);
    border-radius: 4px;
    padding: 0.5rem 0.55rem;
    font: inherit;
    color: var(--color-dark-teal);
    background: var(--color-white);
  }

  .add-row {
    display: flex;
    gap: 0.45rem;
  }

  .event-tone {
    flex: 1;
    min-width: 0;
    border: 2px solid var(--color-secondary);
    border-radius: 4px;
    padding: 0.45rem 0.5rem;
    font: inherit;
    color: var(--color-dark-teal);
    background: var(--color-white);
    cursor: pointer;
  }

  .add-btn {
    flex-shrink: 0;
    border: 2px solid var(--color-primary);
    background: var(--color-primary);
    color: #fff;
    border-radius: 4px;
    padding: 0.45rem 0.9rem;
    font-weight: 700;
    cursor: pointer;
  }

  .add-btn .jp {
    color: #fff;
    opacity: 0.85;
    margin-left: 0.25rem;
  }

  .event-input:disabled,
  .event-tone:disabled,
  .add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .event-hint {
    margin: 0;
    color: #b0563f;
    font-size: 0.82rem;
    line-height: 1.3;
  }

  .stats-wrap {
    display: grid;
    align-content: start;
    gap: 0.55rem;
  }

  .stats-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid var(--color-secondary);
    border-radius: 4px;
    background: var(--color-beige);
    padding: 0.5rem 0.65rem;
  }

  .stat-key {
    color: var(--color-primary);
    font-weight: 700;
  }

  .stat-input {
    width: 6.5rem;
    border: 2px solid var(--color-secondary);
    border-radius: 4px;
    background: var(--color-white);
    color: var(--color-dark-teal);
    font: inherit;
    font-weight: 900;
    font-size: 1.1rem;
    text-align: right;
    padding: 0.3rem 0.45rem;
  }

  .stats-note {
    margin: 0;
    color: var(--color-dark-teal);
    font-size: 0.9rem;
    line-height: 1.35;
  }

  @keyframes jitter {
    0% { transform: translateX(-1px); }
    25% { transform: translateX(1px); }
    50% { transform: translateX(0); }
    75% { transform: translateX(1px); }
    100% { transform: translateX(-1px); }
  }

  @keyframes pop {
    0% { transform: scale(0.88); opacity: 0.2; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }

  @media (max-width: 1024px) {
    .play-layout {
      grid-template-columns: 1fr;
    }

    .center-stage {
      order: 1;
    }

    .event-list-wrap {
      order: 2;
    }

    .stats-wrap {
      order: 3;
    }
  }
</style>
