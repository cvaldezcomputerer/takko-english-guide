---
import GameLayout from '../../layouts/GameLayout.astro';
import WordSelectorModal from '../../components/WordSelectorModal.astro';
---

<GameLayout showBackBar title="Anarika's Challenge" description="A Japanese vocabulary quiz game.">
<div class="game-wrap">

  <!-- Category Select -->
  <div id="screen-select" class="screen">
    <div class="anarika-card">
      <div class="anarika-avatar">
        <img src="/images/anarika-challenge/anarika-face.png" alt="Anarika" class="avatar-img" />
      </div>
      <h1 class="game-title">Anarika's Challenge<span class="title-ja">アナリカのちょうせん</span></h1>
      <p class="game-desc"><span class="bilingual-line"><span>Choose a category.</span><span>カテゴリーをえらぼう。</span></span><span class="bilingual-line"><span>Type the Japanese answer for each word.</span><span>にほんごでこたえてね。</span></span></p>
    </div>

    <div class="category-grid" id="category-grid"></div>
  </div>

  <!-- Category Modal -->
  <WordSelectorModal>
    <div class="mode-select" id="mode-select">
      <button class="mode-btn active" data-mode="easy">Easy ／ かんたん</button>
      <button class="mode-btn" data-mode="medium">Medium ／ ふつう</button>
      <button class="mode-btn" data-mode="hard">Hard ／ むずかしい</button>
      <button class="mode-btn" data-mode="challenge">Challenge ／ チャレンジ</button>
    </div>
  </WordSelectorModal>

  <!-- Quiz Screen -->
  <div id="screen-quiz" class="screen hidden">
    <div class="quiz-header">
      <button class="back-btn" id="back-btn">← Back / もどる</button>
      <div class="progress-wrap">
        <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
        <span class="progress-label" id="progress-label"></span>
      </div>
      <div class="score-display" id="score-display">0 / 0</div>
    </div>

    <div class="question-card">
      <p class="question-label" id="question-label"></p>
      <div class="english-word" id="english-word"></div>
      <div class="choices-grid hidden" id="choices-grid"></div>
      <input
        type="text"
        id="answer-input"
        class="answer-input"
        placeholder="ひらがなでこたえてください"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
      />
      <button class="submit-btn" id="submit-btn">Check / かくにん</button>
    </div>

    <div class="feedback-card hidden" id="feedback-card">
      <div class="feedback-icon" id="feedback-icon"></div>
      <div class="feedback-text" id="feedback-text"></div>
      <div class="accepted-answers" id="accepted-answers"></div>
      <button class="next-btn" id="next-btn">Next / つぎ →</button>
    </div>
  </div>

  <!-- Results Screen -->
  <div id="screen-results" class="screen hidden">
    <div class="anarika-card">
      <div class="anarika-avatar">
        <img src="/images/anarika-challenge/anarika-face.png" alt="Anarika" class="avatar-img" />
      </div>
      <h2 class="result-title" id="result-title"></h2>
      <div class="score-big" id="score-big"></div>
    </div>

    <div class="missed-section" id="missed-section">
      <h3 class="missed-title">Review ／ ふくしゅう</h3>
      <table class="missed-table" id="missed-table">
        <thead>
          <tr>
            <th>English ／ えいご</th>
            <th>Your answer ／ こたえ</th>
            <th>Correct ／ せいかい</th>
          </tr>
        </thead>
        <tbody id="missed-body"></tbody>
      </table>
    </div>

    <div class="results-actions">
      <button class="play-again-btn" id="play-again-btn">Play again / もういちど</button>
      <button class="back-to-select-btn" id="back-to-select-btn">Categories / もどる</button>
    </div>
  </div>

</div>
</GameLayout>
<script>
  import type { VocabWord } from '../../data/vocab/words';
  import { categories } from '../../data/vocab/words';
  import { categoryGroups } from '../../data/vocab/groups';
  import { buildCategoryGrid, openModal, closeModal, initModalListeners, getSelectedWords } from '../../lib/wordSelector';

  interface MissedEntry { en: string; yourAnswer: string; correct: string; }

  let words: VocabWord[] = [];
  let lastWordsForReplay: VocabWord[] = [];
  let wordIndex = 0;
  let score = 0;
  let missed: MissedEntry[] = [];
  let quizMode = 'easy';
  let lastMode = 'easy';

  const screenSelect  = document.getElementById('screen-select')!;
  const screenQuiz    = document.getElementById('screen-quiz')!;
  const screenResults = document.getElementById('screen-results')!;

  const categoryGrid  = document.getElementById('category-grid')!;
  const englishWord   = document.getElementById('english-word')!;
  const answerInput   = document.getElementById('answer-input') as HTMLInputElement;
  const submitBtn     = document.getElementById('submit-btn') as HTMLButtonElement;
  const feedbackCard  = document.getElementById('feedback-card')!;
  const feedbackIcon  = document.getElementById('feedback-icon')!;
  const feedbackText  = document.getElementById('feedback-text')!;
  const acceptedEl    = document.getElementById('accepted-answers')!;
  const nextBtn       = document.getElementById('next-btn')!;
  const backBtn       = document.getElementById('back-btn')!;
  const progressFill  = document.getElementById('progress-fill')!;
  const progressLabel = document.getElementById('progress-label')!;
  const scoreDisplay  = document.getElementById('score-display')!;
  const questionLabel = document.getElementById('question-label')!;
  const choicesGrid   = document.getElementById('choices-grid')!;

  const resultTitle     = document.getElementById('result-title')!;
  const scoreBig        = document.getElementById('score-big')!;
  const missedSection   = document.getElementById('missed-section')!;
  const missedBody      = document.getElementById('missed-body')!;
  const playAgainBtn    = document.getElementById('play-again-btn')!;
  const backToSelectBtn = document.getElementById('back-to-select-btn')!;

  const modeBtns = document.querySelectorAll<HTMLButtonElement>('.mode-btn');

  modeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      quizMode = btn.dataset.mode ?? 'easy';
      modeBtns.forEach(b => b.classList.toggle('active', b === btn));
    });
  });

  buildCategoryGrid(categoryGrid, categoryGroups, (group) => {
    openModal(group, categories);
  });

  initModalListeners(() => {
    const merged = getSelectedWords(categories);
    closeModal();
    startQuiz(merged, quizMode);
  });

  function showScreen(id: string): void {
    [screenSelect, screenQuiz, screenResults].forEach(s => s.classList.add('hidden'));
    document.getElementById(id)!.classList.remove('hidden');
  }

  function normalize(str: string): string {
    return str.trim().replace(/\s+/g, '');
  }

  function checkAnswer(input: string, accepted: string[]): boolean {
    const norm = normalize(input);
    return accepted.some(a => normalize(a) === norm);
  }

  function startQuiz(wordsArray: VocabWord[], mode: string): void {
    words = [...wordsArray];
    lastWordsForReplay = [...wordsArray];
    lastMode = mode;
    wordIndex = 0;
    score = 0;
    missed = [];
    showScreen('screen-quiz');
    showQuestion();
  }

  function getChoices(correctWord: VocabWord): VocabWord[] {
    const pool = words.filter(w => w.en !== correctWord.en);
    const shuffled = pool.sort(() => Math.random() - 0.5).slice(0, 3);
    return [correctWord, ...shuffled].sort(() => Math.random() - 0.5);
  }

  function showQuestion(): void {
    feedbackCard.classList.add('hidden');

    const word = words[wordIndex];
    const pct = (wordIndex / words.length) * 100;
    progressFill.style.width = pct + '%';
    progressLabel.textContent = `${wordIndex + 1} / ${words.length}`;
    scoreDisplay.textContent = `${score} / ${wordIndex}`;

    if (lastMode === 'easy' || lastMode === 'medium') {
      const isMedium = lastMode === 'medium';
      questionLabel.textContent = isMedium
        ? 'What does this mean? ／ どういう いみ？'
        : 'What is this in Japanese? ／ にほんごでなんですか？';
      englishWord.textContent = isMedium ? word.ja[0] : word.en;
      answerInput.classList.add('hidden');
      submitBtn.classList.add('hidden');
      choicesGrid.classList.remove('hidden');

      const choices = getChoices(word);
      choicesGrid.innerHTML = '';
      choices.forEach(choice => {
        const btn = document.createElement('button');
        btn.className = 'choice-btn';
        const display = isMedium ? choice.en : choice.ja[0];
        const correctText = isMedium ? word.en : word.ja[0];
        btn.textContent = display;
        btn.addEventListener('click', () => submitChoiceAnswer(display, correctText, word));
        choicesGrid.appendChild(btn);
      });
    } else {
      const isChallenge = lastMode === 'challenge';
      questionLabel.textContent = isChallenge
        ? 'What is this in English? ／ えいごでなんですか？'
        : 'What is this in Japanese? ／ にほんごでなんですか？';
      englishWord.textContent = isChallenge ? word.ja[0] : word.en;
      choicesGrid.classList.add('hidden');
      answerInput.classList.remove('hidden');
      submitBtn.classList.remove('hidden');
      answerInput.value = '';
      answerInput.disabled = false;
      answerInput.placeholder = isChallenge ? 'Type in English' : 'ひらがなでこたえてください';
      submitBtn.disabled = false;
      answerInput.focus();
    }
  }

  function submitChoiceAnswer(chosenText: string, correctText: string, word: VocabWord): void {
    choicesGrid.querySelectorAll<HTMLButtonElement>('.choice-btn').forEach(btn => {
      btn.disabled = true;
      if (btn.textContent === correctText) btn.classList.add('choice-correct');
      else if (btn.textContent === chosenText) btn.classList.add('choice-wrong');
    });

    const correct = chosenText === correctText;
    if (correct) {
      score++;
      feedbackIcon.textContent = 'O';
      feedbackIcon.className = 'feedback-icon correct';
      feedbackText.innerHTML = 'Correct! ／ <span class="ja">せいかい！</span>';
    } else {
      missed.push({ en: word.en, yourAnswer: chosenText, correct: correctText });
      feedbackIcon.textContent = 'X';
      feedbackIcon.className = 'feedback-icon wrong';
      feedbackText.innerHTML = 'Not quite. ／ <span class="ja">ざんねん！</span>';
    }
    acceptedEl.innerHTML = `<span class="accepted-label">Answer ／ こたえ：</span> ${correctText}`;
    feedbackCard.classList.remove('hidden');
  }

  function submitAnswer(): void {
    const word = words[wordIndex];
    const input = answerInput.value;
    if (!input.trim()) return;

    answerInput.disabled = true;
    submitBtn.disabled = true;

    const isChallenge = lastMode === 'challenge';
    const correct = isChallenge
      ? normalize(input) === normalize(word.en)
      : checkAnswer(input, word.ja);

    if (correct) {
      score++;
      feedbackIcon.textContent = 'O';
      feedbackIcon.className = 'feedback-icon correct';
      feedbackText.innerHTML = 'Correct! ／ <span class="ja">せいかい！</span>';
    } else {
      const correctAnswer = isChallenge ? word.en : word.ja[0];
      missed.push({ en: word.en, yourAnswer: input, correct: correctAnswer });
      feedbackIcon.textContent = 'X';
      feedbackIcon.className = 'feedback-icon wrong';
      feedbackText.innerHTML = 'Not quite. ／ <span class="ja">ざんねん！</span>';
    }

    const answersLabel = isChallenge ? word.en : word.ja.join('、 ');
    acceptedEl.innerHTML = `<span class="accepted-label">Answer ／ こたえ：</span> ${answersLabel}`;
    feedbackCard.classList.remove('hidden');
  }

  function nextQuestion(): void {
    wordIndex++;
    if (wordIndex >= words.length) {
      showResults();
    } else {
      showQuestion();
    }
  }

  function showResults(): void {
    scoreDisplay.textContent = `${score} / ${words.length}`;
    showScreen('screen-results');

    const pct = Math.round((score / words.length) * 100);
    scoreBig.textContent = `${score} / ${words.length}`;

    if (pct === 100) {
      resultTitle.textContent = 'Perfect! かんぺき！';
    } else if (pct >= 70) {
      resultTitle.textContent = 'Well done! よくできました！';
    } else if (pct >= 40) {
      resultTitle.textContent = 'Good try! よくがんばりました！';
    } else {
      resultTitle.textContent = 'Keep practicing! もっとれんしゅうしよう！';
    }

    if (missed.length === 0) {
      missedSection.classList.add('hidden');
    } else {
      missedSection.classList.remove('hidden');
      missedBody.innerHTML = '';
      missed.forEach(m => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${m.en}</td>
          <td class="wrong-answer">${m.yourAnswer || '—'}</td>
          <td class="right-answer">${m.correct}</td>
        `;
        missedBody.appendChild(tr);
      });
    }
  }

  submitBtn.addEventListener('click', submitAnswer);
  answerInput.addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      if (!feedbackCard.classList.contains('hidden')) {
        nextQuestion();
      } else {
        submitAnswer();
      }
    }
  });
  nextBtn.addEventListener('click', nextQuestion);
  backBtn.addEventListener('click', () => showScreen('screen-select'));
  playAgainBtn.addEventListener('click', () => startQuiz(lastWordsForReplay, lastMode));
  backToSelectBtn.addEventListener('click', () => showScreen('screen-select'));
</script>

<style>
  .game-wrap {
    min-height: 100vh;
    background: #fff5f5;
    font-family: 'Andika', sans-serif;
    padding: 2rem 1rem;
  }

  .screen { max-width: 800px; margin: 0 auto; }

  /* Anarika Card */
  .anarika-card {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .anarika-avatar {
    width: 140px;
    height: 140px;
    margin: 0 auto 1rem;
    border-radius: var(--radius-round);
    overflow: hidden;
    border: 4px solid #f4a0aa;
    box-shadow: 0 4px 16px rgba(192, 57, 75, 0.15);
  }

  .avatar-img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }

  .game-title {
    font-size: 2rem;
    color: var(--color-danger);
    margin: 0 0 0.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .title-ja {
    font-size: 1.3rem;
    color: var(--color-danger);
    font-weight: 700;
  }

  .game-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .bilingual-line {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .bilingual-line span:first-child { color: var(--color-text-faint); }
  .bilingual-line span:last-child  { color: var(--color-text); font-weight: 600; }

  /* Category Grid */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.4rem;
  }


  .mode-select {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid #f0f0f0;
    flex-shrink: 0;
  }

  .mode-btn {
    flex: 1;
    background: white;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.55rem 0.5rem;
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: all 0.15s;
  }

  .mode-btn:hover { border-color: var(--color-border-strong); color: var(--color-text); }

  .mode-btn[data-mode="easy"].active {
    background: #2e7d32;
    border-color: #2e7d32;
    color: white;
    font-weight: 700;
  }

  .mode-btn[data-mode="medium"].active {
    background: #e6a817;
    border-color: #e6a817;
    color: white;
    font-weight: 700;
  }

  .mode-btn[data-mode="hard"].active {
    background: var(--color-danger);
    border-color: var(--color-danger);
    color: white;
    font-weight: 700;
  }

  .mode-btn[data-mode="challenge"].active {
    background: #7c5cbf;
    border-color: #7c5cbf;
    color: white;
    font-weight: 700;
  }

  /* Quiz Header */
  .quiz-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .back-btn {
    background: none;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.4rem 0.8rem;
    cursor: pointer;
    font-family: inherit;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .back-btn:hover { border-color: var(--color-border-strong); }

  .progress-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .progress-bar {
    height: 8px;
    background: #f0d0d4;
    border-radius: var(--radius-xs);
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-danger);
    border-radius: var(--radius-xs);
    transition: width 0.3s;
  }

  .progress-label {
    font-size: 0.75rem;
    color: var(--color-text-faint);
    text-align: center;
  }

  .score-display {
    font-weight: bold;
    color: var(--color-danger);
    font-size: 1.1rem;
    flex-shrink: 0;
    min-width: 3rem;
    text-align: right;
  }

  /* Question Card */
  .question-card {
    background: white;
    border: 2px solid #f4a0aa;
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    text-align: center;
  }

  .question-label {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    font-weight: 600;
    margin: 0 0 1.5rem;
  }

  .english-word {
    font-size: 2.5rem;
    font-weight: bold;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    min-height: 3rem;
  }

  .answer-input {
    width: 100%;
    max-width: 360px;
    font-size: 1.4rem;
    padding: 0.8rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 10px;
    text-align: center;
    font-family: 'M PLUS Rounded 1c', sans-serif;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .answer-input:focus { border-color: var(--color-danger); }

  .submit-btn {
    display: block;
    margin: 1.2rem auto 0;
    background: var(--color-danger);
    color: white;
    border: none;
    border-radius: var(--radius-pill);
    padding: 0.8rem 0;
    width: 220px;
    font-size: 1rem;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.2s;
  }

  .submit-btn:hover { background: #a02d3d; }
  .submit-btn:disabled { background: var(--color-border); cursor: default; }

  .choices-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .choice-btn {
    background: white;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.9rem 0.75rem;
    font-size: 1rem;
    font-family: inherit;
    cursor: pointer;
    color: var(--color-text);
    transition: border-color 0.15s, background 0.15s;
    line-height: 1.3;
  }

  .choice-btn:hover:not(:disabled) { border-color: var(--color-border-strong); background: #fafafa; }
  .choice-btn:disabled { cursor: default; }
  .choice-btn.choice-correct { border-color: #2e7d32; background: #f0faf0; color: #2e7d32; font-weight: 700; }
  .choice-btn.choice-wrong   { border-color: var(--color-danger); background: #fff0f1; color: var(--color-danger); }

  /* Feedback Card */
  .feedback-card {
    background: white;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    margin-top: 1.5rem;
  }

  .feedback-icon {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .feedback-icon.correct { color: #2e7d32; }
  .feedback-icon.wrong   { color: var(--color-danger); }

  .feedback-text {
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--color-text);
    margin-bottom: 0.8rem;
  }

  .accepted-answers {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-family: 'M PLUS Rounded 1c', sans-serif;
    margin-bottom: 1.2rem;
  }

  .accepted-label {
    color: var(--color-text-faint);
    font-family: 'Andika', sans-serif;
    font-size: 0.85rem;
    margin-right: 0.3rem;
  }

  .next-btn {
    background: var(--color-text);
    color: white;
    border: none;
    border-radius: var(--radius-pill);
    padding: 0.8rem 0;
    width: 220px;
    font-size: 1rem;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.2s;
  }

  .next-btn:hover { background: var(--color-text-muted); }

  /* Results */
  .result-title {
    font-size: 1.8rem;
    color: var(--color-danger);
    margin: 0 0 0.5rem;
  }

  .score-big {
    font-size: 3rem;
    font-weight: bold;
    color: var(--color-text);
  }

  .missed-section {
    background: white;
    border: 2px solid #f4a0aa;
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-top: 2rem;
  }

  .missed-title {
    font-size: 1.2rem;
    color: var(--color-danger);
    margin: 0 0 1rem;
  }

  .missed-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .missed-table th {
    text-align: left;
    color: var(--color-text-faint);
    font-weight: normal;
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--color-border);
  }

  .missed-table td {
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid #f5f5f5;
    font-family: 'M PLUS Rounded 1c', sans-serif;
  }

  .wrong-answer { color: var(--color-danger); }
  .right-answer { color: #2e7d32; font-weight: bold; }

  .results-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .play-again-btn {
    background: var(--color-danger);
    color: white;
    border: none;
    border-radius: var(--radius-pill);
    padding: 0.8rem 0;
    width: 220px;
    font-size: 1rem;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.2s;
  }

  .play-again-btn:hover { background: #a02d3d; }

  .back-to-select-btn {
    background: white;
    color: var(--color-danger);
    border: 2px solid var(--color-danger);
    border-radius: var(--radius-pill);
    padding: 0.8rem 0;
    width: 220px;
    font-size: 1rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s;
  }

  .back-to-select-btn:hover {
    background: #fff0f1;
