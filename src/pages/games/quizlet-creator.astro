---
import GameLayout from '../../layouts/GameLayout.astro';
import WordSelectorModal from '../../components/WordSelectorModal.astro';
---

<GameLayout showBackBar title="Blooket/Quizlet Exporter" description="Make sets for Quizlet or Blooket based on vocab from New Horizons books.">
<div class="wrap">

  <!-- Select Screen -->
  <div id="screen-select" class="screen">
    <div class="header-card">
      <div class="header-icon" aria-hidden="true">
        <svg viewBox="0 0 80 80" fill="none">
          <!-- Back card -->
          <rect x="24" y="10" width="40" height="28" rx="6" fill="#dbeafe" stroke="#2563eb" stroke-width="2"/>
          <!-- Front card -->
          <rect x="14" y="18" width="40" height="28" rx="6" fill="white" stroke="#2563eb" stroke-width="2"/>
          <!-- Lines suggesting text -->
          <line x1="22" y1="28" x2="46" y2="28" stroke="#93c5fd" stroke-width="2" stroke-linecap="round"/>
          <line x1="22" y1="35" x2="40" y2="35" stroke="#bfdbfe" stroke-width="2" stroke-linecap="round"/>
          <line x1="22" y1="40" x2="44" y2="40" stroke="#bfdbfe" stroke-width="2" stroke-linecap="round"/>
          <!-- Export arrow -->
          <path d="M34 52 L34 68" stroke="#2563eb" stroke-width="2.5" stroke-linecap="round"/>
          <path d="M26 61 L34 69 L42 61" fill="none" stroke="#2563eb" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h1 class="page-title">Blooket / Quizlet Exporter<span class="title-ja">エクスポートツール</span></h1>
      <p class="page-desc">
        <span class="desc-en">Make sets for Quizlet or Blooket based on 5th and 6th grade New Horizons vocab.</span>
        <span class="desc-ja">小5・小6のニューホライズンの単語からクイズレット・ブルーケット用のセットを作れます。</span>
      </p>
    </div>
    <div class="category-grid" id="category-grid"></div>
  </div>

  <!-- Category Modal -->
  <WordSelectorModal />

  <!-- Output Screen -->
  <div id="screen-output" class="screen hidden">
    <div class="output-header">
      <button class="back-btn" id="back-btn">← Back ／ もどる</button>
      <span class="word-count" id="word-count"></span>
    </div>

    <div class="output-card">
      <div class="output-top">
        <h2 class="output-title">Your Set ／ セット完成</h2>
        <div class="output-actions">
          <button class="caps-btn" id="caps-btn">Capitalize ／ 大文字</button>
          <button class="copy-btn" id="copy-btn">Copy ／ コピー</button>
        </div>
      </div>
      <textarea class="output-area" id="output-area" readonly spellcheck="false"></textarea>
    </div>

    <div class="instructions">
      <div class="instr-block">
        <h3 class="instr-title">Quizlet</h3>
        <ol class="instr-list">
          <li>Go to <strong>quizlet.com</strong> → Create</li>
          <li>Click <strong>Import</strong></li>
          <li>Paste the text above</li>
          <li>Separators: Term/Definition = <strong>Tab</strong>, Rows = <strong>New line</strong></li>
          <li>Click <strong>Import</strong></li>
        </ol>
      </div>
      <div class="instr-block">
        <h3 class="instr-title">Blooket</h3>
        <ol class="instr-list">
          <li>Go to <strong>blooket.com</strong> → Create Set</li>
          <li>Select <strong>Import from Blooket</strong></li>
          <li>Press <strong>Next</strong></li>
          <li>Press <strong>Next</strong></li>
          <li>Paste in the values above</li>
        </ol>
      </div>
    </div>
  </div>

</div>
</GameLayout>

<script>
  import type { VocabWord } from '../../data/vocab/words';
  import { categories } from '../../data/vocab/words';
  import { categoryGroups } from '../../data/vocab/groups';
  import { buildCategoryGrid, openModal, closeModal, initModalListeners, getSelectedWords, formatJapanese } from '../../lib/wordSelector';

  const screenSelect = document.getElementById('screen-select')!;
  const screenOutput = document.getElementById('screen-output')!;
  const categoryGrid = document.getElementById('category-grid')!;
  const backBtn      = document.getElementById('back-btn')!;
  const outputArea   = document.getElementById('output-area') as HTMLTextAreaElement;
  const wordCount    = document.getElementById('word-count')!;
  const copyBtn      = document.getElementById('copy-btn') as HTMLButtonElement;
  const capsBtn      = document.getElementById('caps-btn') as HTMLButtonElement;

  let currentWords: VocabWord[] = [];
  let capsOn = false;

  function showScreen(id: string): void {
    [screenSelect, screenOutput].forEach(s => s.classList.add('hidden'));
    document.getElementById(id)!.classList.remove('hidden');
  }

  function buildOutput(): string {
    return currentWords.map(w => {
      const en = capsOn ? w.en.toUpperCase() : w.en;
      return `${en}\t${formatJapanese(w)}`;
    }).join('\n');
  }

  buildCategoryGrid(categoryGrid, categoryGroups, (group) => {
    openModal(group, categories);
  });

  initModalListeners(() => {
    const merged = getSelectedWords(categories);
    closeModal();
    showSet(merged);
  });

  function showSet(words: VocabWord[]): void {
    currentWords = words;
    capsOn = false;
    capsBtn.textContent = 'Capitalize ／ 大文字';
    capsBtn.classList.remove('active');
    outputArea.value = buildOutput();
    wordCount.textContent = `${words.length} words ／ ${words.length} たんご`;
    showScreen('screen-output');
  }

  backBtn.addEventListener('click', () => showScreen('screen-select'));

  capsBtn.addEventListener('click', () => {
    capsOn = !capsOn;
    capsBtn.textContent = capsOn ? 'lowercase ／ 小文字' : 'Capitalize ／ 大文字';
    capsBtn.classList.toggle('active', capsOn);
    outputArea.value = buildOutput();
  });

  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(outputArea.value).then(() => {
      copyBtn.textContent = 'Copied! ／ コピーしました';
      copyBtn.classList.add('copied');
      setTimeout(() => {
        copyBtn.textContent = 'Copy ／ コピー';
        copyBtn.classList.remove('copied');
      }, 2000);
    });
  });
</script>

<style>
  .wrap {
    min-height: 100vh;
    background: #f0f5ff;
    font-family: 'Andika', sans-serif;
    padding: 2rem 1rem;
  }

  .screen { max-width: 800px; margin: 0 auto; }

  /* Header */
  .header-card {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .header-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1rem;
  }

  .header-icon svg { width: 100%; height: 100%; }

  .page-title {
    font-size: 2rem;
    color: #2563eb;
    margin: 0 0 0.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .title-ja {
    font-size: 1.3rem;
    color: #2563eb;
    font-weight: 700;
    font-family: 'M PLUS Rounded 1c', sans-serif;
  }

  .page-desc {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .desc-en {
    font-size: 0.95rem;
    color: #666;
  }

  .desc-ja {
    font-size: 0.88rem;
    color: #888;
    font-family: 'M PLUS Rounded 1c', sans-serif;
  }

  /* Category Grid */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.4rem;
  }

  /* Output screen */
  .output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .back-btn {
    background: none;
    border: 2px solid #ddd;
    border-radius: var(--radius-sm);
    padding: 0.4rem 0.8rem;
    cursor: pointer;
    font-family: inherit;
    color: #666;
  }

  .back-btn:hover { border-color: #aaa; }

  .word-count {
    font-size: 0.9rem;
    color: #888;
  }

  .output-card {
    background: white;
    border: 2px solid #bfdbfe;
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .output-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .output-title {
    font-size: 1.2rem;
    color: #2563eb;
    margin: 0;
  }

  .output-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .caps-btn {
    background: white;
    border: 2px solid #2563eb;
    color: #2563eb;
    border-radius: var(--radius-pill);
    padding: 0.45rem 1rem;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
  }

  .caps-btn:hover { background: #eff6ff; }

  .caps-btn.active {
    background: #2563eb;
    color: white;
  }

  .copy-btn {
    background: #2563eb;
    color: white;
    border: none;
    border-radius: var(--radius-pill);
    padding: 0.45rem 1.2rem;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s;
  }

  .copy-btn:hover { background: #1d4ed8; }
  .copy-btn.copied { background: #16a34a; }

  .output-area {
    width: 100%;
    min-height: 380px;
    font-size: 0.95rem;
    font-family: 'M PLUS Rounded 1c', monospace;
    border: 2px solid #e2e8f0;
    border-radius: 10px;
    padding: 1rem;
    resize: vertical;
    box-sizing: border-box;
    line-height: 1.7;
    color: var(--color-text);
    background: #f8fafc;
  }

  /* Instructions */
  .instructions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .instr-block {
    background: white;
    border: 2px solid #bfdbfe;
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
  }

  .instr-title {
    font-size: 1.05rem;
    color: #2563eb;
    margin: 0 0 0.75rem;
    font-weight: 700;
  }

  .instr-list {
    margin: 0;
    padding-left: 1.25rem;
    color: #444;
    font-size: 0.9rem;
    line-height: 1.8;
  }

  @media (max-width: 600px) {
    .page-title { font-size: 1.6rem; }
    .category-grid { grid-template-columns: 1fr; }
    .instructions { grid-template-columns: 1fr; }
    .output-area { min-height: 260px; }
  }
</style>
