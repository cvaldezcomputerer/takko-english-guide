---
import GameLayout from '../../layouts/GameLayout.astro';
---

<GameLayout
  title="Write Your Name in English — Takkotaco"
  description="Type your name in kana and see it big in English letters on writing lines, ready to copy onto paper."
  showBackBar={true}
>
  <main class="nw-main">
    <header class="nw-head">
      <h1 class="nw-title">
        Write Your Name<span class="nw-title-ja">なまえをえいごでかこう</span>
      </h1>
      <p class="nw-sub">
        <span class="nw-en">Type your name in kana.</span>
        <span class="nw-ja">ひらがなやカタカナでなまえをいれてね。</span>
      </p>
    </header>

    <div class="nw-input-wrap">
      <input
        id="nw-input"
        class="nw-input"
        type="text"
        lang="ja"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        placeholder="さとう"
        aria-label="Your name in kana"
      />
    </div>

    <!-- The big name sits on the 4-line writing guide (SVG, so the baseline is exact). -->
    <div class="nw-card">
      <div class="nw-stage" id="nw-stage" aria-live="polite">
        <p class="nw-placeholder" id="nw-placeholder">
          <span class="nw-en">Your name appears here</span>
          <span class="nw-ja">ここになまえがでます</span>
        </p>
      </div>
    </div>

    <!-- "How to write": replays the name being drawn stroke by stroke. -->
    <div class="nw-write" id="nw-write" hidden>
      <button class="nw-draw-btn" id="nw-draw-btn" type="button">
        <svg class="nw-pencil" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
            fill="currentColor"
          />
        </svg>
        <span class="nw-btn-text">
          <span class="nw-en">How to write</span>
          <span class="nw-ja">かきかた</span>
        </span>
      </button>

      <div class="nw-speed" role="group" aria-label="Speed / スピード">
        <span class="nw-speed-label">
          <span class="nw-en">Speed</span>
          <span class="nw-ja">スピード</span>
        </span>
        <button class="nw-speed-btn is-selected" type="button" data-speed="normal">
          <svg class="nw-spd-icon" viewBox="0 0 22 16" fill="none" aria-hidden="true">
            <path d="M3 4l4 4-4 4M9 4l4 4-4 4M15 4l4 4-4 4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="nw-spd-text"><span class="nw-en">Normal</span><span class="nw-ja">ふつう</span></span>
        </button>
        <button class="nw-speed-btn" type="button" data-speed="slow">
          <svg class="nw-spd-icon" viewBox="0 0 22 16" fill="none" aria-hidden="true">
            <path d="M6 4l4 4-4 4M12 4l4 4-4 4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="nw-spd-text"><span class="nw-en">Slow</span><span class="nw-ja">おそい</span></span>
        </button>
        <button class="nw-speed-btn" type="button" data-speed="vslow">
          <svg class="nw-spd-icon" viewBox="0 0 22 16" fill="none" aria-hidden="true">
            <path d="M9 4l4 4-4 4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="nw-spd-text"><span class="nw-en">Very slow</span><span class="nw-ja">とてもおそい</span></span>
        </button>
      </div>
    </div>

    <!-- Spelling options, most common first. -->
    <div class="nw-options" id="nw-options" hidden>
      <p class="nw-options-label">
        <span class="nw-en">Choose a spelling</span>
        <span class="nw-ja">スペルをえらんでね</span>
      </p>
      <div class="nw-chips" id="nw-chips" role="group" aria-label="Spelling options"></div>
    </div>

    <!-- Quick tips for students. -->
    <section class="nw-tips" aria-label="Tips">
      <h2 class="nw-tips-title">
        <span class="nw-en">Tips</span>
        <span class="nw-ja">ヒント</span>
      </h2>
      <ul class="nw-tips-list">
        <li>
          <span class="nw-en">Names start with a capital letter.</span>
          <span class="nw-ja">なまえはおおもじではじめます。</span>
        </li>
        <li>
          <span class="nw-en">One sound can have a few spellings. Pick the one you like.</span>
          <span class="nw-ja">よみかたはひとつでも、スペルはいくつかあります。すきなものをえらんでね。</span>
        </li>
        <li>
          <span class="nw-en">Press "How to write" to watch each letter, then copy it onto paper.</span>
          <span class="nw-ja">「かきかた」をおしてかきじゅんをみて、かみにかいてみよう。</span>
        </li>
        <li>
          <span class="nw-en">Stroke order and the number of strokes can vary. This shows one common way.</span>
          <span class="nw-ja">かきじゅんや せんのかずは、ほかの かきかたと ちがう ことが あります。これは よくある ひとつの れいだよ。</span>
        </li>
      </ul>
    </section>
  </main>
</GameLayout>

<script>
  import { letterStrokes } from '../../data/letter-strokes';

  // ── Kana → romaji engine ───────────────────────────────────────────────
  // A small Hepburn map. Katakana is folded to hiragana first, so one table
  // covers both. The value-add over a plain transliterator is the long-vowel
  // variants below (さとう → Sato / Satou / Satoh), ranked most-common first.

  const BASE: Record<string, string> = {
    あ:'a', い:'i', う:'u', え:'e', お:'o',
    か:'ka', き:'ki', く:'ku', け:'ke', こ:'ko',
    さ:'sa', し:'shi', す:'su', せ:'se', そ:'so',
    た:'ta', ち:'chi', つ:'tsu', て:'te', と:'to',
    な:'na', に:'ni', ぬ:'nu', ね:'ne', の:'no',
    は:'ha', ひ:'hi', ふ:'fu', へ:'he', ほ:'ho',
    ま:'ma', み:'mi', む:'mu', め:'me', も:'mo',
    や:'ya', ゆ:'yu', よ:'yo',
    ら:'ra', り:'ri', る:'ru', れ:'re', ろ:'ro',
    わ:'wa', ゐ:'i', ゑ:'e', を:'o', ん:'n',
    が:'ga', ぎ:'gi', ぐ:'gu', げ:'ge', ご:'go',
    ざ:'za', じ:'ji', ず:'zu', ぜ:'ze', ぞ:'zo',
    だ:'da', ぢ:'ji', づ:'zu', で:'de', ど:'do',
    ば:'ba', び:'bi', ぶ:'bu', べ:'be', ぼ:'bo',
    ぱ:'pa', ぴ:'pi', ぷ:'pu', ぺ:'pe', ぽ:'po',
    ゔ:'vu',
    ぁ:'a', ぃ:'i', ぅ:'u', ぇ:'e', ぉ:'o',
    ゃ:'ya', ゅ:'yu', ょ:'yo', ゎ:'wa',
    '　':' ',
  };

  const YOUON: Record<string, string> = {
    きゃ:'kya', きゅ:'kyu', きょ:'kyo',
    しゃ:'sha', しゅ:'shu', しょ:'sho',
    ちゃ:'cha', ちゅ:'chu', ちょ:'cho',
    にゃ:'nya', にゅ:'nyu', にょ:'nyo',
    ひゃ:'hya', ひゅ:'hyu', ひょ:'hyo',
    みゃ:'mya', みゅ:'myu', みょ:'myo',
    りゃ:'rya', りゅ:'ryu', りょ:'ryo',
    ぎゃ:'gya', ぎゅ:'gyu', ぎょ:'gyo',
    じゃ:'ja', じゅ:'ju', じょ:'jo',
    ぢゃ:'ja', ぢゅ:'ju', ぢょ:'jo',
    びゃ:'bya', びゅ:'byu', びょ:'byo',
    ぴゃ:'pya', ぴゅ:'pyu', ぴょ:'pyo',
  };

  const SMALL_Y = new Set(['ゃ', 'ゅ', 'ょ']);

  function kanaToRomaji(input: string): string {
    // Fold katakana → hiragana (keep the long mark ー and everything else).
    let s = '';
    for (const ch of input) {
      const code = ch.codePointAt(0)!;
      s += code >= 0x30a1 && code <= 0x30f6 ? String.fromCodePoint(code - 0x60) : ch;
    }

    let out = '';
    let sokuon = false; // small っ → double the next consonant
    for (let i = 0; i < s.length; i++) {
      const ch = s[i];

      if (ch === 'ー') {                       // long mark: repeat the last vowel
        const m = out.match(/[aeiou]$/);
        if (m) out += m[0];
        continue;
      }
      if (ch === 'っ' || ch === 'ッ') { sokuon = true; continue; }

      let rom: string;
      const pair = s.slice(i, i + 2);
      if (SMALL_Y.has(s[i + 1]) && YOUON[pair]) { rom = YOUON[pair]; i++; }
      else if (BASE[ch] !== undefined) { rom = BASE[ch]; }
      else { rom = ch; }                        // unknown (kanji, punctuation) → as-is

      if (sokuon) {
        if (rom.startsWith('ch')) out += 't';   // っち → tch (matcha)
        else if (/^[a-z]/.test(rom)) out += rom[0];
        sokuon = false;
      }
      out += rom;
    }
    return out;
  }

  function titleCase(r: string): string {
    return r.replace(/\b[a-z]/g, (c) => c.toUpperCase());
  }

  // Build the spelling options for a name, most common first.
  function spellings(kana: string): string[] {
    const literal = kanaToRomaji(kana.trim()).trim();
    if (!literal) return [];

    // "Passport / everyday" Hepburn drops long o and u — the most common style.
    const collapsed = literal
      .replace(/ou/g, 'o').replace(/oo/g, 'o')
      .replace(/uu/g, 'u').replace(/aa/g, 'a').replace(/ii/g, 'i');
    const hasLongO = /ou|oo/.test(literal);
    const ohStyle = literal.replace(/ou/g, 'oh').replace(/oo/g, 'oh');

    const list: string[] = [];
    const add = (v: string) => { if (v && !list.includes(v)) list.push(v); };
    add(collapsed);          // 1. Sato   (most common)
    add(literal);            // 2. Satou  (literal)
    if (hasLongO) add(ohStyle); // 3. Satoh
    return list.map(titleCase);
  }

  // ── Rendering ──────────────────────────────────────────────────────────
  // The name is built from our own stroke letters (src/letter-strokes.ts), not a
  // web font, so the shapes match what kids practise tracing. Each glyph lives in
  // a shared 100-unit box whose lowercase metrics double as the 4-line guide:
  //   top/ascender 10 · x-height 39 · baseline 76 (red) · descender 96.
  const SVGNS = 'http://www.w3.org/2000/svg';
  const ASC = 10, XH = 39, BASE_Y = 76, DESC = 96;
  const VBH = 102;          // viewBox height — a little room for descender stroke
  const PAD_X = 24;         // left/right breathing room
  const SPACING = 12;       // gap between letters
  const SPACE_W = 34;       // advance for a space
  const STROKE = 9;         // pen weight (held constant via non-scaling-stroke)
  // Capitals are authored taller (top 8 → baseline 91). Scale + shift them so the
  // cap-height fills the top-line→baseline band and the baseline matches lowercase.
  const CAP_SCALE = (BASE_Y - ASC) / (91 - 8);
  const CAP_TY = BASE_Y - 91 * CAP_SCALE;

  const isCap = (ch: string) => ch >= 'A' && ch <= 'Z';

  // One letter → a <g> of stroke <path>s (capitals wrapped in a scale/shift group).
  function makeGlyph(ch: string): SVGGElement | null {
    const strokes = letterStrokes[ch];
    if (!strokes) return null;
    const cap = isCap(ch);
    const g = document.createElementNS(SVGNS, 'g');
    let host: SVGGElement = g;
    if (cap) {
      const inner = document.createElementNS(SVGNS, 'g');
      inner.setAttribute('transform', `translate(0 ${CAP_TY}) scale(${CAP_SCALE})`);
      g.appendChild(inner);
      host = inner;
    }
    // Capitals sit in a scaled group, so bump their pen weight to land at ~STROKE
    // after scaling. We deliberately avoid vector-effect:non-scaling-stroke here —
    // it breaks the pathLength dash math the "how to write" draw-on relies on.
    const strokeW = cap ? STROKE / CAP_SCALE : STROKE;
    for (const d of strokes) {
      const p = document.createElementNS(SVGNS, 'path');
      p.setAttribute('d', d);
      p.setAttribute('fill', 'none');
      p.setAttribute('stroke', '#333');
      p.setAttribute('stroke-width', String(strokeW));
      p.setAttribute('stroke-linecap', 'round');
      p.setAttribute('stroke-linejoin', 'round');
      host.appendChild(p);
    }
    return g;
  }

  const input = document.getElementById('nw-input') as HTMLInputElement;
  const stage = document.getElementById('nw-stage')!;
  const placeholder = document.getElementById('nw-placeholder')!;
  const optionsBox = document.getElementById('nw-options') as HTMLElement;
  const chipsBox = document.getElementById('nw-chips')!;
  const writeBox = document.getElementById('nw-write') as HTMLElement;
  const drawBtn = document.getElementById('nw-draw-btn') as HTMLButtonElement;

  // ── "How to write" animation ─────────────────────────────────────────────
  // Each stroke <path> is revealed by animating a dash offset (same trick as
  // StrokeLetter), one after another in DOM order = writing order. Stroke time is
  // proportional to its length so a long stem isn't as quick as a dot. Pen speed
  // is ms-per-unit-length; `gap` is the pen-lift pause between strokes.
  const SPEEDS: Record<string, { ms: number; gap: number }> = {
    normal: { ms: 7, gap: 90 },
    slow: { ms: 14, gap: 160 },
    vslow: { ms: 24, gap: 260 },
  };
  let speed = 'normal';
  let drawAnims: Animation[] = [];

  function animateDraw() {
    drawAnims.forEach((a) => a.cancel());
    drawAnims = [];
    const paths = Array.from(
      stage.querySelectorAll<SVGPathElement>('.nw-svg path')
    );
    if (!paths.length) return;

    const { ms, gap } = SPEEDS[speed];
    // Hide every stroke up front (offset just past 1 avoids a round-cap dot).
    for (const p of paths) {
      p.setAttribute('pathLength', '1');
      p.style.strokeDasharray = '1 2';
      p.style.strokeDashoffset = '1.05';
    }
    // Then reveal them one by one.
    let delay = 0;
    for (const p of paths) {
      const dur = Math.max(p.getTotalLength() * ms, 90);
      const a = p.animate(
        [{ strokeDashoffset: '1.05' }, { strokeDashoffset: '0' }],
        { duration: dur, delay, easing: 'ease-in-out', fill: 'forwards' }
      );
      drawAnims.push(a);
      delay += dur + gap;
    }
  }

  drawBtn.addEventListener('click', animateDraw);
  for (const b of Array.from(writeBox.querySelectorAll<HTMLButtonElement>('.nw-speed-btn'))) {
    b.addEventListener('click', () => {
      speed = b.dataset.speed!;
      writeBox.querySelectorAll('.nw-speed-btn').forEach((x) =>
        x.classList.toggle('is-selected', x === b)
      );
    });
  }

  function drawName(text: string) {
    const svg = document.createElementNS(SVGNS, 'svg');
    svg.setAttribute('class', 'nw-svg');
    svg.setAttribute('viewBox', `0 0 100 ${VBH}`);
    stage.replaceChildren(svg); // attach first so getBBox can measure each glyph

    // Lay glyphs left→right, advancing by each one's measured ink width so the
    // spacing reads proportionally instead of monospace.
    let penX = PAD_X;
    for (const ch of text) {
      if (ch === ' ') { penX += SPACE_W; continue; }
      const g = makeGlyph(ch);
      if (!g) continue;
      svg.appendChild(g);
      const bb = g.getBBox();
      g.setAttribute('transform', `translate(${penX - bb.x} 0)`);
      penX += bb.width + SPACING;
    }
    const firstGlyph = svg.firstChild; // guide lines get inserted before this
    const W = Math.max(penX - SPACING + PAD_X, 160);
    svg.setAttribute('viewBox', `0 0 ${W} ${VBH}`);

    const line = (y: number, color: string, dashed = false) => {
      const l = document.createElementNS(SVGNS, 'line');
      l.setAttribute('x1', '0'); l.setAttribute('x2', String(W));
      l.setAttribute('y1', String(y)); l.setAttribute('y2', String(y));
      l.setAttribute('stroke', color); l.setAttribute('stroke-width', '1.5');
      if (dashed) l.setAttribute('stroke-dasharray', '6 7');
      return l;
    };
    // Lines go under the letters (inserted before the first glyph).
    svg.insertBefore(line(ASC, '#333'), firstGlyph);
    svg.insertBefore(line(XH, '#333', true), firstGlyph); // dashed midline
    svg.insertBefore(line(BASE_Y, '#d94b3e'), firstGlyph); // red baseline
    svg.insertBefore(line(DESC, '#333'), firstGlyph);
  }

  function selectChip(idx: number, options: string[]) {
    Array.from(chipsBox.children).forEach((c, i) =>
      c.classList.toggle('is-selected', i === idx)
    );
    drawName(options[idx]);
  }

  function render() {
    const options = spellings(input.value);
    if (options.length === 0) {
      stage.replaceChildren(placeholder);
      optionsBox.hidden = true;
      writeBox.hidden = true;
      chipsBox.replaceChildren();
      return;
    }

    writeBox.hidden = false;

    chipsBox.replaceChildren();
    options.forEach((opt, i) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'nw-chip';
      b.textContent = opt;
      b.addEventListener('click', () => selectChip(i, options));
      chipsBox.appendChild(b);
    });
    // One spelling = no choice to make; hide the chips row entirely.
    optionsBox.hidden = options.length < 2;
    selectChip(0, options);
  }

  // On mobile, Japanese IME fires compositionstart/compositionend around the
  // character commitment phase. Avoid rendering mid-composition (the value is
  // partial/romaji at that point), and render once the user commits kana.
  let composing = false;
  input.addEventListener('compositionstart', () => { composing = true; });
  input.addEventListener('compositionend', () => { composing = false; render(); });
  input.addEventListener('input', () => { if (!composing) render(); });
  render();
</script>

<style>
  .nw-main {
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(1.25rem, 4vw, 2.5rem) clamp(1rem, 4vw, 2rem) 3rem;
    font-family: var(--font-body);
    color: var(--color-text);
  }

  .nw-head { text-align: center; }
  .nw-title {
    font-family: var(--font-main);
    color: var(--color-primary);
    font-size: clamp(1.6rem, 5vw, 2.6rem);
    margin: 0 0 0.3rem;
  }
  .nw-title-ja {
    display: block;
    font-family: 'M PLUS Rounded 1c', sans-serif;
    font-size: clamp(1rem, 3vw, 1.4rem);
    font-weight: 700;
    margin-top: 0.1rem;
  }
  .nw-sub {
    margin: 0;
    color: #7a6f5c;
    font-size: clamp(0.95rem, 2.4vw, 1.15rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  /* Bilingual text: English on top, Japanese companion below/after (muted). */
  .nw-ja {
    font-family: 'M PLUS Rounded 1c', sans-serif;
    color: #9a8d76;
  }

  .nw-input-wrap {
    margin: clamp(1.25rem, 4vw, 2rem) auto 0;
    max-width: 420px;
  }
  .nw-input {
    width: 100%;
    box-sizing: border-box;
    text-align: center;
    font-family: var(--font-body);
    font-size: clamp(1.6rem, 6vw, 2.4rem);
    padding: 0.5rem 0.9rem;
    border: 3px solid var(--color-secondary);
    border-radius: var(--radius-lg);
    background: var(--color-white);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .nw-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(74, 124, 89, 0.15);
  }
  .nw-input::placeholder { color: #c8bca3; }

  /* The writing card holds the big name on its 4-line guide. */
  .nw-card {
    margin: clamp(1.25rem, 4vw, 2rem) 0 0;
    background: var(--color-white);
    border: 2px solid #efe7d6;
    border-radius: 20px;
    padding: clamp(1rem, 4vw, 2rem);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.05);
  }
  .nw-stage {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: clamp(110px, 26vw, 180px);
  }
  .nw-svg {
    width: 100%;
    height: auto;
    max-height: clamp(140px, 32vw, 220px);
    display: block;
  }
  .nw-placeholder {
    margin: 0;
    color: #c8bca3;
    font-size: clamp(1.1rem, 3.5vw, 1.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }
  .nw-placeholder .nw-ja { color: #cabfa6; font-size: 0.85em; }

  /* Spelling option chips. */
  .nw-options { margin: clamp(1.1rem, 3.5vw, 1.6rem) 0 0; text-align: center; }
  .nw-options-label {
    margin: 0 0 0.6rem;
    color: #7a6f5c;
    font-size: clamp(0.85rem, 2.2vw, 1rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.05rem;
  }
  .nw-options-label .nw-ja { font-size: 0.9em; }
  .nw-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }
  .nw-chip {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 3vw, 1.4rem);
    padding: 0.4rem 1.1rem;
    border: 2px solid var(--color-secondary);
    border-radius: var(--radius-pill);
    background: var(--color-white);
    color: var(--color-text);
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast), transform 0.12s;
  }
  .nw-chip:hover {
    border-color: var(--color-primary);
    transform: translateY(-1px);
  }
  .nw-chip.is-selected {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-white);
  }

  /* "How to write" controls. */
  .nw-write {
    margin: clamp(1.1rem, 3.5vw, 1.6rem) 0 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.6rem 1.2rem;
  }
  .nw-draw-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 3vw, 1.3rem);
    padding: 0.45rem 1.2rem;
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: var(--color-white);
    cursor: pointer;
    transition: background var(--transition-fast), transform 0.12s, box-shadow var(--transition-fast);
  }
  .nw-draw-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(74, 124, 89, 0.25);
  }
  .nw-pencil {
    width: 1.2em;
    height: 1.2em;
