---
import GameLayout from "../../layouts/GameLayout.astro";
import frontUrl from '../../assets/trains/hayabusa-front.svg?url';
import carUrl from '../../assets/trains/hayabusa-car.svg?url';
---

<GameLayout showBackBar title="Timer">
  <div class="timer-page">
    <main class="timer-shell">
      <section class="timer-panel">
        <div class="panel-stripe panel-stripe-teal" aria-hidden="true"></div>
        <div class="panel-stripe panel-stripe-pink" aria-hidden="true"></div>
        <div class="led-housing">
          <div class="led-header" aria-hidden="true">
            <span class="led-label">はやぶさ 229</span>
            <span class="led-dest">田子 ゆき</span>
          </div>
          <div class="led-time" id="timeDisplay">00:30</div>
        </div>
        <p id="statusText" class="status-text">Set your time and press start.</p>
      </section>

      <section class="controls-panel">
        <label for="durationInput" class="input-label">Duration (seconds)</label>
        <input id="durationInput" class="duration-input" type="number" min="1" max="3600" value="30" />
        <p class="help-text">Or use the buttons below to add time.</p>

        <div class="add-buttons">
          <button type="button" class="add-btn" data-add="10">+10s</button>
          <button type="button" class="add-btn" data-add="30">+30s</button>
          <button type="button" class="add-btn" data-add="60">+1m</button>
          <button type="button" class="add-btn" data-add="300">+5m</button>
        </div>

        <div class="action-buttons">
          <button id="startBtn" type="button" class="action-btn action-start">Start</button>
          <button id="pauseBtn" type="button" class="action-btn">Pause</button>
          <button id="resetBtn" type="button" class="action-btn">Reset</button>
        </div>
      </section>
    </main>

    <div class="track-section" id="trackSection" aria-hidden="true">
      <div class="crossing crossing-left">
        <div class="gate-arm"></div>
        <div class="signal-head">
          <div class="light light-a"></div>
          <div class="light light-b"></div>
        </div>
        <div class="post"></div>
      </div>

      <div class="crossing crossing-right">
        <div class="gate-arm"></div>
        <div class="signal-head">
          <div class="light light-a"></div>
          <div class="light light-b"></div>
        </div>
        <div class="post"></div>
      </div>

      <div class="train-consist" id="timerTrain">
        <img src={frontUrl} class="t-front" alt="" width="200" height="44" />
        <img src={carUrl}   class="t-car"   alt="" width="196" height="44" />
        <img src={carUrl}   class="t-car"   alt="" width="196" height="44" />
        <img src={carUrl}   class="t-car"   alt="" width="196" height="44" />
        <img src={carUrl}   class="t-car"   alt="" width="196" height="44" />
        <img src={frontUrl} class="t-rear"  alt="" width="200" height="44" />
      </div>

      <!-- Shinkansen concrete ballast base + rails -->
      <div class="ground"></div>
      <div class="rail rail-a"></div>
      <div class="rail rail-b"></div>
    </div>
  </div>
</GameLayout>

<script>
  const MAX_SECONDS     = 3600;
  const DEFAULT_SECONDS = 30;

  const timeDisplay   = document.getElementById("timeDisplay")!;
  const statusText    = document.getElementById("statusText")!;
  const durationInput = document.getElementById("durationInput") as HTMLInputElement;
  const startBtn      = document.getElementById("startBtn")!;
  const pauseBtn      = document.getElementById("pauseBtn")!;
  const resetBtn      = document.getElementById("resetBtn")!;
  const trackSection  = document.getElementById("trackSection")!;
  const timerTrain    = document.getElementById("timerTrain")!;
  const addButtons    = document.querySelectorAll<HTMLButtonElement>(".add-btn");

  const crossingBell = new Audio("/audio/sfx/crossing-bell.mp3");
  crossingBell.preload = "auto";
  const hornSound = new Audio("/audio/sfx/train-horn.mp3");
  hornSound.preload = "auto";
  hornSound.volume = 0.35;

  let remainingSeconds  = DEFAULT_SECONDS;
  let timerId: number | null = null;
  let trainTimerId: number | null = null;
  let trainAnim: Animation | null = null;
  let running           = false;
  let paused            = false;
  let crossingActive    = false;

  const clampSeconds = (value: number | string): number => {
    const n = Number.parseInt(String(value), 10);
    if (!Number.isFinite(n)) return DEFAULT_SECONDS;
    return Math.min(MAX_SECONDS, Math.max(1, n));
  };

  const formatTime = (seconds: number): string => {
    const total = Math.max(0, seconds);
    const m = Math.floor(total / 60);
    const s = total % 60;
    return `${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
  };

  const render = (): void => {
    timeDisplay.textContent = formatTime(remainingSeconds);
    const critical = remainingSeconds > 0 && remainingSeconds <= 5 && running;
    timeDisplay.classList.toggle("critical", critical);
    timeDisplay.classList.toggle("finished", remainingSeconds === 0);
  };

  const addTime = (seconds: number): void => {
    remainingSeconds = Math.min(MAX_SECONDS, remainingSeconds + seconds);
    if (!running) durationInput.value = String(remainingSeconds);
    render();
  };

  const startTrain = (): void => {
    if (trainAnim) trainAnim.cancel();
    // Measure real pixel widths so the start is guaranteed fully off-screen-left.
    const trainWidth = timerTrain.offsetWidth;
    const trackWidth = trackSection.clientWidth;
    const startX = -(trainWidth + 40);   // entire train off the left edge
    const endX   = trackWidth + 40;       // entire train off the right edge
    timerTrain.style.visibility = "visible";
    trainAnim = timerTrain.animate(
      [
        { transform: `translateX(${startX}px)` },
        { transform: `translateX(${endX}px)` },
      ],
      { duration: 3000, easing: "linear", fill: "forwards" }
    );
  };

  const stopTrain = (): void => {
    if (trainAnim) { trainAnim.cancel(); trainAnim = null; }
    timerTrain.style.visibility = "hidden";
  };

  const activateCrossing = (): void => {
    if (crossingActive) return;
    crossingActive = true;
    trackSection.classList.add("crossing-active");
    crossingBell.currentTime = 0;
    crossingBell.play().catch(() => {});
    // Train is launched separately, at 1 s remaining (see the interval below).
  };

  // keepTrain: on natural finish let the train ride out its animation;
  // on pause/reset snap everything back.
  const deactivateCrossing = (keepTrain = false): void => {
    if (!crossingActive) return;
    crossingActive = false;
    if (trainTimerId !== null) { window.clearTimeout(trainTimerId); trainTimerId = null; }
    trackSection.classList.remove("crossing-active");
    if (!keepTrain) stopTrain();
    crossingBell.pause();
    crossingBell.currentTime = 0;
  };

  const stopTimer = (): void => {
    if (timerId !== null) { window.clearInterval(timerId); timerId = null; }
    running = false;
  };

  const startTimer = (): void => {
    if (running) return;
    if (!paused) {
      remainingSeconds = clampSeconds(durationInput.value);
      durationInput.value = String(remainingSeconds);
    }
    running = true;
    paused = false;
    statusText.textContent = "Timer running.";
    render();
    if (remainingSeconds <= 5) activateCrossing();

    timerId = window.setInterval(() => {
      remainingSeconds -= 1;

      if (remainingSeconds <= 5 && remainingSeconds > 0) activateCrossing();
      if (remainingSeconds === 1) {
        // Launch the train half a second into the final second, honking as it appears
        trainTimerId = window.setTimeout(() => {
          startTrain();
          hornSound.play().catch(() => {});
        }, 500);
      }

      if (remainingSeconds <= 0) {
        remainingSeconds = 0;
        render();
        stopTimer();
        deactivateCrossing(true);
        statusText.textContent = "Time is up.";
        return;
      }
      render();
    }, 1000);
  };

  const pauseTimer = (): void => {
    if (!running) return;
    stopTimer();
    deactivateCrossing();
    paused = true;
    statusText.textContent = "Paused.";
    render();
  };

  const resetTimer = (): void => {
    stopTimer();
    deactivateCrossing();
    paused = false;
    remainingSeconds = clampSeconds(durationInput.value);
    statusText.textContent = "Ready.";
    render();
  };

  durationInput.addEventListener("change", () => {
    if (running) return;
    remainingSeconds = clampSeconds(durationInput.value);
    durationInput.value = String(remainingSeconds);
    render();
  });

  addButtons.forEach((btn) => {
    btn.addEventListener("click", () => addTime(Number(btn.dataset.add)));
  });

  startBtn.addEventListener("click", startTimer);
  pauseBtn.addEventListener("click", pauseTimer);
  resetBtn.addEventListener("click", resetTimer);

  render();
</script>

<style>
  /* ── Page ── */
  .timer-page {
    padding: 1.5rem 1.5rem 3rem;
    background: var(--color-bg);
  }

  /* ── Shell card ── */
  .timer-shell {
    width: min(760px, 100%);
    margin: 0 auto;
    background: #ffffff;
    border: 2px solid #cfcfcf;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  /* ── Timer panel — E5 train body ── */
  .timer-panel {
    text-align: center;
    padding: 1.75rem 1.5rem 1.25rem;
    border-bottom: 2px solid #d0d0d0;
    background: #f8f8f6; /* E5 white body */
    position: relative;
    overflow: hidden;
  }

  /* Horizontal stripes running across the panel like the E5 livery */
  .panel-stripe {
    position: absolute;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  .panel-stripe-teal {
    background: #3fbf9f;
    top: 0;
    height: calc(50% + 22px);
  }

  .panel-stripe-pink {
    background: #ee3d77;
    top: calc(50% + 22px);
    height: 8px;
  }

  /* LED destination board housing */
  .led-housing {
    display: inline-block;
    position: relative;
    z-index: 1;
    background: #070707;
    border-radius: 8px;
    padding: 0.85rem 2rem 0.8rem;
    box-shadow: inset 0 2px 12px rgba(0,0,0,0.95);
  }

  .status-text {
    position: relative;
    z-index: 1;
    margin-top: 0.75rem;
    color: #5a5a5a;
    font-size: 0.92rem;
    font-weight: 500;
  }

  /*
    Dot-grid overlay: transparent circles separated by dark grid lines.
    On the glowing text this creates visible circular "pixels" with dark gaps —
    the classic LED dot-matrix look.
  */
  .led-housing::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 5px;
    background-image: radial-gradient(circle, transparent 42%, rgba(0,0,0,0.82) 42%);
    background-size: 5px 5px;
    pointer-events: none;
    z-index: 1;
  }

  /* Header row: train name + destination on one line */
  .led-header {
    display: flex;
    align-items: baseline;
    gap: 1em;
    margin-bottom: 0.3rem;
    position: relative;
    z-index: 2;
  }

  .led-label {
    font-family: 'Dot Gothic 16', monospace;
    font-size: 0.9rem;
    color: #ff7a00;
    letter-spacing: 0.25em;
    text-shadow: 0 0 8px #ff7a00;
    opacity: 0.8;
  }

  .led-dest {
    font-family: 'Dot Gothic 16', monospace;
    font-size: 0.9rem;
    color: #ff9a20;
    letter-spacing: 0.15em;
    text-shadow: 0 0 8px #ff8800;
  }

  .led-time {
    font-family: 'Dot Gothic 16', monospace;
    font-size: clamp(3.5rem, 13vw, 5.5rem);
    color: #ff8c00;
    letter-spacing: 0.08em;
    line-height: 1;
    text-shadow: 0 0 14px #ff8c00, 0 0 30px #ff6600;
    position: relative;
    z-index: 2;
    font-variant-numeric: tabular-nums;
  }

  .led-time.critical {
    color: #ff2060;
    text-shadow: 0 0 14px #ff2060, 0 0 30px #cc0040;
    animation: led-pulse 0.8s ease-in-out infinite;
  }

  .led-time.finished {
    color: #ff2060;
    text-shadow: 0 0 14px #ff2060, 0 0 30px #cc0040;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.55; }
  }

  /* ── Controls ── */
  .controls-panel { padding: 1.25rem; }

  .input-label {
    display: block;
    font-weight: 700;
    color: #1a1a28;
    margin-bottom: 0.35rem;
    font-size: 0.95rem;
  }

  .duration-input {
    width: 100%;
    border: 2px solid #cfcfcf;
    border-radius: 10px;
    padding: 0.65rem 0.75rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a28;
    background: #ffffff;
    transition: border-color 0.15s;
  }

  .duration-input:focus { outline: none; border-color: #3fbf9f; }
  .help-text { color: #5a5a5a; font-size: 0.88rem; margin-top: 0.35rem; }

  .add-buttons {
    margin-top: 0.9rem;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .add-btn {
    border: 2px solid #3fbf9f;
    background: #ffffff;
    color: #3fbf9f;
    border-radius: 8px;
    padding: 0.5rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    font-size: 0.95rem;
  }

  .add-btn:hover { background: #3fbf9f; color: #ffffff; }

  .action-buttons {
    margin-top: 0.85rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
  }

  .action-btn {
    border: 2px solid #3fbf9f;
    background: #ffffff;
    color: #3fbf9f;
    border-radius: 10px;
    padding: 0.65rem 0.5rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .action-btn:hover { background: #3fbf9f; color: #ffffff; }
  .action-start { background: #3fbf9f; color: #ffffff; }
  .action-start:hover { background: #32a989; }

  /* ── Track section ── */
  .track-section {
    position: relative;
    width: min(760px, 100%);
    margin: 0 auto;
    height: 90px;
    overflow: hidden;
  }

  /*
    Shinkansen runs on a concrete slab track (direct fixation),
    no gravel ballast — two rails laid on a continuous concrete bed.
  */
  .ground {
    position: absolute;
    bottom: 0;
    left: 0; right: 0;
    height: 20px;
    background: #c2c2ba;
    border-top: 3px solid #a8a8a0;
  }

  /* Two steel rails on the concrete */
  .rail {
    position: absolute;
    left: 0; right: 0;
    height: 4px;
    background: #888880;
    border-radius: 2px;
  }
  .rail-a { bottom: 30px; }
  .rail-b { bottom: 22px; }

  /* Train */
  .train-consist {
    position: absolute;
    bottom: 20px;
    display: flex;
    align-items: flex-end;
    /* size to the real combined car width, not the shrink-to-fit clamp of the
       absolutely-positioned box (which would otherwise cap at the track width
       and make the train start mid-track) */
    width: max-content;
    transform: translateX(calc(-100% - 80px));
    z-index: 2;
    visibility: hidden; /* never visible at rest — JS drives the crossing animation */
  }

  .t-front, .t-car { display: block; flex-shrink: 0; margin-right: -1px; }
  .t-rear { transform: scaleX(-1); }

  /* ── Crossing signals ── */
  .crossing { position: absolute; bottom: 20px; z-index: 3; }
  .crossing-left  { left: 38%; }
  .crossing-right { right: 38%; }

  .post {
    position: absolute;
    bottom: 0;
    width: 5px;
    height: 52px;
    background: #333;
    border-radius: 2px 2px 0 0;
  }
  .crossing-left  .post { left: 0; }
  .crossing-right .post { right: 0; }

  .signal-head {
    position: absolute;
    bottom: 50px;
    width: 14px;
    height: 28px;
    background: #222;
    border-radius: 3px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-evenly;
    padding: 3px 0;
  }
  .crossing-left  .signal-head { left: -5px; }
  .crossing-right .signal-head { right: -5px; }

  .light { width: 8px; height: 8px; border-radius: 50%; background: #444; }

  .crossing-active .light-a { animation: blink-a 1s step-end infinite; }
  .crossing-active .light-b { animation: blink-b 1s step-end infinite; }

  @keyframes blink-a {
    0%, 49%   { background: #ff2200; box-shadow: 0 0 5px #ff4400; }
    50%, 100% { background: #440000; box-shadow: none; }
  }
  @keyframes blink-b {
    0%, 49%   { background: #440000; box-shadow: none; }
    50%, 100% { background: #ff2200; box-shadow: 0 0 5px #ff4400; }
  }

  .gate-arm {
    position: absolute;
    bottom: 46px;
    height: 7px;
    width: 120px;
    border-radius: 4px;
    transition: transform 0.9s ease-in-out;
  }

  .crossing-left .gate-arm {
    left: 5px;
    transform-origin: left center;
    transform: rotate(-85deg);
    background: repeating-linear-gradient(90deg, #f5d00a 0 10px, #1a1a1a 10px 18px);
  }

  .crossing-right .gate-arm {
    right: 5px;
    transform-origin: right center;
    transform: rotate(85deg);
    background: repeating-linear-gradient(270deg, #f5d00a 0 10px, #1a1a1a 10px 18px);
  }

  .crossing-active .crossing-left .gate-arm  { transform: rotate(0deg); }
  .crossing-active .crossing-right .gate-arm { transform: rotate(0deg); }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .timer-page { padding: 1rem 0.75rem 2rem; }
    .timer-panel { padding: 1.25rem 1rem 1rem; }
    .controls-panel { padding: 1rem; }
    .led-housing { padding: 0.65rem 1rem 0.6rem; }
    .crossing { display: none; }
  }
</style>
