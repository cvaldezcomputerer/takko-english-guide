---
import GameLayout from "../../layouts/GameLayout.astro";
import StrokeLetter from "../../components/StrokeLetter.astro";

// Background alphabet: all 26 letters appear in order, each a random color.
const abcAlpha = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");
const abcPalette = [
  "#e63946", "#2a9d8f", "#457b9d", "#e76f51", "#8338ec",
  "#f4a261", "#43aa8b", "#ef476f", "#118ab2", "#f9844a",
];
const abcColors = abcAlpha.map(
  () => abcPalette[Math.floor(Math.random() * abcPalette.length)],
);
---

<GameLayout title="ABC Order Game">
  <link
    href="https://fonts.googleapis.com/css2?family=Crete+Round&display=swap"
    rel="stylesheet"
  />

  <!-- Back button — fixed, shown on every screen (start / game / win / lose) -->
  <a href="/game" class="back-link" data-astro-reload>← Back</a>

  <!-- START SCREEN -->
  <div id="start-screen" class="screen">
    <div class="deco-letters" aria-hidden="true">
      {abcAlpha.map((L, i) => (
        <div class="deco-cell" style={`--i:${i}`}>
          <StrokeLetter letter={L} color={abcColors[i]} outline="#000" />
        </div>
      ))}
    </div>

    <div class="start-card">
      <h1 class="game-title">ABC ORDER</h1>
      <p class="title-ja">ABC順に並べよう</p>
      <div class="rules">
        <p id="instruction-text">Click the letters in ABC order. You can also use the keyboard.</p>
        <p class="ja" id="instruction-ja">ABC順にクリック、またはキーボードで入力しましょう。</p>
      </div>

      <div class="settings-area">

        <div class="setting-row">
          <span class="setting-label">Difficulty / むずかしさ</span>
          <span class="setting-desc">Higher levels add a timer, flipped letters, and tricks / レベルが上がると制限時間や反転文字などが追加されます</span>
          <div class="opt-group" id="opt-difficulty">
            <button class="opt-btn active" data-value="easy">Easy</button>
            <button class="opt-btn" data-value="medium">Medium</button>
            <button class="opt-btn" data-value="hard">Hard</button>
          </div>
        </div>

        <div class="setting-row">
          <span class="setting-label">Letters / 文字</span>
          <span class="setting-desc">Show capital or lowercase letters / 大文字か小文字で表示します</span>
          <div class="opt-group" id="opt-letters">
            <button class="opt-btn active" data-value="upper">ABC</button>
            <button class="opt-btn" data-value="lower">abc</button>
          </div>
        </div>

        <div class="setting-row">
          <span class="setting-label">Sound / 音</span>
          <span class="setting-desc">Play a note for each correct letter / 正解するたびに音が鳴ります</span>
          <div class="opt-group" id="opt-sound">
            <button class="opt-btn active" data-value="on">On</button>
            <button class="opt-btn" data-value="off">Off</button>
          </div>
        </div>

      </div>

      <button id="start-btn" class="btn">START</button>
    </div>
  </div>

  <!-- WIN SCREEN -->
  <div id="win-screen" class="screen hidden">
    <div class="win-card">
      <p class="win-label">GREAT JOB!</p>
      <p class="win-label-ja">よくできました！</p>
      <p id="win-time" class="win-time hidden">Time / タイム: <span id="win-time-val">0:00</span></p>
      <div id="win-alphabet" class="win-alphabet"></div>
      <button id="play-again-btn" class="btn">PLAY AGAIN</button>
    </div>
  </div>

  <!-- LOSE SCREEN -->
  <div id="lose-screen" class="screen hidden">
    <div class="win-card lose-card">
      <p class="win-label" id="lose-label">GAME OVER</p>
      <p class="win-label-ja" id="lose-label-ja">ゲームオーバー</p>
      <p class="lose-sub">You reached <span id="lose-prog">0</span> / 26</p>
      <button id="retry-btn" class="btn">TRY AGAIN</button>
    </div>
  </div>

  <!-- GAME SCREEN -->
  <div id="game-screen" class="screen hidden">
    <div class="shelf-area">
      <div class="shelf-header">
        <span class="shelf-title">ABC ORDER</span>
        <span id="hud-timer" class="hud-timer hidden">2:00</span>
        <span id="hud-lives" class="hud-lives hidden"></span>
        <span class="progress-text"><span id="prog">0</span> / 26</span>
      </div>
      <div id="shelf" class="shelf"></div>
    </div>
    <div id="play-area" class="play-area"></div>
  </div>
</GameLayout>

<style>
  :global(body) {
    margin: 0;
    padding: 0;
    overflow: hidden;
    background: #faf8f2;
  }

  .screen {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Decorative background alphabet (all 26, appear in order) ─── */
  .deco-letters {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    display: grid;
    /* 3 columns on the left, an empty gutter for the menu, 3 columns on the right */
    grid-template-columns: repeat(3, 1fr) 34% repeat(3, 1fr);
    grid-auto-rows: 1fr;
    place-items: center;
    padding: 3% 2%;
    gap: 0.5rem;
  }

  /* Place each letter so they fill left 3, then right 3, skipping the center gutter */
  .deco-cell:nth-child(6n + 1) { grid-column: 1; }
  .deco-cell:nth-child(6n + 2) { grid-column: 2; }
  .deco-cell:nth-child(6n + 3) { grid-column: 3; }
  .deco-cell:nth-child(6n + 4) { grid-column: 5; }
  .deco-cell:nth-child(6n + 5) { grid-column: 6; }
  .deco-cell:nth-child(6n + 6) { grid-column: 7; }

  .deco-cell {
    width: 52%;
    opacity: 0;
    animation: deco-appear 1.2s ease forwards;
    animation-delay: calc(var(--i) * 0.55s);
  }

  @keyframes deco-appear {
    from { opacity: 0; transform: scale(0.7); }
    to   { opacity: 0.22; transform: scale(1); }
  }

  @media (max-width: 700px) {
    .deco-letters { display: none; }
  }

  /* ─── Back link ─── */
  .back-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-sm);
    background: white;
    border: 2px solid #c5b99a;
    color: #555;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    z-index: 10;
    transition: background 0.15s;
  }

  .back-link:hover {
    background: #f0ece0;
  }

  /* ─── Start Screen ─── */
  .start-card {
    background: white;
    border: 3px solid #c5b99a;
    border-radius: var(--radius-lg);
    padding: 3rem 4rem;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: 520px;
    width: 90%;
    position: relative;
    z-index: 1;
    max-height: 90vh;
    overflow-y: auto;
  }

  .game-title {
    font-family: "Crete Round", serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: #2c3e50;
    letter-spacing: 0.15em;
    margin: 0;
  }

  .title-ja {
    font-size: 1.2rem;
    color: #888;
    margin: 0;
  }

  .rules p {
    margin: 0.2rem 0;
    color: #555;
    font-size: 1rem;
  }

  .rules .ja {
    color: #aaa;
    font-size: 0.9rem;
  }

  .settings-area {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    border-top: 2px solid #ede8de;
    padding-top: 1rem;
    margin-top: 0.25rem;
    text-align: left;
  }

  .setting-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
  }

  .setting-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .setting-desc {
    font-size: 0.78rem;
    color: #999;
    margin-top: -0.1rem;
  }

  .opt-group {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .opt-btn {
    padding: 0.32rem 0.85rem;
    border: 2px solid #ccc5b8;
    border-radius: var(--radius-pill);
    background: #f5f2eb;
    color: #555;
    font-family: inherit;
    font-size: 0.85rem;
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
  }

  .opt-btn.active {
    background: #e76f51;
    border-color: #e76f51;
    color: white;
    font-weight: 600;
  }

  .opt-btn:hover:not(.active) {
    border-color: #a89880;
    color: #333;
    background: #ede8de;
  }

  .btn {
    margin-top: 0.5rem;
    padding: 0.85rem 2.5rem;
    background: #e76f51;
    color: white;
    border: none;
    border-radius: var(--radius-pill);
    font-family: "Crete Round", serif;
    font-size: 1.2rem;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 0.1em;
    box-shadow: 0 4px 0 #b54e35;
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 0 #b54e35;
  }

  .btn:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 #b54e35;
  }

  /* ─── Win Screen ─── */
  .win-card {
    background: white;
    border: 3px solid #c5b99a;
    border-radius: var(--radius-lg);
    padding: 3rem 4rem;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: 600px;
    width: 90%;
  }

  .win-label {
    font-family: "Crete Round", serif;
    font-size: 3rem;
    font-weight: 700;
    color: #2c3e50;
    margin: 0;
    letter-spacing: 0.1em;
  }

  .win-label-ja {
    font-size: 1.3rem;
    color: #888;
    margin: 0;
  }

  .win-time {
    margin: 0;
    font-family: "Crete Round", serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: #4a7c59;
    font-variant-numeric: tabular-nums;
  }

  .win-alphabet {
    font-family: "Crete Round", serif;
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 2;
  }

  /* ─── Game Screen ─── */
  #game-screen {
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
  }

  /* Shelf */
  .shelf-area {
    height: 25vh;
    min-height: 100px;
    background: #f0ece0;
    border-bottom: 3px solid #c5b99a;
    display: flex;
    flex-direction: column;
    padding: 0.4rem 0.75rem 0.5rem;
    box-sizing: border-box;
    gap: 0.3rem;
  }

  .shelf-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-shrink: 0;
  }

  .shelf-title {
    font-family: "Crete Round", serif;
    font-size: 0.75rem;
    font-weight: 700;
    color: #b0a090;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .progress-text {
    font-size: 0.85rem;
    color: #b0a090;
    font-family: system-ui, sans-serif;
    font-variant-numeric: tabular-nums;
  }

  .hud-timer {
    display: inline-block;
    font-family: "Crete Round", serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #4a7c59;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.05em;
  }

  .hud-lives {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  /* .life imgs are created in JS, so they need :global to dodge Astro scoping.
     Transparent cutout — just the floating head, no frame. */
  .hud-lives :global(.life) {
    height: 32px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.35));
    transition: filter 0.2s, opacity 0.2s;
  }

  .hud-lives :global(.life.lost) {
    filter: grayscale(1) drop-shadow(0 1px 1px rgba(0, 0, 0, 0.25));
    opacity: 0.3;
  }

  /* ─── Lose Screen ─── */
  .lose-card {
    border-color: #e76f51;
  }

  .lose-sub {
    font-size: 1.1rem;
    color: #777;
    margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .shelf {
    display: grid;
    grid-template-columns: repeat(13, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: 4px;
    flex: 1;
    min-height: 0;
    align-content: stretch;
  }

  /* Play Area */
  .play-area {
    flex: 1;
    position: relative;
    overflow: hidden;
    background: #faf8f2;
  }

  /* ─── Dynamic elements (created by JS) ─── */
  :global(.shelf-slot) {
    border: 2px dashed #c5b99a;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Crete Round", serif;
    font-weight: 700;
    font-size: clamp(11px, 2.6vw, 28px);
    color: #2c3e50;
    transition:
      background 0.15s,
      border-color 0.15s,
      box-shadow 0.15s;
    overflow: hidden;
  }

  :global(.shelf-slot.next) {
    border-style: solid;
    border-color: #e76f51;
    box-shadow: 0 0 0 2px rgba(231, 111, 81, 0.25);
  }

  :global(.shelf-slot.filled) {
    background: white;
    border-style: solid;
    color: var(--token-color, #2c3e50);
    border-color: var(--token-color, #c5b99a);
  }

  :global(.letter-token) {
    position: absolute;
    transform: translate(-50%, -50%) rotate(var(--tilt, 0deg)) scaleX(var(--flip, 1));
    width: min(14vw, 17vh);
    height: min(14vw, 17vh);
    background: white;
    border: 3px solid var(--token-color, #c5b99a);
    border-radius: min(1.6vw, 2vh);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Crete Round", serif;
    font-weight: 700;
    font-size: 54px;
    color: #2c3e50;
    cursor: pointer;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.1),
      0 3px 0 var(--token-color, #c5b99a);
    padding: 0;
    line-height: 1;
    user-select: none;
    -webkit-user-select: none;
    transition: transform 0.12s;
  }

  :global(.letter-token:hover) {
    transform: translate(-50%, -50%) rotate(var(--tilt, 0deg)) scaleX(var(--flip, 1)) scale(1.1);
  }

  /* ─── Super Hard: spinning tokens ─── */
  :global(.letter-token.spin) {
    animation: token-spin var(--spin-dur, 6s) linear infinite;
    animation-direction: var(--spin-dir, normal);
  }

  @keyframes token-spin {
    from { transform: translate(-50%, -50%) rotate(0deg) scaleX(var(--flip, 1)); }
    to   { transform: translate(-50%, -50%) rotate(360deg) scaleX(var(--flip, 1)); }
  }

  /* ─── Symbol decoys (Super Hard) ─── */
  :global(.symbol-token) {
    color: #9b8c74;
    border-color: #c5b99a;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.1),
      0 3px 0 #c5b99a;
  }

  /* .wrong placed after .spin so the shake overrides the spin while it plays */
  :global(.letter-token.wrong) {
    animation: token-wrong 0.4s ease forwards;
  }

  @keyframes token-wrong {
    0%,
    100% {
      transform: translate(-50%, -50%) rotate(var(--tilt, 0deg)) scaleX(var(--flip, 1));
      background: white;
    }
    15% {
      transform: translate(calc(-50% - 8px), -50%) rotate(var(--tilt, 0deg)) scaleX(var(--flip, 1));
      background: #fecaca;
    }
    35% {
      transform: translate(calc(-50% + 8px), -50%) rotate(var(--tilt, 0deg)) scaleX(var(--flip, 1));
    }
    55% {
      transform: translate(calc(-50% - 5px), -50%) rotate(var(--tilt, 0deg)) scaleX(var(--flip, 1));
      background: #fecaca;
    }
    75% {
      transform: translate(calc(-50% + 5px), -50%) rotate(var(--tilt, 0deg)) scaleX(var(--flip, 1));
    }
    90% {
      transform: translate(calc(-50% - 2px), -50%) rotate(var(--tilt, 0deg)) scaleX(var(--flip, 1));
    }
  }

  :global(.fly-clone) {
    pointer-events: none !important;
    cursor: default !important;
  }

  :global(.letter-token svg) {
    display: block;
    width: 78%;
    height: 78%;
  }

  :global(.shelf-slot svg) {
    display: block;
    width: 90%;
    height: 90%;
  }

  @media (max-width: 600px) {
    .game-title {
      font-size: 2.5rem;
    }
    .win-label {
      font-size: 2.2rem;
    }
    /* token size already responsive via min(vw,vh) — no override needed */
  }
</style>

<script>
  const LETTERS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");
  const COLORS = ["#e76f51", "#2a9d8f", "#e9c46a", "#457b9d", "#8338ec"];

  // ── Settings ───────────────────────────────────────────────────────────────

  const settings = { difficulty: "easy", sound: true, lowercase: false };

  // Per-difficulty modifiers. Easy = original game.
  type Mods = {
    timed: boolean;
    scramble: boolean; // random rotation / flip on tokens
    symbols: number;   // number of symbol decoys
    spin: boolean;     // tokens spin continuously
    lives: number;     // 0 = unlimited (no life system)
  };
  const DIFFICULTY: Record<string, Mods> = {
    easy:   { timed: false, scramble: false, symbols: 0, spin: false, lives: 0 },
    medium: { timed: true,  scramble: true,  symbols: 0, spin: false, lives: 0 },
    hard:   { timed: true,  scramble: true,  symbols: 6, spin: true,  lives: 3 },
  };
  const SYMBOLS = ["#", "@", "&", "%", "?", "*", "!", "+", "="];

  function mods(): Mods {
    return DIFFICULTY[settings.difficulty] ?? DIFFICULTY.easy;
  }

  document.querySelectorAll<HTMLElement>(".opt-group").forEach((group) => {
    group.querySelectorAll<HTMLButtonElement>(".opt-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        group.querySelectorAll(".opt-btn").forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        const v = btn.dataset.value!;
        if (group.id === "opt-difficulty") { settings.difficulty = v; updateInstruction(); }
        if (group.id === "opt-sound")      settings.sound = v === "on";
        if (group.id === "opt-letters")    settings.lowercase = v === "lower";
      });
    });
  });

  // Keyboard input is an easy-mode aid; only mention it when easy is selected.
  const instrEl = document.getElementById("instruction-text");
  const instrJaEl = document.getElementById("instruction-ja");
  function updateInstruction() {
    const easy = settings.difficulty === "easy";
    if (instrEl) instrEl.textContent = easy
      ? "Click the letters in ABC order. You can also use the keyboard."
      : "Click the letters in ABC order.";
    if (instrJaEl) instrJaEl.textContent = easy
      ? "ABC順にクリック、またはキーボードで入力しましょう。"
      : "ABC順にクリックしましょう。";
  }
  updateInstruction();

  import { LETTER_PATHS, LETTER_PATHS_LOWER } from "../../data/letter-paths";

  function makeSVG(letter: string): string {
    // Letters are tracked internally as A–Z; the lowercase toggle only swaps the
    // rendered glyph (filled outlines from LETTER_PATHS_LOWER) without changing logic.
    const lower = settings.lowercase;
    const d = lower
      ? LETTER_PATHS_LOWER[letter.toLowerCase()]
      : LETTER_PATHS[letter];
    if (!d) return letter;
    // Lowercase glyphs share a baseline at y=76. Drawing it on the card lets kids
    // tell p/q/b/d apart even when medium/hard rotates or flips the token: the
    // line transforms with the letter, so descenders always hang below it.
    const baseline = lower
      ? `<line x1="8" y1="76" x2="92" y2="76" stroke="#c5b99a" stroke-width="3" stroke-linecap="round"/>`
      : "";
    return `<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">${baseline}<path d="${d}" fill="currentColor"/></svg>`;
  }

  let currentIndex = 0;
  const tokens: Record<string, HTMLElement> = {};
  const slots: Record<string, HTMLElement> = {};

  function getColor(letter: string): string {
    return COLORS[LETTERS.indexOf(letter) % COLORS.length];
  }

  function generatePositions(
    container: HTMLElement,
    count: number
  ): { x: number; y: number }[] {
    const w = container.offsetWidth;
    const h = container.offsetHeight;

    // Measure actual rendered token size so positions match CSS
    const probe = document.createElement("button") as HTMLButtonElement;
    probe.className = "letter-token";
    probe.style.cssText = "visibility:hidden;pointer-events:none;position:absolute";
    container.appendChild(probe);
    const tokenSize = probe.offsetWidth || 130;
    container.removeChild(probe);

    const HALF = Math.ceil(tokenSize / 2) + 10;
    const spacing = tokenSize * 1.15;
    const COLS = Math.max(5, Math.floor(w / spacing));
    const ROWS = Math.max(4, Math.floor(h / spacing));
    const cellW = w / COLS;
    const cellH = h / ROWS;

    const cells: { r: number; c: number }[] = [];
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        cells.push({ r, c });
      }
    }
    cells.sort(() => Math.random() - 0.5);

    return cells.slice(0, count).map(({ r, c }) => ({
      x: Math.max(
        HALF,
        Math.min(
          w - HALF,
          (c + 0.5) * cellW + (Math.random() - 0.5) * cellW * 0.5
        )
      ),
      y: Math.max(
        HALF,
        Math.min(
          h - HALF,
          (r + 0.5) * cellH + (Math.random() - 0.5) * cellH * 0.5
        )
      ),
    }));
  }

  // ── Audio ──────────────────────────────────────────────────────────────────

  // Both modes use the same verified note mapping (user-confirmed against sheet music).
  // The "classic vs modern" distinction is about pacing (fast LMNOP vs slow),
  // which doesn't apply in a click-based game — so notes are identical.
  //   A–G  : C C G G A A G
  //   H–P  : F F E E D D D D C  (LMNOP = D D D D C)
  //   Q–V  : G G F E E D
  //   W–Z  : G G G F E E D  →  W=G X=F Y=E Z=D
  const SONG_NOTES: Record<string, number> = {
    A: 523.25, B: 523.25, C: 783.99, D: 783.99, E: 880.00, F: 880.00, G: 783.99,
    H: 698.46, I: 698.46, J: 659.25, K: 659.25,
    L: 587.33, M: 587.33, N: 587.33, O: 587.33, P: 523.25,
    Q: 783.99, R: 783.99, S: 698.46, T: 659.25, U: 659.25, V: 587.33,
    W: 783.99, X: 698.46, Y: 659.25, Z: 587.33,
  };

  let audioCtx: AudioContext | null = null;

  function getCtx(): AudioContext {
    if (!audioCtx) audioCtx = new AudioContext();
    if (audioCtx.state === "suspended") audioCtx.resume();
    return audioCtx;
  }

  function playNote(letter: string) {
    if (!settings.sound) return;
    const freq = SONG_NOTES[letter];
    if (!freq) return;
    const ctx = getCtx();
    const now = ctx.currentTime;

    // Triangle wave fundamental — warm, xylophone-like
    const osc1 = ctx.createOscillator();
    const g1 = ctx.createGain();
    osc1.type = "triangle";
    osc1.frequency.setValueAtTime(freq, now);
    g1.gain.setValueAtTime(0.55, now);
    g1.gain.exponentialRampToValueAtTime(0.001, now + 0.9);
    osc1.connect(g1); g1.connect(ctx.destination);
    osc1.start(now); osc1.stop(now + 0.9);

    // Sine at 2× frequency — adds bell shimmer
    const osc2 = ctx.createOscillator();
    const g2 = ctx.createGain();
    osc2.type = "sine";
    osc2.frequency.setValueAtTime(freq * 2, now);
    g2.gain.setValueAtTime(0.2, now);
    g2.gain.exponentialRampToValueAtTime(0.001, now + 0.4);
    osc2.connect(g2); g2.connect(ctx.destination);
    osc2.start(now); osc2.stop(now + 0.4);
  }

  function playWrong() {
    if (!settings.sound) return;
    const ctx = getCtx();
    const now = ctx.currentTime;
    const osc = ctx.createOscillator();
    const g = ctx.createGain();
    osc.type = "sine";
    osc.frequency.setValueAtTime(220, now);
    osc.frequency.exponentialRampToValueAtTime(160, now + 0.18);
    g.gain.setValueAtTime(0.3, now);
    g.gain.exponentialRampToValueAtTime(0.001, now + 0.18);
    osc.connect(g); g.connect(ctx.destination);
    osc.start(now); osc.stop(now + 0.18);
  }

  // ── Timer & lives ────────────────────────────────────────────────────────────

  let timerId: number | null = null;
  let timeElapsed = 0; // seconds, counts up — for future high scores
  let lives = 0;
  let gameActive = false;

  const timerEl = document.getElementById("hud-timer")!;
  const livesEl = document.getElementById("hud-lives")!;
  const backLink = document.querySelector<HTMLElement>(".back-link")!;

  function formatTime(s: number): string {
    const m = Math.floor(s / 60);
    const sec = s % 60;
    return `${m}:${sec.toString().padStart(2, "0")}`;
  }

  function stopTimer() {
    if (timerId !== null) { clearInterval(timerId); timerId = null; }
  }

  function startTimer() {
    timeElapsed = 0;
    timerEl.textContent = formatTime(timeElapsed);
    timerEl.classList.remove("hidden");
    stopTimer();
    timerId = window.setInterval(() => {
      timeElapsed++;
      timerEl.textContent = formatTime(timeElapsed);
    }, 1000);
  }

  function renderLives() {
    livesEl.innerHTML = "";
    const total = mods().lives;
    for (let i = 0; i < total; i++) {
      const img = document.createElement("img");
      img.className = "life" + (i >= lives ? " lost" : "");
      img.src = "/images/selfies/selfie-suit.png"; // transparent cutout
      img.alt = "life";
      livesEl.appendChild(img);
    }
  }

  function loseLife() {
    if (lives <= 0) return;
    lives--;
    renderLives();
    if (lives <= 0) showLose("GAME OVER", "ゲームオーバー");
  }

  // ── Game logic ─────────────────────────────────────────────────────────────

  function updateHighlight() {
    LETTERS.forEach((l, i) => {
      const s = slots[l];
      if (s) s.classList.toggle("next", i === currentIndex);
    });
  }

  function shakeToken(t: HTMLElement) {
    t.classList.remove("wrong");
    void t.offsetWidth;
    t.classList.add("wrong");
    t.addEventListener("animationend", () => t.classList.remove("wrong"), {
      once: true,
    });
  }

  function handleSymbolClick(token: HTMLElement) {
    if (!gameActive) return;
    playWrong();
    shakeToken(token);
    loseLife();
  }

  function handleClick(letter: string) {
    if (!gameActive) return;
    if (letter !== LETTERS[currentIndex]) {
      playWrong();
      shakeToken(tokens[letter]);
      return;
    }
    playNote(letter);
    const t = tokens[letter];
    t.style.pointerEvents = "none";

    // Advance state immediately — next letter is clickable without waiting for animation
    currentIndex++;
    const prog = document.getElementById("prog");
    if (prog) prog.textContent = String(currentIndex);
    if (currentIndex < 26) updateHighlight();

    animateToShelf(letter, t);
  }

  function animateToShelf(letter: string, token: HTMLElement) {
    const tr = token.getBoundingClientRect();
    const slot = slots[letter];
    const sr = slot.getBoundingClientRect();

    const srcCX = tr.left + tr.width / 2;
    const srcCY = tr.top + tr.height / 2;
    const dstCX = sr.left + sr.width / 2;
    const dstCY = sr.top + sr.height / 2;

    const fly = document.createElement("div") as HTMLDivElement;
    fly.className = "letter-token fly-clone";
    fly.innerHTML = token.innerHTML;
    fly.style.setProperty("--token-color", getColor(letter));
    fly.style.position = "fixed";
    fly.style.left = `${srcCX}px`;
    fly.style.top = `${srcCY}px`;
    fly.style.width = `${tr.width}px`;
    fly.style.height = `${tr.height}px`;
    fly.style.zIndex = "9999";
    fly.style.margin = "0";
    // Start at the token's current tilt, will straighten as it flies
    const startTilt = token.dataset.tilt ?? "0";
    fly.style.transform = `translate(-50%, -50%) rotate(${startTilt}deg)`;
    document.body.appendChild(fly);

    token.style.visibility = "hidden";

    // Force reflow before starting transition
    fly.getBoundingClientRect();

    fly.style.transition = [
      "left 0.45s cubic-bezier(0.4,0,0.2,1)",
      "top 0.45s cubic-bezier(0.4,0,0.2,1)",
      "width 0.45s cubic-bezier(0.4,0,0.2,1)",
      "height 0.45s cubic-bezier(0.4,0,0.2,1)",
      "border-radius 0.45s",
      "transform 0.45s cubic-bezier(0.4,0,0.2,1)",
    ].join(", ");

    fly.style.left = `${dstCX}px`;
    fly.style.top = `${dstCY}px`;
    fly.style.width = `${sr.width}px`;
    fly.style.height = `${sr.height}px`;
    fly.style.borderRadius = "5px";
    fly.style.transform = "translate(-50%, -50%) rotate(0deg)";

    fly.addEventListener(
      "transitionend",
      () => {
        fly.remove();
        slot.innerHTML = makeSVG(letter);
        slot.classList.add("filled");
        slot.classList.remove("next");
        slot.style.setProperty("--token-color", getColor(letter));
        if (currentIndex === 26) setTimeout(showWin, 350);
      },
      { once: true }
    );
  }

  // ── Keyboard input ─────────────────────────────────────────────────────────

  let kbHandler: ((e: KeyboardEvent) => void) | null = null;

  function attachKeyboard() {
    if (kbHandler) return;
    kbHandler = (e: KeyboardEvent) => {
      const letter = e.key.toUpperCase();
      if (!/^[A-Z]$/.test(letter)) return;
      const token = tokens[letter];
      if (!token || token.style.visibility === "hidden") return;
      handleClick(letter);
    };
    document.addEventListener("keydown", kbHandler);
  }

  function detachKeyboard() {
    if (kbHandler) { document.removeEventListener("keydown", kbHandler); kbHandler = null; }
  }

  // ── Win / Lose ─────────────────────────────────────────────────────────────

  function showWin() {
    gameActive = false;
    stopTimer();
    detachKeyboard();
    backLink.classList.remove("hidden");
    const winTime = document.getElementById("win-time")!;
    if (mods().timed) {
      document.getElementById("win-time-val")!.textContent = formatTime(timeElapsed);
      winTime.classList.remove("hidden");
    } else {
      winTime.classList.add("hidden");
    }
    const alphaEl = document.getElementById("win-alphabet");
    if (alphaEl) {
      alphaEl.innerHTML = LETTERS.map(
        (l) => `<span style="color:${getColor(l)}">${l}</span>`
      ).join("");
    }
    document.getElementById("game-screen")!.classList.add("hidden");
    document.getElementById("win-screen")!.classList.remove("hidden");
  }

  function showLose(label: string, labelJa: string) {
    if (!gameActive) return; // avoid double-trigger (e.g. timer + lives)
    gameActive = false;
    stopTimer();
    detachKeyboard();
    backLink.classList.remove("hidden");
    document.getElementById("lose-label")!.textContent = label;
    document.getElementById("lose-label-ja")!.textContent = labelJa;
    document.getElementById("lose-prog")!.textContent = String(currentIndex);
    document.getElementById("game-screen")!.classList.add("hidden");
    document.getElementById("lose-screen")!.classList.remove("hidden");
  }

  // Apply rotation / flip / spin to a token based on the active difficulty.
  function applyOrientation(token: HTMLElement, m: Mods) {
    let tilt: number;
    if (m.scramble) {
      // Quarter-turns (incl. upside down) plus jitter → "mixed up" look.
      tilt = Math.floor(Math.random() * 4) * 90 + (Math.random() * 20 - 10);
      if (Math.random() < 0.5) token.style.setProperty("--flip", "-1");
    } else {
      tilt = Math.random() * 40 - 20;
    }
    token.style.setProperty("--tilt", `${tilt.toFixed(1)}deg`);

    if (m.spin) {
      token.classList.add("spin");
      token.style.setProperty("--spin-dur", `${(4 + Math.random() * 4).toFixed(1)}s`);
      token.style.setProperty("--spin-dir", Math.random() < 0.5 ? "normal" : "reverse");
      token.dataset.tilt = "0"; // spinning — fly-out clone just starts upright
    } else {
      token.dataset.tilt = tilt.toFixed(1);
    }
  }

  function init() {
    const m = mods();
    detachKeyboard();
    // Keyboard play is an easy-mode aid only; medium/hard are click-only.
    if (settings.difficulty === "easy") attachKeyboard();
    stopTimer();
    currentIndex = 0;
    gameActive = true;
    Object.keys(tokens).forEach((k) => delete tokens[k]);
    Object.keys(slots).forEach((k) => delete slots[k]);

    const shelf = document.getElementById("shelf")!;
    const playArea = document.getElementById("play-area")!;
    const prog = document.getElementById("prog");

    shelf.innerHTML = "";
    playArea.innerHTML = "";
    if (prog) prog.textContent = "0";

    // Back button is for the menu screens only — hide it while playing.
    backLink.classList.add("hidden");

    // HUD: timer + lives, shown only when the difficulty uses them.
    timerEl.classList.toggle("hidden", !m.timed);
    livesEl.classList.toggle("hidden", m.lives === 0);
    if (m.lives > 0) { lives = m.lives; renderLives(); }

    LETTERS.forEach((l) => {
      const slot = document.createElement("div") as HTMLDivElement;
      slot.className = "shelf-slot";
      shelf.appendChild(slot);
      slots[l] = slot;
    });
    updateHighlight();

    const shuffled = [...LETTERS].sort(() => Math.random() - 0.5);

    requestAnimationFrame(() => {
      const positions = generatePositions(playArea, 26 + m.symbols);
      shuffled.forEach((letter, i) => {
        const token = document.createElement("button") as HTMLButtonElement;
        token.className = "letter-token";
        token.setAttribute("aria-label", `Letter ${letter}`);
        token.innerHTML = makeSVG(letter);
        token.style.setProperty("--token-color", getColor(letter));
        token.style.zIndex = String(LETTERS.length - LETTERS.indexOf(letter));
        applyOrientation(token, m);
        token.style.left = `${positions[i].x}px`;
        token.style.top = `${positions[i].y}px`;
        token.addEventListener("click", () => handleClick(letter));
        playArea.appendChild(token);
        tokens[letter] = token;
      });

      // Symbol decoys (Super Hard) — clicking one costs a life.
      const symbolSet = [...SYMBOLS].sort(() => Math.random() - 0.5).slice(0, m.symbols);
      symbolSet.forEach((sym, i) => {
        const pos = positions[26 + i];
        if (!pos) return;
        const token = document.createElement("button") as HTMLButtonElement;
        token.className = "letter-token symbol-token";
        token.setAttribute("aria-label", "Wrong symbol");
        token.textContent = sym;
        applyOrientation(token, m);
        token.style.left = `${pos.x}px`;
        token.style.top = `${pos.y}px`;
        token.addEventListener("click", () => handleSymbolClick(token));
        playArea.appendChild(token);
      });

      if (m.timed) startTimer();
    });
  }

  document.getElementById("start-btn")!.addEventListener("click", () => {
    document.getElementById("start-screen")!.classList.add("hidden");
    document.getElementById("game-screen")!.classList.remove("hidden");
    init();
  });

  document.getElementById("play-again-btn")!.addEventListener("click", () => {
    document.getElementById("win-screen")!.classList.add("hidden");
    document.getElementById("game-screen")!.classList.remove("hidden");
    init();
  });

  document.getElementById("retry-btn")!.addEventListener("click", () => {
    document.getElementById("lose-screen")!.classList.add("hidden");
    document.getElementById("game-screen")!.classList.remove("hidden");
    init();
  });

</script>
