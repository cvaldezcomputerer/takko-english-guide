</GameLayout>

<style>
  :global(body) {
    margin: 0;
    padding: 0;
    overflow: hidden;
    background: #faf8f2;
  }

  .screen {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Decorative side letters ─── */
  .deco-letters {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .deco-svg {
    position: absolute;
    opacity: 0.18;
  }

  .deco-a {
    width: 120px;
    height: 120px;
    left: 5%;
    top: 18%;
  }

  .deco-b {
    width: 130px;
    height: 130px;
    right: 4%;
    top: 28%;
  }

  .deco-c {
    width: 110px;
    height: 110px;
    left: 6%;
    bottom: 18%;
  }

  @media (max-width: 700px) {
    .deco-letters { display: none; }
  }

  /* shared stroke base */
  .a-s1, .a-s2, .a-s3,
  .b-s1, .b-s2, .b-s3,
  .c-s1 {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }

  /* ── A ── */
  .a-s1 { animation: a1 6s ease-in-out infinite; }
  .a-s2 { animation: a2 6s ease-in-out infinite; }
  .a-s3 { animation: a3 6s ease-in-out infinite; }
  @keyframes a1 {
    0%  { stroke-dashoffset: 1; }  20% { stroke-dashoffset: 0; }
    78% { stroke-dashoffset: 0; }  96% { stroke-dashoffset: 1; }
  }
  @keyframes a2 {
    0%  { stroke-dashoffset: 1; }  20% { stroke-dashoffset: 1; }
    40% { stroke-dashoffset: 0; }  78% { stroke-dashoffset: 0; }
    96% { stroke-dashoffset: 1; }
  }
  @keyframes a3 {
    0%  { stroke-dashoffset: 1; }  40% { stroke-dashoffset: 1; }
    52% { stroke-dashoffset: 0; }  78% { stroke-dashoffset: 0; }
    96% { stroke-dashoffset: 1; }
  }

  /* ── B (staggered start) ── */
  .b-s1 { animation: b1 6s ease-in-out infinite; animation-delay: -2s; }
  .b-s2 { animation: b2 6s ease-in-out infinite; animation-delay: -2s; }
  .b-s3 { animation: b3 6s ease-in-out infinite; animation-delay: -2s; }
  @keyframes b1 {
    0%  { stroke-dashoffset: 1; }  19% { stroke-dashoffset: 0; }
    78% { stroke-dashoffset: 0; }  96% { stroke-dashoffset: 1; }
  }
  @keyframes b2 {
    0%  { stroke-dashoffset: 1; }  19% { stroke-dashoffset: 1; }
    38% { stroke-dashoffset: 0; }  78% { stroke-dashoffset: 0; }
    96% { stroke-dashoffset: 1; }
  }
  @keyframes b3 {
    0%  { stroke-dashoffset: 1; }  38% { stroke-dashoffset: 1; }
    57% { stroke-dashoffset: 0; }  78% { stroke-dashoffset: 0; }
    96% { stroke-dashoffset: 1; }
  }

  /* ── C (staggered start) ── */
  .c-s1 { animation: c1 6s ease-in-out infinite; animation-delay: -4s; }
  @keyframes c1 {
    0%  { stroke-dashoffset: 1; }  57% { stroke-dashoffset: 0; }
    78% { stroke-dashoffset: 0; }  96% { stroke-dashoffset: 1; }
  }

  /* ─── Back link ─── */
  .back-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    padding: 0.35rem 0.85rem;
    border-radius: 8px;
    background: white;
    border: 2px solid #c5b99a;
