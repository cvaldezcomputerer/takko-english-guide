---
import GameLayout from "../../layouts/GameLayout.astro";
---

<GameLayout title="ABC Order Game">
  <link
    href="https://fonts.googleapis.com/css2?family=Crete+Round&display=swap"
    rel="stylesheet"
  />

  <!-- START SCREEN -->
  <div id="start-screen" class="screen">
    <a href="/game" class="back-link" data-astro-reload>← Back</a>

    <div class="deco-letters" aria-hidden="true">
      <svg class="deco-svg deco-a" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <path d="M 23,91 L 50,8" fill="none" stroke="#e76f51" stroke-width="11" stroke-linecap="round" stroke-linejoin="round" pathLength="1" class="a-s1" />
        <path d="M 50,8 L 77,91" fill="none" stroke="#e76f51" stroke-width="11" stroke-linecap="round" stroke-linejoin="round" pathLength="1" class="a-s2" />
        <path d="M 32,62 L 68,62" fill="none" stroke="#e76f51" stroke-width="11" stroke-linecap="round" pathLength="1" class="a-s3" />
      </svg>
      <svg class="deco-svg deco-b" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <path d="M 29,8 L 29,91" fill="none" stroke="#e76f51" stroke-width="11" stroke-linecap="round" stroke-linejoin="round" pathLength="1" class="b-s1" />
        <path d="M 29,8 C 52,7 68,10 68,25 C 68,40 52,43 29,42" fill="none" stroke="#e76f51" stroke-width="11" stroke-linecap="round" stroke-linejoin="round" pathLength="1" class="b-s2" />
        <path d="M 29,52 C 53,50 70,55 70,71.5 C 70,88 53,93 29,91" fill="none" stroke="#e76f51" stroke-width="11" stroke-linecap="round" stroke-linejoin="round" pathLength="1" class="b-s3" />
      </svg>
      <svg class="deco-svg deco-c" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <path d="M 74,28 A 29,29 0 1 0 74,70" fill="none" stroke="#e76f51" stroke-width="11" stroke-linecap="round" stroke-linejoin="round" pathLength="1" class="c-s1" />
      </svg>
    </div>

    <div class="start-card">
      <h1 class="game-title">ABC ORDER</h1>
      <p class="title-ja">ABC順に並べよう</p>
      <div class="rules">
        <p id="instruction-text">Click the letters in ABC order. You can also use the keyboard.</p>
        <p class="ja" id="instruction-ja">ABC順にクリック、またはキーボードで入力しましょう。</p>
      </div>

      <div class="settings-area">

        <div class="setting-row">
          <span class="setting-label">Difficulty / むずかしさ</span>
          <span class="setting-desc">How many letters appear on screen at once / 一度に表示される文字数</span>
          <div class="opt-group" id="opt-difficulty">
            <button class="opt-btn active" data-value="easy">Easy</button>
            <button class="opt-btn" data-value="normal">Normal</button>
            <button class="opt-btn" data-value="hard">Hard</button>
            <button class="opt-btn" data-value="super">Super</button>
          </div>
        </div>

        <div class="setting-row">
          <span class="setting-label">Sound / 音</span>
          <span class="setting-desc">Play a note for each correct letter / 正解するたびに音が鳴ります</span>
          <div class="opt-group" id="opt-sound">
            <button class="opt-btn active" data-value="on">On</button>
            <button class="opt-btn" data-value="off">Off</button>
          </div>
        </div>

        <!-- SVG comparison grid A–G -->
        <div class="setting-row">
          <span class="setting-label">Style Comparison / スタイル比較</span>
          <div class="cmp-grid" aria-hidden="true">
            <span class="cmp-row-label"></span>
            <span class="cmp-col-hdr">A</span><span class="cmp-col-hdr">B</span><span class="cmp-col-hdr">C</span><span class="cmp-col-hdr">D</span><span class="cmp-col-hdr">E</span><span class="cmp-col-hdr">F</span><span class="cmp-col-hdr">G</span>

            <span class="cmp-row-label">Old</span>
