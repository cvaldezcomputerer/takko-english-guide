---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import T from '../components/T.astro';
import { GARLIC_SILO_PATH } from '../data/garlic';

// ── Speaker icon (reused on the question + every word card) ──
const SPEAKER = `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 9v6h4l5 5V4L8 9H4z" fill="currentColor"/><path d="M16.5 8.5a4.5 4.5 0 0 1 0 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>`;
const MAGNIFY = `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5" fill="currentColor"/><line x1="10.5" y1="7.5" x2="10.5" y2="13.5" stroke="#fff" stroke-width="2" stroke-linecap="round"/><line x1="7.5" y1="10.5" x2="13.5" y2="10.5" stroke="#fff" stroke-width="2" stroke-linecap="round"/><line x1="15.5" y1="15.5" x2="21" y2="21" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>`;

// Word art lives in /public/images/weather/ (irasutoya .webp, one per word).
const IMG_BASE = '/images/weather';

const weatherWords = [
    { word: 'sunny',         en: 'sunny',         ja: 'はれ' },
    { word: 'partly_cloudy', en: 'partly cloudy', ja: 'はれときどきくもり' },
    { word: 'cloudy',        en: 'cloudy',        ja: 'くもり' },
    { word: 'rainy',         en: 'rainy',         ja: 'あめ' },
    { word: 'snowy',         en: 'snowy',         ja: 'ゆき' },
    { word: 'windy',         en: 'windy',         ja: 'かぜ' },
];

const feelingWords = [
    { word: 'hot',  en: 'hot',  ja: 'あつい' },
    { word: 'warm', en: 'warm', ja: 'あたたかい' },
    { word: 'cool', en: 'cool', ja: 'すずしい' },
    { word: 'cold', en: 'cold', ja: 'さむい' },
];
---

<Layout
    title="How's the Weather? — TakkoTaco"
    description="A daily warm-up for English class: how's the weather today, and how does it feel?"
>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600&family=Patrick+Hand&display=swap" rel="stylesheet">

    <div class="weather-body">
        <Navbar />

        <main class="weather-main">
            <!-- Clickable question (plays the teacher's voice) -->
            <header class="weather-head">
                <button class="question" id="question-btn" data-audio="/audio/weather/how-is-the-weather.mp3" data-say="How's the weather today?">
                    <span class="question-text">
                        <T>
                            <span slot="en">How's the weather today?</span>
                            <span slot="ja">きょうの天気はどうですか？</span>
                        </T>
                    </span>
                    <span class="question-speaker" set:html={SPEAKER}></span>
                </button>
            </header>

            <!-- Answer sentence with drop slots -->
            <div class="answers">
                <div class="answer-line">
                <div class="answer-row">
                    <p class="sentence">
                        <span class="sentence-start">It's</span>
                        <span class="drop-slot" data-accept="weather">
                            <span class="slot-hint">
                                <T><span slot="en">drag here</span><span slot="ja">ここへ</span></T>
                            </span>
                        </span>
                        <span class="sentence-word">and</span>
                        <span class="drop-slot" data-accept="feeling">
                            <span class="slot-hint">
                                <T><span slot="en">drag here</span><span slot="ja">ここへ</span></T>
                            </span>
                        </span>
                        <span class="sentence-end">.</span>
                    </p>
                </div>
                <div class="sentence-actions">
                    <button class="sentence-play" id="sentence-play" disabled aria-label="Read the sentence">
                        <span class="sp-icon" set:html={SPEAKER}></span>
                        <T><span slot="en">Read it</span><span slot="ja">読んでみよう</span></T>
                    </button>
                    <button class="sentence-big" id="sentence-big" disabled aria-label="Write it big">
                        <span class="sb-icon" set:html={MAGNIFY}></span>
                        <T><span slot="en">Big</span><span slot="ja">おおきく</span></T>
                    </button>
                </div>
                </div>
            </div>

            <!-- Word bank -->
            <div class="banks">
                <section class="bank-group">
                    <div class="word-bank" data-category="weather">
                        {weatherWords.map((w, i) => (
                            <div class="word-card" data-category="weather" data-order={i}>
                                <span class="card-icon">
                                    <img src={`${IMG_BASE}/${w.word}.webp`} alt="" loading="lazy" onerror="this.classList.add('img-missing')" />
                                </span>
                                <span class="card-label">
                                    <T><span slot="en">{w.en}</span><span slot="ja">{w.ja}</span></T>
                                </span>
                                <button class="play-btn card-play" data-audio={`/audio/weather/${w.word}.mp3`} data-say={w.en} aria-label={`Play ${w.en}`} set:html={SPEAKER}></button>
                            </div>
                        ))}
                    </div>
                </section>

                <div class="bank-divider" aria-hidden="true">
                    <span class="bank-div-line"></span>
                    <svg viewBox="120 140 780 750" class="bank-div-icon" xmlns="http://www.w3.org/2000/svg"><path d={GARLIC_SILO_PATH} fill="currentColor"/></svg>
                    <svg viewBox="120 140 780 750" class="bank-div-icon" xmlns="http://www.w3.org/2000/svg"><path d={GARLIC_SILO_PATH} fill="currentColor"/></svg>
                    <svg viewBox="120 140 780 750" class="bank-div-icon" xmlns="http://www.w3.org/2000/svg"><path d={GARLIC_SILO_PATH} fill="currentColor"/></svg>
                    <span class="bank-div-line"></span>
                </div>

                <section class="bank-group">
                    <div class="word-bank" data-category="feeling">
                        {feelingWords.map((w, i) => (
                            <div class="word-card" data-category="feeling" data-order={i}>
                                <span class="card-icon">
                                    <img src={`${IMG_BASE}/${w.word}.webp`} alt="" loading="lazy" onerror="this.classList.add('img-missing')" />
                                </span>
                                <span class="card-label">
                                    <T><span slot="en">{w.en}</span><span slot="ja">{w.ja}</span></T>
                                </span>
                                <button class="play-btn card-play" data-audio={`/audio/weather/${w.word}.mp3`} data-say={w.en} aria-label={`Play ${w.en}`} set:html={SPEAKER}></button>
                            </div>
                        ))}
                    </div>
                </section>
            </div>
        </main>

        <!-- Writing modal (centered card with backdrop) -->
        <div class="big-modal" id="big-modal" hidden aria-modal="true" role="dialog">
            <div class="big-card">
                <button class="big-close" id="big-close" aria-label="Close">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                        <line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    </svg>
                </button>
                <div class="big-stage" id="big-stage"></div>
            </div>
        </div>

        <!-- Audio-not-ready note -->
        <div class="toast" id="audio-toast" role="status" aria-live="polite">
            <T>
                <span slot="en">Voice not available</span>
                <span slot="ja">音声を再生できません</span>
            </T>
        </div>
    </div>
</Layout>

<script>
    import { LETTER_PATHS, LETTER_PATHS_LOWER } from '../data/letter-paths';
    import { speakMii, speakPlain, isMiiVoiceOn, playClip, playFromEl } from '../lib/speak';

    // ── Audio ──
    const toast = document.getElementById('audio-toast');
    let toastTimer: number | undefined;
    function showToast() {
        if (!toast) return;
        toast.classList.add('show');
        clearTimeout(toastTimer);
        toastTimer = window.setTimeout(() => toast.classList.remove('show'), 2200);
    }
    const play = (el: HTMLElement) => playFromEl(el, showToast);

    // Question + every word's speaker button
    document.getElementById('question-btn')?.addEventListener('click', (e) => {
        play(e.currentTarget as HTMLElement);
    });
    document.querySelectorAll<HTMLButtonElement>('.play-btn').forEach((btn) => {
        btn.addEventListener('pointerdown', (e) => e.stopPropagation());
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            play(btn);
        });
    });

    // ── Drag & drop (pointer events → works with mouse and touch) ──
    const bankByCategory: Record<string, HTMLElement> = {};
    document.querySelectorAll<HTMLElement>('.word-bank').forEach((bank) => {
        bankByCategory[bank.dataset.category ?? ''] = bank;
    });
    const slots = Array.from(document.querySelectorAll<HTMLElement>('.drop-slot'));
    const slotByCategory: Record<string, HTMLElement> = {};
    slots.forEach((s) => { slotByCategory[s.dataset.accept ?? ''] = s; });

    const CLICK_THRESHOLD = 6;   // px of movement below which a quick release counts as a click
    const DRAG_HOLD_MS = 100;    // press-and-hold this long to pick a card up for dragging
    let dragEl: HTMLElement | null = null;
    let dragActive = false;
    let holdTimer: number | undefined;
    let originSlot: HTMLElement | null = null;
    let offsetX = 0;
    let offsetY = 0;
    let startX = 0;
    let startY = 0;
    let lastX = 0;
    let lastY = 0;
    let ghostEl: HTMLElement | null = null;

    function removeGhost() {
        ghostEl?.remove();
        ghostEl = null;
    }

    function insertSorted(bank: HTMLElement, card: HTMLElement) {
        const order = Number(card.dataset.order ?? 0);
        const after = Array.from(bank.querySelectorAll<HTMLElement>('.word-card'))
            .find((c) => Number(c.dataset.order ?? 0) > order);
        bank.insertBefore(card, after ?? null);
    }

    // While a card lives in a slot, a faded clone holds its place in the bank
    // so the bank never reshuffles (whether the card was clicked or dragged there).
    const homeGhosts = new Map<HTMLElement, HTMLElement>();

    function makeHomeGhost(card: HTMLElement) {
        if (homeGhosts.has(card)) return;
        const bank = bankByCategory[card.dataset.category ?? ''];
        if (!bank) return;
        const ghost = card.cloneNode(true) as HTMLElement;
        ghost.classList.add('card-ghost');
        ghost.classList.remove('arming', 'dragging');
        ghost.dataset.order = card.dataset.order;
        insertSorted(bank, ghost);
        homeGhosts.set(card, ghost);
    }

    function removeHomeGhost(card: HTMLElement) {
        homeGhosts.get(card)?.remove();
        homeGhosts.delete(card);
    }

    function returnCard(card: HTMLElement) {
        removeHomeGhost(card);
        const bank = bankByCategory[card.dataset.category ?? ''];
        if (bank) insertSorted(bank, card);
    }

    function clearSlot(slot: HTMLElement) {
        const existing = slot.querySelector<HTMLElement>('.word-card:not(.card-ghost)');
        if (existing) returnCard(existing);
        slot.classList.remove('filled');
    }

    function placeInSlot(card: HTMLElement, slot: HTMLElement) {
        clearSlot(slot);
        makeHomeGhost(card);
        slot.appendChild(card);
        slot.classList.add('filled');
    }

    function slotUnderPoint(x: number, y: number): HTMLElement | null {
        for (const slot of slots) {
            const r = slot.getBoundingClientRect();
            if (x >= r.left && x <= r.right && y >= r.top && y <= r.bottom) return slot;
        }
        return null;
    }

    function highlight(active: HTMLElement | null, category: string) {
        slots.forEach((s) => {
            const ok = s === active && s.dataset.accept === category;
            s.classList.toggle('drop-hover', ok);
        });
    }

    // Promote a held card into an actual drag: lift it out of flow under the pointer.
    function activateDrag() {
        if (!dragEl || dragActive) return;
        const card = dragEl;
        dragActive = true;
        card.classList.remove('arming');

        const r = card.getBoundingClientRect();
        offsetX = lastX - r.left;
        offsetY = lastY - r.top;

        // Keep the original spot occupied by a faded clone while dragging.
        if (originSlot) {
            // dragging out of a slot: hold the slot with a temporary ghost
            const ghost = card.cloneNode(true) as HTMLElement;
            ghost.classList.add('card-ghost');
            ghost.classList.remove('arming', 'dragging');
            originSlot.insertBefore(ghost, card);
            ghostEl = ghost;
        } else {
            // dragging out of the bank: its persistent home ghost holds the spot
            makeHomeGhost(card);
        }

        card.style.width = `${r.width}px`;
        card.style.left = `${r.left}px`;
        card.style.top = `${r.top}px`;
        card.classList.add('dragging');
        document.body.appendChild(card);

        // show where this word goes back to
        bankByCategory[card.dataset.category ?? '']?.classList.add('bank-return');
    }

    function endInteraction() {
        removeGhost();
        clearTimeout(holdTimer);
        holdTimer = undefined;
        window.removeEventListener('pointermove', onPointerMove);
        window.removeEventListener('pointerup', onPointerUp);
        dragEl = null;
        dragActive = false;
        originSlot = null;
        updateSentenceButton();
    }

    function onPointerMove(e: PointerEvent) {
        if (!dragEl) return;
        lastX = e.clientX;
        lastY = e.clientY;
        if (dragActive) {
            dragEl.style.left = `${e.clientX - offsetX}px`;
            dragEl.style.top = `${e.clientY - offsetY}px`;
            highlight(slotUnderPoint(e.clientX, e.clientY), dragEl.dataset.category ?? '');
        }
    }

    function onPointerUp(e: PointerEvent) {
        if (!dragEl) return;
        const card = dragEl;
        const category = card.dataset.category ?? '';

        if (dragActive) {
            // released after a real drag → drop on a matching slot, else send home
            removeGhost();
            if (originSlot) originSlot.classList.remove('filled');
            card.classList.remove('dragging');
            card.style.left = card.style.top = card.style.width = '';
            const target = slotUnderPoint(e.clientX, e.clientY);
            if (target && target.dataset.accept === category) placeInSlot(card, target);
            else returnCard(card);
            highlight(null, category);
            bankByCategory[category]?.classList.remove('bank-return');
        } else {
            // released before the hold armed → treat a still press as a click toggle
            card.classList.remove('arming');
            const isClick = Math.hypot(e.clientX - startX, e.clientY - startY) < CLICK_THRESHOLD;
            if (isClick) {
                if (originSlot) {
                    originSlot.classList.remove('filled');
                    returnCard(card);               // in a slot → snap down to the bank
                } else {
                    const slot = slotByCategory[category];
                    if (slot) placeInSlot(card, slot); // in the bank → snap up into its slot
                }
            }
        }

        endInteraction();
    }

    function onPointerDown(e: PointerEvent) {
        const card = (e.target as HTMLElement).closest<HTMLElement>('.word-card');
        if (!card || (e.button !== undefined && e.button !== 0)) return;
        e.preventDefault();

        originSlot = card.parentElement?.classList.contains('drop-slot')
            ? card.parentElement
            : null;

        startX = lastX = e.clientX;
        startY = lastY = e.clientY;
        dragEl = card;
        dragActive = false;

        // arm: hold long enough and it lifts into a drag (a quick release = click)
        card.classList.add('arming');
        clearTimeout(holdTimer);
        holdTimer = window.setTimeout(activateDrag, DRAG_HOLD_MS);

        window.addEventListener('pointermove', onPointerMove);
        window.addEventListener('pointerup', onPointerUp);
    }

    document.querySelectorAll<HTMLElement>('.word-card').forEach((card) => {
        card.addEventListener('pointerdown', onPointerDown);
    });

    // ── "Read it" + "Big" buttons: active once both slots are filled ──
    const sentenceBtn = document.getElementById('sentence-play') as HTMLButtonElement | null;
    const bigBtn = document.getElementById('sentence-big') as HTMLButtonElement | null;

    function placedWord(category: string): string {
        const card = slotByCategory[category]?.querySelector<HTMLElement>('.word-card:not(.card-ghost)');
        return card?.querySelector<HTMLElement>('.card-play')?.dataset.say ?? '';
    }

    function placedAudio(category: string): string {
        const card = slotByCategory[category]?.querySelector<HTMLElement>('.word-card:not(.card-ghost)');
        return card?.querySelector<HTMLElement>('.card-play')?.dataset.audio ?? '';
    }

    function updateSentenceButton() {
        if (!sentenceBtn) return;
        const ready = !!(placedWord('weather') && placedWord('feeling'));
        sentenceBtn.disabled = !ready;
        if (bigBtn) bigBtn.disabled = !ready;
    }

    sentenceBtn?.addEventListener('click', async () => {
        const sentence = `It's ${placedWord('weather')} and ${placedWord('feeling')}.`;
        if (isMiiVoiceOn()) { if (!speakMii(sentence)) showToast(); return; }
        const wAudio = placedAudio('weather');
        const fAudio = placedAudio('feeling');
        if (wAudio && fAudio) {
            await playClip('/audio/weather/its.mp3');
            await playClip(wAudio);
            await playClip('/audio/weather/and.mp3');
            await playClip(fAudio);
        } else if (!speakPlain(sentence)) {
            showToast();
        }
    });

    updateSentenceButton();

    // ── "Big" writing modal (same SVG system as name-writer) ──────────────────
    const bigModal = document.getElementById('big-modal') as HTMLElement | null;
    const bigClose = document.getElementById('big-close') as HTMLButtonElement | null;
    const bigStage = document.getElementById('big-stage') as HTMLElement | null;

    const BSVG = 'http://www.w3.org/2000/svg';
    const B_PAD = 24, B_GAP = 12, B_SPW = 34, B_STROKE = 9;
    // Writing-guide lines (same metrics as the lowercase letters / name-writer):
    // ascender top, x-height top, baseline, descender bottom.
    const B_ASC = 10, B_XH = 39, B_BASE = 76, B_DESC = 96;

    function bGlyph(ch: string): SVGGElement | null {
        // Prefer the exact-case glyph: lowercase from LETTER_PATHS_LOWER, capitals
        // from LETTER_PATHS. Fall back to the capital so unknown cases still draw.
        const d = LETTER_PATHS_LOWER[ch] ?? LETTER_PATHS[ch] ?? LETTER_PATHS[ch.toUpperCase()];
        if (!d) return null;
        const g = document.createElementNS(BSVG, 'g');
        const p = document.createElementNS(BSVG, 'path');
        p.setAttribute('d', d);
        p.setAttribute('fill', '#333');
        g.appendChild(p);
        return g;
    }

    function bPunct(d: string, advanceX: number): (svg: SVGSVGElement, x: number) => number {
        return (svg, x) => {
            const g = document.createElementNS(BSVG, 'g');
            const p = document.createElementNS(BSVG, 'path');
            p.setAttribute('d', d);
            p.setAttribute('fill', 'none');
            p.setAttribute('stroke', '#333');
            p.setAttribute('stroke-width', String(B_STROKE));
            p.setAttribute('stroke-linecap', 'round');
            p.setAttribute('stroke-linejoin', 'round');
            g.appendChild(p);
            svg.appendChild(g);
            // Place by known center x=50 in path coords; advance by explicit width
            g.setAttribute('transform', `translate(${x - 50} 0)`);
            return x + advanceX + B_GAP;
        };
    }
    // Period: zero-length path with round cap = perfect circle dot at the baseline
    const placePeriod = bPunct('M 50,71.5 L 50,71.5', B_STROKE);
    // Apostrophe: short diagonal comma-like stroke above the x-height
    // advanceX is negative to cancel most of B_GAP — apostrophes hug the next letter
    const placeApostrophe = bPunct('M 52,10 L 49,22', -5);

    const isCap = (ch: string) => ch >= 'A' && ch <= 'Z';

    function bRow(svg: SVGSVGElement, text: string): number {
        let x = B_PAD;
        for (const ch of text) {
            if (ch === ' ') { x += B_SPW; continue; }
            if (ch === '.') { x = placePeriod(svg, x); continue; }
            if (ch === "'") { x = placeApostrophe(svg, x); continue; }
            const g = bGlyph(ch);
            if (!g) continue;
            svg.appendChild(g);
            const bb = g.getBBox();
            if (isCap(ch)) {
                // Capitals are authored full-box (top ≈ascender, bottom below the
                // baseline). Scale them into the ascender→baseline band and sit them
                // on the red baseline so they line up with the lowercase glyphs.
                const s = (B_BASE - B_ASC) / bb.height;
                const tx = x - bb.x * s;
                const ty = B_BASE - (bb.y + bb.height) * s;
                g.setAttribute('transform', `translate(${tx} ${ty}) scale(${s})`);
                x += bb.width * s + B_GAP;
            } else {
                g.setAttribute('transform', `translate(${x - bb.x} 0)`);
                x += bb.width + B_GAP;
            }
        }
        return Math.max(x - B_GAP + B_PAD, 160);
    }

    // Build the 4 writing-guide lines as one <g>, sized to the row width.
    function bGuides(w: number): SVGGElement {
        const g = document.createElementNS(BSVG, 'g');
        const add = (y: number, dashed: boolean) => {
            const line = document.createElementNS(BSVG, 'line');
            line.setAttribute('x1', '0');
            line.setAttribute('x2', String(w));
            line.setAttribute('y1', String(y));
            line.setAttribute('y2', String(y));
            line.setAttribute('stroke', dashed ? '#c9b6a0' : '#b34a3a');
            line.setAttribute('stroke-width', dashed ? '1' : '1.4');
            if (dashed) line.setAttribute('stroke-dasharray', '4 5');
            g.appendChild(line);
        };
        add(B_ASC, true);   // ascender (top, dashed)
        add(B_XH, true);    // x-height (dashed)
        add(B_BASE, false); // baseline (solid red)
        add(B_DESC, true);  // descender (bottom, dashed)
        return g;
    }

    function drawBig() {
        if (!bigStage) return;
        const text = `It's ${placedWord('weather')} and ${placedWord('feeling')}.`;
        const svg = document.createElementNS(BSVG, 'svg');
        svg.setAttribute('class', 'big-svg');
        svg.setAttribute('viewBox', '0 0 100 100');
        bigStage.replaceChildren(svg);
        const W = bRow(svg, text);
        // Insert guides as the first child so they render behind the letters.
        svg.insertBefore(bGuides(W), svg.firstChild);
        svg.setAttribute('viewBox', `0 0 ${W} 100`);
    }

    bigBtn?.addEventListener('click', () => {
        bigModal?.removeAttribute('hidden');  // must be visible before drawBig so getBBox works
        drawBig();
        bigClose?.focus();
    });

    const closeBigModal = () => {
        bigModal?.setAttribute('hidden', '');
        bigBtn?.focus();
    };
    bigClose?.addEventListener('click', closeBigModal);
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && bigModal && !bigModal.hasAttribute('hidden')) closeBigModal();
    });
</script>

<style>
    /* The whole tool is sized to fit one screen — no scrolling in class. */
    .weather-body {
        background: var(--color-bg);
        font-family: var(--font-main);
        color: var(--color-text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        border-bottom: 8px solid var(--color-primary);
    }

    .weather-main {
        flex: 1;
        width: 100%;
        max-width: 1100px;
        margin: 0 auto;
        padding: clamp(1rem, 2.5vh, 2.25rem) clamp(1rem, 3vw, 2.5rem);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: clamp(1rem, 3vh, 2.5rem);
    }

    /* ── Clickable question ── */
    .weather-head { text-align: center; }

    .question {
        display: inline-flex;
        align-items: center;
        gap: clamp(0.5rem, 1.2vw, 1rem);
        margin: 0 auto;
        border: none;
        background: none;
        cursor: pointer;
        font-family: var(--font-main);
        font-weight: 600;
        color: var(--color-primary);
        line-height: 1.15;
        padding: 0.2rem 0.4rem;
        transition: transform 0.12s, color var(--transition-fast);
    }
    .question-text {
        font-size: clamp(1.7rem, 5vw, 3.4rem);
        border-bottom: 3px dashed transparent;
    }
