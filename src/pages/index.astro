---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import AnimatedLogo from '../components/AnimatedLogo.astro';
import T from '../components/T.astro';

const SHEET_CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vT2r7rHiUTy7tfJNkVnajXQuXoELP_27frVBYS-S0EsXzQBI71VQcWbGmb9n8-J023R_Ldso-XJg5JY/pub?output=csv';

const FALLBACK = {
    dialect: 'あいきた',
    romaji:  'aikita',
    standard: 'よしきた・ほいきた',
    english:  'alright, got it, sure thing',
};

function splitCSVLine(line: string): string[] {
    const values: string[] = [];
    let current = '';
    let inQuotes = false;
    for (const char of line) {
        if (char === '"')            inQuotes = !inQuotes;
        else if (char === ',' && !inQuotes) { values.push(current); current = ''; }
        else                         current += char;
    }
    values.push(current);
    return values.map(v => v.trim().replace(/^"|"$/g, ''));
}

function parseCSV(text: string) {
    const lines = text.trim().split('\n');
    if (lines.length < 2) return [];
    const headers = splitCSVLine(lines[0]).map(h => h.toLowerCase());
    return lines.slice(1)
        .map(line => Object.fromEntries(headers.map((h, i) => [h, splitCSVLine(line)[i] ?? ''])))
        .filter(row => Object.values(row).some(v => v));
}

function pick(row: Record<string, string>, ...keys: string[]): string {
    for (const key of keys) {
        const found = Object.keys(row).find(k => k.includes(key));
        if (found && row[found]) return row[found];
    }
    return '';
}

let word = FALLBACK;
let allWords: typeof FALLBACK[] = [FALLBACK];

try {
    const res = await fetch(SHEET_CSV_URL, { signal: AbortSignal.timeout(5000) });
    if (res.ok) {
        const rows = parseCSV(await res.text());
        if (rows.length > 0) {
            const now = new Date();
            const dayOfYear = Math.floor((now.getTime() - new Date(now.getFullYear(), 0, 0).getTime()) / 86_400_000);
            const row = rows[dayOfYear % rows.length];
            word = {
                dialect:  pick(row, 'dialect_kana'),
                romaji:   pick(row, 'dialect_romaji'),
                standard: pick(row, 'standard_japanese'),
                english:  pick(row, 'english'),
            };
            allWords = rows.map(r => ({
                dialect:  pick(r, 'dialect_kana'),
                romaji:   pick(r, 'dialect_romaji'),
                standard: pick(r, 'standard_japanese'),
                english:  pick(r, 'english'),
            })).filter(w => w.dialect || w.romaji);
        }
    }
} catch (_) { /* use fallback */ }

// ── Weather ──
const WEATHER_API = 'https://api.open-meteo.com/v1/forecast?latitude=40.32&longitude=141.20&current=temperature_2m,weathercode,apparent_temperature&timezone=Asia/Tokyo';

const WMO: Record<number, { en: string; ja: string; icon: string }> = {
    0:  { en: "It's Sunny!",           ja: '快晴です！',       icon: 'sun' },
    1:  { en: "It's Sunny!",           ja: '晴れです！',       icon: 'sun' },
