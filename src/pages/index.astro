<script is:inline define:vars={{ WEATHER_API, WMO, WEATHER_ICONS }}>
    const wxCard = document.querySelector('.weather-card');
    if (wxCard) {
        const iconEl  = wxCard.querySelector('.weather-icon');
        const descEn  = wxCard.querySelector('.weather-desc .t-en');
        const descJa  = wxCard.querySelector('.weather-desc .t-ja');
        const tempEl  = wxCard.querySelector('.weather-temp');
        const feelsEn = wxCard.querySelector('.weather-feels .t-en');
        const feelsJa = wxCard.querySelector('.weather-feels .t-ja');

        function feelsLike(t) {
            if (t < 0)  return { en: "It's Freezing!",     ja: '凍えそうです！' };
            if (t < 8)  return { en: "It's Very Cold!",    ja: 'とても寒いです！' };
            if (t < 14) return { en: "It's Cold!",         ja: '寒いです！' };
            if (t < 20) return { en: "It's a Little Cool", ja: '少し涼しいです' };
            if (t < 25) return { en: "It's Nice!",         ja: '気持ちいいです！' };
            if (t < 31) return { en: "It's a Little Hot",  ja: '少し暑いです' };
            if (t < 36) return { en: "It's Hot!",          ja: '暑いです！' };
            return            { en: "It's Very Hot!",      ja: 'とても暑いです！' };
        }

        async function loadWeather() {
            try {
                const res = await fetch(WEATHER_API, { signal: AbortSignal.timeout(5000) });
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const c = (await res.json()).current;
                const info = WMO[c.weathercode] ?? { en: 'Unknown', ja: '不明', icon: 'cloud' };
                const feels = feelsLike(c.apparent_temperature);

                iconEl.innerHTML  = WEATHER_ICONS[info.icon] ?? WEATHER_ICONS.cloud;
                descEn.textContent  = info.en;
                descJa.textContent  = info.ja;
                tempEl.textContent  = Math.round(c.temperature_2m) + '°C';
                feelsEn.textContent = feels.en;
                feelsJa.textContent = feels.ja;
                wxCard.classList.remove('is-loading');
            } catch (err) {
                console.warn('Weather fetch failed:', err);
                iconEl.innerHTML  = WEATHER_ICONS.cloud;
                descEn.textContent  = 'Weather unavailable';
                descJa.textContent  = '天気を取得できません';
                tempEl.textContent  = '—';
                feelsEn.textContent = '';
                feelsJa.textContent = '';
                wxCard.classList.remove('is-loading');
                wxCard.classList.add('is-error');
            }
        }

        loadWeather();
    }
</script>

<script>
    const card = document.querySelector<HTMLElement>('.wod-card');
    if (card) {
        type Word = { dialect: string; romaji: string; standard: string; english: string };
        const words: Word[] = JSON.parse(card.dataset.words ?? '[]');
        const dialectEl  = card.querySelector<HTMLElement>('.wod-dialect');
        const standardEl = card.querySelector<HTMLElement>('.wod-standard');

        let currentIdx = -1;
        let raf: number | null = null;
        let holdStart = 0;
        let suppressClick = false; // set when a hold shuffles, so it doesn't also navigate
        const HOLD_MS = 650;

        function setScale(s: number) {
            card!.style.transform = `scale(${s})`;
        }

        function swapWord() {
            if (words.length < 2) return;
            let next: number;
            do { next = Math.floor(Math.random() * words.length); } while (next === currentIdx);
            currentIdx = next;
            const w = words[next];
            if (dialectEl) {
                dialectEl.querySelector('.t-en')!.textContent = w.romaji;
                dialectEl.querySelector('.t-ja')!.textContent = w.dialect;
            }
            if (standardEl) {
                standardEl.querySelector('.t-en')!.textContent = w.english;
                standardEl.querySelector('.t-ja')!.textContent = w.standard;
            }
        }

        function triggerPop(inflatedScale: number) {
            raf = null;
            suppressClick = true;
            swapWord();
            card!.style.setProperty('--wod-inflate', inflatedScale.toString());
            card!.classList.add('wod-popping');
            card!.addEventListener('animationend', () => {
                card!.classList.remove('wod-popping');
                card!.style.transform = '';
            }, { once: true });
        }

        function inflate(now: number) {
            const t = Math.min((now - holdStart) / HOLD_MS, 1);
            const scale = 1 + 0.06 * (t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t);
            setScale(scale);
            if (t < 1) {
                raf = requestAnimationFrame(inflate);
            } else {
                triggerPop(scale);
            }
        }

        function startHold() {
            if (raf !== null) return;
            card!.style.transition = '';
            holdStart = performance.now();
            raf = requestAnimationFrame(inflate);
        }

        function cancelHold() {
            if (raf === null) return;
            cancelAnimationFrame(raf);
            raf = null;
            card!.style.transition = 'transform 0.18s ease-out';
            setScale(1);
            card!.addEventListener('transitionend', () => {
                card!.style.transition = '';
                card!.style.transform = '';
            }, { once: true });
        }

        card.addEventListener('mousedown',  startHold);
        card.addEventListener('mouseup',    cancelHold);
        card.addEventListener('mouseleave', cancelHold);
        card.addEventListener('touchstart', startHold,  { passive: true });
        card.addEventListener('touchend',   cancelHold);
        card.addEventListener('touchcancel',cancelHold);
        card.addEventListener('selectstart', e => e.preventDefault());

        // A quick click/tap follows the link; a press-and-hold shuffles instead of navigating.
        card.addEventListener('click', (e) => {
            if (suppressClick) {
                e.preventDefault();
                suppressClick = false;
            }
        });
    }
</script>
