---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import T from '../components/T.astro';
---

<Layout
    title="TakkoTaco"
    description="TakkoTaco is the unofficial English website for Takko Machi — English learning tools for students, and an English guide to the town."
>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600&family=Patrick+Hand&display=swap" rel="stylesheet">

    <div class="town-guide-body">
        <Navbar />

        <!-- Hero -->
        <header class="hero">
            <div class="hero-content">
                <span class="welcome-text">
                    <T>
                        <span slot="en">Welcome to</span>
                        <span slot="ja">ようこそ</span>
                    </T>
                </span>
                <h1 class="town-name">
                    <T>
                        <span slot="en">Takko Machi</span>
                        <span slot="ja">田子町</span>
                    </T>
                </h1>
                <p class="tagline">
                    <T>
                        <span slot="en">Learn English. Explore Takko.</span>
                        <span slot="ja">英語で楽しむ田子町</span>
                    </T>
                </p>
                <div class="hero-ctas">
                    <a href="/game" class="cta-button cta-games">
                        <T>
                            <span slot="en">English Games</span>
                            <span slot="ja">英語ゲーム</span>
                        </T>
                    </a>
                    <a href="#town-guide" class="cta-button cta-secondary">
                        <T>
                            <span slot="en">Town Guide</span>
                            <span slot="ja">町の案内</span>
                        </T>
                    </a>
                </div>
            </div>
            <div class="hero-overlay"></div>
        </header>

        <!-- English Learning -->
        <section class="site-section">
            <div class="section-inner">
                <div class="section-header">
                    <h2>
                        <T>
                            <span slot="en">English Learning</span>
                            <span slot="ja">英語学習</span>
                        </T>
                    </h2>
                    <p>
                        <T>
                            <span slot="en">Games and tools for Takko students and teachers.</span>
                            <span slot="ja">田子の生徒と先生のためのゲームとツール</span>
                        </T>
                    </p>
                </div>
                <div class="card-grid">
                    <a href="/game" class="site-card">
                        <h3>
                            <T>
                                <span slot="en">Games and Tools</span>
                                <span slot="ja">ゲームとツール</span>
                            </T>
                        </h3>
                        <p>
                            <T>
                                <span slot="en">Vocabulary games, drawing games, classroom tools, and more.</span>
                                <span slot="ja">語彙ゲーム、絵描きゲーム、授業ツールなど</span>
                            </T>
                        </p>
                    </a>
                </div>
            </div>
        </section>

        <!-- Town Guide -->
        <section class="site-section section-alt" id="town-guide">
            <div class="section-inner">
                <div class="section-header">
                    <h2>
                        <T>
                            <span slot="en">Town Guide</span>
                            <span slot="ja">町の案内</span>
                        </T>
                    </h2>
                    <p>
                        <T>
                            <span slot="en">An unofficial English guide to Takko Machi.</span>
                            <span slot="ja">田子町の非公式英語ガイド</span>
                        </T>
                    </p>
                </div>
                <div class="card-grid">
                    <a href="/shrines" class="site-card shrine-card-home">
                        <div class="card-home-torii" aria-hidden="true">
                            <svg viewBox="0 0 120 100" xmlns="http://www.w3.org/2000/svg">
                                <rect x="22" y="28" width="10" height="72" rx="2" fill="currentColor"/>
                                <rect x="88" y="28" width="10" height="72" rx="2" fill="currentColor"/>
                                <rect x="18" y="47" width="84" height="8" rx="2" fill="currentColor"/>
                                <path d="M4,25 L4,17 Q14,3 24,11 L96,11 Q106,3 116,17 L116,25 Z" fill="currentColor"/>
                                <rect x="18" y="25" width="16" height="5" rx="1" fill="currentColor"/>
                                <rect x="86" y="25" width="16" height="5" rx="1" fill="currentColor"/>
                            </svg>
                        </div>
                        <h3>
                            <T>
                                <span slot="en">Shrines</span>
                                <span slot="ja">神社</span>
                            </T>
                        </h3>
                        <p>
                            <T>
                                <span slot="en">Shinto shrines in and around Takko.</span>
                                <span slot="ja">田子町の神社を紹介します。</span>
                            </T>
                        </p>
                    </a>
                    <div class="site-card coming-soon">
                        <h3>
                            <T>
                                <span slot="en">Restaurants</span>
                                <span slot="ja">飲食店</span>
                            </T>
                        </h3>
                        <p class="soon-label">
                            <T>
                                <span slot="en">Coming soon</span>
                                <span slot="ja">準備中</span>
                            </T>
                        </p>
                    </div>
                    <div class="site-card coming-soon">
                        <h3>
                            <T>
                                <span slot="en">Events</span>
                                <span slot="ja">イベント</span>
                            </T>
                        </h3>
                        <p class="soon-label">
                            <T>
                                <span slot="en">Coming soon</span>
                                <span slot="ja">準備中</span>
                            </T>
                        </p>
                    </div>
                    <div class="site-card coming-soon">
                        <h3>
                            <T>
                                <span slot="en">Things to Do</span>
                                <span slot="ja">観光・体験</span>
                            </T>
                        </h3>
                        <p class="soon-label">
                            <T>
                                <span slot="en">Coming soon</span>
                                <span slot="ja">準備中</span>
                            </T>
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>

<style>
    .town-guide-body {
        --color-bg: #fffbf0;
        --color-primary: #4a7c59;
        --color-secondary: #d4a373;
        --color-accent: #e76f51;
        --font-main: 'Fredoka', sans-serif;
        --font-hand: 'Patrick Hand', cursive;

        background-color: var(--color-bg);
        font-family: var(--font-main);
        color: #333;
    }

    h1, h2, h3 { font-family: var(--font-main); }

    /* Hero */
    .hero {
        height: 70vh;
        background-image: url('/images/yo2.jpg');
        background-size: cover;
        background-position: center;
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        color: white;
        border-bottom: 8px solid var(--color-primary);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.4);
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .welcome-text {
        font-family: var(--font-hand);
        font-size: 2rem;
        display: block;
        margin-bottom: -1rem;
        color: #f1f8e9;
    }

    .town-name {
        font-size: 6rem;
        margin: 0;
        text-shadow: 4px 4px 0px var(--color-primary);
    }

    .tagline {
        font-size: 1.5rem;
        margin-bottom: 2rem;
        opacity: 0.9;
    }

    .hero-ctas {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .cta-button {
        display: inline-block;
        background: var(--color-accent);
        color: white;
        padding: 1rem 2rem;
        border-radius: 50px;
        text-decoration: none;
        font-weight: bold;
        transition: transform 0.2s;
        box-shadow: 0 4px 0px #c05035;
    }

    .cta-button.cta-secondary {
        background: transparent;
        border: 2px solid white;
        box-shadow: none;
    }

    .cta-button:active {
        transform: translateY(4px);
        box-shadow: none;
        animation: none;
    }

    @keyframes bob {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-5px); }
    }

    .cta-games {
        animation: bob 2.4s ease-in-out infinite;
    }

    /* Sections */
    .site-section {
        padding: 5rem 2rem;
    }

    .section-alt {
        background: #f0f7f2;
        border-top: 4px solid var(--color-primary);
    }

    .section-inner {
        max-width: 1100px;
        margin: 0 auto;
    }

    .section-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .section-header h2 {
        font-size: 2.5rem;
        color: var(--color-primary);
        margin-bottom: 0.5rem;
    }

    .section-header p {
        font-size: 1.1rem;
        color: #555;
    }

    /* Cards */
    .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
    }

    .site-card {
        background: white;
        border: 3px solid var(--color-secondary);
        border-radius: 16px;
        padding: 2rem;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s, box-shadow 0.2s;
        display: block;
    }

    .site-card:not(.coming-soon):hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 20px rgba(74, 124, 89, 0.15);
        border-color: var(--color-primary);
    }

    .site-card.coming-soon {
        opacity: 0.6;
        border-style: dashed;
        cursor: default;
    }

    .site-card h3 {
        font-size: 1.4rem;
        color: var(--color-primary);
        margin-bottom: 0.5rem;
    }

    .site-card p {
        font-size: 1rem;
        color: #666;
        margin: 0;
    }

    .soon-label {
        font-family: var(--font-hand);
        color: #999 !important;
        font-size: 1rem;
    }

    .shrine-card-home .card-home-torii {
        color: #b5291c;
        width: 44px;
        height: 37px;
        margin-bottom: 0.75rem;
    }

    .shrine-card-home .card-home-torii svg {
        width: 100%;
        height: 100%;
    }

    @media (max-width: 768px) {
        .town-name { font-size: 3.5rem; }
        .hero-ctas { flex-direction: column; align-items: center; }
    }
</style>
