    85: { en: "Snow Showers",          ja: 'にわか雪です',     icon: 'snow' },
    86: { en: "Heavy Snow Showers!",   ja: '大雪です！',       icon: 'snow' },
    95: { en: "It's Stormy!",          ja: '雷雨です！',       icon: 'thunder' },
    96: { en: "It's Stormy!",          ja: '雷雨です！',       icon: 'thunder' },
    99: { en: "It's Stormy!",          ja: '雷雨です！',       icon: 'thunder' },
};

const WEATHER_ICONS: Record<string, string> = {
    sun: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="24" cy="24" r="9" fill="#e8a838"/><g stroke="#e8a838" stroke-width="2.5" stroke-linecap="round"><line x1="24" y1="5" x2="24" y2="12"/><line x1="24" y1="36" x2="24" y2="43"/><line x1="5" y1="24" x2="12" y2="24"/><line x1="36" y1="24" x2="43" y2="24"/><line x1="10.1" y1="10.1" x2="15.4" y2="15.4"/><line x1="32.6" y1="32.6" x2="37.9" y2="37.9"/><line x1="37.9" y1="10.1" x2="32.6" y2="15.4"/><line x1="15.4" y1="32.6" x2="10.1" y2="37.9"/></g></svg>`,
    'partly-cloudy': `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="7" fill="#e8a838"/><g stroke="#e8a838" stroke-width="2" stroke-linecap="round"><line x1="17" y1="4" x2="17" y2="8"/><line x1="17" y1="26" x2="17" y2="30"/><line x1="4" y1="17" x2="8" y2="17"/><line x1="26" y1="17" x2="30" y2="17"/><line x1="8.5" y1="8.5" x2="11.5" y2="11.5"/><line x1="22.5" y1="22.5" x2="25.5" y2="25.5"/><line x1="25.5" y1="8.5" x2="22.5" y2="11.5"/><line x1="11.5" y1="22.5" x2="8.5" y2="25.5"/></g><path d="M16,40 Q10,40 10,34 Q10,28 17,28 Q19,22 25,22 Q31,22 33,27 Q38,27 40,32 Q41,40 35,40Z" fill="#99aab5"/></svg>`,
    cloud: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8,36 Q2,36 2,29 Q2,22 9,22 Q11,14 21,14 Q30,14 33,21 Q40,20 43,26 Q45,36 37,36Z" fill="#99aab5"/></svg>`,
    rain:  `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8,30 Q2,30 2,23 Q2,16 9,16 Q11,8 21,8 Q30,8 33,15 Q40,14 43,20 Q45,30 37,30Z" fill="#99aab5"/><g stroke="#5b9bd5" stroke-width="2.5" stroke-linecap="round"><line x1="15" y1="35" x2="12" y2="43"/><line x1="25" y1="35" x2="22" y2="43"/><line x1="35" y1="35" x2="32" y2="43"/></g></svg>`,
    snow:  `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8,30 Q2,30 2,23 Q2,16 9,16 Q11,8 21,8 Q30,8 33,15 Q40,14 43,20 Q45,30 37,30Z" fill="#99aab5"/><g stroke="#a8d4f5" stroke-width="2" stroke-linecap="round"><line x1="13" y1="36" x2="13" y2="44"/><line x1="9" y1="40" x2="17" y2="40"/><line x1="25" y1="34" x2="25" y2="42"/><line x1="21" y1="38" x2="29" y2="38"/><line x1="37" y1="36" x2="37" y2="44"/><line x1="33" y1="40" x2="41" y2="40"/></g></svg>`,
    thunder: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8,30 Q2,30 2,23 Q2,16 9,16 Q11,8 21,8 Q30,8 33,15 Q40,14 43,20 Q45,30 37,30Z" fill="#6b7a8d"/><path d="M27,30 L20,41 L25,41 L19,50 L34,37 L28,37Z" fill="#f5c842"/></svg>`,
    fog:   `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><g stroke="#aab0bb" stroke-width="3" stroke-linecap="round"><line x1="6" y1="12" x2="42" y2="12"/><line x1="4" y1="20" x2="44" y2="20"/><line x1="6" y1="28" x2="42" y2="28"/><line x1="4" y1="36" x2="44" y2="36"/></g></svg>`,
};

// ── Today's Date ──
const todayJST = new Date(Date.now() + 9 * 3_600_000);
const EN_MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const EN_DAYS = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const JA_DAYS = ['日曜日','月曜日','火曜日','水曜日','木曜日','金曜日','土曜日'];
const todayWeekday = todayJST.getUTCDay();
const todayDate = todayJST.getUTCDate();
const ordinalSuffix = (d: number) => {
    const t = d % 100;
    if (t >= 11 && t <= 13) return 'th';
    return ['th','st','nd','rd','th','th','th','th','th','th'][d % 10];
};

// Cache until midnight JST (UTC+9)
const nowMs = Date.now();
const jstMidnight = new Date(nowMs + 9 * 3_600_000);
jstMidnight.setUTCHours(24, 0, 0, 0);
const ttl = Math.floor((jstMidnight.getTime() - 9 * 3_600_000 - nowMs) / 1000);
Astro.response.headers.set('Cache-Control', `public, s-maxage=${ttl}, stale-while-revalidate=60`);
---

