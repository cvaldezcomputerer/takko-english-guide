<style>
    /* Variables */
    .town-guide-body {
        --color-bg: #fffbf0; /* Warm paper white */
        --color-primary: #4a7c59; /* Forest Green */
        --color-secondary: #d4a373; /* Wood/Earth tone */
        --color-accent: #e76f51; /* Terra cotta */
        --font-main: 'Fredoka', sans-serif;
        --font-hand: 'Patrick Hand', cursive;

        background-color: var(--color-bg);
        font-family: var(--font-main);
        color: #333;
    }

    /* Typography Overrides */
    h1, h2, h3 { font-family: var(--font-main); }

    /* Hero */
    .hero {
        height: 70vh;
        background-image: url('/images/yo2.jpg');
        background-size: cover;
        background-position: center;
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        color: white;
        border-bottom: 8px solid var(--color-primary);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.4); /* Solid semi-transparent overlay */
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .welcome-text {
        font-family: var(--font-hand);
        font-size: 2rem;
        display: block;
        margin-bottom: -1rem;
        color: #f1f8e9;
    }

    .town-name {
        font-size: 6rem;
        margin: 0;
        text-shadow: 4px 4px 0px var(--color-primary);
    }

    .tagline {
        font-size: 1.5rem;
        margin-bottom: 2rem;
        opacity: 0.9;
    }

    .cta-button {
        display: inline-block;
        background: var(--color-accent);
        color: white;
        padding: 1rem 2rem;
        border-radius: 50px;
        text-decoration: none;
        font-weight: bold;
        transition: transform 0.2s;
        box-shadow: 0 4px 0px #c05035;
    }

    .cta-button:active {
        transform: translateY(4px);
        box-shadow: none;
    }

    /* Town Grid */
    .town-grid {
        padding: 4rem 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .grid-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .grid-header h2 {
        font-size: 3rem;
        color: var(--color-primary);
        margin-bottom: 0.5rem;
    }

    .category-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
    }

    .cat-card {
        background: white;
        border: 3px solid var(--color-secondary);
        border-radius: 20px;
        padding: 2rem;
        text-align: center;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .cat-card:hover {
        transform: translateY(-5px) rotate(1deg);
        border-color: var(--color-primary);
        box-shadow: 8px 8px 0px rgba(74, 124, 89, 0.2);
    }

    .cat-icon {
        font-size: 3.5rem;
        margin-bottom: 1rem;
    }

    .cat-card h3 {
        font-size: 1.5rem;
        color: var(--color-primary);
        margin-bottom: 0.5rem;
    }

    /* English Corner */
    .english-corner {
        background: #e8f5e9;
        padding: 4rem 2rem;
        text-align: center;
        border-top: 4px dashed var(--color-primary);
        border-bottom: 4px dashed var(--color-primary);
    }

    .game-links {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .game-btn {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 2rem;
        background: white;
        border-radius: 15px;
        text-decoration: none;
        color: #333;
        font-weight: bold;
        font-size: 1.2rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: transform 0.2s;
    }

    .game-btn:hover {
        transform: scale(1.05);
    }

    .map-theme { border-bottom: 5px solid #4ecdc4; }
    .letter-theme { border-bottom: 5px solid #ff6b6b; }

    /* Community Board */
    .community-board {
        padding: 5rem 2rem;
        display: flex;
        justify-content: center;
        background-color: var(--color-bg);
    }

    .board-paper {
        background: white;
        padding: 3rem;
        max-width: 600px;
        width: 100%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        position: relative;
        transform: rotate(-1deg);
    }

    .pin {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 2rem;
    }

    .newsletter-form {
        display: flex;
        gap: 1rem;
        margin: 2rem 0;
    }

    .newsletter-form input {
        flex: 1;
        padding: 0.8rem;
        border: 2px solid #ddd;
        border-radius: 8px;
    }

    .newsletter-form button {
        background: var(--color-primary);
        color: white;
        border: none;
        padding: 0 1.5rem;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
    }

    .recent-updates ul {
        list-style: none;
        padding: 0;
        text-align: left;
    }

    .recent-updates li {
        padding: 0.8rem 0;
        border-bottom: 1px dashed #eee;
        font-family: var(--font-hand);
        font-size: 1.2rem;
    }

    @media (max-width: 768px) {
        .town-name { font-size: 4rem; }
        .newsletter-form { flex-direction: column; }
    }
</style>
