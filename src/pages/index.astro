</Layout>

<style>
    .town-guide-body {
        background-color: #fff;
        font-family: var(--font-main);
        color: #333;
        border-bottom: 8px solid var(--color-primary);
    }

    h1, h2, h3 { font-family: var(--font-main); }

    /* Hero */
    .hero {
        height: 52vh;
        background-image: url('/images/yo2.jpg');
        background-size: cover;
        background-position: center;
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        color: white;
        border-bottom: 8px solid var(--color-primary);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.4);
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .dialect-card-home .card-home-cat {
        font-size: 3.2rem;
        color: var(--color-primary);
        margin-bottom: 0.75rem;
    }

    /* Cat is static by default, animates only on hover. */
    .dialect-card-home :global(.mouth-closed),
    .dialect-card-home :global(.mouth-open),
    .dialect-card-home :global(.al-pupil) {
        animation-play-state: paused;
    }

    .dialect-card-home:hover :global(.mouth-closed),
    .dialect-card-home:hover :global(.mouth-open),
    .dialect-card-home:hover :global(.al-pupil) {
        animation-play-state: running;
    }

    .welcome-text {
        font-family: var(--font-hand);
        font-size: 1.4rem;
        display: block;
        margin-bottom: -0.5rem;
        color: #f1f8e9;
    }

    .town-name {
        font-size: 4.5rem;
        margin: 0;
        text-shadow: 3px 3px 0px var(--color-primary);
    }

    .tagline {
        font-size: 1.2rem;
        margin-bottom: 1.5rem;
        opacity: 0.9;
    }

    .hero-ctas {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .cta-button {
        display: inline-block;
        background: var(--color-accent);
        color: white;
        padding: 0.75rem 1.75rem;
        border-radius: 50px;
        text-decoration: none;
        font-weight: bold;
        transition: transform 0.2s;
        box-shadow: 0 3px 0px #c05035;
    }

    .cta-button.cta-secondary {
        background: transparent;
        border: 2px solid white;
        box-shadow: none;
    }

    .cta-button:active {
        transform: translateY(4px);
        box-shadow: none;
        animation: none;
    }

    @keyframes bob {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-5px); }
    }

    .cta-games {
        animation: bob 2.4s ease-in-out infinite;
    }

