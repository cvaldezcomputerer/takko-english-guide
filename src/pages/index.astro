    51: { en: "It's Drizzling",        ja: '霧雨です',         icon: 'rain' },
    53: { en: "It's Drizzling",        ja: '霧雨です',         icon: 'rain' },
    55: { en: "It's Drizzling Hard",   ja: '強い霧雨です',     icon: 'rain' },
    61: { en: "It's Raining Lightly",  ja: '小雨です',         icon: 'rain' },
    63: { en: "It's Raining!",         ja: '雨です！',         icon: 'rain' },
    65: { en: "It's Raining Hard!",    ja: '大雨です！',       icon: 'rain' },
    71: { en: "It's Snowing Lightly",  ja: '小雪です',         icon: 'snow' },
    73: { en: "It's Snowing!",         ja: '雪です！',         icon: 'snow' },
