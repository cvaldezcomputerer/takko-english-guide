---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import T from '../../components/T.astro';
import { shrines } from '../../data/shrines';
---

<Layout
    title="Shrines - TakkoTaco"
    description="A guide to the Shinto shrines of Takko Machi."
>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600&family=Patrick+Hand&display=swap" rel="stylesheet">

    <div class="shrine-body">
        <Navbar />

        <header class="page-header">
            <div class="page-header-inner">
                <div class="torii-icon" aria-hidden="true">
                    <svg viewBox="0 0 120 100" xmlns="http://www.w3.org/2000/svg">
                        <rect x="22" y="28" width="10" height="72" rx="2" fill="currentColor"/>
                        <rect x="88" y="28" width="10" height="72" rx="2" fill="currentColor"/>
                        <rect x="18" y="47" width="84" height="8" rx="2" fill="currentColor"/>
                        <path d="M4,25 L4,17 Q14,3 24,11 L96,11 Q106,3 116,17 L116,25 Z" fill="currentColor"/>
                        <rect x="18" y="25" width="16" height="5" rx="1" fill="currentColor"/>
                        <rect x="86" y="25" width="16" height="5" rx="1" fill="currentColor"/>
                    </svg>
                </div>
                <h1>
                    <T>
                        <span slot="en">Shrines</span>
                        <span slot="ja">神社</span>
                    </T>
                </h1>
                <p class="header-sub">
                    <T>
                        <span slot="en">Shinto shrines in and around Takko Machi.</span>
                        <span slot="ja">田子町の神社</span>
                    </T>
                </p>
            </div>
        </header>

        <!-- Shrine list -->
        <section class="shrine-list-section">
            <div class="section-inner">
                {shrines.map(shrine => (
                    <a href={`/shrines/${shrine.slug}`} class="shrine-card">
                        <div class="card-torii" aria-hidden="true">
                            <svg viewBox="0 0 120 100" xmlns="http://www.w3.org/2000/svg">
                                <rect x="22" y="28" width="10" height="72" rx="2" fill="currentColor"/>
                                <rect x="88" y="28" width="10" height="72" rx="2" fill="currentColor"/>
                                <rect x="18" y="47" width="84" height="8" rx="2" fill="currentColor"/>
                                <path d="M4,25 L4,17 Q14,3 24,11 L96,11 Q106,3 116,17 L116,25 Z" fill="currentColor"/>
                                <rect x="18" y="25" width="16" height="5" rx="1" fill="currentColor"/>
                                <rect x="86" y="25" width="16" height="5" rx="1" fill="currentColor"/>
                            </svg>
                        </div>
                        <div class="card-text">
                            <h2>
                                <T>
                                    <span slot="en">{shrine.name.en}</span>
                                    <span slot="ja">{shrine.name.ja}</span>
                                </T>
                            </h2>
                            <p>
                                <T>
                                    <span slot="en">{shrine.deity.en}</span>
                                    <span slot="ja">{shrine.deity.ja}</span>
                                </T>
                            </p>
                        </div>
                        <span class="card-arrow" aria-hidden="true">→</span>
                    </a>
                ))}
            </div>
        </section>

        <!-- Shrine etiquette -->
        <section class="etiquette-section">
            <div class="section-inner">
                <h2 class="etiquette-title">
                    <T>
                        <span slot="en">Shrine Etiquette</span>
                        <span slot="ja">参拝のマナー</span>
                    </T>
                </h2>
                <p class="etiquette-sub">
                    <T>
                        <span slot="en">A few things to know before you visit.</span>
                        <span slot="ja">参拝前に知っておきたいこと</span>
                    </T>
                </p>
                <div class="etiquette-grid">
                    <div class="etiquette-item">
                        <div class="etiquette-num">1</div>
                        <div>
                            <p class="etiquette-label">
                                <T><span slot="en">Bow at the torii gate</span><span slot="ja">鳥居で一礼</span></T>
                            </p>
                            <p class="etiquette-detail">
                                <T>
                                    <span slot="en">Bow once before passing through. The torii marks the entrance to sacred space.</span>
                                    <span slot="ja">鳥居をくぐる前に一礼しましょう。鳥居は神域への入り口です。</span>
                                </T>
                            </p>
                        </div>
                    </div>
                    <div class="etiquette-item">
                        <div class="etiquette-num">2</div>
                        <div>
                            <p class="etiquette-label">
                                <T><span slot="en">Walk to the side of the path</span><span slot="ja">参道の端を歩く</span></T>
                            </p>
                            <p class="etiquette-detail">
                                <T>
                                    <span slot="en">The center of the path is for the deity. Walk on the left or right side.</span>
                                    <span slot="ja">参道の中央は神様の通り道です。端を歩きましょう。</span>
                                </T>
                            </p>
                        </div>
                    </div>
                    <div class="etiquette-item">
                        <div class="etiquette-num">3</div>
                        <div>
                            <p class="etiquette-label">
                                <T><span slot="en">Wash your hands</span><span slot="ja">手を清める</span></T>
                            </p>
                            <p class="etiquette-detail">
                                <T>
                                    <span slot="en">Use the purification fountain (手水舎, temizuya) to wash your hands before praying.</span>
                                    <span slot="ja">手水舎で手を清めてから参拝しましょう。</span>
                                </T>
                            </p>
                        </div>
                    </div>
                    <div class="etiquette-item">
                        <div class="etiquette-num">4</div>
                        <div>
                            <p class="etiquette-label">
                                <T><span slot="en">Be quiet and respectful</span><span slot="ja">静かに、敬意を持って</span></T>
                            </p>
                            <p class="etiquette-detail">
                                <T>
                                    <span slot="en">Speak quietly inside the shrine grounds. Photography is usually fine, but be respectful.</span>
                                    <span slot="ja">境内では静かに行動しましょう。写真撮影は通常問題ありませんが、マナーを守ってください。</span>
                                </T>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </div>
</Layout>

<style>
    .shrine-body {
        --color-bg: #fffbf0;
        --color-primary: #4a7c59;
        --color-secondary: #d4a373;
        --color-torii: #b5291c;
        --font-main: 'Fredoka', sans-serif;
        --font-hand: 'Patrick Hand', cursive;

        background-color: var(--color-bg);
        font-family: var(--font-main);
        color: #333;
        min-height: 100vh;
    }

    h1, h2, h3 { font-family: var(--font-main); }

    /* Header */
    .page-header {
        background-color: var(--color-bg);
        border-bottom: 4px solid var(--color-primary);
        padding: 4rem 2rem 3rem;
        text-align: center;
    }

    .page-header-inner {
        max-width: 700px;
        margin: 0 auto;
    }

    .torii-icon {
        color: var(--color-torii);
        width: 72px;
        height: 60px;
        margin: 0 auto 1.25rem;
    }

    .torii-icon svg { width: 100%; height: 100%; }

    .page-header h1 {
        font-size: 3rem;
        color: var(--color-primary);
        margin-bottom: 0.5rem;
    }

    .header-sub {
        font-size: 1.15rem;
        color: #666;
        font-family: var(--font-hand);
    }

    /* Shrine list */
    .shrine-list-section {
        padding: 4rem 2rem;
    }

    .section-inner {
        max-width: 780px;
        margin: 0 auto;
    }

    .shrine-list-section .section-inner {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .shrine-card {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        background: white;
        border: 3px solid var(--color-secondary);
        border-radius: 16px;
        padding: 1.5rem 1.75rem;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    }

    .shrine-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(74, 124, 89, 0.12);
        border-color: var(--color-primary);
    }

    .card-torii {
        color: var(--color-torii);
        flex-shrink: 0;
        width: 52px;
        height: 44px;
    }

    .card-torii svg { width: 100%; height: 100%; }

    .card-text { flex: 1; }

    .card-text h2 {
        font-size: 1.4rem;
        color: var(--color-primary);
        margin-bottom: 0.25rem;
    }

    .card-text p {
        font-size: 1rem;
        color: #666;
        margin: 0;
    }

    .card-arrow {
        font-size: 1.5rem;
        color: var(--color-primary);
        flex-shrink: 0;
        opacity: 0.6;
    }

    /* Etiquette section */
    .etiquette-section {
        padding: 4rem 2rem;
        background: #f0f7f2;
        border-top: 4px solid var(--color-primary);
    }

    .etiquette-title {
        font-size: 2rem;
        color: var(--color-primary);
        margin-bottom: 0.4rem;
    }

    .etiquette-sub {
        font-family: var(--font-hand);
        font-size: 1.1rem;
        color: #666;
        margin-bottom: 2rem;
    }

    .etiquette-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }

    .etiquette-item {
        display: flex;
        gap: 1rem;
        background: white;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        border: 2px solid #dde8e0;
    }

    .etiquette-num {
        font-size: 1.6rem;
        font-weight: 600;
        color: var(--color-torii);
        opacity: 0.4;
        flex-shrink: 0;
        line-height: 1;
        padding-top: 0.1rem;
    }

    .etiquette-label {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--color-primary);
        margin-bottom: 0.3rem;
    }

    .etiquette-detail {
        font-size: 0.95rem;
        color: #555;
        line-height: 1.5;
        margin: 0;
    }

    @media (max-width: 640px) {
        .page-header h1 { font-size: 2.2rem; }
        .shrine-card { padding: 1.25rem; gap: 1rem; }
        .card-arrow { display: none; }
        .etiquette-grid { grid-template-columns: 1fr; }
    }
</style>
