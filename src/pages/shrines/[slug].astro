---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ShrineIcon from '../../components/ShrineIcon.astro';
import T from '../../components/T.astro';
import { shrines } from '../../data/shrines';

export function getStaticPaths() {
  return shrines.map(shrine => ({
    params: { slug: shrine.slug },
    props: { shrine },
  }));
}

const { shrine } = Astro.props;
---

<Layout
    title={`${shrine.name.en} - TakkoTaco`}
    description={`${shrine.name.en} — a Shinto shrine in Takko Machi, Aomori.`}
>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600&family=Patrick+Hand&display=swap" rel="stylesheet">

    <div class="shrine-body">
        <Navbar />

        <header class="shrine-header">
            <a href="/shrines" class="back-link">
                <T>
                    <span slot="en">← All Shrines</span>
                    <span slot="ja">← 神社一覧</span>
                </T>
            </a>
            <div class="shrine-header-inner">
                <div class="header-torii" aria-hidden="true">
                    <ShrineIcon framed />
                </div>
                <p class="shrine-ja-name">{shrine.name.ja}</p>
                <h1>
                    <T>
                        <span slot="en">{shrine.name.en}</span>
                        <span slot="ja">{shrine.name.ja}</span>
                    </T>
                </h1>
            </div>
        </header>

        <!-- Photo gallery -->
        <section class="photo-section">
            <div class="content-inner">

                {/* Strip: main full-width, horizontal scrolling row below */}
                {shrine.galleryLayout === 'strip' && (
                    <div class="gallery-strip">
                        <div class="g-main">
                            <img src={shrine.mainImage} alt={shrine.name.en} />
                        </div>
                        <div class="strip-row">
                            {shrine.galleryImages?.map(img => (
                                <div class="strip-thumb">
                                    <img src={img} alt="" />
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                {/* Grid: main full-width, 3-column grid below */}
                {shrine.galleryLayout === 'grid' && (
                    <div class="gallery-grid">
                        <div class="g-main">
                            <img src={shrine.mainImage} alt={shrine.name.en} />
                        </div>
                        <div class="grid-below">
                            {shrine.galleryImages?.map(img => (
                                <div class="grid-thumb">
                                    <img src={img} alt="" />
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                {/* Mosaic: main left 60%, 2-col grid of thumbnails right */}
                {shrine.galleryLayout === 'mosaic' && (
                    <div class="gallery-mosaic">
                        <div class="g-main mosaic-main">
                            <img src={shrine.mainImage} alt={shrine.name.en} />
                        </div>
                        <div class="mosaic-side">
                            {shrine.galleryImages?.map(img => (
                                <div class="mosaic-thumb">
                                    <img src={img} alt="" />
                                </div>
                            ))}
                        </div>
                    </div>
                )}

            </div>
        </section>

        <!-- About + Location -->
        <section class="info-section">
            <div class="content-inner">
                <div class="info-grid">

                    <div class="info-block">
                        <h2 class="block-title">
                            <T><span slot="en">About</span><span slot="ja">神社について</span></T>
                        </h2>
                        {shrine.description.map(para => (
                            <p>
                                <T>
                                    <span slot="en">{para.en}</span>
                                    <span slot="ja">{para.ja}</span>
                                </T>
                            </p>
                        ))}

                    </div>

                    <div class="info-block">
                        <h2 class="block-title">
                            <T><span slot="en">Location</span><span slot="ja">場所</span></T>
                        </h2>

                        {shrine.roadViewImage && (
                            <div class="road-view">
                                <img src={shrine.roadViewImage} alt={`View from the road — ${shrine.name.en}`} class="road-view-img" />
                                <p class="road-view-caption">
                                    <T>
                                        <span slot="en">View from the road</span>
                                        <span slot="ja">道路からの眺め</span>
                                    </T>
                                </p>
                            </div>
                        )}

                        <div class="address-block">
                            <p class="address-label">
                                <T><span slot="en">Address</span><span slot="ja">住所</span></T>
                            </p>
                            <p class="address-text">
                                <T>
                                    <span slot="en">{shrine.address.en}</span>
                                    <span slot="ja">{shrine.address.ja}</span>
                                </T>
                            </p>
                        </div>

                        {shrine.accessNotes && (
                            <div class="address-block">
                                <p class="address-label">
                                    <T><span slot="en">Access Notes</span><span slot="ja">アクセスメモ</span></T>
                                </p>
                                <p class="address-text">
                                    <T>
                                        <span slot="en">{shrine.accessNotes.en}</span>
                                        <span slot="ja">{shrine.accessNotes.ja}</span>
                                    </T>
                                </p>
                            </div>
                        )}

                    </div>

                </div>
            </div>
        </section>

        <!-- Sub-shrines -->
        {shrine.subShrines && shrine.subShrines.length > 0 && (
            <section class="subshrines-section">
                <div class="content-inner">
                    <h2 class="block-title">
                        <T><span slot="en">Small Shrines</span><span slot="ja">末社・摂社</span></T>
                    </h2>
                    <p class="subshrines-sub">
                        <T>
                            <span slot="en">Smaller shrines within the grounds, each dedicated to a different deity.</span>
                            <span slot="ja">境内にある小さな神社。それぞれ異なる神様をお祀りしています。</span>
                        </T>
                    </p>
                    <div class="subshrine-grid">
                        {shrine.subShrines.map(sub => (
                            <div class="subshrine-card">
                                <div class="subshrine-photo">
                                    {sub.image
                                        ? <img src={sub.image} alt={sub.name.en} />
                                        : <div class="subshrine-placeholder">
                                            <svg viewBox="0 0 60 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                                <polygon points="30,8 46,36 14,36" fill="#c8d8c0" opacity="0.6"/>
                                                <polygon points="42,16 54,36 30,36" fill="#b0c8a8" opacity="0.5"/>
                                                <rect x="18" y="20" width="3" height="16" rx="1" fill="#b5291c" opacity="0.35"/>
                                                <rect x="39" y="20" width="3" height="16" rx="1" fill="#b5291c" opacity="0.35"/>
                                                <rect x="16" y="27" width="28" height="2.5" rx="1" fill="#b5291c" opacity="0.35"/>
                                                <path d="M13,24 L13,21 Q16,16 19.5,19 L40.5,19 Q44,16 47,21 L47,24 Z" fill="#b5291c" opacity="0.35"/>
                                            </svg>
                                        </div>
                                    }
                                </div>
                                <div class="subshrine-info">
                                    <p class="subshrine-name">
                                        <T>
                                            <span slot="en">{sub.name.en}</span>
                                            <span slot="ja">{sub.name.ja}</span>
                                        </T>
                                    </p>
                                    {sub.description && (
                                        <p class="subshrine-desc">
                                            <T>
                                                <span slot="en">{sub.description.en}</span>
                                                <span slot="ja">{sub.description.ja}</span>
                                            </T>
                                        </p>
                                    )}
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </section>
        )}

    </div>
</Layout>

<style>
    .shrine-body {

        background-color: var(--color-bg);
        font-family: var(--font-main);
        color: var(--color-text);
        min-height: 100vh;
    }

    h1, h2, h3, h4 { font-family: var(--font-main); }

    .shrine-header {
        background-color: #fdf6e8;
        padding: 2rem 2rem 1.75rem;
        text-align: center;
        border-bottom: 4px solid var(--color-primary);
        position: relative;
    }

    .back-link {
        position: absolute;
        top: 1.1rem;
        left: 1.75rem;
        font-family: var(--font-hand);
        font-size: 1.25rem;
        color: var(--color-primary);
        text-decoration: none;
        opacity: 0.8;
        font-weight: 600;
    }

    .back-link:hover { opacity: 1; }

    .shrine-header-inner {
        max-width: 700px;
        margin: 0 auto;
    }

    .header-torii {
        color: var(--color-torii);
        width: 84px;
        height: 84px;
        margin: 0 auto 0.75rem;
    }

    .header-torii svg { width: 100%; height: 100%; }

    .shrine-ja-name {
        font-size: 1.1rem;
        letter-spacing: 0.15em;
        color: var(--color-torii);
        margin-bottom: 0.2rem;
    }

    :global(body.lang-ja) .shrine-ja-name { display: none; }

    .shrine-header h1 {
        font-size: 2.4rem;
        color: var(--color-primary);
        line-height: 1.15;
    }

    .content-inner {
        max-width: 1000px;
        margin: 0 auto;
    }

    /* Photo section — shared */
    .photo-section {
        padding: 3rem 2rem;
    }

    .g-main {
        border-radius: var(--radius-md);
        overflow: hidden;
        border: 2px solid #ddd6c4;
    }

    .g-main img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* Strip layout */
    .gallery-strip .g-main {
        aspect-ratio: 16/9;
        margin-bottom: 0.75rem;
    }

    .strip-row {
        display: flex;
        gap: 0.75rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
        /* hide scrollbar on webkit but keep it functional */
        scrollbar-width: thin;
        scrollbar-color: var(--color-secondary) transparent;
    }

    .strip-thumb {
        flex-shrink: 0;
        width: 180px;
        height: 135px;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 2px solid #ddd6c4;
    }

    .strip-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* Grid layout */
    .gallery-grid .g-main {
        aspect-ratio: 16/9;
        margin-bottom: 1rem;
    }

    .grid-below {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
    }

    .grid-thumb {
        aspect-ratio: 4/3;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 2px solid #ddd6c4;
    }

    .grid-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* Mosaic layout */
    .gallery-mosaic {
        display: grid;
        grid-template-columns: 3fr 2fr;
        gap: 0.75rem;
    }

    .mosaic-main {
        aspect-ratio: 3/4;
    }

    .mosaic-side {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        align-content: start;
    }

    .mosaic-thumb {
        aspect-ratio: 1;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 2px solid #ddd6c4;
    }

    .mosaic-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* Info section */
    .info-section {
        padding: 3rem 2rem;
        background: #f0f7f2;
        border-top: 4px solid var(--color-primary);
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
    }

    .block-title {
        font-size: 1.5rem;
        color: var(--color-primary);
        border-bottom: 2px solid var(--color-secondary);
        padding-bottom: 0.5rem;
        margin-bottom: 1.25rem;
    }

    .info-block p {
        font-size: 1.05rem;
        color: var(--color-text);
        line-height: 1.7;
        margin-bottom: 1rem;
    }

    .sub-title {
        font-size: 1.15rem;
        color: var(--color-primary);
        margin: 1.5rem 0 0.75rem;
    }

    .feature-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .feature-list li {
        font-size: 1.05rem;
        color: var(--color-text);
        padding-left: 1.25rem;
        position: relative;
    }

    .feature-list li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.55em;
        width: 8px;
        height: 8px;
        border-radius: var(--radius-round);
        background: var(--color-torii);
        opacity: 0.6;
    }

    .road-view {
        margin-bottom: 1.5rem;
        border: 2px solid #ddd6c4;
        display: flex;
        flex-direction: column;
    }

    .road-view-img {
        width: 100%;
        aspect-ratio: 4/3;
        object-fit: cover;
        display: block;
    }

    .road-view .road-view-caption {
        background: #fdf6e8;
        padding: 0.5rem 0.85rem;
        font-family: var(--font-hand);
        font-size: 0.9rem;
        color: var(--color-text-faint);
        margin: 0;
        text-align: center;
        line-height: 1.2;
    }

    .address-block {
        margin-bottom: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #e0d8cc;
    }

    .address-block:last-child { border-bottom: none; }

    .address-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-torii);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.25rem;
    }

    .address-text {
        font-size: 1.05rem;
        color: var(--color-text);
        margin: 0;
    }

    /* Sub-shrines */
    .subshrines-section {
        padding: 3rem 2rem;
        background: var(--color-bg);
    }

    .subshrines-sub {
        font-family: var(--font-hand);
        font-size: 1.05rem;
        color: var(--color-text-muted);
        margin-bottom: 2rem;
    }

    .subshrine-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.25rem;
    }

    .subshrine-card {
        background: white;
        border: 2px solid #ddd6c4;
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    .subshrine-photo {
        aspect-ratio: 4/3;
        overflow: hidden;
        background: #f0ece3;
    }

    .subshrine-photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .subshrine-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .subshrine-placeholder svg {
        width: 52px;
        height: 42px;
        opacity: 0.7;
    }

    .subshrine-info {
        padding: 0.75rem 1rem;
    }

    .subshrine-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-primary);
        margin-bottom: 0.2rem;
    }

    .subshrine-desc {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        margin: 0;
        line-height: 1.4;
    }

    @media (max-width: 768px) {
        .shrine-header h1 { font-size: 2rem; }
        .shrine-ja-name { font-size: 1.2rem; }
        .info-grid { grid-template-columns: 1fr; gap: 2rem; }
        .gallery-mosaic { grid-template-columns: 1fr; }
        .grid-below { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 480px) {
        .grid-below { grid-template-columns: 1fr; }
        .mosaic-side { grid-template-columns: 1fr 1fr; }
    }
</style>
