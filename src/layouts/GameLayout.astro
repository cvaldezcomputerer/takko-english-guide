---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  showBackBar?: boolean;
}

const {
  title = "Takkotaco",
  description = "Takkotaco is the unofficial English website for Takko Machi.",
  showBackBar = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Andika:ital,wght@0,400;0,700;1,400;1,700&family=M+PLUS+Rounded+1c:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  </head>
  <body class="game-layout-body">
    {showBackBar && (
      <div class="tool-back-wrap">
        <a href="/game" class="tool-back-btn">
          <svg viewBox="0 0 16 16" fill="none" width="16" height="16" aria-hidden="true">
            <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="back-en">Go back</span>
          <span class="back-ja">もどる</span>
        </a>
      </div>
    )}
    <slot />
  </body>
</html>

<style>
  .game-layout-body {
    margin: 0;
    min-height: 100vh;
  }

  .tool-back-wrap {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.6rem 0.9rem;
    background: var(--color-bg);
    border-bottom: 1px solid #ece3d0;
  }

  .tool-back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.1rem;
    background: var(--color-white);
    border: 2px solid var(--color-secondary);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-primary);
    font-family: 'Andika', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.06);
    transition: background 0.15s, color 0.15s, transform 0.15s;
  }

  .tool-back-btn:hover {
    background: var(--color-primary);
    color: #fff;
    transform: translateX(-2px);
  }

  .tool-back-btn svg {
    flex-shrink: 0;
  }

  .back-ja {
    font-family: 'M PLUS Rounded 1c', sans-serif;
    font-size: 0.82em;
    opacity: 0.75;
  }

  .tool-back-btn:hover .back-ja {
    opacity: 0.9;
  }
</style>
